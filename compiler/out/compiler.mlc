// Token types - split out for mlcc parser compatibility
// TKind must be first: parser skips it when it follows extend Shared

export type TKind =
  | KFn | KType | KLet | KMut | KConst | KReturn
  | KBreak | KContinue | KIf | KThen | KElse | KUnless
  | KWhile | KFor | KIn | KDo | KEnd | KMatch
  | KImport | KFrom | KAs | KExtern | KExtend | KWhere
  | KTrue | KFalse
  | LInt(i32) | LStr(string) | Ident(string)
  | Arrow | FatArrow | Pipe | Bar | Equal | Question | Dot | Spread
  | LParen | RParen | LBrace | RBrace | LBracket | RBracket
  | Comma | Semicolon | Colon | Op(string) | Eof

extend Shared<T> {
  extern fn new(value: T) -> Shared<T>
}

export type Token  = Token  { kind: TKind, line: i32, col: i32 }
export type LexOut = LexOut { tokens: [Token], errors: [string] }

export extend LexOut {
  fn has_errors(self) -> bool = errors.length() > 0
}

export extend Token {
  fn kind_value(self) -> TKind = kind
  fn line_number(self) -> i32 = line
  fn column(self) -> i32 = col
}

// Shared AST type definitions for the self-hosted MLC compiler.


// ─── AST ─────────────────────────────────────────────────────────────────

export type TypeExpr =
  | TyI32 | TyString | TyBool | TyUnit | TyNamed(string)
  | TyArray(Shared<TypeExpr>)
  | TyShared(Shared<TypeExpr>)
  | TyGeneric(string, [Shared<TypeExpr>])
  | TyFn([Shared<TypeExpr>], Shared<TypeExpr>)

export type Pat =
  | PatWild | PatIdent(string) | PatInt(i32) | PatStr(string)
  | PatBool(bool) | PatUnit
  | PatCtor(string, [Shared<Pat>])

export type FieldPat = FieldPat { name: string, pat: Shared<Pat> }
export type MatchArm = MatchArm { pat: Shared<Pat>, body: Shared<Expr> }
export type FieldVal = FieldVal { name: string, val: Shared<Expr> }

export type Expr =
  | ExprInt(i32) | ExprStr(string) | ExprBool(bool) | ExprUnit
  | ExprIdent(string)
  | ExprBin(string, Shared<Expr>, Shared<Expr>)
  | ExprUn(string, Shared<Expr>)
  | ExprCall(Shared<Expr>, [Shared<Expr>])
  | ExprMethod(Shared<Expr>, string, [Shared<Expr>])
  | ExprField(Shared<Expr>, string)
  | ExprIndex(Shared<Expr>, Shared<Expr>)
  | ExprIf(Shared<Expr>, Shared<Expr>, Shared<Expr>)
  | ExprBlock([Shared<Stmt>], Shared<Expr>)
  | ExprWhile(Shared<Expr>, [Shared<Stmt>])
  | ExprFor(string, Shared<Expr>, [Shared<Stmt>])
  | ExprMatch(Shared<Expr>, [Shared<MatchArm>])
  | ExprRecord(string, [Shared<FieldVal>])
  | ExprRecordUpdate(string, Shared<Expr>, [Shared<FieldVal>])
  | ExprArray([Shared<Expr>])
  | ExprQuestion(Shared<Expr>)
  | ExprLambda([string], Shared<Expr>)

export type Stmt =
  | StmtLet(string, bool, Shared<TypeExpr>, Shared<Expr>)
  | StmtExpr(Shared<Expr>)
  | StmtBreak | StmtContinue | StmtReturn(Shared<Expr>)

export type Param    = Param    { name: string, is_mut: bool, typ: Shared<TypeExpr> }
export type FieldDef = FieldDef { name: string, typ: Shared<TypeExpr> }

export type TypeVariant =
  | VarUnit(string)
  | VarTuple(string, [Shared<TypeExpr>])
  | VarRecord(string, [Shared<FieldDef>])

export type Decl =
  | DeclFn(string, [Shared<Param>], Shared<TypeExpr>, Shared<Expr>)
  | DeclType(string, [Shared<TypeVariant>])
  | DeclExtend(string, [Shared<Decl>])
  | DeclImport(string, [string])
  | DeclExported(Shared<Decl>)

export type Program = Program { decls: [Shared<Decl>] }

export fn decl_inner(decl: Shared<Decl>) -> Shared<Decl> = match decl {
  DeclExported(d) => d,
  _ => decl
}

export fn decl_name(decl: Shared<Decl>) -> string = match decl {
  DeclFn(name, _, _, _) => name,
  DeclType(name, _) => name,
  DeclExtend(type_name, _) => type_name,
  DeclImport(_, _) => "",
  DeclExported(d) => decl_name(d)
}

// ─── Shared utility ───────────────────────────────────────────────────────

export fn errs_append(mut dst: [string], src: [string]) -> [string] = do
  let i = 0
  while i < src.length() do
    dst.push(src[i])
    i = i + 1
  end
  dst
end

// Lexer: source string → token array.


type LexState     = LexState     { src: string, pos: i32, line: i32, col: i32 }
type ScanResult   = ScanResult   { state: LexState, token: Token }
type ScanStrResult = ScanStrResult { state: LexState, token: Token, error: string }

extend LexState {
  fn eof(self) -> bool =
    pos >= src.length()

  fn current(self) -> string =
    if self.eof() then "\0" else src.char_at(pos) end

  fn peek(self, offset: i32) -> string = do
    const position = pos + offset
    if position >= src.length() then "\0" else src.char_at(position) end
  end

  fn advance(self) -> LexState =
    if self.current() == "\n"
    then LexState { src, pos: pos + 1, line: line + 1, col: 1 }
    else LexState { src, pos: pos + 1, line, col: col + 1 }
    end

  fn advance_by(self, count: i32) -> LexState = do
    let state = self
    let i = 0
    while i < count do state = state.advance(); i = i + 1 end
    state
  end

  fn token(self, kind: TKind) -> Token = Token { kind, line, col }
}

fn is_alpha(character: string) -> bool =
  (character >= "a" && character <= "z") ||
  (character >= "A" && character <= "Z") ||
   character == "_"

fn is_digit(character: string) -> bool = character >= "0" && character <= "9"
fn is_alnum(character: string) -> bool = is_alpha(character) || is_digit(character)
fn is_ws(character: string) -> bool =
  character == " " || character == "\t" || character == "\r" || character == "\n"

fn keyword_kind(word: string) -> TKind =
  if      word == "fn"       then KFn
  else if word == "type"     then KType
  else if word == "let"      then KLet
  else if word == "mut"      then KMut
  else if word == "const"    then KConst
  else if word == "return"   then KReturn
  else if word == "break"    then KBreak
  else if word == "continue" then KContinue
  else if word == "if"       then KIf
  else if word == "then"     then KThen
  else if word == "else"     then KElse
  else if word == "unless"   then KUnless
  else if word == "while"    then KWhile
  else if word == "for"      then KFor
  else if word == "in"       then KIn
  else if word == "do"       then KDo
  else if word == "end"      then KEnd
  else if word == "match"    then KMatch
  else if word == "import"   then KImport
  else if word == "from"     then KFrom
  else if word == "as"       then KAs
  else if word == "extern"   then KExtern
  else if word == "extend"   then KExtend
  else if word == "where"    then KWhere
  else if word == "true"     then KTrue
  else if word == "false"    then KFalse
  else Ident(word)
  end

fn scan_ident(state: LexState) -> ScanResult = do
  const start = state.pos
  const source = state.src
  const token_line = state.line
  const token_col  = state.col
  let current = state
  while !current.eof() && is_alnum(current.current()) do
    current = current.advance()
  end
  const word = source.substring(start, current.pos - start)
  ScanResult { state: current, token: Token { kind: keyword_kind(word), line: token_line, col: token_col } }
end

fn scan_int(state: LexState) -> ScanResult = do
  const token_line = state.line
  const token_col  = state.col
  let current = state
  let value = 0
  while !current.eof() && is_digit(current.current()) do
    value = value * 10 + current.current().to_i()
    current = current.advance()
  end
  ScanResult { state: current, token: Token { kind: LInt(value), line: token_line, col: token_col } }
end

fn map_escape(character: string) -> string =
  if      character == "n"  then "\n"
  else if character == "t"  then "\t"
  else if character == "r"  then "\r"
  else if character == "\"" then "\""
  else if character == "\\" then "\\"
  else if character == "0"  then "\0"
  else if character == "{"  then "{"
  else if character == "}"  then "}"
  else ""
  end

fn scan_string(state: LexState) -> ScanStrResult = do
  const token_line = state.line
  const token_col  = state.col
  let current = state.advance()
  let parts: [string] = []
  let error = ""
  while !current.eof() && current.current() != "\"" do
    if current.current() == "\\" then
      current = current.advance()
      const mapped = map_escape(current.current())
      if mapped != "" then
        parts.push(mapped)
      else
        parts.push("\\")
        parts.push(current.current())
      end
      current = current.advance()
    else
      parts.push(current.current())
      current = current.advance()
    end
  end
  if current.eof() then
    error = "unterminated string"
  else
    current = current.advance()
  end
  ScanStrResult {
    state: current,
    token: Token { kind: LStr(parts.join("")), line: token_line, col: token_col },
    error
  }
end

fn skip_whitespace(state: LexState) -> LexState = do
  let current = state
  while !current.eof() do
    const character = current.current()
    if is_ws(character) then
      current = current.advance()
    else if character == "/" && current.peek(1) == "/" then
      current = current.advance_by(2)
      while !current.eof() && current.current() != "\n" do current = current.advance() end
    else if character == "/" && current.peek(1) == "*" then
      current = current.advance_by(2)
      while !current.eof() do
        if current.current() == "*" && current.peek(1) == "/" then
          current = current.advance_by(2); break
        end
        current = current.advance()
      end
    else
      break
    end
  end
  current
end

fn scan_op(state: LexState) -> ScanResult = do
  const token_line = state.line
  const token_col  = state.col
  const character  = state.current()
  const next       = state.peek(1)
  if      character == "-" && next == ">" then ScanResult { state: state.advance_by(2), token: state.token(Arrow) }
  else if character == "=" && next == ">" then ScanResult { state: state.advance_by(2), token: state.token(FatArrow) }
  else if character == "|" && next == ">" then ScanResult { state: state.advance_by(2), token: state.token(Pipe) }
  else if character == "=" && next == "=" then ScanResult { state: state.advance_by(2), token: state.token(Op("==")) }
  else if character == "!" && next == "=" then ScanResult { state: state.advance_by(2), token: state.token(Op("!=")) }
  else if character == "<" && next == "=" then ScanResult { state: state.advance_by(2), token: state.token(Op("<=")) }
  else if character == ">" && next == "=" then ScanResult { state: state.advance_by(2), token: state.token(Op(">=")) }
  else if character == "&" && next == "&" then ScanResult { state: state.advance_by(2), token: state.token(Op("&&")) }
  else if character == "|" && next == "|" then ScanResult { state: state.advance_by(2), token: state.token(Op("||")) }
  else if character == "=" then ScanResult { state: state.advance(), token: state.token(Equal) }
  else if character == "|" then ScanResult { state: state.advance(), token: state.token(Bar) }
  else if character == "?" then ScanResult { state: state.advance(), token: state.token(Question) }
  else if character == "." && next == "." && state.peek(2) == "."
    then ScanResult { state: state.advance_by(3), token: state.token(Spread) }
  else if character == "."  then ScanResult { state: state.advance(), token: state.token(Dot) }
  else if character == "("  then ScanResult { state: state.advance(), token: state.token(LParen) }
  else if character == ")"  then ScanResult { state: state.advance(), token: state.token(RParen) }
  else if character == "\{" then ScanResult { state: state.advance(), token: state.token(LBrace) }
  else if character == "\}" then ScanResult { state: state.advance(), token: state.token(RBrace) }
  else if character == "["  then ScanResult { state: state.advance(), token: state.token(LBracket) }
  else if character == "]"  then ScanResult { state: state.advance(), token: state.token(RBracket) }
  else if character == ","  then ScanResult { state: state.advance(), token: state.token(Comma) }
  else if character == ";"  then ScanResult { state: state.advance(), token: state.token(Semicolon) }
  else if character == ":"  then ScanResult { state: state.advance(), token: state.token(Colon) }
  else ScanResult { state: state.advance(), token: state.token(Op(character)) }
  end
end

export fn tokenize(source: string) -> LexOut = do
  let state = LexState { src: source, pos: 0, line: 1, col: 1 }
  const tokens: [Token] = []
  let errors: [string] = []
  while !state.eof() do
    state = skip_whitespace(state)
    if state.eof() then break end
    const character = state.current()
    if is_alpha(character) then
      const result = scan_ident(state); tokens.push(result.token); state = result.state
    else if is_digit(character) then
      const result = scan_int(state); tokens.push(result.token); state = result.state
    else if character == "\"" then
      const result = scan_string(state); tokens.push(result.token); state = result.state
      if result.error != "" then errors.push(result.error) end
    else
      const result = scan_op(state); tokens.push(result.token); state = result.state
    end
  end
  tokens.push(state.token(Eof))
  LexOut { tokens, errors }
end

// Parser state, result types, and token kind predicates.


// ─── Parser state ─────────────────────────────────────────────────────────

export type Parser = Parser { tokens: [Token], pos: i32 }

export fn parser_new(tokens: [Token]) -> Parser =
  Parser { tokens: tokens, pos: 0 }

fn parser_kind(parser: Parser) -> TKind =
  parser.tokens[parser.pos].kind

fn parser_advance(parser: Parser) -> Parser =
  Parser { tokens: parser.tokens, pos: parser.pos + 1 }

fn parser_advance_by(parser: Parser, count: i32) -> Parser =
  Parser { tokens: parser.tokens, pos: parser.pos + count }

fn parser_at_eof(parser: Parser) -> bool =
  match parser_kind(parser) { Eof => true, _ => false }

fn parser_skip_semi(parser: Parser) -> Parser =
  match parser_kind(parser) { Semicolon => parser_advance(parser), _ => parser }

// ─── Result types ─────────────────────────────────────────────────────────

export type ExprResult      = ExprResult      { expr:       Shared<Expr>,          parser: Parser }
export type TypeResult      = TypeResult      { type_expr:  Shared<TypeExpr>,       parser: Parser }
export type PatResult       = PatResult       { pat:        Shared<Pat>,            parser: Parser }
export type StmtResult      = StmtResult      { stmt:       Shared<Stmt>,           parser: Parser }
export type StmtsResult     = StmtsResult     { stmts:      [Shared<Stmt>],         parser: Parser }
export type ExprsResult     = ExprsResult     { exprs:      [Shared<Expr>],         parser: Parser }
export type ArmsResult      = ArmsResult      { arms:       [Shared<MatchArm>],     parser: Parser }
export type VariantResult   = VariantResult   { variant:    Shared<TypeVariant>,    parser: Parser }
export type VariantsResult  = VariantsResult  { variants:   [Shared<TypeVariant>],  parser: Parser }
export type ParamsResult    = ParamsResult    { params:     [Shared<Param>],        parser: Parser }
export type DeclResult      = DeclResult      { decl:       Shared<Decl>,           parser: Parser }
export type FieldValsResult = FieldValsResult { field_vals: [Shared<FieldVal>],     parser: Parser }
export type PatsResult      = PatsResult      { pats:       [Shared<Pat>],          parser: Parser }
export type FieldDefsResult = FieldDefsResult { field_defs: [Shared<FieldDef>],     parser: Parser }
export type TypesResult     = TypesResult     { types:      [Shared<TypeExpr>],     parser: Parser }
export type ParamResult     = ParamResult     { param:      Shared<Param>,          parser: Parser }
export type NamesResult     = NamesResult     { exprs:      [string],               parser: Parser }

// ─── Token kind predicates ────────────────────────────────────────────────

fn is_keyword_fn(kind: TKind)       -> bool = match kind { KFn       => true, _ => false }
fn is_keyword_type(kind: TKind)     -> bool = match kind { KType     => true, _ => false }
fn is_keyword_let(kind: TKind)      -> bool = match kind { KLet      => true, _ => false }
fn is_keyword_mut(kind: TKind)      -> bool = match kind { KMut      => true, _ => false }
fn is_keyword_const(kind: TKind)    -> bool = match kind { KConst    => true, _ => false }
fn is_keyword_if(kind: TKind)       -> bool = match kind { KIf       => true, _ => false }
fn is_keyword_unless(kind: TKind)   -> bool = match kind { KUnless   => true, _ => false }
fn is_keyword_else(kind: TKind)     -> bool = match kind { KElse     => true, _ => false }
fn is_keyword_end(kind: TKind)      -> bool = match kind { KEnd      => true, _ => false }
fn is_keyword_do(kind: TKind)       -> bool = match kind { KDo       => true, _ => false }
fn is_keyword_while(kind: TKind)    -> bool = match kind { KWhile    => true, _ => false }
fn is_keyword_for(kind: TKind)      -> bool = match kind { KFor      => true, _ => false }
fn is_keyword_match(kind: TKind)    -> bool = match kind { KMatch    => true, _ => false }
fn is_keyword_return(kind: TKind)   -> bool = match kind { KReturn   => true, _ => false }
fn is_keyword_break(kind: TKind)    -> bool = match kind { KBreak    => true, _ => false }
fn is_keyword_continue(kind: TKind) -> bool = match kind { KContinue => true, _ => false }
fn is_keyword_true(kind: TKind)     -> bool = match kind { KTrue     => true, _ => false }
fn is_keyword_false(kind: TKind)    -> bool = match kind { KFalse    => true, _ => false }
fn is_keyword_extern(kind: TKind)   -> bool = match kind { KExtern   => true, _ => false }
fn is_keyword_extend(kind: TKind)   -> bool = match kind { KExtend   => true, _ => false }

fn is_ident(kind: TKind)         -> bool = match kind { Ident(_)  => true, _ => false }
fn is_int_literal(kind: TKind)   -> bool = match kind { LInt(_)   => true, _ => false }
fn is_str_literal(kind: TKind)   -> bool = match kind { LStr(_)   => true, _ => false }
fn is_equal(kind: TKind)         -> bool = match kind { Equal     => true, _ => false }
fn is_bar(kind: TKind)           -> bool = match kind { Bar       => true, _ => false }
fn is_pipe(kind: TKind)          -> bool = match kind { Pipe      => true, _ => false }
fn is_colon(kind: TKind)         -> bool = match kind { Colon     => true, _ => false }
fn is_comma(kind: TKind)         -> bool = match kind { Comma     => true, _ => false }
fn is_dot(kind: TKind)           -> bool = match kind { Dot       => true, _ => false }
fn is_spread(kind: TKind)        -> bool = match kind { Spread    => true, _ => false }
fn is_arrow(kind: TKind)         -> bool = match kind { Arrow     => true, _ => false }
fn is_fat_arrow(kind: TKind)     -> bool = match kind { FatArrow  => true, _ => false }
fn is_question(kind: TKind)      -> bool = match kind { Question  => true, _ => false }
fn is_left_paren(kind: TKind)    -> bool = match kind { LParen    => true, _ => false }
fn is_right_paren(kind: TKind)   -> bool = match kind { RParen    => true, _ => false }
fn is_left_brace(kind: TKind)    -> bool = match kind { LBrace    => true, _ => false }
fn is_right_brace(kind: TKind)   -> bool = match kind { RBrace    => true, _ => false }
fn is_left_bracket(kind: TKind)  -> bool = match kind { LBracket  => true, _ => false }
fn is_right_bracket(kind: TKind) -> bool = match kind { RBracket  => true, _ => false }
fn is_operator(kind: TKind)      -> bool = match kind { Op(_)     => true, _ => false }

fn get_ident(kind: TKind)        -> string = match kind { Ident(name) => name, _ => "" }
fn get_int_literal(kind: TKind)  -> i32    = match kind { LInt(n)    => n,    _ => 0 }
fn get_str_literal(kind: TKind)  -> string = match kind { LStr(s)    => s,    _ => "" }
fn get_operator(kind: TKind)     -> string = match kind { Op(s)      => s,    _ => "" }

export fn is_ctor_name(name: string) -> bool =
  name.char_at(0) >= "A" && name.char_at(0) <= "Z"

// ─── extend TKind ─────────────────────────────────────────────────────────

export extend TKind {
  fn is_fn(self)       -> bool = match self { KFn       => true, _ => false }
  fn is_type(self)     -> bool = match self { KType     => true, _ => false }
  fn is_let(self)      -> bool = match self { KLet      => true, _ => false }
  fn is_mut(self)      -> bool = match self { KMut      => true, _ => false }
  fn is_const(self)    -> bool = match self { KConst    => true, _ => false }
  fn is_if(self)       -> bool = match self { KIf       => true, _ => false }
  fn is_unless(self)   -> bool = match self { KUnless   => true, _ => false }
  fn is_else(self)     -> bool = match self { KElse     => true, _ => false }
  fn is_end(self)      -> bool = match self { KEnd      => true, _ => false }
  fn is_do(self)       -> bool = match self { KDo       => true, _ => false }
  fn is_while(self)    -> bool = match self { KWhile    => true, _ => false }
  fn is_for(self)      -> bool = match self { KFor      => true, _ => false }
  fn is_match(self)    -> bool = match self { KMatch    => true, _ => false }
  fn is_return(self)   -> bool = match self { KReturn   => true, _ => false }
  fn is_break(self)    -> bool = match self { KBreak    => true, _ => false }
  fn is_continue(self) -> bool = match self { KContinue => true, _ => false }
  fn is_true(self)     -> bool = match self { KTrue     => true, _ => false }
  fn is_false(self)    -> bool = match self { KFalse    => true, _ => false }
  fn is_extern(self)   -> bool = match self { KExtern   => true, _ => false }
  fn is_extend(self)   -> bool = match self { KExtend   => true, _ => false }
  fn is_import(self)   -> bool = match self { KImport   => true, _ => false }
  fn is_from(self)     -> bool = match self { KFrom     => true, _ => false }
  fn is_eof(self)      -> bool = match self { Eof       => true, _ => false }
  fn is_ident(self)    -> bool = match self { Ident(_)  => true, _ => false }
  fn is_int(self)      -> bool = match self { LInt(_)   => true, _ => false }
  fn is_str(self)      -> bool = match self { LStr(_)   => true, _ => false }
  fn is_equal(self)    -> bool = match self { Equal     => true, _ => false }
  fn is_bar(self)      -> bool = match self { Bar       => true, _ => false }
  fn is_pipe(self)     -> bool = match self { Pipe      => true, _ => false }
  fn is_colon(self)    -> bool = match self { Colon     => true, _ => false }
  fn is_comma(self)    -> bool = match self { Comma     => true, _ => false }
  fn is_dot(self)      -> bool = match self { Dot       => true, _ => false }
  fn is_spread(self)   -> bool = match self { Spread    => true, _ => false }
  fn is_arrow(self)    -> bool = match self { Arrow     => true, _ => false }
  fn is_fat_arrow(self) -> bool = match self { FatArrow => true, _ => false }
  fn is_question(self) -> bool = match self { Question  => true, _ => false }
  fn is_lparen(self)   -> bool = match self { LParen    => true, _ => false }
  fn is_rparen(self)   -> bool = match self { RParen    => true, _ => false }
  fn is_lbrace(self)   -> bool = match self { LBrace    => true, _ => false }
  fn is_rbrace(self)   -> bool = match self { RBrace    => true, _ => false }
  fn is_lbracket(self) -> bool = match self { LBracket  => true, _ => false }
  fn is_rbracket(self) -> bool = match self { RBracket  => true, _ => false }
  fn is_op(self)       -> bool = match self { Op(_)     => true, _ => false }
  fn ident(self)       -> string = match self { Ident(name) => name, _ => "" }
  fn int_val(self)     -> i32    = match self { LInt(n)     => n,    _ => 0 }
  fn str_val(self)     -> string = match self { LStr(s)     => s,    _ => "" }
  fn op_val(self)      -> string = match self { Op(s)       => s,    _ => "" }
}

// ─── extend Parser ────────────────────────────────────────────────────────

export extend Parser {
  fn kind(self)      -> TKind  = tokens[pos].kind
  fn advance(self)   -> Parser = Parser { tokens, pos: pos + 1 }
  fn advance_by(self, count: i32) -> Parser = Parser { tokens, pos: pos + count }
  fn at_eof(self)    -> bool   = tokens[pos].kind.is_eof()
  fn skip_semi(self) -> Parser =
    match tokens[pos].kind { Semicolon => self.advance(), _ => self }
}

// ─── Type expression parser ───────────────────────────────────────────────


export fn parse_type(parser: Parser) -> TypeResult = do
  const base = parse_base_type(parser)
  if base.parser.kind().is_arrow() then
    const ret = parse_type(base.parser.advance())
    const params: [Shared<TypeExpr>] = [base.type_expr]
    TypeResult { type_expr: Shared.new(TyFn(params, ret.type_expr)), parser: ret.parser }
  else
    base
  end
end

fn parse_base_type(parser: Parser) -> TypeResult = do
  const kind = parser.kind()
  if kind.is_lbracket() then
    const inner = parse_type(parser.advance())
    TypeResult { type_expr: Shared.new(TyArray(inner.type_expr)), parser: inner.parser.advance() }
  else if kind.is_ident() then
    const name = kind.ident()
    if      name == "i32"    then TypeResult { type_expr: Shared.new(TyI32),    parser: parser.advance() }
    else if name == "string" then TypeResult { type_expr: Shared.new(TyString), parser: parser.advance() }
    else if name == "bool"   then TypeResult { type_expr: Shared.new(TyBool),   parser: parser.advance() }
    else if name == "unit"   then TypeResult { type_expr: Shared.new(TyUnit),   parser: parser.advance() }
    else
      const after = parser.advance()
      if after.kind().is_op() && after.kind().op_val() == "<" then
        const args = parse_type_args(after.advance())
        const type_expr =
          if name == "Shared" && args.types.length() == 1 then Shared.new(TyShared(args.types[0]))
          else Shared.new(TyGeneric(name, args.types))
          end
        TypeResult { type_expr, parser: args.parser }
      else
        TypeResult { type_expr: Shared.new(TyNamed(name)), parser: after }
      end
    end
  else
    TypeResult { type_expr: Shared.new(TyUnit), parser: parser.advance_by(2) }
  end
end

fn parse_type_args(parser: Parser) -> TypesResult = do
  const types: [Shared<TypeExpr>] = []
  const first = parse_type(parser)
  types.push(first.type_expr)
  let state = first.parser
  while state.kind().is_comma() do
    const next = parse_type(state.advance())
    types.push(next.type_expr)
    state = next.parser
  end
  const end_state =
    if state.kind().is_op() && state.kind().op_val() == ">" then state.advance()
    else state
    end
  TypesResult { types, parser: end_state }
end

// ─── Expression and pattern parser ───────────────────────────────────────


// ─── Statement parsers (merged to break exprs<->stmts cycle) ──────────────

export fn parse_stmts_until_end(parser: Parser) -> StmtsResult = do
  const stmts: [Shared<Stmt>] = []
  let state = parser
  while !state.kind().is_end() && !state.at_eof() do
    const result = parse_stmt(state)
    stmts.push(result.stmt)
    state = result.parser.skip_semi()
  end
  StmtsResult { stmts, parser: state.advance() }
end

export fn parse_stmts_until_else_end(parser: Parser) -> StmtsResult = do
  const stmts: [Shared<Stmt>] = []
  let state = parser
  while !state.kind().is_end() && !state.kind().is_else() && !state.at_eof() do
    const result = parse_stmt(state)
    stmts.push(result.stmt)
    state = result.parser
  end
  StmtsResult { stmts, parser: state }
end

fn parse_stmt(parser: Parser) -> StmtResult = do
  const kind = parser.kind()
  if kind.is_let() then
    const after_let  = parser.advance()
    const is_const   = after_let.kind().is_const()
    const name_pos   = if is_const then after_let.advance() else after_let end
    const var_name   = name_pos.kind().ident()
    const type_result =
      if name_pos.advance().kind().is_colon() then
        parse_type(name_pos.advance_by(2))
      else
        TypeResult { type_expr: Shared.new(TyUnit), parser: name_pos.advance() }
      end
    const value_result = parse_expr(type_result.parser.advance())
    StmtResult {
      stmt: Shared.new(StmtLet(var_name, !is_const, type_result.type_expr, value_result.expr)),
      parser: value_result.parser
    }
  else if kind.is_const() then
    const name_pos    = parser.advance()
    const var_name    = name_pos.kind().ident()
    const type_result =
      if name_pos.advance().kind().is_colon() then
        parse_type(name_pos.advance_by(2))
      else
        TypeResult { type_expr: Shared.new(TyUnit), parser: name_pos.advance() }
      end
    const value_result = parse_expr(type_result.parser.advance())
    StmtResult {
      stmt: Shared.new(StmtLet(var_name, false, type_result.type_expr, value_result.expr)),
      parser: value_result.parser
    }
  else if kind.is_break()    then StmtResult { stmt: Shared.new(StmtBreak),    parser: parser.advance() }
  else if kind.is_continue() then StmtResult { stmt: Shared.new(StmtContinue), parser: parser.advance() }
  else if kind.is_return() then
    const value_result = parse_expr(parser.advance())
    StmtResult { stmt: Shared.new(StmtReturn(value_result.expr)), parser: value_result.parser }
  else
    const expr_result = parse_expr(parser)
    if expr_result.parser.kind().is_equal() then
      const rhs = parse_expr(expr_result.parser.advance())
      StmtResult {
        stmt: Shared.new(StmtExpr(Shared.new(ExprBin("=", expr_result.expr, rhs.expr)))),
        parser: rhs.parser
      }
    else
      StmtResult { stmt: Shared.new(StmtExpr(expr_result.expr)), parser: expr_result.parser }
    end
  end
end

// ─── Expression and pattern parser ───────────────────────────────────────

fn parse_pat(parser: Parser) -> PatResult = do
  const kind = parser.kind()
  if kind.is_ident() then
    const name = kind.ident()
    if name == "_" then
      PatResult { pat: Shared.new(PatWild), parser: parser.advance() }
    else if is_ctor_name(name) then
      const after = parser.advance()
      if after.kind().is_lparen() then
        const sub_pats = parse_pat_args(after.advance())
        PatResult { pat: Shared.new(PatCtor(name, sub_pats.pats)), parser: sub_pats.parser }
      else
        PatResult { pat: Shared.new(PatCtor(name, [])), parser: after }
      end
    else
      PatResult { pat: Shared.new(PatIdent(name)), parser: parser.advance() }
    end
  else if kind.is_int() then
    PatResult { pat: Shared.new(PatInt(kind.int_val())), parser: parser.advance() }
  else if kind.is_str() then
    PatResult { pat: Shared.new(PatStr(kind.str_val())), parser: parser.advance() }
  else if kind.is_true() then
    PatResult { pat: Shared.new(PatBool(true)),  parser: parser.advance() }
  else if kind.is_false() then
    PatResult { pat: Shared.new(PatBool(false)), parser: parser.advance() }
  else
    PatResult { pat: Shared.new(PatWild), parser: parser.advance() }
  end
end

fn parse_pat_args(parser: Parser) -> PatsResult = do
  const pats: [Shared<Pat>] = []
  if parser.kind().is_rparen() then
    PatsResult { pats, parser: parser.advance() }
  else
    const first = parse_pat(parser)
    pats.push(first.pat)
    let state = first.parser
    while state.kind().is_comma() do
      const next = parse_pat(state.advance())
      pats.push(next.pat)
      state = next.parser
    end
    PatsResult { pats, parser: state.advance() }
  end
end

// ─── Expression parser (precedence climbing) ─────────────────────────────

export fn parse_expr(parser: Parser) -> ExprResult = parse_pipe(parser)

export fn pipe_desugar(left_expr: Shared<Expr>, right_expr: Shared<Expr>) -> Shared<Expr> =
  match right_expr {
    ExprCall(callee, existing_args) => do
      const new_args: [Shared<Expr>] = [left_expr]
      let i = 0
      while i < existing_args.length() do
        new_args.push(existing_args[i]); i = i + 1
      end
      Shared.new(ExprCall(callee, new_args))
    end,
    _ => do
      const call_args: [Shared<Expr>] = [left_expr]
      Shared.new(ExprCall(right_expr, call_args))
    end
  }

fn parse_pipe(parser: Parser) -> ExprResult = do
  const left = parse_or(parser)
  let expr = left.expr
  let state = left.parser
  while state.kind().is_pipe() do
    const right = parse_or(state.advance())
    expr = pipe_desugar(expr, right.expr)
    state = right.parser
  end
  ExprResult { expr, parser: state }
end

fn parse_or(parser: Parser) -> ExprResult = do
  const left = parse_and(parser)
  let expr = left.expr
  let state = left.parser
  while state.kind().is_op() && state.kind().op_val() == "||" do
    const right = parse_and(state.advance())
    expr = Shared.new(ExprBin("||", expr, right.expr))
    state = right.parser
  end
  ExprResult { expr, parser: state }
end

fn parse_and(parser: Parser) -> ExprResult = do
  const left = parse_cmp(parser)
  let expr = left.expr
  let state = left.parser
  while state.kind().is_op() && state.kind().op_val() == "&&" do
    const right = parse_cmp(state.advance())
    expr = Shared.new(ExprBin("&&", expr, right.expr))
    state = right.parser
  end
  ExprResult { expr, parser: state }
end

fn is_cmp_op(op: string) -> bool =
  op == "==" || op == "!=" || op == "<" || op == ">" || op == "<=" || op == ">="

fn parse_cmp(parser: Parser) -> ExprResult = do
  const left = parse_add(parser)
  let expr = left.expr
  let state = left.parser
  const kind = state.kind()
  if kind.is_op() && is_cmp_op(kind.op_val()) then
    const right = parse_add(state.advance())
    expr = Shared.new(ExprBin(kind.op_val(), expr, right.expr))
    state = right.parser
  end
  ExprResult { expr, parser: state }
end

fn parse_add(parser: Parser) -> ExprResult = do
  const left = parse_mul(parser)
  let expr = left.expr
  let state = left.parser
  let go = true
  while go do
    const kind = state.kind()
    if kind.is_op() && (kind.op_val() == "+" || kind.op_val() == "-") then
      const right = parse_mul(state.advance())
      expr = Shared.new(ExprBin(kind.op_val(), expr, right.expr))
      state = right.parser
    else
      go = false
    end
  end
  ExprResult { expr, parser: state }
end

fn parse_mul(parser: Parser) -> ExprResult = do
  const left = parse_unary(parser)
  let expr = left.expr
  let state = left.parser
  let go = true
  while go do
    const kind = state.kind()
    if kind.is_op() && (kind.op_val() == "*" || kind.op_val() == "/" || kind.op_val() == "%") then
      const right = parse_unary(state.advance())
      expr = Shared.new(ExprBin(kind.op_val(), expr, right.expr))
      state = right.parser
    else
      go = false
    end
  end
  ExprResult { expr, parser: state }
end

fn parse_unary(parser: Parser) -> ExprResult = do
  const kind = parser.kind()
  if kind.is_op() && (kind.op_val() == "!" || kind.op_val() == "-") then
    const inner = parse_unary(parser.advance())
    ExprResult { expr: Shared.new(ExprUn(kind.op_val(), inner.expr)), parser: inner.parser }
  else
    parse_postfix(parser)
  end
end

fn parse_postfix(parser: Parser) -> ExprResult = do
  const base = parse_primary(parser)
  let expr = base.expr
  let state = base.parser
  let go = true
  while go do
    const kind = state.kind()
    if kind.is_dot() then
      const field_name = state.advance().kind().ident()
      if state.advance_by(2).kind().is_lparen() then
        const args = parse_arg_list(state.advance_by(3))
        expr = Shared.new(ExprMethod(expr, field_name, args.exprs))
        state = args.parser
      else
        expr = Shared.new(ExprField(expr, field_name))
        state = state.advance_by(2)
      end
    else if kind.is_lparen() then
      const args = parse_arg_list(state.advance())
      expr = Shared.new(ExprCall(expr, args.exprs))
      state = args.parser
    else if kind.is_lbracket() then
      const index = parse_expr(state.advance())
      expr = Shared.new(ExprIndex(expr, index.expr))
      state = index.parser.advance()
    else if kind.is_question() then
      expr = Shared.new(ExprQuestion(expr))
      state = state.advance()
    else
      go = false
    end
  end
  ExprResult { expr, parser: state }
end

fn parse_arg_list(parser: Parser) -> ExprsResult = do
  const exprs: [Shared<Expr>] = []
  if parser.kind().is_rparen() then
    ExprsResult { exprs, parser: parser.advance() }
  else
    const first = parse_expr(parser)
    exprs.push(first.expr)
    let state = first.parser
    while state.kind().is_comma() do
      const next = parse_expr(state.advance())
      exprs.push(next.expr)
      state = next.parser
    end
    ExprsResult { exprs, parser: state.advance() }
  end
end

fn parse_primary(parser: Parser) -> ExprResult = do
  const kind = parser.kind()
  if kind.is_int() then
    ExprResult { expr: Shared.new(ExprInt(kind.int_val())), parser: parser.advance() }
  else if kind.is_str() then
    ExprResult { expr: Shared.new(ExprStr(kind.str_val())), parser: parser.advance() }
  else if kind.is_true() then
    ExprResult { expr: Shared.new(ExprBool(true)),  parser: parser.advance() }
  else if kind.is_false() then
    ExprResult { expr: Shared.new(ExprBool(false)), parser: parser.advance() }
  else if kind.is_lparen() then
    if parser.advance().kind().is_rparen() then
      if parser.advance_by(2).kind().is_fat_arrow() then
        const params: [string] = []
        const body = parse_expr(parser.advance_by(3))
        ExprResult { expr: Shared.new(ExprLambda(params, body.expr)), parser: body.parser }
      else
        ExprResult { expr: Shared.new(ExprUnit), parser: parser.advance_by(2) }
      end
    else if looks_like_lambda_params(parser.advance()) then
      const param_result = parse_lambda_params(parser.advance())
      const body = parse_expr(param_result.parser.advance())
      ExprResult { expr: Shared.new(ExprLambda(param_result.exprs, body.expr)), parser: body.parser }
    else
      const inner = parse_expr(parser.advance())
      ExprResult { expr: inner.expr, parser: inner.parser.advance() }
    end
  else if kind.is_lbracket() then
    parse_array_lit(parser.advance())
  else if kind.is_if() || kind.is_unless() then
    parse_if_expr(parser)
  else if kind.is_do() then
    parse_block(parser.advance())
  else if kind.is_while() then
    parse_while_expr(parser.advance())
  else if kind.is_for() then
    parse_for_expr(parser.advance())
  else if kind.is_match() then
    parse_match_expr(parser.advance())
  else if kind.is_return() then
    const value = parse_expr(parser.advance())
    const stmts: [Shared<Stmt>] = []
    stmts.push(Shared.new(StmtReturn(value.expr)))
    ExprResult { expr: Shared.new(ExprBlock(stmts, Shared.new(ExprUnit))), parser: value.parser }
  else if kind.is_ident() then
    const name = kind.ident()
    if parser.advance().kind().is_fat_arrow() then
      const params: [string] = [name]
      const body = parse_expr(parser.advance_by(2))
      ExprResult { expr: Shared.new(ExprLambda(params, body.expr)), parser: body.parser }
    else if is_ctor_name(name) && parser.advance().kind().is_lbrace() then
      parse_record_expr(parser.advance_by(2), name)
    else
      ExprResult { expr: Shared.new(ExprIdent(name)), parser: parser.advance() }
    end
  else
    ExprResult { expr: Shared.new(ExprUnit), parser: parser.advance() }
  end
end

// Check if parser (after `(`) looks like lambda params: IDENT (, IDENT)* ) =>
fn looks_like_lambda_params(parser: Parser) -> bool = do
  let state = parser
  let ok = true
  if !state.kind().is_ident() then
    ok = false
  else
    state = state.advance()
    while state.kind().is_comma() do
      state = state.advance()
      if !state.kind().is_ident() then
        ok = false
        state = state.advance()
      else
        state = state.advance()
      end
    end
    if !state.kind().is_rparen() then
      ok = false
    else
      ok = state.advance().kind().is_fat_arrow()
    end
  end
  ok
end

// Parse lambda params: IDENT (, IDENT)* ) — stops AFTER `)`
fn parse_lambda_params(parser: Parser) -> NamesResult = do
  const names: [string] = []
  let state = parser
  names.push(state.kind().ident())
  state = state.advance()
  while state.kind().is_comma() do
    state = state.advance()
    names.push(state.kind().ident())
    state = state.advance()
  end
  NamesResult { exprs: names, parser: state.advance() }
end

fn parse_array_lit(parser: Parser) -> ExprResult = do
  const exprs: [Shared<Expr>] = []
  if parser.kind().is_rbracket() then
    ExprResult { expr: Shared.new(ExprArray(exprs)), parser: parser.advance() }
  else
    const first = parse_expr(parser)
    exprs.push(first.expr)
    let state = first.parser
    while state.kind().is_comma() do
      const next = parse_expr(state.advance())
      exprs.push(next.expr)
      state = next.parser
    end
    ExprResult { expr: Shared.new(ExprArray(exprs)), parser: state.advance() }
  end
end

export fn parse_if_expr(parser: Parser) -> ExprResult = do
  const is_negated = parser.kind().is_unless()
  const cond_result = parse_expr(parser.advance())
  const condition = if is_negated
    then Shared.new(ExprUn("!", cond_result.expr))
    else cond_result.expr
    end
  const then_result = parse_stmts_until_else_end(cond_result.parser.advance())
  const then_expr = then_result.to_block_expr()
  if then_result.parser.kind().is_else() then
    const after_else = then_result.parser.advance()
    if after_else.kind().is_if() || after_else.kind().is_unless() then
      const else_result = parse_if_expr(after_else)
      ExprResult { expr: Shared.new(ExprIf(condition, then_expr, else_result.expr)), parser: else_result.parser }
    else
      const else_stmts = parse_stmts_until_end(after_else)
      ExprResult { expr: Shared.new(ExprIf(condition, then_expr, else_stmts.to_block_expr())), parser: else_stmts.parser }
    end
  else
    ExprResult {
      expr: Shared.new(ExprIf(condition, then_expr, Shared.new(ExprUnit))),
      parser: then_result.parser.advance()
    }
  end
end

fn parse_block(parser: Parser) -> ExprResult = do
  const result = parse_stmts_until_end(parser)
  ExprResult { expr: result.to_block_expr(), parser: result.parser }
end

fn is_unit_expr(expr: Shared<Expr>) -> bool =
  match expr {
    ExprUnit                => true,
    ExprBlock(_, result)    => is_unit_expr(result),
    ExprIf(_, _, else_expr) => is_unit_expr(else_expr),
    _                       => false
  }

fn block_result(stmts: [Shared<Stmt>]) -> Shared<Expr> =
  if stmts.length() == 0 then Shared.new(ExprUnit)
  else match stmts[stmts.length() - 1] {
    StmtExpr(expr) => if is_unit_expr(expr) then Shared.new(ExprUnit) else expr end,
    _              => Shared.new(ExprUnit)
  }
  end

fn block_body(stmts: [Shared<Stmt>]) -> [Shared<Stmt>] = do
  if stmts.length() == 0 then stmts
  else match stmts[stmts.length() - 1] {
    StmtExpr(expr) =>
      if is_unit_expr(expr) then stmts
      else
        let result: [Shared<Stmt>] = []; let i = 0
        while i < stmts.length() - 1 do result.push(stmts[i]); i = i + 1 end
        result
      end,
    _ => stmts
  }
  end
end

extend StmtsResult {
  fn to_block_expr(self) -> Shared<Expr> =
    Shared.new(ExprBlock(block_body(self.stmts), block_result(self.stmts)))
}

fn parse_while_expr(parser: Parser) -> ExprResult = do
  const cond = parse_expr(parser)
  const body = parse_stmts_until_end(cond.parser.advance())
  ExprResult { expr: Shared.new(ExprWhile(cond.expr, body.stmts)), parser: body.parser }
end

fn parse_for_expr(parser: Parser) -> ExprResult = do
  const var_name = parser.kind().ident()
  const iter = parse_expr(parser.advance_by(2))
  const body = parse_stmts_until_end(iter.parser.advance())
  ExprResult { expr: Shared.new(ExprFor(var_name, iter.expr, body.stmts)), parser: body.parser }
end

fn parse_match_expr(parser: Parser) -> ExprResult = do
  const subject = parse_expr(parser)
  const arms = parse_arms(subject.parser.advance())
  ExprResult { expr: Shared.new(ExprMatch(subject.expr, arms.arms)), parser: arms.parser }
end

fn parse_arms(parser: Parser) -> ArmsResult = do
  const arms: [Shared<MatchArm>] = []
  let state = parser
  while !state.kind().is_rbrace() && !state.at_eof() do
    const pat_result  = parse_pat(state)
    const body_result = parse_expr(pat_result.parser.advance())
    arms.push(Shared.new(MatchArm { pat: pat_result.pat, body: body_result.expr }))
    state = body_result.parser
    if state.kind().is_comma() then state = state.advance() end
  end
  ArmsResult { arms, parser: state.advance() }
end

fn parse_record_fields(parser: Parser) -> FieldValsResult = do
  const field_vals: [Shared<FieldVal>] = []
  let state = parser
  while !state.kind().is_rbrace() && !state.at_eof() do
    const field_name = state.kind().ident()
    const after_name = state.advance()
    if after_name.kind().is_colon() then
      const value_result = parse_expr(after_name.advance())
      field_vals.push(Shared.new(FieldVal { name: field_name, val: value_result.expr }))
      state = value_result.parser
    else
      field_vals.push(Shared.new(FieldVal { name: field_name, val: Shared.new(ExprIdent(field_name)) }))
      state = after_name
    end
    if state.kind().is_comma() then state = state.advance() end
  end
  FieldValsResult { field_vals, parser: state.advance() }
end

fn parse_record_expr(parser: Parser, record_name: string) -> ExprResult =
  if parser.kind().is_spread() then
    const base_result = parse_expr(parser.advance())
    let after_base = base_result.parser
    if after_base.kind().is_comma() then after_base = after_base.advance() end
    const fields_result = parse_record_fields(after_base)
    ExprResult {
      expr: Shared.new(ExprRecordUpdate(record_name, base_result.expr, fields_result.field_vals)),
      parser: fields_result.parser
    }
  else
    const fields_result = parse_record_fields(parser)
    ExprResult { expr: Shared.new(ExprRecord(record_name, fields_result.field_vals)), parser: fields_result.parser }
  end

// ─── Declaration parsers ──────────────────────────────────────────────────


fn parse_import_decl(parser: Parser) -> DeclResult = do
  let state = parser
  const symbols: [string] = []
  if state.kind().is_op() && state.kind().op_val() == "*" then
    symbols.push("*")
    state = state.advance()
  else if state.kind().is_lbrace() then
    state = state.advance()
    while state.kind().is_ident() || (state.kind().is_op() && state.kind().op_val() == "*") do
      if state.kind().is_op() && state.kind().op_val() == "*" then
        symbols.push("*")
        state = state.advance()
      else
        symbols.push(state.kind().ident())
        state = state.advance()
      end
      if state.kind().is_comma() then state = state.advance() end
    end
    state = if state.kind().is_rbrace() then state.advance() else state end
  end
  state = if state.kind().is_from() then state.advance() else state end
  const path = if state.kind().is_str() then state.kind().str_val() else "" end
  DeclResult { decl: Shared.new(DeclImport(path, symbols)), parser: state.advance() }
end

fn parse_extend_decl(parser: Parser) -> DeclResult = do
  const type_name = parser.kind().ident()
  let state = parser
  while state.kind().is_colon() || (state.kind().is_ident() && !state.kind().is_lbrace()) do
    state = state.advance()
  end
  let methods_state = if state.kind().is_lbrace() then state.advance() else state end
  const methods: [Shared<Decl>] = []
  while !methods_state.kind().is_rbrace() && !methods_state.at_eof() do
    if methods_state.kind().is_fn() then
      const method_result = parse_extend_method(methods_state, type_name)
      methods.push(method_result.decl)
      methods_state = method_result.parser
    else
      methods_state = methods_state.advance()
    end
  end
  DeclResult { decl: Shared.new(DeclExtend(type_name, methods)), parser: methods_state.advance() }
end

fn parse_extend_method(parser: Parser, type_name: string) -> DeclResult = do
  const fn_name       = parser.advance().kind().ident()
  const mangled_name  = type_name + "_" + fn_name
  const after_lparen  = parser.advance_by(3)
  const after_self    = if after_lparen.kind().is_ident() && after_lparen.kind().ident() == "self"
    then after_lparen.advance()
    else after_lparen
    end
  const self_param = Shared.new(Param { name: "self", is_mut: false, typ: Shared.new(TyNamed(type_name)) })
  const params: [Shared<Param>] = []
  params.push(self_param)
  const params_state = if after_self.kind().is_comma() then after_self.advance() else after_self end
  const rest_params = if params_state.kind().is_rparen()
    then ParamsResult { params: [], parser: params_state.advance() }
    else parse_params(params_state)
    end
  let index = 0
  while index < rest_params.params.length() do
    params.push(rest_params.params[index]); index = index + 1
  end
  const ret_type_result = parse_type(rest_params.parser.advance())
  const body_result     = parse_expr(ret_type_result.parser.advance())
  DeclResult {
    decl:   Shared.new(DeclFn(mangled_name, params, ret_type_result.type_expr, body_result.expr)),
    parser: body_result.parser
  }
end

export fn parse_decl(parser: Parser) -> DeclResult = do
  const kind = parser.kind()
  if kind.is_ident() && kind.ident() == "export" then
    const inner = parse_decl(parser.advance())
    DeclResult { decl: Shared.new(DeclExported(inner.decl)), parser: inner.parser }
  else if kind.is_fn() || (kind.is_extern() && parser.advance().kind().is_fn()) then
    parse_fn_decl(parser)
  else if kind.is_type() then
    parse_type_decl(parser.advance())
  else if kind.is_extend() then
    parse_extend_decl(parser.advance())
  else if kind.is_import() then
    parse_import_decl(parser.advance())
  else
    DeclResult { decl: Shared.new(DeclFn("__skip__", [], Shared.new(TyUnit), Shared.new(ExprUnit))), parser: parser.advance() }
  end
end

fn parse_fn_decl(parser: Parser) -> DeclResult = do
  const fn_start        = if parser.kind().is_extern() then parser.advance() else parser end
  const fn_name         = fn_start.advance().kind().ident()
  const params_result   = parse_params(fn_start.advance_by(3))
  const ret_type_result = parse_type(params_result.parser.advance())
  const body_result     = parse_expr(ret_type_result.parser.advance())
  DeclResult {
    decl:   Shared.new(DeclFn(fn_name, params_result.params, ret_type_result.type_expr, body_result.expr)),
    parser: body_result.parser
  }
end

fn parse_params(parser: Parser) -> ParamsResult = do
  const params: [Shared<Param>] = []
  if parser.kind().is_rparen() then
    ParamsResult { params, parser: parser.advance() }
  else
    const first = parse_param(parser)
    params.push(first.param)
    let state = first.parser
    while state.kind().is_comma() do
      const next = parse_param(state.advance())
      params.push(next.param)
      state = next.parser
    end
    ParamsResult { params, parser: state.advance() }
  end
end

fn parse_param(parser: Parser) -> ParamResult = do
  const is_mutable  = parser.kind().is_mut()
  const name_pos    = if is_mutable then parser.advance() else parser end
  const type_result = parse_type(name_pos.advance_by(2))
  ParamResult {
    param:  Shared.new(Param { name: name_pos.kind().ident(), is_mut: is_mutable, typ: type_result.type_expr }),
    parser: type_result.parser
  }
end

fn parse_type_decl(parser: Parser) -> DeclResult = do
  const type_name  = parser.kind().ident()
  const after_eq   = parser.advance_by(2)
  const first_kind = after_eq.kind()
  if first_kind.is_lbrace() then
    const field_defs_result = parse_field_defs(after_eq.advance())
    const variants: [Shared<TypeVariant>] = []
    variants.push(Shared.new(VarRecord(type_name, field_defs_result.field_defs)))
    DeclResult { decl: Shared.new(DeclType(type_name, variants)), parser: field_defs_result.parser }
  else if first_kind.is_ident() && is_ctor_name(first_kind.ident()) && after_eq.advance().kind().is_lbrace() then
    const field_defs_result = parse_field_defs(after_eq.advance_by(2))
    const variants: [Shared<TypeVariant>] = []
    variants.push(Shared.new(VarRecord(first_kind.ident(), field_defs_result.field_defs)))
    DeclResult { decl: Shared.new(DeclType(type_name, variants)), parser: field_defs_result.parser }
  else
    const variants_result = parse_variants(after_eq)
    DeclResult { decl: Shared.new(DeclType(type_name, variants_result.variants)), parser: variants_result.parser }
  end
end

fn is_decl_start(kind: TKind) -> bool =
  kind.is_type() || kind.is_fn() || kind.is_extend() || kind.is_import()
  || (kind.is_ident() && (kind.ident() == "export" || kind.ident() == "type" || kind.ident() == "fn" || kind.ident() == "extend" || kind.ident() == "import"))

fn parse_variants_continue(state: Parser) -> bool =
  if state.at_eof() then false
  else if is_decl_start(state.kind()) then false
  else state.kind().is_bar() || state.kind().is_ident()
  end

fn parse_variants(parser: Parser) -> VariantsResult = do
  const variants: [Shared<TypeVariant>] = []
  let state = if parser.kind().is_bar() then parser.advance() else parser end
  while parse_variants_continue(state) do
    const variant_result = parse_variant(state)
    variants.push(variant_result.variant)
    state = variant_result.parser
    if state.kind().is_bar() then state = state.advance() end
  end
  VariantsResult { variants, parser: state }
end

fn parse_variant(parser: Parser) -> VariantResult = do
  const variant_name = parser.kind().ident()
  const after_name   = parser.advance()
  if after_name.kind().is_lparen() then
    const types_result = parse_tuple_types(after_name.advance())
    VariantResult { variant: Shared.new(VarTuple(variant_name, types_result.types)), parser: types_result.parser }
  else if after_name.kind().is_lbrace() then
    const field_defs_result = parse_field_defs(after_name.advance())
    VariantResult { variant: Shared.new(VarRecord(variant_name, field_defs_result.field_defs)), parser: field_defs_result.parser }
  else
    VariantResult { variant: Shared.new(VarUnit(variant_name)), parser: after_name }
  end
end

fn parse_tuple_types(parser: Parser) -> TypesResult = do
  const types: [Shared<TypeExpr>] = []
  const first = parse_type(parser)
  types.push(first.type_expr)
  let state = first.parser
  while state.kind().is_comma() do
    const next = parse_type(state.advance())
    types.push(next.type_expr)
    state = next.parser
  end
  TypesResult { types, parser: state.advance() }
end

fn parse_field_defs(parser: Parser) -> FieldDefsResult = do
  const field_defs: [Shared<FieldDef>] = []
  let state = parser
  while !state.kind().is_rbrace() && !state.at_eof() do
    const field_name  = state.kind().ident()
    const type_result = parse_type(state.advance_by(2))
    field_defs.push(Shared.new(FieldDef { name: field_name, typ: type_result.type_expr }))
    state = type_result.parser
    if state.kind().is_comma() then state = state.advance() end
  end
  FieldDefsResult { field_defs, parser: state.advance() }
end

// ─── Entry point ──────────────────────────────────────────────────────────

export fn parse_program(tokens: [Token]) -> Program = do
  const decls: [Shared<Decl>] = []
  let state = parser_new(tokens)
  while !state.at_eof() do
    const result = parse_decl(state)
    decls.push(result.decl)
    state = result.parser
  end
  Program { decls }
end

// Checker: name resolution.


fn scope_contains(scope: [string], name: string) -> bool = do
  let found = false
  let index = 0
  while index < scope.length() do
    if scope[index] == name then found = true end
    index = index + 1
  end
  found
end

fn pattern_bindings(pattern: Shared<Pat>) -> [string] = do
  const accumulator: [string] = []
  collect_pattern_bindings(pattern, accumulator)
end

fn collect_pattern_bindings(pattern: Shared<Pat>, mut accumulator: [string]) -> [string] = do
  match pattern {
    PatIdent(name) => do accumulator.push(name); accumulator end,
    PatCtor(_, sub_patterns) => do
      let index = 0
      while index < sub_patterns.length() do
        accumulator = collect_pattern_bindings(sub_patterns[index], accumulator); index = index + 1
      end
      accumulator
    end,
    _ => accumulator
  }
end

// ─── Name resolution ──────────────────────────────────────────────────────

export fn collect_globals(prog: Program) -> [string] = do
  const names: [string] = []
  names.push("true"); names.push("false"); names.push("exit")
  names.push("print"); names.push("println"); names.push("args")
  names.push("File"); names.push("Shared"); names.push("Map")
  let i = 0
  while i < prog.decls.length() do
    match decl_inner(prog.decls[i]) {
      DeclFn(name, _, _, _) => do names.push(name); () end,
      DeclType(name, variants) => do
        names.push(name); let j = 0
        while j < variants.length() do
          match variants[j] {
            VarUnit(variant_name)     => do names.push(variant_name); () end,
            VarTuple(variant_name, _) => do names.push(variant_name); () end,
            VarRecord(variant_name, _) => do names.push(variant_name); () end
          }
          j = j + 1
        end
        ()
      end,
      DeclExtend(_, _) => do () end,
      DeclImport(_, _) => do () end,
      DeclExported(_)  => do () end
    }
    i = i + 1
  end
  names
end

export fn check_names_expr(expr: Shared<Expr>, locals: [string], globals: [string]) -> [string] = do
  match expr {
    ExprIdent(name) => do
      let errors: [string] = []
      if !scope_contains(locals, name) && !scope_contains(globals, name) then
        errors.push("undefined: " + name)
      end
      errors
    end,
    ExprBin(_, left, right) =>
      errs_append(check_names_expr(left, locals, globals), check_names_expr(right, locals, globals)),
    ExprUn(_, inner) => check_names_expr(inner, locals, globals),
    ExprCall(func, args) => do
      let errors = check_names_expr(func, locals, globals); let i = 0
      while i < args.length() do
        errors = errs_append(errors, check_names_expr(args[i], locals, globals)); i = i + 1
      end
      errors
    end,
    ExprMethod(obj, _, args) => do
      let errors = check_names_expr(obj, locals, globals); let i = 0
      while i < args.length() do
        errors = errs_append(errors, check_names_expr(args[i], locals, globals)); i = i + 1
      end
      errors
    end,
    ExprField(obj, _) => check_names_expr(obj, locals, globals),
    ExprIndex(obj, idx) =>
      errs_append(check_names_expr(obj, locals, globals), check_names_expr(idx, locals, globals)),
    ExprIf(cond, then_expr, else_expr) =>
      errs_append(
        errs_append(check_names_expr(cond, locals, globals), check_names_expr(then_expr, locals, globals)),
        check_names_expr(else_expr, locals, globals)),
    ExprBlock(stmts, result) => do
      const stmt_result = check_names_stmts(stmts, locals, globals)
      stmt_result.append_expr_errors(check_names_expr(result, stmt_result.scope, globals))
    end,
    ExprWhile(cond, stmts) => do
      const check_result = check_names_stmts(stmts, locals, globals)
      errs_append(check_names_expr(cond, locals, globals), check_result.errors)
    end,
    ExprFor(var, iter, stmts) => do
      const inner = locals; inner.push(var)
      const check_result = check_names_stmts(stmts, inner, globals)
      errs_append(check_names_expr(iter, locals, globals), check_result.errors)
    end,
    ExprMatch(subject, arms) => do
      let errors = check_names_expr(subject, locals, globals); let i = 0
      while i < arms.length() do
        const bindings = pattern_bindings(arms[i].pat)
        const arm_scope = locals; let index = 0
        while index < bindings.length() do arm_scope.push(bindings[index]); index = index + 1 end
        errors = errs_append(errors, check_names_expr(arms[i].body, arm_scope, globals)); i = i + 1
      end
      errors
    end,
    ExprRecord(_, field_vals) => do
      let errors: [string] = []; let i = 0
      while i < field_vals.length() do
        errors = errs_append(errors, check_names_expr(field_vals[i].val, locals, globals)); i = i + 1
      end
      errors
    end,
    ExprRecordUpdate(_, base, field_vals) => do
      let errors: [string] = check_names_expr(base, locals, globals); let i = 0
      while i < field_vals.length() do
        errors = errs_append(errors, check_names_expr(field_vals[i].val, locals, globals)); i = i + 1
      end
      errors
    end,
    ExprArray(exprs) => do
      let errors: [string] = []; let i = 0
      while i < exprs.length() do
        errors = errs_append(errors, check_names_expr(exprs[i], locals, globals)); i = i + 1
      end
      errors
    end,
    ExprQuestion(inner) => check_names_expr(inner, locals, globals),
    ExprLambda(params, body) => do
      const lambda_locals: [string] = []
      let i = 0
      while i < locals.length() do lambda_locals.push(locals[i]); i = i + 1 end
      let j = 0
      while j < params.length() do lambda_locals.push(params[j]); j = j + 1 end
      check_names_expr(body, lambda_locals, globals)
    end,
    _ => []
  }
end

export type NameCheckResult = NameCheckResult { errors: [string], scope: [string] }

extend NameCheckResult {
  fn append_expr_errors(self, expr_errors: [string]) -> [string] =
    errs_append(errors, expr_errors)
}

export fn check_names_stmts(stmts: [Shared<Stmt>], locals: [string], globals: [string]) -> NameCheckResult = do
  let errors: [string] = []; const scope = locals; let i = 0
  while i < stmts.length() do
    match stmts[i] {
      StmtLet(name, _, _, value) => do
        errors = errs_append(errors, check_names_expr(value, scope, globals))
        scope.push(name)
        ()
      end,
      StmtExpr(expr)   => do errors = errs_append(errors, check_names_expr(expr, scope, globals)); () end,
      StmtReturn(expr) => do errors = errs_append(errors, check_names_expr(expr, scope, globals)); () end,
      StmtBreak    => do () end,
      StmtContinue => do () end
    }
    i = i + 1
  end
  NameCheckResult { errors: errors, scope: scope }
end

// ─── Semantic type ────────────────────────────────────────────────────────


export type Type =
  | TI32 | TString | TBool | TUnit
  | TArray(Shared<Type>)
  | TShared(Shared<Type>)
  | TNamed(string)
  | TFn([Shared<Type>], Shared<Type>)
  | TUnknown

// ─── Type registry ────────────────────────────────────────────────────────

export type TypeRegistry = TypeRegistry {
  fn_types:    Map<string, Shared<Type>>,
  ctor_types:  Map<string, Shared<Type>>,
  ctor_params: Map<string, [Shared<Type>]>,
  field_types: Map<string, Map<string, Shared<Type>>>
}

export extend TypeRegistry {
  fn fn_type(self, name: string) -> Shared<Type> =
    fn_types.get(name)

  fn has_fn(self, name: string) -> bool =
    fn_types.has(name)

  fn ctor_type(self, name: string) -> Shared<Type> =
    ctor_types.get(name)

  fn has_ctor(self, name: string) -> bool =
    ctor_types.has(name)

  fn ctor_params_for(self, name: string) -> [Shared<Type>] =
    if ctor_params.has(name) then ctor_params.get(name) else [] end

  fn fields_for(self, type_name: string) -> Map<string, Shared<Type>> =
    field_types.get(type_name)

  fn has_fields(self, type_name: string) -> bool =
    field_types.has(type_name)
}

export fn empty_registry() -> TypeRegistry =
  TypeRegistry { fn_types: Map.new(), ctor_types: Map.new(),
                 ctor_params: Map.new(), field_types: Map.new() }

export fn type_from_annotation(type_expr: Shared<TypeExpr>) -> Shared<Type> =
  match type_expr {
    TyI32     => Shared.new(TI32),
    TyString  => Shared.new(TString),
    TyBool    => Shared.new(TBool),
    TyUnit    => Shared.new(TUnit),
    TyNamed(name)   => Shared.new(TNamed(name)),
    TyArray(inner)  => Shared.new(TArray(type_from_annotation(inner))),
    TyShared(inner) => Shared.new(TShared(type_from_annotation(inner))),
    TyFn(params, ret) => do
      const param_types: [Shared<Type>] = []; let i = 0
      while i < params.length() do param_types.push(type_from_annotation(params[i])); i = i + 1 end
      Shared.new(TFn(param_types, type_from_annotation(ret)))
    end,
    _ => Shared.new(TUnknown)
  }

export fn build_registry(prog: Program) -> TypeRegistry = do
  let registry = empty_registry()
  let i = 0
  while i < prog.decls.length() do
    registry = register_decl(registry, prog.decls[i]); i = i + 1
  end
  registry
end

fn register_decl(mut registry: TypeRegistry, decl: Shared<Decl>) -> TypeRegistry = do
  match decl {
    DeclExtend(_, _) => registry,
    DeclFn(name, params, return_type, _) => do
      const param_types: [Shared<Type>] = []
      let i = 0
      while i < params.length() do
        param_types.push(type_from_annotation(params[i].typ)); i = i + 1
      end
      registry.fn_types.set(name, Shared.new(TFn(param_types, type_from_annotation(return_type))))
      registry
    end,
    DeclType(type_name, variants) => do
      let i = 0
      while i < variants.length() do
        registry = register_variant(registry, type_name, variants[i]); i = i + 1
      end
      registry
    end,
    DeclImport(_, _) => registry,
    DeclExported(d) => register_decl(registry, d)
  }
end

fn register_variant(mut registry: TypeRegistry, type_name: string, variant: Shared<TypeVariant>) -> TypeRegistry = do
  const result_type = Shared.new(TNamed(type_name))
  match variant {
    VarUnit(variant_name) => do
      registry.ctor_types.set(variant_name, result_type)
      registry.ctor_params.set(variant_name, [])
      registry
    end,
    VarTuple(variant_name, field_types) => do
      const field_type_list: [Shared<Type>] = []
      let i = 0
      while i < field_types.length() do
        field_type_list.push(type_from_annotation(field_types[i])); i = i + 1
      end
      registry.ctor_types.set(variant_name, result_type)
      registry.ctor_params.set(variant_name, field_type_list)
      registry
    end,
    VarRecord(variant_name, field_defs) => do
      const field_map: Map<string, Shared<Type>> = Map.new()
      let i = 0
      while i < field_defs.length() do
        field_map.set(field_defs[i].name, type_from_annotation(field_defs[i].typ)); i = i + 1
      end
      registry.ctor_types.set(variant_name, result_type)
      registry.ctor_params.set(variant_name, [])
      registry.field_types.set(variant_name, field_map)
      registry.field_types.set(type_name, field_map)
      registry
    end
  }
end

// ─── Type inference ───────────────────────────────────────────────────────


type InferResult     = InferResult     { inferred_type: Shared<Type>,             errors: [string] }
type StmtInferResult = StmtInferResult { type_env:      Map<string, Shared<Type>>, errors: [string] }

extend InferResult {
  fn with_type(self, new_type: Shared<Type>) -> InferResult =
    InferResult { inferred_type: new_type, errors }

  fn absorb(self, other: InferResult) -> InferResult =
    InferResult { inferred_type, errors: errs_append(errors, other.errors) }

  fn absorb_stmt(self, stmt_result: StmtInferResult) -> InferResult =
    InferResult { inferred_type, errors: errs_append(stmt_result.errors, errors) }
}

fn infer_ok(type_val: Shared<Type>) -> InferResult =
  InferResult { inferred_type: type_val, errors: [] }

fn binary_op_type(op: string, left_type: Shared<Type>) -> Shared<Type> =
  if op == "+" || op == "-" || op == "*" || op == "/" || op == "%" then
    match left_type { TString => Shared.new(TString), _ => Shared.new(TI32) }
  else if op == "=" then Shared.new(TUnit)
  else Shared.new(TBool)
  end

fn method_return_type(method_name: string) -> Shared<Type> =
  if method_name == "length" || method_name == "size" || method_name == "to_i" then Shared.new(TI32)
  else if method_name == "push" || method_name == "set" then Shared.new(TUnit)
  else if method_name == "char_at" || method_name == "join" || method_name == "to_string"
       || method_name == "substring" || method_name == "to_lower" then Shared.new(TString)
  else if method_name == "has" then Shared.new(TBool)
  else Shared.new(TUnknown)
  end

fn infer_args_errors(initial: InferResult, args: [Shared<Expr>], type_env: Map<string, Shared<Type>>, registry: TypeRegistry) -> InferResult = do
  let result = initial
  let index = 0
  while index < args.length() do
    result = result.absorb(infer_expr(args[index], type_env, registry))
    index = index + 1
  end
  result
end

fn infer_field_vals_errors(initial: InferResult, field_vals: [Shared<FieldVal>], type_env: Map<string, Shared<Type>>, registry: TypeRegistry) -> InferResult = do
  let result = initial
  let index = 0
  while index < field_vals.length() do
    result = result.absorb(infer_expr(field_vals[index].val, type_env, registry))
    index = index + 1
  end
  result
end

fn field_lookup_type(obj_type: Shared<Type>, field_name: string, registry: TypeRegistry) -> Shared<Type> = do
  const type_name = match obj_type { TNamed(name) => name, _ => "" }
  if type_name != "" && registry.has_fields(type_name) then
    const field_map = registry.fields_for(type_name)
    if field_map.has(field_name) then field_map.get(field_name) else Shared.new(TUnknown) end
  else Shared.new(TUnknown)
  end
end

fn infer_expr(expr: Shared<Expr>, type_env: Map<string, Shared<Type>>, registry: TypeRegistry) -> InferResult = do
  match expr {
    ExprInt(_)  => infer_ok(Shared.new(TI32)),
    ExprStr(_)  => infer_ok(Shared.new(TString)),
    ExprBool(_) => infer_ok(Shared.new(TBool)),
    ExprUnit    => infer_ok(Shared.new(TUnit)),
    ExprIdent(name) =>
      if type_env.has(name) then infer_ok(type_env.get(name))
      else if registry.has_fn(name) then infer_ok(registry.fn_type(name))
      else if registry.has_ctor(name) then infer_ok(registry.ctor_type(name))
      else infer_ok(Shared.new(TUnknown))
      end,
    ExprBin(op, left, right) => do
      const left_result  = infer_expr(left, type_env, registry)
      const right_result = infer_expr(right, type_env, registry)
      left_result.absorb(right_result).with_type(binary_op_type(op, left_result.inferred_type))
    end,
    ExprUn(op, inner) => do
      const inner_result = infer_expr(inner, type_env, registry)
      const result_type  = if op == "!" then Shared.new(TBool) else inner_result.inferred_type end
      inner_result.with_type(result_type)
    end,
    ExprCall(func, args) => do
      const func_result  = infer_expr(func, type_env, registry)
      const with_args    = infer_args_errors(func_result, args, type_env, registry)
      const return_type  = match func_result.inferred_type { TFn(_, ret) => ret, _ => Shared.new(TUnknown) }
      with_args.with_type(return_type)
    end,
    ExprMethod(obj, method_name, args) => do
      const obj_result = infer_expr(obj, type_env, registry)
      infer_args_errors(obj_result, args, type_env, registry).with_type(method_return_type(method_name))
    end,
    ExprField(obj, field_name) => do
      const obj_result = infer_expr(obj, type_env, registry)
      obj_result.with_type(field_lookup_type(obj_result.inferred_type, field_name, registry))
    end,
    ExprIndex(obj, idx) => do
      const obj_result  = infer_expr(obj, type_env, registry)
      const idx_result  = infer_expr(idx, type_env, registry)
      const elem_type   = match obj_result.inferred_type { TArray(inner) => inner, _ => Shared.new(TUnknown) }
      obj_result.absorb(idx_result).with_type(elem_type)
    end,
    ExprIf(cond, then_expr, else_expr) => do
      const cond_result = infer_expr(cond, type_env, registry)
      const then_result = infer_expr(then_expr, type_env, registry)
      const else_result = infer_expr(else_expr, type_env, registry)
      then_result.absorb(cond_result).absorb(else_result)
    end,
    ExprBlock(stmts, result) => do
      const stmts_result = infer_stmts(stmts, type_env, registry)
      const result_infer = infer_expr(result, stmts_result.type_env, registry)
      result_infer.absorb_stmt(stmts_result)
    end,
    ExprWhile(cond, stmts) => do
      const cond_result  = infer_expr(cond, type_env, registry)
      const stmts_result = infer_stmts(stmts, type_env, registry)
      cond_result.absorb_stmt(stmts_result).with_type(Shared.new(TUnit))
    end,
    ExprFor(var, iter, stmts) => do
      const iter_result  = infer_expr(iter, type_env, registry)
      const elem_type    = match iter_result.inferred_type { TArray(inner) => inner, _ => Shared.new(TUnknown) }
      const inner_env    = type_env; inner_env.set(var, elem_type)
      const stmts_result = infer_stmts(stmts, inner_env, registry)
      iter_result.absorb_stmt(stmts_result).with_type(Shared.new(TUnit))
    end,
    ExprMatch(subject, arms) => do
      const subject_result = infer_expr(subject, type_env, registry)
      let errors = subject_result.errors
      let arm_type: Shared<Type> = Shared.new(TUnknown)
      let i = 0
      while i < arms.length() do
        const arm_env    = env_for_pat(type_env, arms[i].pat, registry)
        const arm_result = infer_expr(arms[i].body, arm_env, registry)
        errors = errs_append(errors, arm_result.errors)
        if i == 0 then arm_type = arm_result.inferred_type end
        i = i + 1
      end
      InferResult { inferred_type: arm_type, errors: errors }
    end,
    ExprRecord(name, field_vals) =>
      infer_field_vals_errors(infer_ok(Shared.new(TNamed(name))), field_vals, type_env, registry),
    ExprRecordUpdate(name, base, field_vals) => do
      const base_result = infer_expr(base, type_env, registry)
      infer_field_vals_errors(base_result.with_type(Shared.new(TNamed(name))), field_vals, type_env, registry)
    end,
    ExprArray(exprs) => do
      const first_type = if exprs.length() > 0
        then infer_expr(exprs[0], type_env, registry).inferred_type
        else Shared.new(TUnknown)
        end
      infer_args_errors(infer_ok(Shared.new(TArray(first_type))), exprs, type_env, registry)
    end,
    ExprQuestion(inner) => infer_expr(inner, type_env, registry),
    ExprLambda(params, body) => do
      let lambda_env = type_env
      let i = 0
      while i < params.length() do
        lambda_env.set(params[i], Shared.new(TUnknown)); i = i + 1
      end
      const ret_result = infer_expr(body, lambda_env, registry)
      infer_ok(Shared.new(TFn([], ret_result.inferred_type)))
    end
  }
end

fn infer_stmts(stmts: [Shared<Stmt>], type_env: Map<string, Shared<Type>>, registry: TypeRegistry) -> StmtInferResult = do
  let errors: [string] = []; let current_env = type_env; let i = 0
  while i < stmts.length() do
    match stmts[i] {
      StmtLet(name, _, _, value) => do
        const value_result = infer_expr(value, current_env, registry)
        current_env.set(name, value_result.inferred_type)
        errors = errs_append(errors, value_result.errors)
      end,
      StmtExpr(expr)   => do
        const expr_res = infer_expr(expr, current_env, registry)
        errors = errs_append(errors, expr_res.errors)
      end,
      StmtReturn(expr) => do
        const ret_res = infer_expr(expr, current_env, registry)
        errors = errs_append(errors, ret_res.errors)
      end,
      StmtBreak    => do end,
      StmtContinue => do end
    }
    i = i + 1
  end
  StmtInferResult { errors: errors, type_env: current_env }
end

fn env_for_pat(type_env: Map<string, Shared<Type>>, pat: Shared<Pat>, registry: TypeRegistry) -> Map<string, Shared<Type>> = do
  match pat {
    PatIdent(name) => do let env = type_env; env.set(name, Shared.new(TUnknown)); env end,
    PatCtor(ctor_name, sub_pats) => do
      const param_types = registry.ctor_params_for(ctor_name)
      let current_env = type_env; let i = 0
      while i < sub_pats.length() do
        const sub_type = if i < param_types.length() then param_types[i] else Shared.new(TUnknown) end
        current_env = env_for_pat_with_type(current_env, sub_pats[i], sub_type, registry); i = i + 1
      end
      current_env
    end,
    _ => type_env
  }
end

fn env_for_pat_with_type(type_env: Map<string, Shared<Type>>, pat: Shared<Pat>, type_val: Shared<Type>, registry: TypeRegistry) -> Map<string, Shared<Type>> = do
  match pat {
    PatIdent(name) => do let env = type_env; env.set(name, type_val); env end,
    _ => env_for_pat(type_env, pat, registry)
  }
end

// ─── Entry point ──────────────────────────────────────────────────────────

export type CheckOut = CheckOut { errors: [string], registry: TypeRegistry }

extend CheckOut {
  fn has_errors(self) -> bool = errors.length() > 0
}

export fn check(prog: Program) -> CheckOut = do
  const globals  = collect_globals(prog)
  let registry = build_registry(prog)
  let all_errors: [string] = []
  let i = 0
  while i < prog.decls.length() do
    match decl_inner(prog.decls[i]) {
      DeclFn(_, params, _, body) => do
        const locals: [string] = []
        const type_env: Map<string, Shared<Type>> = Map.new()
        let j = 0
        while j < params.length() do
          locals.push(params[j].name)
          type_env.set(params[j].name, type_from_annotation(params[j].typ))
          j = j + 1
        end
        all_errors = errs_append(all_errors, check_names_expr(body, locals, globals))
        const infer_result = infer_expr(body, type_env, registry)
        all_errors = errs_append(all_errors, infer_result.errors)
      end,
      DeclType(_, _)    => do end,
      DeclExtend(_, _)  => do end,
      DeclImport(_, _)  => do end,
      DeclExported(d)   => do end
    }
    i = i + 1
  end
  CheckOut { errors: all_errors, registry: registry }
end

// Code generator: Program AST → C++ source string.


// ─── Context (DI-style) ───────────────────────────────────────────────────

type FieldOrder = FieldOrder { type_name: string, fields: [string] }
type CodegenContext = CodegenContext { field_orders: [Shared<FieldOrder>] }

fn create_codegen_context(prog: Program) -> CodegenContext =
  CodegenContext { field_orders: build_field_orders(prog) }

// ─── Field order registry ─────────────────────────────────────────────────

fn build_field_orders(prog: Program) -> [Shared<FieldOrder>] = do
  const orders: [Shared<FieldOrder>] = []
  let i = 0
  while i < prog.decls.length() do
    match prog.decls[i] {
      DeclExported(d) => match decl_inner(d) {
        DeclType(type_name, variants) => do
          let j = 0
          while j < variants.length() do
            match variants[j] {
              VarRecord(variant_name, field_defs) => do
                const field_names: [string] = []; let k = 0
                while k < field_defs.length() do field_names.push(field_defs[k].name); k = k + 1 end
                orders.push(Shared.new(FieldOrder { type_name: variant_name, fields: field_names }))
                if variants.length() == 1 then
                  orders.push(Shared.new(FieldOrder { type_name: type_name, fields: field_names }))
                end
                const _d1 = 0
              end,
              VarTuple(_, _) => do end,
              VarUnit(_)     => do end
            }
            j = j + 1
          end
          const _d2 = 0
        end,
        DeclFn(_, _, _, _)  => do end,
        DeclExtend(_, _)    => do end,
        DeclImport(_, _)    => do end,
        DeclExported(_)     => do end
      },
      DeclType(type_name, variants) => do
        let j = 0
        while j < variants.length() do
          match variants[j] {
            VarRecord(variant_name, field_defs) => do
              const field_names: [string] = []; let k = 0
              while k < field_defs.length() do field_names.push(field_defs[k].name); k = k + 1 end
              orders.push(Shared.new(FieldOrder { type_name: variant_name, fields: field_names }))
              if variants.length() == 1 then
                orders.push(Shared.new(FieldOrder { type_name: type_name, fields: field_names }))
              end
              const _d1 = 0
            end,
            VarTuple(_, _) => do end,
            VarUnit(_)     => do end
          }
          j = j + 1
        end
        const _d2 = 0
      end,
      DeclFn(_, _, _, _)  => do end,
      DeclExtend(_, _)    => do end,
      DeclImport(_, _)    => do end
    }
    i = i + 1
  end
  orders
end

fn lookup_fields(orders: [Shared<FieldOrder>], name: string) -> [string] = do
  let result: [string] = []
  let i = 0
  let found = false
  while i < orders.length() && !found do
    if orders[i].type_name == name then
      result = orders[i].fields
      found = true
    end
    i = i + 1
  end
  result
end

// ─── C++ identifier safety ───────────────────────────────────────────────

fn cpp_keyword(name: string) -> bool =
  name == "export" || name == "import" || name == "module" || name == "struct" || name == "class"
  || name == "template" || name == "typename" || name == "const" || name == "return"
  || name == "if" || name == "else" || name == "for" || name == "while" || name == "do"
  || name == "switch" || name == "case" || name == "default" || name == "break" || name == "continue"
  || name == "try" || name == "catch" || name == "throw" || name == "new" || name == "delete"
  || name == "virtual" || name == "override" || name == "final" || name == "public" || name == "private"
  || name == "protected" || name == "friend" || name == "static" || name == "extern" || name == "inline"
  || name == "using" || name == "namespace" || name == "typedef" || name == "enum" || name == "union"
  || name == "true" || name == "false" || name == "nullptr" || name == "void" || name == "bool"
  || name == "int" || name == "long" || name == "short" || name == "char" || name == "float" || name == "double"
  || name == "signed" || name == "unsigned" || name == "auto" || name == "typeid" || name == "sizeof"
  || name == "and" || name == "or" || name == "not" || name == "xor" || name == "and_eq" || name == "or_eq"
  || name == "not_eq" || name == "xor_eq" || name == "bitand" || name == "bitor" || name == "compl"
  || name == "alignas" || name == "alignof" || name == "asm" || name == "concept" || name == "consteval"
  || name == "constexpr" || name == "constinit" || name == "const_cast" || name == "decltype"
  || name == "dynamic_cast" || name == "explicit" || name == "mutable" || name == "noexcept"
  || name == "operator" || name == "reinterpret_cast" || name == "requires" || name == "static_cast"
  || name == "this" || name == "thread_local" || name == "volatile" || name == "wchar_t"

fn cpp_safe(name: string) -> string =
  if cpp_keyword(name) then name + "_" else name end

// ─── Type name → C++ ─────────────────────────────────────────────────────

fn lower_first(name: string) -> string =
  if name.length() == 0 then name
  else name.char_at(0).to_lower() + name.substring(1, name.length())
  end

fn type_to_cpp(type_expr: Shared<TypeExpr>) -> string =
  match type_expr {
    TyI32     => "int",
    TyString  => "mlc::String",
    TyBool    => "bool",
    TyUnit    => "void",
    TyNamed(name)   => cpp_safe(name),
    TyArray(inner)  => "mlc::Array<" + type_to_cpp(inner) + ">",
    TyShared(inner) => "std::shared_ptr<" + type_to_cpp(inner) + ">",
    TyGeneric(name, args) => do
      const safe = cpp_safe(name)
      if args.length() == 0 then safe
      else if args.length() == 1 then safe + "<" + type_to_cpp(args[0]) + ">"
      else safe + "<" + type_to_cpp(args[0]) + ", " + type_to_cpp(args[1]) + ">"
      end
    end,
    TyFn(params, ret) => do
      const param_types: [string] = []; let i = 0
      while i < params.length() do
        param_types.push(type_to_cpp(params[i])); i = i + 1
      end
      "std::function<" + type_to_cpp(ret) + "(" + param_types.join(", ") + ")>"
    end
  }

// ─── Expression codegen ───────────────────────────────────────────────────

fn escape_str(input: string) -> string = do
  let parts: [string] = []; let i = 0
  while i < input.length() do
    let c = input.char_at(i)
    if c == "\\" then parts.push("\\\\")
    else if c == "\"" then parts.push("\\\"")
    else if c == "\n" then parts.push("\\n")
    else if c == "\r" then parts.push("\\r")
    else if c == "\t" then parts.push("\\t")
    else if c == "\0" then parts.push("\\0")
    else parts.push(c)
    end
    i = i + 1
  end
  parts.join("")
end

fn gen_args(args: [Shared<Expr>], ctx: CodegenContext) -> string = do
  let parts: [string] = []; let i = 0
  while i < args.length() do parts.push(gen_expr(args[i], ctx)); i = i + 1 end
  parts.join(", ")
end

fn map_method(method_name: string) -> string =
  if method_name == "length" || method_name == "len" then "length"
  else if method_name == "push" then "push_back"
  else if method_name == "to_string" then "to_string"
  else if method_name == "to_int" || method_name == "to_i" then "to_i"
  else if method_name == "upper" || method_name == "to_upper" then "upper"
  else if method_name == "lower" || method_name == "to_lower" then "lower"
  else method_name
  end

fn map_builtin(name: string) -> string =
  if name == "print"   then "mlc::io::print"
  else if name == "println" then "mlc::io::println"
  else if name == "exit"    then "mlc::io::exit"
  else if name == "args"    then "mlc::io::args"
  else name
  end

fn gen_stmts_str(stmts: [Shared<Stmt>], ctx: CodegenContext) -> string = do
  let parts: [string] = []; let i = 0
  while i < stmts.length() do parts.push(gen_stmt(stmts[i], ctx)); i = i + 1 end
  parts.join("")
end

fn gen_block_body(expr: Shared<Expr>, ctx: CodegenContext) -> string =
  match expr {
    ExprBlock(stmts, result) => do
      const stmts_code  = gen_stmts_str(stmts, ctx)
      const result_code = gen_expr(result, ctx)
      if result_code == "/* unit */" then stmts_code else stmts_code + result_code + ";\n" end
    end,
    ExprIf(_, _, _) => gen_stmt_expr(expr, ctx),
    _ => gen_expr(expr, ctx) + ";\n"
  }

fn gen_expr(expr: Shared<Expr>, ctx: CodegenContext) -> string =
  match expr {
    ExprInt(n)   => n.to_string(),
    ExprStr(s)   => "mlc::String(\"" + escape_str(s) + "\")",
    ExprBool(b)  => if b then "true" else "false" end,
    ExprUnit     => "/* unit */",
    ExprIdent(name) => do
      const mapped = map_builtin(name)
      const safe = cpp_safe(mapped)
      const first = safe.char_at(0)
      if first >= "A" && first <= "Z" then safe + "{}" else safe end
    end,
    ExprBin(op, left_expr, right_expr) =>
      "(" + gen_expr(left_expr, ctx) + " " + op + " " + gen_expr(right_expr, ctx) + ")",
    ExprUn(op, inner) =>
      "(" + op + gen_expr(inner, ctx) + ")",
    ExprCall(func, args) => do
      const fn_code = match func {
        ExprIdent(name) => cpp_safe(map_builtin(name)),
        _ => gen_expr(func, ctx)
      }
      fn_code + "(" + gen_args(args, ctx) + ")"
    end,
    ExprMethod(obj, method_name, args) => do
      const obj_code = match obj {
        ExprIdent(name) => cpp_safe(map_builtin(name)),
        _ => gen_expr(obj, ctx)
      }
      if obj_code == "File" then
        const cpp_fn = if method_name == "read" then "mlc::file::read_to_string"
                     else "mlc::file::" + method_name
                     end
        cpp_fn + "(" + gen_args(args, ctx) + ")"
      else
        const base = obj_code + "." + map_method(method_name) + "("
        if args.length() == 0 then base + ")" else base + gen_args(args, ctx) + ")" end
      end
    end,
    ExprField(obj, field_name) =>
      gen_expr(obj, ctx) + "." + cpp_safe(field_name),
    ExprIndex(obj, idx) =>
      gen_expr(obj, ctx) + "[" + gen_expr(idx, ctx) + "]",
    ExprIf(cond, then_expr, else_expr) =>
      "(" + gen_expr(cond, ctx) + " ? " + gen_expr(then_expr, ctx) + " : " + gen_expr(else_expr, ctx) + ")",
    ExprBlock(stmts, result) => do
      if stmts.length() == 0 then
        gen_expr(result, ctx)
      else
        const body = gen_stmts_str(stmts, ctx) + "return " + gen_expr(result, ctx) + ";\n"
        "[&]() \{\n" + body + "\}()"
      end
    end,
    ExprWhile(cond, stmts) =>
      "[&]() \{\nwhile (" + gen_expr(cond, ctx) + ") \{\n" + gen_stmts_str(stmts, ctx) + "\}\n\}()",
    ExprFor(var, iter, stmts) =>
      "[&]() \{\nfor (auto " + cpp_safe(var) + " : " + gen_expr(iter, ctx) + ") \{\n" + gen_stmts_str(stmts, ctx) + "\}\n\}()",
    ExprMatch(subject, arms) =>
      gen_match(subject, arms, ctx),
    ExprRecord(name, field_vals) => do
      const field_order = lookup_fields(ctx.field_orders, name)
      const vals = if field_order.length() > 0
                 then gen_record_ordered(field_vals, field_order, ctx)
                 else gen_record_unordered(field_vals, ctx)
                 end
      cpp_safe(name) + "\{" + vals + "\}"
    end,
    ExprRecordUpdate(name, base, overrides) => do
      const field_order = lookup_fields(ctx.field_orders, name)
      const vals = gen_record_update_ordered(base, overrides, field_order, ctx)
      cpp_safe(name) + "\{" + vals + "\}"
    end,
    ExprArray(exprs) =>
      "mlc::Array<auto>\{" + gen_args(exprs, ctx) + "\}",
    ExprQuestion(inner) =>
      gen_expr(inner, ctx),
    ExprLambda(params, body) => do
      const capture = if params.length() == 0 then "[]" else "[=]" end
      const param_list = if params.length() == 0
        then ""
        else do
          let parts: [string] = []; let i = 0
          while i < params.length() do parts.push("auto " + cpp_safe(params[i])); i = i + 1 end
          parts.join(", ")
        end
        end
      const body_code = gen_expr(body, ctx)
      capture + "(" + param_list + ") { return " + body_code + "; }"
    end
  }

fn gen_record_ordered(field_vals: [Shared<FieldVal>], field_order: [string], ctx: CodegenContext) -> string = do
  let parts: [string] = []; let i = 0
  while i < field_order.length() do
    let value = find_field_val(field_vals, field_order[i])
    parts.push(gen_expr(value, ctx)); i = i + 1
  end
  parts.join(", ")
end

fn gen_record_unordered(field_vals: [Shared<FieldVal>], ctx: CodegenContext) -> string = do
  let parts: [string] = []; let i = 0
  while i < field_vals.length() do parts.push(gen_expr(field_vals[i].val, ctx)); i = i + 1 end
  parts.join(", ")
end

fn gen_record_update_ordered(base: Shared<Expr>, overrides: [Shared<FieldVal>], field_order: [string], ctx: CodegenContext) -> string = do
  let parts: [string] = []; let i = 0
  while i < field_order.length() do
    const field_name = field_order[i]
    const override_val = find_field_val(overrides, field_name)
    let val_str = match override_val {
      ExprUnit => gen_expr(Shared.new(ExprField(base, field_name)), ctx),
      _        => gen_expr(override_val, ctx)
    }
    parts.push(val_str); i = i + 1
  end
  parts.join(", ")
end

fn find_field_val(field_vals: [Shared<FieldVal>], name: string) -> Shared<Expr> = do
  let result: Shared<Expr> = Shared.new(ExprUnit); let i = 0
  while i < field_vals.length() do
    if field_vals[i].name == name then result = field_vals[i].val end
    i = i + 1
  end
  result
end

fn gen_match(subject: Shared<Expr>, arms: [Shared<MatchArm>], ctx: CodegenContext) -> string = do
  let parts: [string] = []; let i = 0
  while i < arms.length() do parts.push(gen_arm(arms[i], ctx)); i = i + 1 end
  "std::visit(overloaded\{" + parts.join(",\n") + "\n\}, " + gen_expr(subject, ctx) + ")"
end

fn gen_arm(arm: Shared<MatchArm>, ctx: CodegenContext) -> string =
  gen_pat_header(arm.pat) + "\{ return " + gen_expr(arm.body, ctx) + "; \}"

fn gen_pat_header(pat: Shared<Pat>) -> string =
  match pat {
    PatWild    => "[&](auto& __v) ",
    PatUnit    => "[&](auto& __v) ",
    PatBool(_) => "[&](auto& __v) ",
    PatInt(_)  => "[&](auto& __v) ",
    PatStr(_)  => "[&](auto& __v) ",
    PatIdent(name) => "[&](auto " + cpp_safe(name) + ") ",
    PatCtor(name, sub_pats) => do
      const lower_name = cpp_safe(lower_first(name))
      const binding =
        if sub_pats.length() == 0 then ""
        else "\{ auto [" + pat_bind_names(sub_pats) + "] = " + lower_name + "; \} "
        end
      "[&](const " + cpp_safe(name) + "& " + lower_name + ") " + binding
    end
  }

fn pat_bind_names(sub_pats: [Shared<Pat>]) -> string = do
  let parts: [string] = []; let i = 0
  while i < sub_pats.length() do
    const bind_name = match sub_pats[i] { PatIdent(name) => cpp_safe(name), _ => "__" + i.to_string() }
    parts.push(bind_name); i = i + 1
  end
  parts.join(", ")
end

// ─── Statement codegen ────────────────────────────────────────────────────

fn gen_stmt(stmt: Shared<Stmt>, ctx: CodegenContext) -> string =
  match stmt {
    StmtLet(name, _, typ, value) => do
      const val_code = match value {
        ExprArray(elems) =>
          if elems.length() == 0 then
            match typ {
              TyArray(inner) => "mlc::Array<" + type_to_cpp(inner) + ">\{\}",
              _              => "mlc::Array<auto>\{\}"
            }
          else "mlc::Array<auto>\{" + gen_args(elems, ctx) + "\}"
          end,
        _ => gen_expr(value, ctx)
      }
      "auto " + cpp_safe(name) + " = " + val_code + ";\n"
    end,
    StmtExpr(expr)          => gen_stmt_expr(expr, ctx),
    StmtBreak               => "break;\n",
    StmtContinue            => "continue;\n",
    StmtReturn(expr)        => "return " + gen_expr(expr, ctx) + ";\n"
  }

fn gen_stmt_expr(expr: Shared<Expr>, ctx: CodegenContext) -> string =
  match expr {
    ExprBin(op, left_expr, right_expr) =>
      if op == "=" then gen_expr(left_expr, ctx) + " = " + gen_expr(right_expr, ctx) + ";\n"
      else "(" + gen_expr(left_expr, ctx) + " " + op + " " + gen_expr(right_expr, ctx) + ");\n"
      end,
    ExprIf(cond, then_expr, else_expr) => do
      let output = "if (" + gen_expr(cond, ctx) + ") \{\n" + gen_block_body(then_expr, ctx) + "\}"
      const else_str = match else_expr {
        ExprUnit                    => "",
        ExprBlock(stmts, result)    =>
          if stmts.length() == 0 then
            match result { ExprUnit => "", _ => " else \{\n" + gen_block_body(else_expr, ctx) + "\}" }
          else " else \{\n" + gen_block_body(else_expr, ctx) + "\}"
          end,
        ExprIf(_, _, _)             => " else " + gen_stmt_expr(else_expr, ctx),
        _                           => " else \{\n" + gen_block_body(else_expr, ctx) + "\}"
      }
      if else_str.length() > 0 then output = output + else_str end
      output + "\n"
    end,
    ExprWhile(cond, stmts) =>
      "while (" + gen_expr(cond, ctx) + ") \{\n" + gen_stmts_str(stmts, ctx) + "\}\n",
    ExprFor(var, iter, stmts) =>
      "for (auto " + cpp_safe(var) + " : " + gen_expr(iter, ctx) + ") \{\n" + gen_stmts_str(stmts, ctx) + "\}\n",
    ExprBlock(stmts, result) => do
      const stmts_code  = gen_stmts_str(stmts, ctx)
      const result_code = gen_expr(result, ctx)
      if result_code == "/* unit */" then stmts_code else stmts_code + result_code + ";\n" end
    end,
    _ => gen_expr(expr, ctx) + ";\n"
  }

// ─── Declaration codegen ──────────────────────────────────────────────────

fn gen_return_body(expr: Shared<Expr>, ctx: CodegenContext) -> string =
  match expr {
    ExprBlock(stmts, result) => do
      const stmts_code  = gen_stmts_str(stmts, ctx)
      const result_code = gen_expr(result, ctx)
      if result_code == "/* unit */" then stmts_code else stmts_code + "return " + result_code + ";\n" end
    end,
    ExprIf(cond, then_expr, else_expr) => do
      let output = "if (" + gen_expr(cond, ctx) + ") \{\n" + gen_return_body(then_expr, ctx) + "\}"
      const else_str = match else_expr {
        ExprUnit        => "",
        ExprIf(_, _, _) => " else " + gen_return_if_stmt(else_expr, ctx),
        _               => " else \{\n" + gen_return_body(else_expr, ctx) + "\}"
      }
      if else_str.length() > 0 then output = output + else_str end
      output + "\n"
    end,
    _ => "return " + gen_expr(expr, ctx) + ";\n"
  }

fn gen_return_if_stmt(expr: Shared<Expr>, ctx: CodegenContext) -> string =
  match expr {
    ExprIf(cond, then_expr, else_expr) => do
      let output = "if (" + gen_expr(cond, ctx) + ") \{\n" + gen_return_body(then_expr, ctx) + "\}"
      const else_str = match else_expr {
        ExprUnit        => "",
        ExprIf(_, _, _) => " else " + gen_return_if_stmt(else_expr, ctx),
        _               => " else \{\n" + gen_return_body(else_expr, ctx) + "\}"
      }
      if else_str.length() > 0 then output = output + else_str end
      output + "\n"
    end,
    _ => "if (true) \{\n" + gen_return_body(expr, ctx) + "\}\n"
  }

fn gen_fn_body(body: Shared<Expr>, ctx: CodegenContext) -> string =
  gen_return_body(body, ctx)

fn gen_params(params: [Shared<Param>]) -> string = do
  let parts: [string] = []; let i = 0
  while i < params.length() do
    parts.push(type_to_cpp(params[i].typ) + " " + cpp_safe(params[i].name)); i = i + 1
  end
  parts.join(", ")
end

fn gen_type_decl_fwd(type_name: string, variants: [Shared<TypeVariant>]) -> string =
  if variants.length() == 1 then ""
  else gen_adt_fwd(type_name, variants)
  end

fn gen_type_decl_body(type_name: string, variants: [Shared<TypeVariant>]) -> string =
  if variants.length() == 1 then gen_single_variant(type_name, variants[0])
  else gen_adt_defs(type_name, variants)
  end

fn gen_single_variant(type_name: string, variant: Shared<TypeVariant>) -> string =
  match variant {
    VarRecord(_, field_defs) => do
      let parts: [string] = []; let i = 0
      while i < field_defs.length() do
        parts.push(type_to_cpp(field_defs[i].typ) + " " + cpp_safe(field_defs[i].name) + ";"); i = i + 1
      end
      "struct " + cpp_safe(type_name) + " \{" + parts.join("") + "\};\n"
    end,
    VarTuple(_, field_types) => do
      let parts: [string] = []; let i = 0
      while i < field_types.length() do
        parts.push(type_to_cpp(field_types[i]) + " field" + i.to_string() + ";"); i = i + 1
      end
      "struct " + cpp_safe(type_name) + " \{" + parts.join("") + "\};\n"
    end,
    VarUnit(_) => "struct " + cpp_safe(type_name) + " \{\};\n"
  }

fn gen_adt_fwd(type_name: string, variants: [Shared<TypeVariant>]) -> string = do
  let parts: [string] = []; const variant_names: [string] = []; let index = 0
  while index < variants.length() do
    const variant_name = cpp_safe(variant_ctor_name(variants[index]))
    variant_names.push(variant_name)
    parts.push("struct " + variant_name + ";\n")
    index = index + 1
  end
  parts.join("") + "using " + cpp_safe(type_name) + " = std::variant<" + variant_names.join(", ") + ">;\n"
end

fn gen_adt_defs(type_name: string, variants: [Shared<TypeVariant>]) -> string = do
  let parts: [string] = []; let i = 0
  while i < variants.length() do
    parts.push(gen_variant_struct(type_name, variants[i]))
    i = i + 1
  end
  parts.join("")
end

fn variant_ctor_name(variant: Shared<TypeVariant>) -> string =
  match variant { VarUnit(name) => name, VarTuple(name, _) => name, VarRecord(name, _) => name }

fn gen_variant_struct(type_name: string, variant: Shared<TypeVariant>) -> string =
  match variant {
    VarUnit(name) => "struct " + cpp_safe(name) + " \{\};\n",
    VarTuple(name, field_types) => do
      let parts: [string] = []; let i = 0
      while i < field_types.length() do
        parts.push(type_to_cpp(field_types[i]) + " field" + i.to_string() + ";"); i = i + 1
      end
      "struct " + cpp_safe(name) + " \{" + parts.join("") + "\};\n"
    end,
    VarRecord(name, field_defs) => do
      let parts: [string] = []; let i = 0
      while i < field_defs.length() do
        parts.push(type_to_cpp(field_defs[i].typ) + " " + cpp_safe(field_defs[i].name) + ";"); i = i + 1
      end
      "struct " + cpp_safe(name) + " \{" + parts.join("") + "\};\n"
    end
  }

fn gen_fn_decl(name: string, params: [Shared<Param>], return_type: Shared<TypeExpr>, body: Shared<Expr>, ctx: CodegenContext) -> string = do
  const safe_name = cpp_safe(name)
  if name == "main" && params.length() == 0 then
    const preamble = "mlc::io::set_args(std::vector<mlc::String>(argv + 1, argv + argc));\n"
    type_to_cpp(return_type) + " " + safe_name + "(int argc, char** argv) noexcept\{\n" +
    preamble + gen_fn_body(body, ctx) + "\}\n"
  else
    type_to_cpp(return_type) + " " + safe_name + "(" + gen_params(params) + ") noexcept\{\n" +
    gen_fn_body(body, ctx) + "\}\n"
  end
end

fn gen_fn_proto(name: string, params: [Shared<Param>], return_type: Shared<TypeExpr>) -> string = do
  const safe_name = cpp_safe(name)
  if name == "main" && params.length() == 0 then
    type_to_cpp(return_type) + " " + safe_name + "(int argc, char** argv) noexcept;\n"
  else
    type_to_cpp(return_type) + " " + safe_name + "(" + gen_params(params) + ") noexcept;\n"
  end
end

fn gen_type_decl(type_name: string, variants: [Shared<TypeVariant>]) -> string =
  gen_type_decl_fwd(type_name, variants) + gen_type_decl_body(type_name, variants)

fn gen_decl(decl: Shared<Decl>, ctx: CodegenContext) -> string =
  match decl {
    DeclType(type_name, variants) => gen_type_decl(type_name, variants),
    DeclFn(name, params, return_type, body) =>
      gen_fn_decl(name, params, return_type, body, ctx),
    DeclExtend(_, methods) => do
      let parts: [string] = []; let index = 0
      while index < methods.length() do
        parts.push(gen_decl(methods[index], ctx)); index = index + 1
      end
      parts.join("")
    end,
    DeclImport(_, _) => "",
    DeclExported(d) => gen_decl(d, ctx)
  }

// ─── Entry point ──────────────────────────────────────────────────────────

fn gen_proto(decl: Shared<Decl>) -> string =
  match decl {
    DeclType(_, _)               => "",
    DeclFn(name, params, ret, _) => gen_fn_proto(name, params, ret),
    DeclExtend(_, methods) => do
      let parts: [string] = []; let index = 0
      while index < methods.length() do
        parts.push(gen_proto(methods[index])); index = index + 1
      end
      parts.join("")
    end,
    DeclImport(_, _) => "",
    DeclExported(d) => gen_proto(d)
  }

fn collect_decl_parts(decls: [Shared<Decl>], ctx: CodegenContext, phase: i32) -> [string] = do
  let parts: [string] = []
  let index = 0
  while index < decls.length() do
    const segment = match decls[index] {
      DeclType(type_name, variants) =>
        if phase == 0 then gen_type_decl_fwd(type_name, variants)
        else if phase == 1 then gen_type_decl_body(type_name, variants)
        else ""
        end,
      DeclFn(_, _, _, _) =>
        if phase == 2 then gen_proto(decls[index])
        else if phase == 3 then gen_decl(decls[index], ctx)
        else ""
        end,
      DeclExtend(_, _) =>
        if phase == 2 then gen_proto(decls[index])
        else if phase == 3 then gen_decl(decls[index], ctx)
        else ""
        end,
      DeclImport(_, _) => "",
      DeclExported(d) =>
        if phase == 2 then gen_proto(d)
        else if phase == 3 then gen_decl(d, ctx)
        else ""
        end
    }
    if segment.length() > 0 then parts.push(segment) end
    index = index + 1
  end
  parts
end

export fn gen_program(prog: Program) -> string = do
  const ctx = create_codegen_context(prog)
  const preamble = [
    "#include \"mlc/core/string.hpp\"\n",
    "#include \"mlc/core/array.hpp\"\n",
    "#include \"mlc/core/hashmap.hpp\"\n",
    "#include \"mlc/core/match.hpp\"\n",
    "#include \"mlc/io/io.hpp\"\n",
    "#include \"mlc/io/file.hpp\"\n",
    "#include <functional>\n",
    "#include <memory>\n",
    "#include <variant>\n",
    "#include <vector>\n\n"
  ]
  const type_fwds  = collect_decl_parts(prog.decls, ctx, 0)
  const type_defs  = collect_decl_parts(prog.decls, ctx, 1)
  const fn_protos  = collect_decl_parts(prog.decls, ctx, 2)
  const fn_decls   = collect_decl_parts(prog.decls, ctx, 3)
  errs_append(errs_append(errs_append(errs_append(preamble, type_fwds), type_defs), errs_append(fn_protos, ["\n"])), fn_decls).join("")
end

// Entry point. Pipeline: source → tokenize → parse → load imports → check → gen_program


fn dirname(path: string) -> string = do
  let last_slash = -1
  let index = 0
  while index < path.length() do
    if path.char_at(index) == "/" then last_slash = index end
    index = index + 1
  end
  if last_slash <= 0 then "" else path.substring(0, last_slash) end
end

fn resolve_dotdot(path: string) -> string = do
  let p = path
  let i = 0
  while i + 4 <= p.length() do
    if p.substring(i, 4) == "/../" then
      let j = i - 1
      while j >= 0 && p.char_at(j) != "/" do j = j - 1 end
      const prefix = if j <= 0 then "" else p.substring(0, j) end
      const suffix = p.substring(i + 4, p.length() - i - 4)
      p = if prefix == "" then suffix else prefix + "/" + suffix end
      i = 0
    end
    i = i + 1
  end
  if p.length() >= 3 && p.substring(0, 3) == "../" then
    p = p.substring(3, p.length() - 3)
  end
  p
end

fn resolve_import_path(base_path: string, import_path: string) -> string = do
  const base_dir = dirname(base_path)
  const rest = if import_path.length() >= 2 && import_path.substring(0, 2) == "./"
    then import_path.substring(2, import_path.length() - 2)
    else import_path
    end
  const with_ext = if rest.length() >= 4 && rest.substring(rest.length() - 4, 4) == ".mlc"
    then rest
    else rest + ".mlc"
    end
  const raw = if base_dir == "" then with_ext else base_dir + "/" + with_ext end
  resolve_dotdot(raw)
end

fn path_in_loaded(path: string, loaded: [string]) -> bool = do
  let found = false
  let i = 0
  while i < loaded.length() do
    if loaded[i] == path then found = true end
    i = i + 1
  end
  found
end

type LoadItem = LoadItem { path: string, decls: [Shared<Decl>] }
type LoadResult = LoadResult { items: [LoadItem], errors: [string] }

fn load_module_impl(path: string, mut loaded: [string], mut cache: Map<string, LoadResult>) -> LoadResult = do
  const norm_path = resolve_dotdot(path)
  if cache.has(norm_path) then cache.get(norm_path)
  else if path_in_loaded(norm_path, loaded) then
    LoadResult { items: [], errors: ["circular: " + norm_path] }
  else
  loaded.push(norm_path)
  const source = File.read(path)
  if source.length() == 0 && !File.exists(path) then
    LoadResult { items: [], errors: ["file not found: " + path] }
  else
  const lex = tokenize(source)
  if lex.has_errors() then
    LoadResult { items: [], errors: ["lex " + path + ": " + lex.errors[0]] }
  else
    const prog = parse_program(lex.tokens)
    let items: [LoadItem] = []
    let seen: [string] = []
    let my_decls: [Shared<Decl>] = []
    let all_errors: [string] = []
    let index = 0
    while index < prog.decls.length() do
      match prog.decls[index] {
        DeclImport(import_path, _) => do
          const resolved = resolve_dotdot(resolve_import_path(path, import_path))
          const dep_result = load_module_impl(resolved, loaded, cache)
          all_errors = errs_append(all_errors, dep_result.errors)
          let dep_i = 0
          while dep_i < dep_result.items.length() do
            const item = dep_result.items[dep_i]
            if !path_in_loaded(item.path, seen) then
              seen.push(item.path)
              items.push(item)
            end
            dep_i = dep_i + 1
          end
        end,
        DeclExported(d) => my_decls.push(d),
        _ => my_decls.push(prog.decls[index])
      }
      index = index + 1
    end
    items.push(LoadItem { path: norm_path, decls: my_decls })
    const result = LoadResult { items: items, errors: all_errors }
    cache.set(norm_path, result)
    result
  end
  end
  end
end

fn load_module(path: string, mut cache: Map<string, LoadResult>) -> LoadResult =
  load_module_impl(path, [], cache)

type MergeResult = MergeResult { prog: Program, errors: [string] }

fn merge_program(entry_path: string, prog: Program) -> MergeResult = do
  let all_decls: [Shared<Decl>] = []
  let all_errors: [string] = []
  let seen_paths: [string] = []
  let cache: Map<string, LoadResult> = Map.new()
  let index = 0
  while index < prog.decls.length() do
    match prog.decls[index] {
      DeclImport(path, _) => do
        const resolved = resolve_import_path(entry_path, path)
        const dep_result = load_module(resolved, cache)
        all_errors = errs_append(all_errors, dep_result.errors)
        let dep_i = 0
        while dep_i < dep_result.items.length() do
          const item = dep_result.items[dep_i]
          if !path_in_loaded(item.path, seen_paths) then
            seen_paths.push(item.path)
            let d = 0
            while d < item.decls.length() do
              all_decls.push(item.decls[d]); d = d + 1
            end
          end
          dep_i = dep_i + 1
        end
      end,
      DeclExported(d) => all_decls.push(d),
      _ => all_decls.push(prog.decls[index])
    }
    index = index + 1
  end
  MergeResult { prog: Program { decls: all_decls }, errors: all_errors }
end

fn compile_source(src: string, entry_path: string) -> string = do
  const lex = tokenize(src)
  if lex.has_errors() then
    format_errs("lex", lex.errors)
  else
    const prog = parse_program(lex.tokens)
    const merged_result = merge_program(entry_path, prog)
    if merged_result.errors.length() > 0 then format_errs("import", merged_result.errors)
    else
      const chk = check(merged_result.prog)
      if chk.has_errors() then format_errs("check", chk.errors)
      else gen_program(merged_result.prog)
      end
    end
  end
end

fn format_errs(label: string, errors: [string]) -> string = do
  let output = ""; let i = 0
  while i < errors.length() do
    output = output + label + ": " + errors[i] + "\n"; i = i + 1
  end
  output
end

fn main() -> i32 = do
  const cli_args = args()
  if cli_args.length() == 0 then
    println("Usage: mlcc <source.mlc>")
    exit(1)
  end
  const src = File.read(cli_args[0])
  print(compile_source(src, cli_args[0]))
  0
end
