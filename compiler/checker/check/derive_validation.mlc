// Validation for derive { … } clauses (E1 Hash MVP, duplicate / unknown traits).

import {
  TypeVariant, VarUnit, VarTuple, VarRecord, TypeExpr,
  TyI32, TyBool, TyString, Diagnostic, diagnostic_error_with_code, Span
} from '../../frontend/ast'
import {
  diagnostic_code_e069, diagnostic_code_e070, diagnostic_code_e071, diagnostic_code_e072
} from '../diagnostic_codes'

fn derive_trait_name_allowed(trait_name: string) -> bool =
  trait_name == 'Display' || trait_name == 'Eq' || trait_name == 'Ord' || trait_name == 'Hash'

fn string_list_contains_derive_trait(haystack: [string], needle: string) -> bool =
  haystack.any(trait_name => trait_name == needle)

fn type_expr_allowed_for_derive_hash_field(type_expression: Shared<TypeExpr>) -> bool =
  match type_expression {
    TyI32    => true,
    TyBool   => true,
    TyString => true,
    _        => false
  }

fn derive_hash_field_error(
  variant_label: string,
  field_label: string,
  type_expression: Shared<TypeExpr>,
  diagnostic_span: Span
) -> [Diagnostic] = do
  if type_expr_allowed_for_derive_hash_field(type_expression) then []
  else
    [ diagnostic_error_with_code(
      'derive Hash: unsupported field type for "' + field_label + '" in ' + variant_label
        + ' (allowed: i32, bool, string)',
      diagnostic_span,
      diagnostic_code_e069()) ]
  end
end

fn derive_hash_field_errors_for_variant(variant: Shared<TypeVariant>, diagnostic_span: Span) -> [Diagnostic] =
  match variant {
    VarUnit(_, _) => do
      const diagnostics_none: [Diagnostic] = []
      diagnostics_none
    end,
    VarTuple(variant_name, field_types, _) => do
      let collected: [Diagnostic] = []
      let mut field_index = 0
      while field_index < field_types.length() do
        const slot_label = "_" + field_index.to_string()
        const chunk = derive_hash_field_error(
          `variant '${variant_name}'`, slot_label, field_types[field_index], diagnostic_span)
        let mut merge_index = 0
        while merge_index < chunk.length() do
          collected.push(chunk[merge_index]); merge_index = merge_index + 1
        end
        field_index = field_index + 1
      end
      collected
    end,
    VarRecord(variant_name, field_defs, _) =>
      field_defs.flat_map(field_definition =>
        derive_hash_field_error(
          `variant '${variant_name}'`, field_definition.name, field_definition.type_value, diagnostic_span))
  }

fn derive_hash_errors_for_variants(variants: [Shared<TypeVariant>], diagnostic_span: Span) -> [Diagnostic] =
  variants.flat_map(variant => derive_hash_field_errors_for_variant(variant, diagnostic_span))

export fn derive_clause_diagnostics(
  type_parameter_names: [string],
  variants: [Shared<TypeVariant>],
  derive_trait_names: [string],
  diagnostic_span: Span
) -> [Diagnostic] = do
  let collected: [Diagnostic] = []
  if derive_trait_names.length() == 0 then return collected end

  let mut seen: Map<string, bool> = Map.new()
  let mut trait_index = 0
  while trait_index < derive_trait_names.length() do
    const trait_name = derive_trait_names[trait_index]
    if seen.has(trait_name) then
      collected.push(diagnostic_error_with_code(
        'duplicate derive trait "' + trait_name + `"`, diagnostic_span, diagnostic_code_e070()))
    else
      seen.set(trait_name, true)
    end
    if !derive_trait_name_allowed(trait_name) then
      collected.push(diagnostic_error_with_code(
        `unknown derive trait '${trait_name}'`, diagnostic_span, diagnostic_code_e071()))
    end
    trait_index = trait_index + 1
  end

  if string_list_contains_derive_trait(derive_trait_names, 'Hash') then
    if type_parameter_names.length() > 0 then
      collected.push(diagnostic_error_with_code(
        'derive Hash is not supported for generic types in this version',
        diagnostic_span,
        diagnostic_code_e072()))
    else
      const hash_field_errors = derive_hash_errors_for_variants(variants, diagnostic_span)
      let mut merge_index = 0
      while merge_index < hash_field_errors.length() do
        collected.push(hash_field_errors[merge_index]); merge_index = merge_index + 1
      end
    end
  end

  collected
end
