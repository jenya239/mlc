// Validation for derive { … } clauses (E1 Hash MVP, duplicate / unknown traits).

import {
  TypeVariant, VarUnit, VarTuple, VarRecord, TypeExpr,
  TyI32, TyBool, TyString, Diagnostic, diagnostic_error_with_code, diagnostics_append, Span
} from '../../frontend/ast'
import {
  diagnostic_code_e069, diagnostic_code_e070, diagnostic_code_e071, diagnostic_code_e072
} from '../diagnostic_codes'

fn derive_trait_name_allowed(trait_name: string) -> bool =
  match trait_name
  | 'Display' | 'Eq' | 'Ord' | 'Hash' => true
  | _ => false
  end

fn string_list_contains_derive_trait(haystack: [string], needle: string) -> bool =
  haystack.any(trait_name => trait_name == needle)

fn type_expr_allowed_for_derive_hash_field(type_expression: Shared<TypeExpr>) -> bool =
  match type_expression {
    TyI32 | TyBool | TyString => true,
    _                         => false
  }

fn derive_hash_field_error(
  variant_label: string,
  field_label: string,
  type_expression: Shared<TypeExpr>,
  diagnostic_span: Span
) -> [Diagnostic] = do
  if type_expr_allowed_for_derive_hash_field(type_expression) then []
  else
    [ diagnostic_error_with_code(
      'derive Hash: unsupported field type for "' + field_label + '" in ' + variant_label
        + ' (allowed: i32, bool, string)',
      diagnostic_span,
      diagnostic_code_e069()) ]
  end
end

type Derive_hash_tuple_field_fold_state = Derive_hash_tuple_field_fold_state {
  diagnostics: [Diagnostic],
  field_index: i32,
}

fn derive_hash_tuple_field_fold_step(
  state: Derive_hash_tuple_field_fold_state,
  field_type: Shared<TypeExpr>,
  variant_name: string,
  diagnostic_span: Span
) -> Derive_hash_tuple_field_fold_state = do
  const slot_label = "_" + state.field_index.to_string()
  const field_errors = derive_hash_field_error(
    `variant '${variant_name}'`, slot_label, field_type, diagnostic_span)
  Derive_hash_tuple_field_fold_state {
    diagnostics: diagnostics_append(state.diagnostics, field_errors),
    field_index:   state.field_index + 1,
  }
end

fn derive_hash_field_errors_for_variant(variant: Shared<TypeVariant>, diagnostic_span: Span) -> [Diagnostic] =
  match variant {
    VarUnit(_, _) => do
      const diagnostics_none: [Diagnostic] = []
      diagnostics_none
    end,
    VarTuple(variant_name, field_types, _) =>
      field_types
        .fold(
          Derive_hash_tuple_field_fold_state {
            diagnostics: do let empty_diagnostics: [Diagnostic] = []; empty_diagnostics end,
            field_index:   0,
          },
          (state, field_type) =>
            derive_hash_tuple_field_fold_step(state, field_type, variant_name, diagnostic_span))
        .diagnostics,
    VarRecord(variant_name, field_defs, _) =>
      field_defs.flat_map(field_definition =>
        derive_hash_field_error(
          `variant '${variant_name}'`, field_definition.name, field_definition.type_value, diagnostic_span))
  }

fn derive_hash_errors_for_variants(variants: [Shared<TypeVariant>], diagnostic_span: Span) -> [Diagnostic] =
  variants.flat_map(variant => derive_hash_field_errors_for_variant(variant, diagnostic_span))

type Derive_clause_trait_scan_fold_state = Derive_clause_trait_scan_fold_state {
  diagnostics: [Diagnostic],
  seen_traits: Map<string, bool>,
}

fn derive_clause_trait_scan_fold_step(
  state: Derive_clause_trait_scan_fold_state,
  trait_name: string,
  diagnostic_span: Span
) -> Derive_clause_trait_scan_fold_state = do
  const diagnostics_after_duplicate =
    if state.seen_traits.has(trait_name) then
      state.diagnostics.concat([diagnostic_error_with_code(
        'duplicate derive trait "' + trait_name + `"`, diagnostic_span, diagnostic_code_e070())])
    else
      state.diagnostics
    end
  let seen_traits = state.seen_traits
  if !state.seen_traits.has(trait_name) then seen_traits.set(trait_name, true) end
  const diagnostics_after_unknown =
    if !derive_trait_name_allowed(trait_name) then
      diagnostics_after_duplicate.concat([diagnostic_error_with_code(
        `unknown derive trait '${trait_name}'`, diagnostic_span, diagnostic_code_e071())])
    else
      diagnostics_after_duplicate
    end
  Derive_clause_trait_scan_fold_state {
    diagnostics: diagnostics_after_unknown,
    seen_traits:   seen_traits,
  }
end

fn derive_clause_diagnostics_after_trait_scan(
  type_parameter_names: [string],
  variants: [Shared<TypeVariant>],
  derive_trait_names: [string],
  trait_scan_diagnostics: [Diagnostic],
  diagnostic_span: Span
) -> [Diagnostic] =
  if string_list_contains_derive_trait(derive_trait_names, 'Hash') then
    if type_parameter_names.length() > 0 then
      trait_scan_diagnostics.concat([diagnostic_error_with_code(
        'derive Hash is not supported for generic types in this version',
        diagnostic_span,
        diagnostic_code_e072())])
    else
      diagnostics_append(
        trait_scan_diagnostics,
        derive_hash_errors_for_variants(variants, diagnostic_span))
    end
  else
    trait_scan_diagnostics
  end

export fn derive_clause_diagnostics(
  type_parameter_names: [string],
  variants: [Shared<TypeVariant>],
  derive_trait_names: [string],
  diagnostic_span: Span
) -> [Diagnostic] =
  if derive_trait_names.length() == 0 then
    do let empty_diagnostics: [Diagnostic] = []; empty_diagnostics end
  else
    const trait_scan_result = derive_trait_names.fold(
      Derive_clause_trait_scan_fold_state {
        diagnostics: do let empty_diagnostics: [Diagnostic] = []; empty_diagnostics end,
        seen_traits: Map.new(),
      },
      (state, trait_name) => derive_clause_trait_scan_fold_step(state, trait_name, diagnostic_span))
    derive_clause_diagnostics_after_trait_scan(
      type_parameter_names,
      variants,
      derive_trait_names,
      trait_scan_result.diagnostics,
      diagnostic_span)
  end
