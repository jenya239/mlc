// Modular compilation load item (IR layer; shared by driver, checker transform, codegen).

import { Decl } from '../frontend/ast'

export type NamespaceImportAlias = NamespaceImportAlias { alias: string, module_path: string }

export type LoadItem = LoadItem {
  path: string,
  decls: [Shared<Decl>],
  imports: [string],
  namespace_import_aliases: [NamespaceImportAlias]
}
