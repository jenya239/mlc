// C++ AST printer (emit layer).

import { CppType, CppCastKind, CppCapture, CppParam, CppStatement, CppExpression, CppField, CppVariantArm, CppFnModifiers, CppAccessLevel, CppBaseClass, CppFunctionPrototype, CppClassMember, CppClassDefinition, CppDeclaration, CppFile, CppProgram, cpp_fn_modifiers_none, cpp_capture_name, cpp_capture_by_reference, cpp_param_name, cpp_param_type, cpp_field_type, cpp_field_name, cpp_variant_arm_name, cpp_variant_arm_types, cpp_file_header, cpp_file_source } from '../cpp_ir/cpp_ast'

fn printer_indent_unit() -> string = '  '

fn zero_based_indices(count: i32) -> [i32] =
  if count <= 0 then []
  else zero_based_indices(count - 1).concat([count - 1])
  end

fn indent_text(depth: i32) -> string =
  zero_based_indices(depth).map(_ => printer_indent_unit()).join('')

fn escape_cpp_character(character: string) -> string =
  if character == "\\" then '\\\\'
  else if character == "\"" then '\\"'
  else if character == "\n" then '\\n'
  else if character == "\r" then '\\r'
  else if character == "\t" then '\\t'
  else if character == "\0" then '\\0'
  else character
  end

fn escape_cpp_string_content(input: string) -> string =
  zero_based_indices(input.length())
    .map(index => escape_cpp_character(input.char_at(index)))
    .join('')

fn formatted_block(statements_code: string, depth: i32) -> string =
  indent_text(depth) + '{\n' + statements_code + `\n` + indent_text(depth) + `}`

fn print_comma_separated_expressions(expressions: [Shared<CppExpression>]) -> string =
  expressions.map(expression => print_expr(expression)).join(', ')

fn print_comma_separated_types(types: [Shared<CppType>]) -> string =
  types.map(type_node => print_type(type_node)).join(', ')

fn print_comma_separated_strings(strings: [string]) -> string =
  strings.join(', ')

fn type_template(name: string, arguments_code: string) -> string =
  `${name}<${arguments_code}>`

fn type_reference(inner_code: string) -> string =
  `${inner_code}&`

fn type_rvalue_reference(inner_code: string) -> string =
  `${inner_code}&&`

fn type_pointer(inner_code: string) -> string =
  `${inner_code}*`

fn type_const_prefix(inner_code: string) -> string =
  `const ${inner_code}`

export fn print_cpp_type(type_node: Shared<CppType>) -> string =
  match type_node {
    CppTypeName(name) => name,
    CppTypeTemplate(name, arguments) => type_template(name, print_comma_separated_types(arguments)),
    CppTypeRef(inner) => type_reference(print_cpp_type(inner)),
    CppTypeRRef(inner) => type_rvalue_reference(print_cpp_type(inner)),
    CppTypePtr(inner) => type_pointer(print_cpp_type(inner)),
    CppTypeConst(inner) => type_const_prefix(print_cpp_type(inner))
  }

fn print_type(type_node: Shared<CppType>) -> string = print_cpp_type(type_node)

fn render_ternary_conditional(condition_code: string, then_code: string, else_code: string) -> string =
  `(${condition_code} ? (${then_code}) : (${else_code}))`

fn render_parenthesized_binary(left_code: string, operation: string, right_code: string) -> string =
  `(${left_code} ${operation} ${right_code})`

fn render_parenthesized_unary(operation: string, inner_code: string) -> string =
  `(${operation}${inner_code})`

fn render_index_subscript(object_code: string, index_code: string) -> string =
  `${object_code}[${index_code}]`

fn render_function_call_parentheses(callee_code: string, argument_list: string) -> string =
  `${callee_code}(${argument_list})`

fn pointer_field_access(object_code: string, field_name: string) -> string =
  `${object_code}->${field_name}`

fn value_field_access(object_code: string, field_name: string) -> string =
  `${object_code}.${field_name}`

fn init_list_braces(element_list: string) -> string =
  if element_list.length() == 0 then '{}' else `{${element_list}}` end

fn aggregate_initializer_expression(type_name: string, elements: [Shared<CppExpression>]) -> string =
  `${type_name}{${print_comma_separated_expressions(elements)}}`

fn std_visit_expression(arm_lambdas: string, visit_subject: string) -> string =
  `std::visit(overloaded{${arm_lambdas}\n}, ${visit_subject})`

fn print_visit_arm_wild(void_return: bool, return_cpp: string, body: Shared<CppExpression>) -> string =
  if void_return then
    `[&](const auto& __v) -> void { ${print_expr(body)}; }`
  else if return_cpp.length() > 0 then
    `[&](const auto& __v) -> ${return_cpp} { return ${print_expr(body)}; }`
  else
    `[&](const auto& __v) { return ${print_expr(body)}; }`
  end

fn print_visit_arm_binding(parameter_name: string, void_return: bool, return_cpp: string, body: Shared<CppExpression>) -> string =
  if void_return then
    `[&](const auto& ${parameter_name}) -> void { ${print_expr(body)}; }`
  else if return_cpp.length() > 0 then
    `[&](const auto& ${parameter_name}) -> ${return_cpp} { return ${print_expr(body)}; }`
  else
    `[&](const auto& ${parameter_name}) { return ${print_expr(body)}; }`
  end

fn print_visit_arm_constructed(
  parameter_declaration: string,
  binding_prefix: string,
  void_return: bool,
  return_cpp: string,
  body: Shared<CppExpression>
) -> string =
  if void_return then
    `[&](${parameter_declaration}) -> void { ${binding_prefix}${print_expr(body)}; }`
  else if return_cpp.length() > 0 then
    `[&](${parameter_declaration}) -> ${return_cpp} { ${binding_prefix}return ${print_expr(body)}; }`
  else
    `[&](${parameter_declaration}) { ${binding_prefix}return ${print_expr(body)}; }`
  end

fn print_visit_arm_constructed_generic(
  type_name: string,
  binding_name: string,
  binding_prefix: string,
  void_return: bool,
  return_cpp: string,
  body: Shared<CppExpression>
) -> string =
  if void_return then
    `[&]<typename __mlcT>(const ${type_name}<__mlcT>& ${binding_name}) -> void { ${binding_prefix}${print_expr(body)}; }`
  else if return_cpp.length() > 0 then
    `[&]<typename __mlcT>(const ${type_name}<__mlcT>& ${binding_name}) -> ${return_cpp} { ${binding_prefix}return ${print_expr(body)}; }`
  else
    `[&]<typename __mlcT>(const ${type_name}<__mlcT>& ${binding_name}) { ${binding_prefix}return ${print_expr(body)}; }`
  end

fn cast_expression(kind_prefix: string, type_code: string, operand_code: string) -> string =
  `${kind_prefix}<${type_code}>(${operand_code})`

fn print_cast_kind_prefix(kind: CppCastKind) -> string =
  match kind {
    CppCastStatic => 'static_cast',
    CppCastDynamic => 'dynamic_cast',
    CppCastReinterpret => 'reinterpret_cast',
    CppCastConst => 'const_cast'
  }

fn print_comma_separated_expressions_multiline(expressions: [Shared<CppExpression>]) -> string =
  expressions.map(expression => print_expr(expression)).join(',\n')

fn print_capture_entry(capture_entry: Shared<CppCapture>) -> string =
  if cpp_capture_by_reference(capture_entry) then `&` + cpp_capture_name(capture_entry)
  else cpp_capture_name(capture_entry)
  end

fn print_capture_list(captures: [Shared<CppCapture>]) -> string =
  `[` + captures.map(capture_entry => print_capture_entry(capture_entry)).join(', ') + `]`

fn print_parameter_entry(parameter: Shared<CppParam>) -> string =
  print_type(cpp_param_type(parameter)) + ` ` + cpp_param_name(parameter)

fn print_parameter_list(parameters: [Shared<CppParam>]) -> string =
  parameters.map(parameter => print_parameter_entry(parameter)).join(', ')

fn block_braces(body_code: string) -> string =
  `{${body_code}}`

fn print_statements(statements: [Shared<CppStatement>], depth: i32) -> string =
  statements.map(statement => print_statement_at_depth(statement, depth)).join(`\n`)

fn print_statement_at_depth(statement: Shared<CppStatement>, depth: i32) -> string =
  match statement {
    CppStatementFragment(fragment) => fragment,
    _ => indent_text(depth) + print_statement_node(statement, depth)
  }

fn print_statement_body(statement: Shared<CppStatement>, depth: i32) -> string =
  match statement {
    CppBlock(statements) =>
      formatted_block(print_statements(statements, depth + 1), depth),
    CppIf(_, _, _) =>
      print_statement_node(statement, depth),
    _ =>
      formatted_block(indent_text(depth + 1) + print_statement_node(statement, depth + 1), depth)
  }

fn if_statement(condition_code: string, then_code: string, else_code: string) -> string =
  `if (${condition_code}) ${then_code} else ${else_code}`

fn while_statement(condition_code: string, body_code: string) -> string =
  `while (${condition_code}) ${body_code}`

fn range_for_statement(variable_name: string, range_code: string, body_code: string) -> string =
  `for (auto ${variable_name} : ${range_code}) ${body_code}`

fn auto_declaration(name: string, initializer_code: string) -> string =
  `auto ${name} = ${initializer_code};`

fn structured_binding_declaration(binding_names: [string], initializer_code: string) -> string =
  `auto [${print_comma_separated_strings(binding_names)}] = ${initializer_code};`

fn constexpr_auto_declaration(name: string, initializer_code: string) -> string =
  `constexpr auto ${name} = ${initializer_code};`

fn const_declaration(type_code: string, name: string, initializer_code: string) -> string =
  `const ${type_code} ${name} = ${initializer_code};`

fn variable_declaration(type_code: string, name: string, initializer_code: string) -> string =
  `${type_code} ${name} = ${initializer_code};`

fn include_angle(path: string) -> string =
  `#include <${path}>\n`

fn include_quoted(path: string) -> string =
  `#include ` + `"` + path + `"` + `\n`

fn ifndef_directive(macro: string) -> string =
  `#ifndef ${macro}\n`

fn define_macro_directive(macro: string, value: string) -> string =
  if value.length() == 0 then
    `#define ${macro}\n`
  else
    `#define ${macro} ${value}\n`
  end

fn endif_directive(comment: string) -> string =
  `#endif // ${comment}\n`

fn undef_directive(macro: string) -> string =
  `#undef ${macro}\n`

fn namespace_begin_directive(name: string) -> string =
  `namespace ${name} {\n`

fn namespace_end_directive(name: string) -> string =
  `} // namespace ${name}\n`

fn using_alias(alias: string, type_code: string) -> string =
  `using ${alias} = ${type_code};\n`

fn using_namespace_directive(namespace_identifier: string) -> string =
  `using namespace ${namespace_identifier};\n`

fn host_entry_main_epilogue(qualified_namespace: string) -> string =
  '\n#undef main\n\n' +
  'static void mlc_cli_set_args(int argc, char** argv) {\n' +
  '  std::vector<mlc::String> arguments;\n' +
  `  arguments.reserve(argc > 0 ? argc - 1 : 0);\n` +
  '  for (int i = 1; i < argc; ++i) { arguments.emplace_back(argv[i]); }\n' +
  '  mlc::io::set_args(std::move(arguments));\n' +
  '}\n\n' +
  'int main(int argc, char** argv) {\n' +
  '  mlc_cli_set_args(argc, argv);\n' +
  '  return ::' + qualified_namespace + '::mlc_user_main(argc, argv);\n' +
  '}\n'

fn struct_forward_declaration(template_prefix: string, name: string) -> string =
  `${template_prefix}struct ${name};\n`

fn class_forward_declaration(name: string) -> string =
  `class ${name};\n`

fn enum_forward_declaration(name: string) -> string =
  `enum ${name};\n`

fn print_forward_declaration(kind: string, name: string) -> string =
  if kind == 'class' then class_forward_declaration(name)
  else if kind == 'enum' then enum_forward_declaration(name)
  else struct_forward_declaration('', name)
  end

fn print_struct_empty_definition(template_prefix: string, name: string) -> string =
  `${template_prefix}struct ${name} {};\n`

fn struct_definition(template_prefix: string, name: string, fields_code: string, forward_only: bool) -> string =
  if fields_code.length() == 0 then
    if forward_only then
      struct_forward_declaration(template_prefix, name)
    else
      print_struct_empty_definition(template_prefix, name)
    end
  else
    `${template_prefix}struct ${name} {\n${fields_code}\n};\n`
  end

fn struct_field_line(type_code: string, field_name: string) -> string =
  `${type_code} ${field_name};`

fn function_prototype(template_prefix: string, return_type: string, name: string, parameters_code: string) -> string =
  `${template_prefix}${return_type} ${name}(${parameters_code}) noexcept;\n`

fn compact_noexcept_function_definition(
  template_prefix: string,
  return_type: string,
  name: string,
  parameters_code: string,
  return_expression_code: string
) -> string =
  `${template_prefix}${return_type} ${name}(${parameters_code}) noexcept { return ${return_expression_code}; }\n`

fn function_definition(template_prefix: string, return_type: string, name: string, parameters_code: string, body_code: string) -> string =
  `${template_prefix}${return_type} ${name}(${parameters_code}) noexcept{\n${body_code}\n}\n`

fn print_function_definition(
  template_prefix: string,
  return_type: string,
  name: string,
  parameters_code: string,
  body: [Shared<CppStatement>],
  body_statement_depth: i32
) -> string =
  if body_statement_depth == -1 && body.length() == 1 then
    match body[0] {
      CppReturn(expression) =>
        compact_noexcept_function_definition(
          template_prefix,
          return_type,
          name,
          parameters_code,
          print_expr(expression)),
      _ =>
        function_definition(
          template_prefix,
          return_type,
          name,
          parameters_code,
          print_statements(body, 1))
    }
  else
    function_definition(
      template_prefix,
      return_type,
      name,
      parameters_code,
      print_statements(body, body_statement_depth))
  end

fn namespace_block(name: string, contents_code: string) -> string =
  `namespace ${name} {\n${contents_code}}`

fn variant_type_alias(template_prefix: string, name: string, types_code: string) -> string =
  `${template_prefix}using ${name} = std::variant<${types_code}>;\n`

fn concept_requires_definition(
  template_prefix: string,
  trait_name: string,
  self_parameter_name: string,
  requires_expressions: [string]
) -> string =
  `${template_prefix}concept ${trait_name} = requires(const ${self_parameter_name}& self) { ${requires_expressions.join('; ')}; };\n`

fn static_assert_declaration(concept_cpp: string, type_arguments: [string], message: string) -> string =
  `static_assert(${concept_cpp}<${print_comma_separated_strings(type_arguments)}>, ` + `"` + message + `"` + `);\n`

fn print_hash_specialization_body(statements: [Shared<CppStatement>]) -> string =
  statements.map(statement => '    ' + print_statement(statement)).join(`\n`)

fn std_hash_specialization_definition(type_name: string, body_statements: [Shared<CppStatement>]) -> string =
  'namespace std {\n' +
  'template<>\n' +
  'struct hash<' + type_name + '> {\n' +
  '  size_t operator()(const ' + type_name + '& self) const noexcept {\n' +
  print_hash_specialization_body(body_statements) + `\n` +
  '  }\n' +
  '};\n' +
  '}\n'

fn print_struct_field_line(field_entry: Shared<CppField>) -> string =
  indent_text(1) + struct_field_line(cpp_field_type(field_entry), cpp_field_name(field_entry))

fn print_struct_fields(fields: [Shared<CppField>]) -> string =
  fields.map(field_entry => print_struct_field_line(field_entry)).join(`\n`)

fn print_access_specifier_for_base(access: CppAccessLevel) -> string =
  match access { CppPublic => "public", CppProtected => "protected", CppPrivate => "private" }

fn print_access_label(access: CppAccessLevel) -> string =
  match access { CppPublic => "public:", CppProtected => "protected:", CppPrivate => "private:" }

fn print_base_class_entry(base_class: CppBaseClass) -> string =
  print_access_specifier_for_base(base_class.access) + " " + base_class.name

fn print_base_class_list(base_classes: [CppBaseClass]) -> string =
  if base_classes.length() == 0 then "" else " : " + base_classes.map(base_class => print_base_class_entry(base_class)).join(", ") end

fn print_function_modifiers_prefix(modifiers: CppFnModifiers) -> string = do
  let parts: [string] = []
  if modifiers.is_static then parts.push("static") end
  if modifiers.is_virtual then parts.push("virtual") end
  if modifiers.is_explicit then parts.push("explicit") end
  if parts.length() == 0 then "" else parts.join(" ") + " " end
end

fn print_function_modifiers_suffix(modifiers: CppFnModifiers) -> string = do
  if modifiers.is_pure_virtual then " = 0"
  else if modifiers.is_deleted then " = delete"
  else if modifiers.is_defaulted then " = default"
  else do
    const const_part = if modifiers.is_const then " const" else "" end
    const override_part = if modifiers.is_override then " override" else "" end
    const_part + override_part
  end
  end
end

fn print_function_prototype_core(prototype: Shared<CppFunctionPrototype>, indent_depth: i32) -> string = do
  const modifiers_prefix = print_function_modifiers_prefix(prototype.modifiers)
  const return_type_code = print_type(prototype.return_type)
  const parameters_code = print_parameter_list(prototype.parameters)
  const modifiers_suffix = print_function_modifiers_suffix(prototype.modifiers)
  indent_text(indent_depth) + modifiers_prefix + return_type_code + " " + prototype.name + "(" + parameters_code + ")" + modifiers_suffix + " noexcept;"
end

fn print_function_prototype_line(prototype: Shared<CppFunctionPrototype>) -> string =
  prototype.template_prefix + print_function_prototype_core(prototype, 0) + "\n"

fn print_member_field_line(field_type: Shared<CppType>, field_name: string, default_value: string) -> string =
  if default_value != "" then
    indent_text(1) + print_type(field_type) + " " + field_name + " = " + default_value + ";"
  else
    indent_text(1) + print_type(field_type) + " " + field_name + ";"
  end

fn print_class_member_line(member: CppClassMember) -> string =
  match member {
    CppClassMemberAccess(access) => indent_text(1) + print_access_label(access),
    CppClassMemberField(field_type, field_name, default_value) => print_member_field_line(field_type, field_name, default_value),
    CppClassMemberTypeAlias(alias, type_node) => indent_text(1) + "using " + alias + " = " + print_type(type_node) + ";",
    CppClassMemberFunction(prototype) => print_function_prototype_core(prototype, 1),
  }

fn print_class_body_members(members: [CppClassMember]) -> string =
  members.map(member => print_class_member_line(member)).join("\n")

fn print_class_definition(definition: CppClassDefinition) -> string = do
  const kind_word = if definition.is_struct then "struct" else "class" end
  const bases = print_base_class_list(definition.base_classes)
  const body = print_class_body_members(definition.members)
  if body.length() == 0 then
    definition.template_prefix + kind_word + " " + definition.name + bases + " {};\n"
  else
    definition.template_prefix + kind_word + " " + definition.name + bases + " {\n" + body + "\n};\n"
  end
end

fn typedef_declaration(name: string, type_code: string) -> string =
  `typedef ${type_code} ${name};\n`

fn extern_block_declaration(linkage: string, body_code: string) -> string =
  "extern " + linkage + " {\n" + body_code + "\n}\n"

fn print_template_declaration(template_parameters: string, inner: Shared<CppDeclaration>) -> string =
  `template<${template_parameters}>\n` + print_decl_node(inner)

fn variant_arm_type_strings(arm: Shared<CppVariantArm>) -> [string] = do
  const types = cpp_variant_arm_types(arm)
  if types.length() == 0 then [cpp_variant_arm_name(arm)]
  else types.map(type_node => print_type(type_node))
  end
end

fn print_variant_types(arms: [Shared<CppVariantArm>]) -> string =
  arms.flat_map(arm => variant_arm_type_strings(arm)).join(', ')

fn is_empty_cpp_block(statement: Shared<CppStatement>) -> bool =
  match statement {
    CppBlock(statements) => statements.length() == 0,
    _ => false
  }

fn conditional_if_statement(
  condition_code: string,
  then_code: string,
  else_branch: Shared<CppStatement>,
  depth: i32
) -> string =
  if is_empty_cpp_block(else_branch) then
    `if (${condition_code}) ${then_code}`
  else
    if_statement(condition_code, then_code, print_statement_body(else_branch, depth))
  end

fn print_statement_node(statement: Shared<CppStatement>, depth: i32) -> string =
  match statement {
    CppAutoDecl(name, initializer) => auto_declaration(name, print_expr(initializer)),
    CppVarDecl(name, type_node, initializer) =>
      variable_declaration(print_type(type_node), name, print_expr(initializer)),
    CppConstDecl(name, type_node, initializer) =>
      const_declaration(print_type(type_node), name, print_expr(initializer)),
    CppConstexprAutoDecl(name, initializer) =>
      constexpr_auto_declaration(name, print_expr(initializer)),
    CppReturn(expression) => 'return ' + print_expr(expression) + `;`,
    CppExpressionStatement(expression) => print_expr(expression) + `;`,
    CppBlock(statements) => formatted_block(print_statements(statements, depth + 1), depth),
    CppIf(condition, then_branch, else_branch) =>
      conditional_if_statement(
        print_expr(condition),
        print_statement_body(then_branch, depth),
        else_branch,
        depth),
    CppWhile(condition, body) =>
      while_statement(print_expr(condition), print_statement_body(body, depth)),
    CppFor(variable_name, range_expression, body) =>
      range_for_statement(
        variable_name,
        print_expr(range_expression),
        formatted_block(print_statements(body, depth + 1), depth)
      ),
    CppStructuredBinding(binding_names, initializer) =>
      structured_binding_declaration(binding_names, print_expr(initializer)),
    CppStatementFragment(fragment) => fragment
  }

fn print_decl_sequence(declarations: [Shared<CppDeclaration>]) -> string =
  declarations.map(declaration => print_decl_node(declaration)).join('')

fn print_decl_node(declaration: Shared<CppDeclaration>) -> string =
  match declaration {
    CppInclude(is_angle, path) =>
      if is_angle then include_angle(path) else include_quoted(path) end,
    CppIfndef(macro) => ifndef_directive(macro),
    CppDefineMacro(macro, value) => define_macro_directive(macro, value),
    CppEndif(comment) => endif_directive(comment),
    CppUndef(macro) => undef_directive(macro),
    CppNamespaceBegin(name) => namespace_begin_directive(name),
    CppNamespaceEnd(name) => namespace_end_directive(name),
    CppUsing(alias, type_code) => using_alias(alias, type_code),
    CppUsingNamespace(namespace_identifier) => using_namespace_directive(namespace_identifier),
    CppStruct(template_prefix, name, fields, forward_only) =>
      struct_definition(template_prefix, name, print_struct_fields(fields), forward_only),
    CppForwardDecl(kind, name) => print_forward_declaration(kind, name),
    CppFnProto(template_prefix, return_type, name, parameters) =>
      function_prototype(template_prefix, return_type, name, print_comma_separated_strings(parameters)),
    CppFnDef(template_prefix, return_type, name, parameters, body, body_statement_depth) =>
      print_function_definition(
        template_prefix,
        return_type,
        name,
        print_comma_separated_strings(parameters),
        body,
        body_statement_depth),
    CppNamespace(name, declarations) => namespace_block(name, print_decls(declarations)),
    CppVariant(template_prefix, name, arms) =>
      variant_type_alias(template_prefix, name, print_variant_types(arms)),
    CppConceptRequires(template_prefix, trait_name, self_parameter_name, requires_expressions) =>
      concept_requires_definition(template_prefix, trait_name, self_parameter_name, requires_expressions),
    CppStaticAssert(concept_cpp, type_arguments, message) =>
      static_assert_declaration(concept_cpp, type_arguments, message),
    CppStdHashSpecialization(type_name, body_statements) =>
      std_hash_specialization_definition(type_name, body_statements),
    CppDeclarationSequence(declarations) => print_decl_sequence(declarations),
    CppDeclarationEmpty => '',
    CppBlankLine => `\n`,
    CppHostEntryMain(qualified_namespace) => host_entry_main_epilogue(qualified_namespace),
    CppClassDeclaration(definition) => print_class_definition(definition),
    CppTypedefDeclaration(name, type_node) => typedef_declaration(name, print_type(type_node)),
    CppTemplateDeclaration(template_parameters, inner) => print_template_declaration(template_parameters, inner),
    CppFunctionPrototypeDecl(prototype) => print_function_prototype_line(Shared.new(prototype)),
    CppExternBlock(linkage, declarations) => extern_block_declaration(linkage, print_decls(declarations)),
    CppDeclarationFragment(code) => code
  }

fn print_decls(declarations: [Shared<CppDeclaration>]) -> string =
  declarations.map(declaration => print_decl_node(declaration)).join('\n\n')

fn print_file_node(file: Shared<CppFile>) -> string = do
  const header_code = print_decls(cpp_file_header(file))
  const source_code = print_decls(cpp_file_source(file))
  if header_code.length() == 0 then source_code
  else if source_code.length() == 0 then header_code
  else header_code + '\n\n' + source_code
  end
end

fn invoked_while_expression(condition: Shared<CppExpression>, body_statements: string) -> string =
  `[&]() {\nwhile (${print_expr(condition)}) {\n${body_statements}}\n}()`

fn invoked_for_expression(variable_name: string, iterator: Shared<CppExpression>, body_statements: string) -> string =
  `[&]() {\nfor (auto ${variable_name} : ${print_expr(iterator)}) {\n${body_statements}}\n}()`

fn invoked_block_expression(body_statements: string) -> string =
  `[&]() {\n${body_statements}}()`

fn invoked_block_with_return_expression(return_type: string, body_statements: string) -> string =
  `[&]() -> ${return_type} {\n${body_statements}}()`

fn question_try_expression(inner: Shared<CppExpression>) -> string =
  `({ auto __q = ${print_expr(inner)}; if (std::get_if<1>(&__q)) return *std::get_if<1>(&__q); std::get<0>(__q).field0; })`

fn with_block_expression(resource: Shared<CppExpression>, binder: string, body_statements: string) -> string =
  `{\nauto ${binder} = (${print_expr(resource)});\n${body_statements}${binder}.drop();\n}\n`

fn lambda_expression(capture_prefix: string, parameters_code: string, return_type_code: string, body_code: string) -> string =
  `${capture_prefix}(${parameters_code}) -> ${return_type_code} {\n${body_code}\n}`

fn print_lambda_expression(
  captures: [Shared<CppCapture>],
  parameters: [Shared<CppParam>],
  return_type: Shared<CppType>,
  body: [Shared<CppStatement>]
) -> string = do
  const capture_prefix = print_capture_list(captures)
  const parameters_code = print_parameter_list(parameters)
  const return_type_code = print_type(return_type)
  const body_code = print_statements(body, 1)
  lambda_expression(capture_prefix, parameters_code, return_type_code, body_code)
end

fn mutable_lambda_expression(capture_prefix: string, parameters_code: string, body_expression_code: string) -> string =
  `${capture_prefix}(${parameters_code}) mutable { return ${body_expression_code}; }`

fn print_mutable_lambda_expression(
  captures: [Shared<CppCapture>],
  parameters: [Shared<CppParam>],
  body: Shared<CppExpression>
) -> string = do
  const capture_prefix = print_capture_list(captures)
  const parameters_code = print_parameter_list(parameters)
  mutable_lambda_expression(capture_prefix, parameters_code, print_expr(body))
end

fn print_member_expression(object: Shared<CppExpression>, member_name: string, is_pointer: bool) -> string =
  if is_pointer then pointer_field_access(print_expr(object), member_name) else value_field_access(print_expr(object), member_name) end

export fn print_integer_literal(integer_value: i32) -> string =
  integer_value.to_string()

export fn print_string_literal(string_value: string) -> string =
  `"` + escape_cpp_string_content(string_value) + `"`

export fn print_boolean_literal(boolean_value: bool) -> string =
  if boolean_value then 'true' else 'false' end

export fn print_identifier(name: string) -> string =
  name

export fn print_expr(expression: Shared<CppExpression>) -> string =
  match expression {
    CppInt(integer_value) => print_integer_literal(integer_value),
    CppStr(string_value) => print_string_literal(string_value),
    CppCharLiteral(character_value) => "'" + escape_cpp_character(character_value) + "'",
    CppFloatLiteral(float_text) => float_text,
    CppBool(boolean_value) => print_boolean_literal(boolean_value),
    CppIdent(name) => print_identifier(name),
    CppCall(callee, arguments) =>
      render_function_call_parentheses(print_expr(callee), print_comma_separated_expressions(arguments)),
    CppMember(object, member_name, is_pointer) =>
      print_member_expression(object, member_name, is_pointer),
    CppIndex(object, index) =>
      render_index_subscript(print_expr(object), print_expr(index)),
    CppBinary(operation, left, right) =>
      render_parenthesized_binary(print_expr(left), operation, print_expr(right)),
    CppUnary(operation, inner) =>
      render_parenthesized_unary(operation, print_expr(inner)),
    CppTernary(condition, then_branch, else_branch) =>
      render_ternary_conditional(print_expr(condition), print_expr(then_branch), print_expr(else_branch)),
    CppInitList(elements) =>
      init_list_braces(print_comma_separated_expressions(elements)),
    CppAggregateInit(type_name, elements) =>
      aggregate_initializer_expression(type_name, elements),
    CppStdVisit(subject, handlers) =>
      std_visit_expression(print_comma_separated_expressions_multiline(handlers), print_expr(subject)),
    CppVisitArmWild(void_return, return_cpp, body) =>
      print_visit_arm_wild(void_return, return_cpp, body),
    CppVisitArmBinding(parameter_name, void_return, return_cpp, body) =>
      print_visit_arm_binding(parameter_name, void_return, return_cpp, body),
    CppVisitArmConstructed(parameter_declaration, binding_prefix, void_return, return_cpp, body) =>
      print_visit_arm_constructed(parameter_declaration, binding_prefix, void_return, return_cpp, body),
    CppVisitArmConstructedGeneric(type_name, binding_name, binding_prefix, void_return, return_cpp, body) =>
      print_visit_arm_constructed_generic(type_name, binding_name, binding_prefix, void_return, return_cpp, body),
    CppCast(kind, target_type, operand) =>
      cast_expression(print_cast_kind_prefix(kind), print_type(target_type), print_expr(operand)),
    CppLambda(captures, parameters, return_type, body) =>
      print_lambda_expression(captures, parameters, return_type, body),
    CppMutableLambda(captures, parameters, body) =>
      print_mutable_lambda_expression(captures, parameters, body),
    CppInvokedWhile(condition, body_statements) => invoked_while_expression(condition, body_statements),
    CppInvokedFor(variable_name, iterator, body_statements) =>
      invoked_for_expression(variable_name, iterator, body_statements),
    CppInvokedBlock(body_statements) => invoked_block_expression(body_statements),
    CppInvokedBlockWithReturn(return_type, body_statements) =>
      invoked_block_with_return_expression(return_type, body_statements),
    CppQuestionTry(inner) => question_try_expression(inner),
    CppWithBlock(resource, binder, body_statements) =>
      with_block_expression(resource, binder, body_statements)
  }

export fn print_statement(statement: Shared<CppStatement>) -> string =
  print_statement_at_depth(statement, 0)

export fn print_decl(declaration: Shared<CppDeclaration>) -> string =
  print_decl_node(declaration)

export fn print_file(file: Shared<CppFile>) -> string =
  print_file_node(file)