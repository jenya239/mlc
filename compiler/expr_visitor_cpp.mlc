// ExprVisitor<Shared<CppExpression>> — batch 1–3: literals through lambda (Phase 2).

import { Type, TNamed, TGeneric, TArray, TFn, TUnit } from './checker/registry'
import { SemanticExpression, SemanticStatement, SemanticMatchArm, SemanticFieldVal, SemanticExpressionIdent, SemanticExpressionArray, SemanticExpressionUnit, SemanticExpressionIf, SemanticExpressionBlock, sexpr_type } from './ir/semantic_ir'
import { CppExpression, CppBinary, CppUnary, CppCall, CppMember, CppIndex, CppInvokedWhile, CppInvokedFor, CppInvokedBlock, CppQuestionTry, CppWithBlock, CppStdVisit, CppAggregateInit, CppInitList, CppTernary, CppLambda, CppMutableLambda, CppCapture, CppParam, CppType, CppTypeName, CppStatement } from './cpp_ir/cpp_ast'
import {print_expr, print_statement} from './cpp_emit/print'
import * as emit_helpers from './cpp_emit/emit_helpers'
import { operator_method_for, array_element_type_from_array_type, type_is_unknown } from './checker/semantic_type_structure'
import * as literals from './codegen/expr/literals'
import * as identifiers from './codegen/expr/identifiers'
import { field_access_operator, find_field_value, is_constructor_call } from './codegen/expr/expression_support'
import { first_arm_needs_deref, should_use_string_match_if_chain } from './codegen/expr/match_analysis'
import * as match_codegen from './codegen/expr/match_gen'
import * as mut_actual_argument from './codegen/expr/mut_actual_argument'
import * as method_gen from './codegen/expr/method_gen'
import * as record_gen from './codegen/expr/record_gen'
import { cpp_safe, map_builtin } from './codegen/cpp_naming'
import { sem_type_to_cpp } from './codegen/decl/type_gen'
import { CodegenContext, lookup_fields_for_context, qualify_function_callee } from './codegen/context'
import { stmts_final_ctx } from './codegen/stmt/statement_context'
import { ExprVisitor } from './expr_visitor'

type CodegenPass = CodegenPass {
  context: CodegenContext,
  gen_stmts: ([Shared<SemanticStatement>], CodegenContext) -> string,
  evaluate_expression: (Shared<SemanticExpression>, CodegenContext, ([Shared<SemanticStatement>], CodegenContext) -> string) -> Shared<CppExpression>,
  seed: i32,
}

fn codegen_pass_new(
  context: CodegenContext,
  gen_stmts: ([Shared<SemanticStatement>], CodegenContext) -> string,
  evaluate_expression: (Shared<SemanticExpression>, CodegenContext, ([Shared<SemanticStatement>], CodegenContext) -> string) -> Shared<CppExpression>
) -> CodegenPass =
  CodegenPass {
    context: context,
    gen_stmts: gen_stmts,
    evaluate_expression: evaluate_expression,
    seed: 0,
  }

fn unsupported_cpp_expression() -> Shared<CppExpression> =
  emit_helpers.make_identifier_cpp_expression('/* unsupported expr */')

fn evaluate_via_cpp_visitor(
  expression: Shared<SemanticExpression>,
  context: CodegenContext,
  _gen_stmts: ([Shared<SemanticStatement>], CodegenContext) -> string
) -> Shared<CppExpression> =
  gen_expr_via_cpp_visitor(expression, context)

fn ignored_gen_stmts(_statements: [Shared<SemanticStatement>], _context: CodegenContext) -> string = ''

export fn eval_expr_cpp(
  expression: Shared<SemanticExpression>,
  context: CodegenContext,
  gen_stmts: ([Shared<SemanticStatement>], CodegenContext) -> string
) -> Shared<CppExpression> =
  eval_expr_with_cpp_visitor(expression, context, gen_stmts, eval_expr_cpp)

fn gen_call_function_cpp_expression(
  function_expression: Shared<SemanticExpression>,
  context: CodegenContext,
  gen_stmts: ([Shared<SemanticStatement>], CodegenContext) -> string
) -> Shared<CppExpression> =
  match function_expression {
    SemanticExpressionIdent(name, _, _) => do
      emit_helpers.make_identifier_cpp_expression(qualify_function_callee(map_builtin(name), context))
    end,
    _ => do
      eval_expr_cpp(function_expression, context, gen_stmts)
    end
  }

fn gen_constructor_call_cpp_expression(
  function_expression: Shared<SemanticExpression>,
  argument_expressions: [Shared<CppExpression>],
  context: CodegenContext,
  gen_stmts: ([Shared<SemanticStatement>], CodegenContext) -> string
) -> Shared<CppExpression> =
  match function_expression {
    SemanticExpressionIdent(name, _, _) => do
      const callee_code = qualify_function_callee(map_builtin(name), context)
      Shared.new(CppAggregateInit(callee_code, argument_expressions))
    end,
    _ => do
      Shared.new(CppCall(
        gen_call_function_cpp_expression(function_expression, context, gen_stmts),
        argument_expressions))
    end
  }

export fn gen_call_via_cpp_visitor(
  function_expression: Shared<SemanticExpression>,
  arguments: [Shared<SemanticExpression>],
  call_parameter_mutability_flags: [i32],
  context: CodegenContext,
  gen_stmts: ([Shared<SemanticStatement>], CodegenContext) -> string
) -> Shared<CppExpression> = do
  const materialization_outcome =
    mut_actual_argument.materialize_positional_actual_arguments_cpp(
      arguments,
      call_parameter_mutability_flags,
      context,
      gen_stmts,
      eval_expr_cpp)
  const invoke_expression =
    if is_constructor_call(function_expression) then
      gen_constructor_call_cpp_expression(
        function_expression,
        materialization_outcome.materialized_argument_expressions,
        context,
        gen_stmts)
    else
      Shared.new(CppCall(
        gen_call_function_cpp_expression(function_expression, context, gen_stmts),
        materialization_outcome.materialized_argument_expressions))
    end
  mut_actual_argument.wrap_invoke_with_mut_prelude_cpp(
    materialization_outcome.prelude_statements,
    invoke_expression)
end

export fn gen_method_via_cpp_visitor(
  object: Shared<SemanticExpression>,
  method_name: string,
  arguments: [Shared<SemanticExpression>],
  receiver_and_parameter_mutability_flags: [i32],
  context: CodegenContext,
  gen_stmts: ([Shared<SemanticStatement>], CodegenContext) -> string
) -> Shared<CppExpression> =
  method_gen.gen_method_expr_cpp(
    object,
    method_name,
    arguments,
    receiver_and_parameter_mutability_flags,
    context,
    gen_stmts,
    eval_expr_cpp)

// Immediate IIFE only (if/while/for/block): [&] — same rationale as `block_as_immediate_invoked_function_expression`.
fn reference_capture_for_immediate_lambda() -> Shared<CppCapture> =
  Shared.new(CppCapture { name: '', by_reference: true })

fn value_capture_for_lambda() -> Shared<CppCapture> =
  Shared.new(CppCapture { name: "=", by_reference: false })

fn invoke_immediate_lambda_cpp(return_type: Shared<CppType>, body_statements: [Shared<CppStatement>]) -> Shared<CppExpression> =
  Shared.new(CppCall(
    Shared.new(CppLambda(
      [reference_capture_for_immediate_lambda()],
      [],
      return_type,
      body_statements)),
    []))

fn gen_if_else_cpp_expression(
  else_expression: Shared<SemanticExpression>,
  if_semantic_type: Shared<Type>,
  then_expression: Shared<SemanticExpression>,
  context: CodegenContext,
  gen_stmts: ([Shared<SemanticStatement>], CodegenContext) -> string
) -> Shared<CppExpression> =
  match else_expression {
    SemanticExpressionArray(elements, _, array_span) =>
      if elements.length() > 0 then eval_expr_cpp(else_expression, context, gen_stmts)
      else do
        const inner_preferred = array_element_type_from_array_type(if_semantic_type)
        const inner_from_then_branch = array_element_type_from_array_type(sexpr_type(then_expression))
        const inner_for_empty_array =
          if !type_is_unknown(inner_preferred) then inner_preferred
          else inner_from_then_branch
          end
        if type_is_unknown(inner_for_empty_array) then eval_expr_cpp(else_expression, context, gen_stmts)
        else
          eval_expr_cpp(
            Shared.new(SemanticExpressionArray(elements, Shared.new(TArray(inner_for_empty_array)), array_span)),
            context,
            gen_stmts)
        end
      end,
    _ => do
      eval_expr_cpp(else_expression, context, gen_stmts)
    end
  }

fn unit_if_block_trailing(
  result_expression: Shared<SemanticExpression>,
  final_context: CodegenContext,
  gen_stmts: ([Shared<SemanticStatement>], CodegenContext) -> string
) -> string =
  match result_expression {
    SemanticExpressionUnit(_, _) => '',
    SemanticExpressionIf(condition, then_expression, else_expression, semantic_type, _) =>
      print_statement(gen_if_cpp_statement(
        condition, then_expression, else_expression, semantic_type, final_context, gen_stmts)),
    _ =>
      print_expr(eval_expr_cpp(result_expression, final_context, gen_stmts)) + ';\n'
  }

fn unit_if_branch_block(
  branch_expression: Shared<SemanticExpression>,
  context: CodegenContext,
  gen_stmts: ([Shared<SemanticStatement>], CodegenContext) -> string
) -> Shared<CppStatement> =
  match branch_expression {
    SemanticExpressionBlock(statements, result_expression, _, _) => do
      const body_fragment = gen_stmts(statements, context)
      const final_context = stmts_final_ctx(statements, context)
      const trailing = unit_if_block_trailing(result_expression, final_context, gen_stmts)
      emit_helpers.make_block_cpp_statement([
        emit_helpers.make_fragment_cpp_statement(body_fragment + trailing)])
    end,
    SemanticExpressionIf(condition, then_expression, else_expression, semantic_type, _) =>
      emit_helpers.make_block_cpp_statement([
        emit_helpers.make_expression_cpp_statement(
          gen_if_via_cpp_visitor(
            condition, then_expression, else_expression, semantic_type, context, gen_stmts))]),
    _ => emit_helpers.make_block_cpp_statement([
      emit_helpers.make_expression_cpp_statement(
        eval_expr_cpp(branch_expression, context, gen_stmts))])
  }

fn unit_if_else_branch(
  else_expression: Shared<SemanticExpression>,
  context: CodegenContext,
  gen_stmts: ([Shared<SemanticStatement>], CodegenContext) -> string
) -> Shared<CppStatement> =
  match else_expression {
    SemanticExpressionUnit(_, _) => emit_helpers.make_block_cpp_statement([]),
    SemanticExpressionIf(condition, then_expression, else_expression, semantic_type, _) =>
      gen_if_cpp_statement(
        condition, then_expression, else_expression, semantic_type, context, gen_stmts),
    _ => unit_if_branch_block(else_expression, context, gen_stmts)
  }

fn gen_if_cpp_statement(
  condition: Shared<SemanticExpression>,
  then_expression: Shared<SemanticExpression>,
  else_expression: Shared<SemanticExpression>,
  if_semantic_type: Shared<Type>,
  context: CodegenContext,
  gen_stmts: ([Shared<SemanticStatement>], CodegenContext) -> string
) -> Shared<CppStatement> =
  emit_helpers.make_if_cpp_statement(
    eval_expr_cpp(condition, context, gen_stmts),
    unit_if_branch_block(then_expression, context, gen_stmts),
    unit_if_else_branch(else_expression, context, gen_stmts))

fn gen_if_unit_via_cpp_visitor(
  condition: Shared<SemanticExpression>,
  then_expression: Shared<SemanticExpression>,
  else_expression: Shared<SemanticExpression>,
  if_semantic_type: Shared<Type>,
  context: CodegenContext,
  gen_stmts: ([Shared<SemanticStatement>], CodegenContext) -> string
) -> Shared<CppExpression> =
  invoke_immediate_lambda_cpp(
    Shared.new(CppTypeName('void')),
    [gen_if_cpp_statement(
      condition, then_expression, else_expression, if_semantic_type, context, gen_stmts)])

export fn gen_if_via_cpp_visitor(
  condition: Shared<SemanticExpression>,
  then_expression: Shared<SemanticExpression>,
  else_expression: Shared<SemanticExpression>,
  if_semantic_type: Shared<Type>,
  context: CodegenContext,
  gen_stmts: ([Shared<SemanticStatement>], CodegenContext) -> string
) -> Shared<CppExpression> = do
  const condition_expression = eval_expr_cpp(condition, context, gen_stmts)
  const then_expression_cpp = eval_expr_cpp(then_expression, context, gen_stmts)
  const else_expression_cpp =
    gen_if_else_cpp_expression(else_expression, if_semantic_type, then_expression, context, gen_stmts)
  match if_semantic_type {
    TNamed(type_name) => do
      const type_cpp = context.resolve(type_name)
      if type_cpp == 'auto' then
        Shared.new(CppTernary(condition_expression, then_expression_cpp, else_expression_cpp))
      else
        invoke_immediate_lambda_cpp(
          Shared.new(CppTypeName(type_cpp)),
          [emit_helpers.make_if_cpp_statement(
            condition_expression,
            emit_helpers.make_block_cpp_statement([emit_helpers.make_return_cpp_statement(then_expression_cpp)]),
            emit_helpers.make_block_cpp_statement([emit_helpers.make_return_cpp_statement(else_expression_cpp)]))])
      end
    end,
    TUnit => gen_if_unit_via_cpp_visitor(
      condition, then_expression, else_expression, if_semantic_type, context, gen_stmts),
    _ => do
      Shared.new(CppTernary(condition_expression, then_expression_cpp, else_expression_cpp))
    end
  }
end

export fn gen_block_via_cpp_visitor(
  statements: [Shared<SemanticStatement>],
  result_expression: Shared<SemanticExpression>,
  context: CodegenContext,
  gen_stmts: ([Shared<SemanticStatement>], CodegenContext) -> string
) -> Shared<CppExpression> =
  if statements.length() == 0 then eval_expr_cpp(result_expression, context, gen_stmts)
  else do
    const final_context = stmts_final_ctx(statements, context)
    const body_fragment =
      gen_stmts(statements, context) +
      'return ' + print_expr(eval_expr_cpp(result_expression, final_context, gen_stmts)) + ';\n'
    Shared.new(CppInvokedBlock(body_fragment))
  end

export fn gen_match_via_cpp_visitor(
  subject: Shared<SemanticExpression>,
  arms: [Shared<SemanticMatchArm>],
  match_semantic_type: Shared<Type>,
  context: CodegenContext,
  gen_stmts: ([Shared<SemanticStatement>], CodegenContext) -> string
) -> Shared<CppExpression> = do
  const expanded_arms = match_codegen.expand_or_arms(arms)
  if match_codegen.expanded_any_guard(expanded_arms) then
    match_codegen.gen_match_guarded_expression_cpp(
      subject, expanded_arms, match_semantic_type, context, gen_stmts, eval_expr_cpp)
  else if should_use_string_match_if_chain(subject, expanded_arms) then
    match_codegen.gen_match_string_literal_expression_cpp(
      subject, expanded_arms, match_semantic_type, context, gen_stmts, eval_expr_cpp)
  else do
    const visit_void = match_codegen.match_visit_uses_void_lambdas(match_semantic_type)
    const handlers =
      expanded_arms.map(arm =>
        match_codegen.gen_arm_cpp(arm, context, gen_stmts, eval_expr_cpp, visit_void))
    const subject_expression = eval_expr_cpp(subject, context, gen_stmts)
    const needs_dereference =
      if expanded_arms.length() > 0 then first_arm_needs_deref(expanded_arms[0], subject, context) else true end
    const visit_subject =
      if needs_dereference then Shared.new(CppUnary("*", subject_expression))
      else subject_expression
      end
    Shared.new(CppStdVisit(visit_subject, handlers))
  end
  end
end

fn record_field_expressions(
  field_values: [Shared<SemanticFieldVal>],
  type_name: string,
  context: CodegenContext,
  gen_stmts: ([Shared<SemanticStatement>], CodegenContext) -> string
) -> [Shared<CppExpression>] = do
  const field_order = lookup_fields_for_context(context, type_name)
  if field_order.length() > 0 then
    field_order.map(field_name =>
      eval_expr_cpp(find_field_value(field_values, field_name), context, gen_stmts))
  else
    field_values.map(field_value => eval_expr_cpp(field_value.value, context, gen_stmts))
  end
end

export fn gen_record_via_cpp_visitor(
  type_name: string,
  field_values: [Shared<SemanticFieldVal>],
  expression_type: Shared<Type>,
  context: CodegenContext,
  gen_stmts: ([Shared<SemanticStatement>], CodegenContext) -> string
) -> Shared<CppExpression> = do
  const cpp_name = match expression_type {
    TGeneric(_, _) => sem_type_to_cpp(context, expression_type),
    _ => context.resolve(type_name)
  }
  Shared.new(CppAggregateInit(
    cpp_name,
    record_field_expressions(field_values, type_name, context, gen_stmts)))
end

export fn gen_array_via_cpp_visitor(
  elements: [Shared<SemanticExpression>],
  element_container_semantic_type: Shared<Type>,
  context: CodegenContext,
  gen_stmts: ([Shared<SemanticStatement>], CodegenContext) -> string
) -> Shared<CppExpression> = do
  const element_expressions = elements.map(element => eval_expr_cpp(element, context, gen_stmts))
  match element_container_semantic_type {
    TArray(inner_type) => do
      const element_cpp = sem_type_to_cpp(context, inner_type)
      if elements.length() == 0 then
        if element_cpp == 'auto' then Shared.new(CppInitList([]))
        else Shared.new(CppAggregateInit(`mlc::Array<${element_cpp}>`, []))
        end
      else if element_cpp == 'auto' then
        Shared.new(CppAggregateInit('mlc::Array', element_expressions))
      else
        Shared.new(CppAggregateInit(`mlc::Array<${element_cpp}>`, element_expressions))
      end
    end,
    _ => do
      if elements.length() == 0 then Shared.new(CppInitList([]))
      else Shared.new(CppAggregateInit('mlc::Array', element_expressions))
      end
    end
  }
end

fn lambda_capture_list(parameter_binding_names: [string]) -> [Shared<CppCapture>] =
  if parameter_binding_names.length() == 0 then []
  else do
    let captures: [Shared<CppCapture>] = []
    captures.push(value_capture_for_lambda())
    captures
  end

fn lambda_parameter_type_cpp(context: CodegenContext, semantic_parameter_type: Shared<Type>) -> Shared<CppType> = do
  const parameter_type_cpp = sem_type_to_cpp(context, semantic_parameter_type)
  if parameter_type_cpp == 'void' then Shared.new(CppTypeName('std::tuple<>'))
  else Shared.new(CppTypeName(parameter_type_cpp))
  end
end

fn lambda_auto_parameters_cpp(parameter_binding_names: [string]) -> [Shared<CppParam>] =
  parameter_binding_names.map(parameter_name =>
    Shared.new(CppParam {
      name: cpp_safe(parameter_name),
      parameter_type: Shared.new(CppTypeName('auto'))
    }))

fn lambda_parameters_cpp(
  parameter_binding_names: [string],
  semantic_function_type_for_lambda_expression: Shared<Type>,
  context: CodegenContext
) -> [Shared<CppParam>] =
  match semantic_function_type_for_lambda_expression {
    TFn(lambda_parameter_semantic_types, _) =>
      if lambda_parameter_semantic_types.length() != parameter_binding_names.length() then
        lambda_auto_parameters_cpp(parameter_binding_names)
      else
        let parameters: [Shared<CppParam>] = []
        let mut lambda_parameter_index = 0
        while lambda_parameter_index < parameter_binding_names.length() do
          parameters.push(Shared.new(CppParam {
            name: cpp_safe(parameter_binding_names[lambda_parameter_index]),
            parameter_type: lambda_parameter_type_cpp(context, lambda_parameter_semantic_types[lambda_parameter_index])
          }))
          lambda_parameter_index = lambda_parameter_index + 1
        end
        parameters
      end,
    _ => lambda_auto_parameters_cpp(parameter_binding_names)
  }

export fn gen_lambda_via_cpp_visitor(
  parameter_binding_names: [string],
  body_expression_under_lambda: Shared<SemanticExpression>,
  semantic_function_type_for_lambda_expression: Shared<Type>,
  context: CodegenContext,
  gen_stmts: ([Shared<SemanticStatement>], CodegenContext) -> string
) -> Shared<CppExpression> =
  Shared.new(CppMutableLambda(
    lambda_capture_list(parameter_binding_names),
    lambda_parameters_cpp(parameter_binding_names, semantic_function_type_for_lambda_expression, context),
    eval_expr_cpp(body_expression_under_lambda, context, gen_stmts)))

export fn gen_field_via_cpp_visitor(
  object: Shared<SemanticExpression>,
  field_name: string,
  context: CodegenContext,
  gen_stmts: ([Shared<SemanticStatement>], CodegenContext) -> string
) -> Shared<CppExpression> = do
  const object_expression = eval_expr_cpp(object, context, gen_stmts)
  const is_pointer = field_access_operator(object, context) == '->'
  Shared.new(CppMember(object_expression, cpp_safe(field_name), is_pointer))
end

export fn gen_index_via_cpp_visitor(
  object: Shared<SemanticExpression>,
  index_expression: Shared<SemanticExpression>,
  context: CodegenContext,
  gen_stmts: ([Shared<SemanticStatement>], CodegenContext) -> string
) -> Shared<CppExpression> =
  Shared.new(CppIndex(
    eval_expr_cpp(object, context, gen_stmts),
    eval_expr_cpp(index_expression, context, gen_stmts)))

export fn gen_while_via_cpp_visitor(
  condition: Shared<SemanticExpression>,
  statements: [Shared<SemanticStatement>],
  context: CodegenContext,
  gen_stmts: ([Shared<SemanticStatement>], CodegenContext) -> string
) -> Shared<CppExpression> =
  Shared.new(CppInvokedWhile(
    eval_expr_cpp(condition, context, gen_stmts),
    gen_stmts(statements, context)))

export fn gen_for_via_cpp_visitor(
  variable: string,
  iterator: Shared<SemanticExpression>,
  statements: [Shared<SemanticStatement>],
  context: CodegenContext,
  gen_stmts: ([Shared<SemanticStatement>], CodegenContext) -> string
) -> Shared<CppExpression> =
  Shared.new(CppInvokedFor(
    cpp_safe(variable),
    eval_expr_cpp(iterator, context, gen_stmts),
    gen_stmts(statements, context)))

export fn gen_record_update_via_cpp_visitor(
  type_name: string,
  base_expression: Shared<SemanticExpression>,
  overrides: [Shared<SemanticFieldVal>],
  context: CodegenContext,
  gen_stmts: ([Shared<SemanticStatement>], CodegenContext) -> string
) -> Shared<CppExpression> =
  record_gen.gen_record_update_expr_cpp(
    type_name, base_expression, overrides, context, gen_stmts, eval_expr_cpp)

export fn gen_tuple_via_cpp_visitor(
  elements: [Shared<SemanticExpression>],
  context: CodegenContext,
  gen_stmts: ([Shared<SemanticStatement>], CodegenContext) -> string
) -> Shared<CppExpression> =
  Shared.new(CppCall(
    emit_helpers.make_identifier_cpp_expression('std::make_tuple'),
    elements.map(element => eval_expr_cpp(element, context, gen_stmts))))

export fn gen_question_via_cpp_visitor(
  inner_expression: Shared<SemanticExpression>,
  context: CodegenContext,
  gen_stmts: ([Shared<SemanticStatement>], CodegenContext) -> string
) -> Shared<CppExpression> =
  Shared.new(CppQuestionTry(eval_expr_cpp(inner_expression, context, gen_stmts)))

export fn gen_with_via_cpp_visitor(
  resource: Shared<SemanticExpression>,
  binder: string,
  statements: [Shared<SemanticStatement>],
  context: CodegenContext,
  gen_stmts: ([Shared<SemanticStatement>], CodegenContext) -> string
) -> Shared<CppExpression> =
  Shared.new(CppWithBlock(
    eval_expr_cpp(resource, context, gen_stmts),
    binder,
    gen_stmts(statements, context)))

export fn gen_binary_via_cpp_visitor(
  operation: string,
  left_expression: Shared<SemanticExpression>,
  right_expression: Shared<SemanticExpression>,
  context: CodegenContext,
  gen_stmts: ([Shared<SemanticStatement>], CodegenContext) -> string,
  evaluate_expression: (Shared<SemanticExpression>, CodegenContext, ([Shared<SemanticStatement>], CodegenContext) -> string) -> Shared<CppExpression>
) -> Shared<CppExpression> = do
  const method = operator_method_for(operation)
  const left_type = sexpr_type(left_expression)
  const type_name = match left_type { TNamed(name) => name, _ => '' }
  if method != '' && type_name != '' then
    Shared.new(CppCall(
      emit_helpers.make_identifier_cpp_expression(type_name + "_" + method),
      [evaluate_expression(left_expression, context, gen_stmts),
       evaluate_expression(right_expression, context, gen_stmts)]))
  else
    Shared.new(CppBinary(
      operation,
      evaluate_expression(left_expression, context, gen_stmts),
      evaluate_expression(right_expression, context, gen_stmts)))
  end
end

export fn gen_unary_via_cpp_visitor(
  operation: string,
  inner_expression: Shared<SemanticExpression>,
  context: CodegenContext,
  gen_stmts: ([Shared<SemanticStatement>], CodegenContext) -> string,
  evaluate_expression: (Shared<SemanticExpression>, CodegenContext, ([Shared<SemanticStatement>], CodegenContext) -> string) -> Shared<CppExpression>
) -> Shared<CppExpression> =
  Shared.new(CppUnary(operation, evaluate_expression(inner_expression, context, gen_stmts)))

fn dispatch_codegen_pass(codegen_pass: CodegenPass, expression: Shared<SemanticExpression>) -> Shared<CppExpression> =
  match expression {
    SemanticExpressionInt(integer_value, type_value, _) =>
      codegen_pass.visit_int(integer_value, type_value),
    SemanticExpressionStr(string_value, type_value, _) =>
      codegen_pass.visit_str(string_value, type_value),
    SemanticExpressionBool(boolean_value, type_value, _) =>
      codegen_pass.visit_bool(boolean_value, type_value),
    SemanticExpressionUnit(type_value, _) =>
      codegen_pass.visit_unit(type_value),
    SemanticExpressionFloat(float_value, type_value, _) =>
      codegen_pass.visit_float(float_value, type_value),
    SemanticExpressionI64(integer_value, type_value, _) =>
      codegen_pass.visit_i64(integer_value, type_value),
    SemanticExpressionU8(byte_value, type_value, _) =>
      codegen_pass.visit_u8(byte_value, type_value),
    SemanticExpressionUsize(size_value, type_value, _) =>
      codegen_pass.visit_usize(size_value, type_value),
    SemanticExpressionChar(character_value, type_value, _) =>
      codegen_pass.visit_char(character_value, type_value),
    SemanticExpressionExtern(type_value, _) =>
      codegen_pass.visit_extern(type_value),
    SemanticExpressionIdent(name_value, type_value, _) =>
      codegen_pass.visit_ident(name_value, type_value),
    SemanticExpressionBin(operation, left_expression, right_expression, type_value, _) =>
      codegen_pass.visit_bin(operation, left_expression, right_expression, type_value),
    SemanticExpressionUn(operation, inner_expression, type_value, _) =>
      codegen_pass.visit_un(operation, inner_expression, type_value),
    SemanticExpressionCall(function_expression, arguments, mutability_flags, type_value, _) =>
      codegen_pass.visit_call(function_expression, arguments, mutability_flags, type_value),
    SemanticExpressionMethod(object, method_name, arguments, mutability_flags, type_value, _) =>
      codegen_pass.visit_method(object, method_name, arguments, mutability_flags, type_value),
    SemanticExpressionField(object, field_name, type_value, _) =>
      codegen_pass.visit_field(object, field_name, type_value),
    SemanticExpressionIndex(object, index_expression, type_value, _) =>
      codegen_pass.visit_index(object, index_expression, type_value),
    SemanticExpressionIf(condition, then_expression, else_expression, type_value, _) =>
      codegen_pass.visit_if(condition, then_expression, else_expression, type_value),
    SemanticExpressionBlock(statements, result_expression, type_value, _) =>
      codegen_pass.visit_block(statements, result_expression, type_value),
    SemanticExpressionWhile(condition, statements, type_value, _) =>
      codegen_pass.visit_while(condition, statements, type_value),
    SemanticExpressionFor(variable, iterator, statements, type_value, _) =>
      codegen_pass.visit_for(variable, iterator, statements, type_value),
    SemanticExpressionMatch(subject, arms, type_value, _) =>
      codegen_pass.visit_match(subject, arms, type_value),
    SemanticExpressionRecord(type_name, field_values, type_value, _) =>
      codegen_pass.visit_record(type_name, field_values, type_value),
    SemanticExpressionRecordUpdate(type_name, base_expression, overrides, type_value, _) =>
      codegen_pass.visit_record_update(type_name, base_expression, overrides, type_value),
    SemanticExpressionArray(elements, type_value, _) =>
      codegen_pass.visit_array(elements, type_value),
    SemanticExpressionTuple(elements, type_value, _) =>
      codegen_pass.visit_tuple(elements, type_value),
    SemanticExpressionQuestion(inner_expression, type_value, _) =>
      codegen_pass.visit_question(inner_expression, type_value),
    SemanticExpressionLambda(parameter_names, body_expression, type_value, _) =>
      codegen_pass.visit_lambda(parameter_names, body_expression, type_value),
    SemanticExpressionWith(resource, binder, statements, type_value, _) =>
      codegen_pass.visit_with(resource, binder, statements, type_value),
    _ => codegen_pass.visit_unsupported(expression)
  }

extend CodegenPass : ExprVisitor<Shared<CppExpression>> {
  fn visit_int(self: CodegenPass, value: i32, _semantic_type: Shared<Type>) -> Shared<CppExpression> =
    literals.gen_integer_literal_cpp(value)
  fn visit_str(self: CodegenPass, value: string, _semantic_type: Shared<Type>) -> Shared<CppExpression> =
    literals.gen_string_literal_cpp(value)
  fn visit_bool(self: CodegenPass, value: bool, _semantic_type: Shared<Type>) -> Shared<CppExpression> =
    literals.gen_boolean_literal_cpp(value)
  fn visit_unit(self: CodegenPass, _semantic_type: Shared<Type>) -> Shared<CppExpression> =
    literals.gen_unit_literal_cpp()
  fn visit_float(self: CodegenPass, value: string, _semantic_type: Shared<Type>) -> Shared<CppExpression> =
    literals.gen_float_literal_cpp(value)
  fn visit_i64(self: CodegenPass, value: string, _semantic_type: Shared<Type>) -> Shared<CppExpression> =
    literals.gen_i64_literal_cpp(value)
  fn visit_u8(self: CodegenPass, value: string, _semantic_type: Shared<Type>) -> Shared<CppExpression> =
    literals.gen_u8_literal_cpp(value)
  fn visit_usize(self: CodegenPass, value: string, _semantic_type: Shared<Type>) -> Shared<CppExpression> =
    literals.gen_usize_literal_cpp(value)
  fn visit_char(self: CodegenPass, value: string, _semantic_type: Shared<Type>) -> Shared<CppExpression> =
    literals.gen_char_literal_cpp(value)
  fn visit_extern(self: CodegenPass, _semantic_type: Shared<Type>) -> Shared<CppExpression> =
    literals.gen_extern_placeholder_cpp()
  fn visit_ident(self: CodegenPass, name: string, _semantic_type: Shared<Type>) -> Shared<CppExpression> =
    identifiers.gen_identifier_cpp(name, self.context)
  fn visit_bin(self: CodegenPass, operation: string, left_expression: Shared<SemanticExpression>, right_expression: Shared<SemanticExpression>, _semantic_type: Shared<Type>) -> Shared<CppExpression> =
    gen_binary_via_cpp_visitor(operation, left_expression, right_expression, self.context, self.gen_stmts, self.evaluate_expression)
  fn visit_un(self: CodegenPass, operation: string, inner_expression: Shared<SemanticExpression>, _semantic_type: Shared<Type>) -> Shared<CppExpression> =
    gen_unary_via_cpp_visitor(operation, inner_expression, self.context, self.gen_stmts, self.evaluate_expression)
  fn visit_call(self: CodegenPass, function_expression: Shared<SemanticExpression>, arguments: [Shared<SemanticExpression>], mutability_flags: [i32], _semantic_type: Shared<Type>) -> Shared<CppExpression> =
    gen_call_via_cpp_visitor(function_expression, arguments, mutability_flags, self.context, self.gen_stmts)
  fn visit_method(self: CodegenPass, object: Shared<SemanticExpression>, method_name: string, arguments: [Shared<SemanticExpression>], mutability_flags: [i32], _semantic_type: Shared<Type>) -> Shared<CppExpression> =
    gen_method_via_cpp_visitor(object, method_name, arguments, mutability_flags, self.context, self.gen_stmts)
  fn visit_field(self: CodegenPass, object: Shared<SemanticExpression>, field_name: string, _semantic_type: Shared<Type>) -> Shared<CppExpression> =
    gen_field_via_cpp_visitor(object, field_name, self.context, self.gen_stmts)
  fn visit_index(self: CodegenPass, object: Shared<SemanticExpression>, index_expression: Shared<SemanticExpression>, _semantic_type: Shared<Type>) -> Shared<CppExpression> =
    gen_index_via_cpp_visitor(object, index_expression, self.context, self.gen_stmts)
  fn visit_if(self: CodegenPass, condition: Shared<SemanticExpression>, then_expression: Shared<SemanticExpression>, else_expression: Shared<SemanticExpression>, semantic_type: Shared<Type>) -> Shared<CppExpression> =
    gen_if_via_cpp_visitor(condition, then_expression, else_expression, semantic_type, self.context, self.gen_stmts)
  fn visit_block(self: CodegenPass, statements: [Shared<SemanticStatement>], result_expression: Shared<SemanticExpression>, _semantic_type: Shared<Type>) -> Shared<CppExpression> =
    gen_block_via_cpp_visitor(statements, result_expression, self.context, self.gen_stmts)
  fn visit_while(self: CodegenPass, condition: Shared<SemanticExpression>, statements: [Shared<SemanticStatement>], _semantic_type: Shared<Type>) -> Shared<CppExpression> =
    gen_while_via_cpp_visitor(condition, statements, self.context, self.gen_stmts)
  fn visit_for(self: CodegenPass, variable: string, iterator: Shared<SemanticExpression>, statements: [Shared<SemanticStatement>], _semantic_type: Shared<Type>) -> Shared<CppExpression> =
    gen_for_via_cpp_visitor(variable, iterator, statements, self.context, self.gen_stmts)
  fn visit_match(self: CodegenPass, subject: Shared<SemanticExpression>, arms: [Shared<SemanticMatchArm>], semantic_type: Shared<Type>) -> Shared<CppExpression> =
    gen_match_via_cpp_visitor(subject, arms, semantic_type, self.context, self.gen_stmts)
  fn visit_record(self: CodegenPass, type_name: string, field_values: [Shared<SemanticFieldVal>], semantic_type: Shared<Type>) -> Shared<CppExpression> =
    gen_record_via_cpp_visitor(type_name, field_values, semantic_type, self.context, self.gen_stmts)
  fn visit_record_update(self: CodegenPass, type_name: string, base_expression: Shared<SemanticExpression>, overrides: [Shared<SemanticFieldVal>], _semantic_type: Shared<Type>) -> Shared<CppExpression> =
    gen_record_update_via_cpp_visitor(type_name, base_expression, overrides, self.context, self.gen_stmts)
  fn visit_array(self: CodegenPass, elements: [Shared<SemanticExpression>], semantic_type: Shared<Type>) -> Shared<CppExpression> =
    gen_array_via_cpp_visitor(elements, semantic_type, self.context, self.gen_stmts)
  fn visit_tuple(self: CodegenPass, elements: [Shared<SemanticExpression>], _semantic_type: Shared<Type>) -> Shared<CppExpression> =
    gen_tuple_via_cpp_visitor(elements, self.context, self.gen_stmts)
  fn visit_question(self: CodegenPass, inner_expression: Shared<SemanticExpression>, _semantic_type: Shared<Type>) -> Shared<CppExpression> =
    gen_question_via_cpp_visitor(inner_expression, self.context, self.gen_stmts)
  fn visit_lambda(self: CodegenPass, parameter_names: [string], body_expression: Shared<SemanticExpression>, semantic_type: Shared<Type>) -> Shared<CppExpression> =
    gen_lambda_via_cpp_visitor(parameter_names, body_expression, semantic_type, self.context, self.gen_stmts)
  fn visit_with(self: CodegenPass, resource: Shared<SemanticExpression>, binder: string, statements: [Shared<SemanticStatement>], _semantic_type: Shared<Type>) -> Shared<CppExpression> =
    gen_with_via_cpp_visitor(resource, binder, statements, self.context, self.gen_stmts)
  fn visit_unsupported(self: CodegenPass, _expression: Shared<SemanticExpression>) -> Shared<CppExpression> =
    unsupported_cpp_expression()
}

export fn eval_expr_with_cpp_visitor(
  expression: Shared<SemanticExpression>,
  context: CodegenContext,
  gen_stmts: ([Shared<SemanticStatement>], CodegenContext) -> string,
  evaluate_expression: (Shared<SemanticExpression>, CodegenContext, ([Shared<SemanticStatement>], CodegenContext) -> string) -> Shared<CppExpression>
) -> Shared<CppExpression> =
  dispatch_codegen_pass(codegen_pass_new(context, gen_stmts, evaluate_expression), expression)

export fn gen_expr_via_cpp_visitor(expression: Shared<SemanticExpression>, context: CodegenContext) -> Shared<CppExpression> =
  eval_expr_with_cpp_visitor(expression, context, ignored_gen_stmts, evaluate_via_cpp_visitor)