// Statement code generation. gen_expr_fn injected as a function parameter to
// break the import cycle with eval.mlc. Private helpers thread gen_expr_fn
// through; recursive eval_stmts_str calls go directly (same module).

import { SemanticExpression, SemanticStatement, SemanticExpressionUnit, SemanticExpressionIf, SemanticExpressionBlock } from '../../ir/semantic_ir'
import { gen_let_pattern_statement } from '../expr/let_pat'
import { Type, TArray, TGeneric, TNamed } from '../../checker/registry'
import { CodegenContext, GenStmtsResult, GenStmtsWithContext, GenStmtResult,
         mutate_context_from_statement } from '../context'
import { cpp_safe } from '../cpp_naming'
import { generate_conditional_else_with_empty_array_coercion } from '../expr/expression_support'
import { sem_type_to_cpp } from '../decl/type_gen'
import { gen_unit_literal } from '../expr/literals'
import * as expression_output from '../expr/expr'

// --- Try unwrap helper -------------------------------------------------------

fn constexpr_binding_value_code(
  value: Shared<SemanticExpression>,
  binding_semantic_type: Shared<Type>,
  context: CodegenContext,
  gen_expr_fn: (Shared<SemanticExpression>, CodegenContext) -> string
) -> string =
  match value {
    SemanticExpressionBlock(inner_statements, result_expression, _, _) =>
      if inner_statements.length() == 0 then
        constexpr_binding_value_code(result_expression, binding_semantic_type, context, gen_expr_fn)
      else gen_expr_fn(value, context)
      end,
    SemanticExpressionIf(condition, then_branch, else_branch, _, _) => do
      const cond_code = gen_expr_fn(condition, context)
      const then_code = gen_expr_fn(then_branch, context)
      const else_code = generate_conditional_else_with_empty_array_coercion(
        then_branch, else_branch, binding_semantic_type, context, gen_expr_fn)
      match binding_semantic_type {
        TNamed(type_name) => do
          const type_cpp = context.resolve(type_name)
          if type_cpp == 'auto' then
            expression_output.ternary_conditional(cond_code, then_code, else_code)
          else
            `[&]() -> ${type_cpp} {\nif (${cond_code}) {\nreturn ${then_code};\n} else {\nreturn ${else_code};\n}\n}()`
          end
        end,
        _ => expression_output.ternary_conditional(cond_code, then_code, else_code)
      }
    end,
    _ => gen_expr_fn(value, context)
  }

export fn eval_try_unwrap(inner_expr: Shared<SemanticExpression>, context: CodegenContext, try_identifier: string, success_line: string, gen_expr_fn: (Shared<SemanticExpression>, CodegenContext) -> string) -> string = do
  const inner_code = gen_expr_fn(inner_expr, context)
  expression_output.try_unwrap_result_block(try_identifier, inner_code, success_line)
end

// --- Statement generation ----------------------------------------------------

fn eval_stmt_if_else_suffix(
  else_expression: Shared<SemanticExpression>,
  context: CodegenContext,
  gen_expr_fn: (Shared<SemanticExpression>, CodegenContext) -> string
) -> string =
  match else_expression {
    SemanticExpressionUnit(_, _) => '',
    SemanticExpressionBlock(statements, result_expression, _, _) =>
      if statements.length() == 0 then
        match result_expression {
          SemanticExpressionUnit(_, _) => '',
          _ => expression_output.else_brace_block(eval_block_body(else_expression, context, gen_expr_fn))
        }
      else expression_output.else_brace_block(eval_block_body(else_expression, context, gen_expr_fn))
      end,
    SemanticExpressionIf(_, _, _, _, _) =>
      expression_output.else_fragment_raw(eval_stmt_if_nested(else_expression, context, gen_expr_fn)),
    _ => expression_output.else_brace_block(eval_block_body(else_expression, context, gen_expr_fn))
  }

fn eval_stmt_if_nested(if_expression: Shared<SemanticExpression>, context: CodegenContext, gen_expr_fn: (Shared<SemanticExpression>, CodegenContext) -> string) -> string =
  match if_expression {
    SemanticExpressionIf(condition_expression, then_expression, else_expression, _, _) => do
      const opening = expression_output.if_brace_block(
        gen_expr_fn(condition_expression, context),
        eval_block_body(then_expression, context, gen_expr_fn))
      const else_suffix = eval_stmt_if_else_suffix(else_expression, context, gen_expr_fn)
      expression_output.fragment_with_newline(expression_output.prefix_with_optional_suffix(opening, else_suffix))
    end,
    _ => expression_output.if_always_true_block(eval_block_body(if_expression, context, gen_expr_fn))
  }

fn eval_block_body(expr: Shared<SemanticExpression>, context: CodegenContext, gen_expr_fn: (Shared<SemanticExpression>, CodegenContext) -> string) -> string =
  match expr {
    SemanticExpressionBlock(statements, result_expr, _, _) => do
      const statements_with_context = eval_stmts_str_with_try(statements, context, 0, gen_expr_fn)
      const statements_code = statements_with_context.statements_parsed.joined_code()
      const final_context   = statements_with_context.codegen_context
      match result_expr {
        SemanticExpressionIf(_, _, _, _, _) => statements_code + eval_stmt_if_nested(result_expr, final_context, gen_expr_fn),
        SemanticExpressionUnit(_, _)        => statements_code,
        _ => do
          const result_code = gen_expr_fn(result_expr, final_context)
          if result_code == gen_unit_literal() then statements_code
          else expression_output.append_trailing_expression_statement(statements_code, result_code)
          end
        end
      }
    end,
    SemanticExpressionIf(_, _, _, _, _) => eval_stmt_if_nested(expr, context, gen_expr_fn),
    _ => expression_output.suffix_semicolon_newline(gen_expr_fn(expr, context))
  }

fn eval_stmt_expr(expression: Shared<SemanticExpression>, context: CodegenContext, gen_expr_fn: (Shared<SemanticExpression>, CodegenContext) -> string) -> string =
  match expression {
    SemanticExpressionBin(operation, left_expr, right_expr, _, _) =>
      if operation == "=" then
        expression_output.assignment_statement(gen_expr_fn(left_expr, context), gen_expr_fn(right_expr, context))
      else
        expression_output.expression_operation_statement(
          operation,
          gen_expr_fn(left_expr, context),
          gen_expr_fn(right_expr, context))
      end,
    SemanticExpressionIf(_, _, _, _, _) =>
      eval_stmt_if_nested(expression, context, gen_expr_fn),
    SemanticExpressionWhile(condition, statements, _, _) =>
      expression_output.while_loop_statement(
        gen_expr_fn(condition, context),
        eval_stmts_str(statements, context, gen_expr_fn)),
    SemanticExpressionFor(variable, iterator, statements, _, _) =>
      expression_output.for_loop_statement(
        cpp_safe(variable),
        gen_expr_fn(iterator, context),
        eval_stmts_str(statements, context, gen_expr_fn)),
    SemanticExpressionWith(resource, binder, stmts, _, _) =>
      expression_output.with_block_statement(
        gen_expr_fn(resource, context),
        cpp_safe(binder),
        eval_stmts_str(stmts, context, gen_expr_fn)),
    SemanticExpressionBlock(statements, result_expr, _, _) => do
      const statements_with_context = eval_stmts_str_with_try(statements, context, 0, gen_expr_fn)
      const statements_code = statements_with_context.statements_parsed.joined_code()
      const result_code = gen_expr_fn(result_expr, statements_with_context.codegen_context)
      if result_code == gen_unit_literal() then statements_code
      else expression_output.append_trailing_expression_statement(statements_code, result_code)
      end
    end,
    _ => expression_output.suffix_semicolon_newline(gen_expr_fn(expression, context))
  }

fn eval_elements_code(elements: [Shared<SemanticExpression>], context: CodegenContext, gen_expr_fn: (Shared<SemanticExpression>, CodegenContext) -> string) -> string =
  elements.map(element => gen_expr_fn(element, context)).join(', ')

export fn eval_stmt_with_try(stmt: Shared<SemanticStatement>, context: CodegenContext, try_counter: i32, gen_expr_fn: (Shared<SemanticExpression>, CodegenContext) -> string) -> GenStmtResult =
  match stmt {
    SemanticStatementLet(name, _, value, value_type, _) => do
      const try_identifier = `__try_${try_counter.to_string()}`
      const next_counter = try_counter + 1
      const statement_parsed = match value {
        SemanticExpressionQuestion(inner_expr, _, _) =>
          GenStmtResult {
            output: eval_try_unwrap(
              inner_expr,
              context,
              try_identifier,
              expression_output.let_from_try_ok_field0(cpp_safe(name), try_identifier),
              gen_expr_fn),
            next_try: next_counter,
            codegen_context: context
          },
        SemanticExpressionArray(elements, array_type, _) => do
          const value_code = match array_type {
            TArray(inner_type) => do
              const element_cpp = sem_type_to_cpp(context, inner_type)
              if elements.length() == 0 then
                expression_output.typed_array_empty_or_untyped_empty(element_cpp)
              else if element_cpp == 'auto' then
                expression_output.array_literal(eval_elements_code(elements, context, gen_expr_fn))
              else
                expression_output.typed_array_braced_initializer(element_cpp, eval_elements_code(elements, context, gen_expr_fn))
              end
            end,
            _ => if elements.length() == 0 then expression_output.array_string_fallback_empty()
                 else expression_output.constructor_call_braces('mlc::Array', eval_elements_code(elements, context, gen_expr_fn))
                 end
          }
          GenStmtResult {
            output: expression_output.auto_binding_statement(cpp_safe(name), value_code),
            next_try: try_counter,
            codegen_context: context
          }
        end,
        SemanticExpressionMethod(map_object, method_name, _, _, _, _) => do
          const value_code = if method_name == 'new' then
            match map_object {
              SemanticExpressionIdent(object_name, _, _) =>
                if object_name == 'Map' then
                  match value_type {
                    TGeneric(type_name, type_args) =>
                      if type_name == 'Map' && type_args.length() == 2 then
                        expression_output.hash_map_empty_instantiation(
                          sem_type_to_cpp(context, type_args[0]),
                          sem_type_to_cpp(context, type_args[1]))
                      else gen_expr_fn(value, context)
                      end,
                    _ => gen_expr_fn(value, context)
                  }
                else gen_expr_fn(value, context)
                end,
              _ => gen_expr_fn(value, context)
            }
          else gen_expr_fn(value, context)
          end
          GenStmtResult {
            output: expression_output.auto_binding_statement(cpp_safe(name), value_code),
            next_try: try_counter,
            codegen_context: context
          }
        end,
        _ => GenStmtResult {
          output: expression_output.auto_binding_statement(cpp_safe(name), gen_expr_fn(value, context)),
          next_try: try_counter,
          codegen_context: context
        }
      }
      statement_parsed
    end,
    SemanticStatementLetPat(pat, _, value, value_type, has_else, else_body, _) => do
      const pattern_parsed = gen_let_pattern_statement(pat, value, value_type, has_else, else_body, context, gen_expr_fn)
      GenStmtResult {
        output: pattern_parsed.output,
        next_try: try_counter,
        codegen_context: pattern_parsed.codegen_context
      }
    end,
    SemanticStatementLetConst(name, value, binding_semantic_type, _) =>
      GenStmtResult {
        output: expression_output.constexpr_auto_binding_statement(
          cpp_safe(name),
          constexpr_binding_value_code(value, binding_semantic_type, context, gen_expr_fn)),
        next_try: try_counter,
        codegen_context: context
      },
    SemanticStatementExpr(expression, _) => match expression {
      SemanticExpressionQuestion(inner_expr, _, _) => do
        const try_identifier = `__try_${try_counter.to_string()}`
        GenStmtResult {
          output: eval_try_unwrap(
            inner_expr,
            context,
            try_identifier,
            expression_output.discard_try_ok_field0_statement(try_identifier),
            gen_expr_fn),
          next_try: try_counter + 1,
          codegen_context: context
        }
      end,
      _ => GenStmtResult {
        output: eval_stmt_expr(expression, context, gen_expr_fn),
        next_try: try_counter,
        codegen_context: context
      }
    },
    SemanticStatementBreak(_)    => GenStmtResult { output: expression_output.break_line(), next_try: try_counter, codegen_context: context },
    SemanticStatementContinue(_) => GenStmtResult { output: expression_output.continue_line(), next_try: try_counter, codegen_context: context },
    SemanticStatementReturn(expression, _) => match expression {
      SemanticExpressionQuestion(inner_expr, _, _) => do
        const try_identifier = `__try_ret_${try_counter.to_string()}`
        GenStmtResult {
          output: eval_try_unwrap(
            inner_expr,
            context,
            try_identifier,
            expression_output.return_try_ok_field0_statement(try_identifier),
            gen_expr_fn),
          next_try: try_counter + 1,
          codegen_context: context
        }
      end,
      _ => GenStmtResult {
        output: expression_output.return_line(gen_expr_fn(expression, context)),
        next_try: try_counter,
        codegen_context: context
      }
    }
  }

export fn eval_stmts_str_with_try(statements: [Shared<SemanticStatement>], context: CodegenContext, try_counter: i32, gen_expr_fn: (Shared<SemanticExpression>, CodegenContext) -> string) -> GenStmtsWithContext = do
  let mut statements_parsed = GenStmtsResult { parts: [], next_try: try_counter }
  let mut codegen_context = context
  let mut index = 0
  while index < statements.length() do
    const statement = statements[index]
    const statement_parsed = eval_stmt_with_try(statement, codegen_context, statements_parsed.next_try, gen_expr_fn)
    statements_parsed = statements_parsed.append_stmt(statement_parsed)
    codegen_context = statement_parsed.codegen_context
    mutate_context_from_statement(statement, codegen_context)
    index = index + 1
  end
  GenStmtsWithContext { statements_parsed: statements_parsed, codegen_context: codegen_context }
end

export fn eval_stmts_str(statements: [Shared<SemanticStatement>], context: CodegenContext, gen_expr_fn: (Shared<SemanticExpression>, CodegenContext) -> string) -> string =
  eval_stmts_str_with_try(statements, context, 0, gen_expr_fn).statements_parsed.joined_code()
