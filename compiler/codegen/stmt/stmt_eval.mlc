export fn eval_stmt_with_try(statement: Shared<SemanticStatement>, context: CodegenContext, try_counter: i32, gen_expr_fn: (Shared<SemanticExpression>, CodegenContext) -> string) -> GenStmtResult =
  match statement {
    SemanticStatementLet(name, _, value, value_type, _) =>
      gen_let_stmt_result(name, value, value_type, context, try_counter, gen_expr_fn),
    SemanticStatementLetPattern(pattern, _, value, value_type, has_else, else_body, _) => do
      const pattern_parsed = gen_let_pattern_statement(pattern, value, value_type, has_else, else_body, context, gen_expr_fn)
      GenStmtResult {
        output: pattern_parsed.output,
        next_try: try_counter,
        codegen_context: pattern_parsed.codegen_context
      }
    end,
    SemanticStatementLetConst(name, value, binding_semantic_type, _) =>
      GenStmtResult {
        output: expression_output.constexpr_auto_binding_statement(
          cpp_safe(name),
          constexpr_binding_value_code(value, binding_semantic_type, context, gen_expr_fn)),
        next_try: try_counter,
        codegen_context: context
      },
    SemanticStatementExpr(expression, _) =>
      gen_expr_stmt_result(expression, context, try_counter, gen_expr_fn),
    SemanticStatementBreak(_)    => GenStmtResult { output: expression_output.break_line(), next_try: try_counter, codegen_context: context },
    SemanticStatementContinue(_) => GenStmtResult { output: expression_output.continue_line(), next_try: try_counter, codegen_context: context },
    SemanticStatementReturn(expression, _) =>
      gen_return_stmt_result(expression, context, try_counter, gen_expr_fn)
  }

export fn eval_stmts_str_with_try(statements: [Shared<SemanticStatement>], context: CodegenContext, try_counter: i32, gen_expr_fn: (Shared<SemanticExpression>, CodegenContext) -> string) -> GenStmtsWithContext = do
  let mut statements_parsed = GenStmtsResult { parts: [], next_try: try_counter }
  let mut codegen_context = context
  let mut index = 0
  while index < statements.length() do
    const statement = statements[index]
    const statement_parsed = eval_stmt_with_try(statement, codegen_context, statements_parsed.next_try, gen_expr_fn)
    statements_parsed = statements_parsed.append_stmt(statement_parsed)
    codegen_context = statement_parsed.codegen_context
    mutate_context_from_statement(statement, codegen_context)
    index = index + 1
  end
  GenStmtsWithContext { statements_parsed: statements_parsed, codegen_context: codegen_context }
end

export fn eval_stmts_str(statements: [Shared<SemanticStatement>], context: CodegenContext, gen_expr_fn: (Shared<SemanticExpression>, CodegenContext) -> string) -> string =
  eval_stmts_str_with_try(statements, context, 0, gen_expr_fn).statements_parsed.joined_code()