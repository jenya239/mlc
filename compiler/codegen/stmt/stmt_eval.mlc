    SemanticExpressionMethod(_, _, _, _, _, _) => gen_let_stmt_result_default(name, value, value_type, context, try_counter, gen_expr_fn),
    SemanticExpressionField(_, _, _, _) => gen_let_stmt_result_default(name, value, value_type, context, try_counter, gen_expr_fn),
    SemanticExpressionIndex(_, _, _, _) => gen_let_stmt_result_default(name, value, value_type, context, try_counter, gen_expr_fn),
    SemanticExpressionIf(_, _, _, _, _) => gen_let_stmt_result_default(name, value, value_type, context, try_counter, gen_expr_fn),
    SemanticExpressionBlock(_, _, _, _) => gen_let_stmt_result_default(name, value, value_type, context, try_counter, gen_expr_fn),
    SemanticExpressionWhile(_, _, _, _) => gen_let_stmt_result_default(name, value, value_type, context, try_counter, gen_expr_fn),
    SemanticExpressionFor(_, _, _, _, _) => gen_let_stmt_result_default(name, value, value_type, context, try_counter, gen_expr_fn),
    SemanticExpressionMatch(_, _, _, _) => gen_let_stmt_result_default(name, value, value_type, context, try_counter, gen_expr_fn),
    SemanticExpressionRecord(_, _, _, _) => gen_let_stmt_result_default(name, value, value_type, context, try_counter, gen_expr_fn),
