// Expression code generation. gen_stmts injected as a function parameter to
// break the import cycle with stmt_eval.mlc. Private helpers thread gen_stmts
// through; recursive eval_expr calls go directly (same module).

import { SExpr, SStmt, sexpr_type, SExprArray } from "../semantic_ir"
import { SExprFloat, SExprI64, SExprU8, SExprUsize, SExprChar } from "../semantic_ir"
import { Type, TArray, TNamed } from "../checker/registry"
import { operator_method_for, array_element_type_from_array_type, type_is_unknown } from "../checker/semantic_type_structure"
import { CodegenContext, context_resolve } from "./context"
import { cpp_safe, map_builtin } from "./cpp_naming"
import { sem_type_to_cpp } from "./type_gen"
import { gen_integer_literal, gen_string_literal, gen_boolean_literal, gen_unit_literal, gen_extern_placeholder } from "./literals"
import { gen_float_literal, gen_i64_literal, gen_u8_literal, gen_usize_literal, gen_char_literal } from "./literals"
import { gen_identifier } from "./identifiers"
import { is_constructor_call, field_access_operator, cpp_lambda_header_prefix } from "./expression_support"
import { gen_match } from "./match_gen"
import { gen_record_expr, gen_record_update_expr } from "./record_gen"
import { gen_method_expr } from "./method_gen"
import { stmts_final_ctx } from "./statement_context"
import * as expression_output from "./expr"

// --- Argument list -----------------------------------------------------------

export fn eval_argument_list(expressions: [Shared<SExpr>], context: CodegenContext, gen_stmts: ([Shared<SStmt>], CodegenContext) -> string) -> string = do
  let parts: [string] = []; let mut index = 0
  while index < expressions.length() do
    parts.push(eval_expr(expressions[index], context, gen_stmts)); index = index + 1
  end
  parts.join(", ")
end

// --- Expression rules --------------------------------------------------------

fn gen_binary_expr(operation: string, left_expr: Shared<SExpr>, right_expr: Shared<SExpr>, context: CodegenContext, gen_stmts: ([Shared<SStmt>], CodegenContext) -> string) -> string = do
  const method    = operator_method_for(operation)
  const left_type = sexpr_type(left_expr)
  const type_name = match left_type { TNamed(n) => n, _ => "" }
  if method != "" && type_name != "" then
    type_name + "_" + method + "(" + eval_expr(left_expr, context, gen_stmts) + ", " + eval_expr(right_expr, context, gen_stmts) + ")"
  else
    expression_output.parenthesized_binary(eval_expr(left_expr, context, gen_stmts), operation, eval_expr(right_expr, context, gen_stmts))
  end
end

fn gen_unary_expr(operation: string, inner_expr: Shared<SExpr>, context: CodegenContext, gen_stmts: ([Shared<SStmt>], CodegenContext) -> string) -> string =
  expression_output.parenthesized_unary(operation, eval_expr(inner_expr, context, gen_stmts))

fn gen_call_function_code(function_expr: Shared<SExpr>, context: CodegenContext, gen_stmts: ([Shared<SStmt>], CodegenContext) -> string) -> string =
  match function_expr {
    SExprIdent(name, _, _) => context_resolve(context, map_builtin(name)),
    _ => eval_expr(function_expr, context, gen_stmts)
  }

fn gen_call_expr(function_expr: Shared<SExpr>, arguments: [Shared<SExpr>], context: CodegenContext, gen_stmts: ([Shared<SStmt>], CodegenContext) -> string) -> string = do
  const function_code = gen_call_function_code(function_expr, context, gen_stmts)
  const argument_list = eval_argument_list(arguments, context, gen_stmts)
  if is_constructor_call(function_expr) then expression_output.constructor_call_braces(function_code, argument_list)
  else expression_output.function_call_parentheses(function_code, argument_list)
  end
end

fn gen_field_expr(object: Shared<SExpr>, field_name: string, context: CodegenContext, gen_stmts: ([Shared<SStmt>], CodegenContext) -> string) -> string = do
  const object_code = eval_expr(object, context, gen_stmts)
  const operator = field_access_operator(object, context)
  expression_output.field_access(object_code, operator, cpp_safe(field_name))
end

fn gen_index_expr(object: Shared<SExpr>, index_expr: Shared<SExpr>, context: CodegenContext, gen_stmts: ([Shared<SStmt>], CodegenContext) -> string) -> string =
  expression_output.index_subscript(eval_expr(object, context, gen_stmts), eval_expr(index_expr, context, gen_stmts))

fn gen_if_else_code(
  else_expr: Shared<SExpr>,
  if_semantic_type: Shared<Type>,
  then_expr: Shared<SExpr>,
  context: CodegenContext,
  gen_stmts: ([Shared<SStmt>], CodegenContext) -> string
) -> string =
  match else_expr {
    SExprArray(elements, _, array_span) =>
      if elements.length() > 0 then eval_expr(else_expr, context, gen_stmts)
      else do
        const inner_preferred = array_element_type_from_array_type(if_semantic_type)
        const inner_from_then_branch = array_element_type_from_array_type(sexpr_type(then_expr))
        const inner_for_empty_array =
          if !type_is_unknown(inner_preferred) then inner_preferred
          else inner_from_then_branch
          end
        if type_is_unknown(inner_for_empty_array) then eval_expr(else_expr, context, gen_stmts)
        else
          eval_expr(
            Shared.new(SExprArray(elements, Shared.new(TArray(inner_for_empty_array)), array_span)),
            context,
            gen_stmts)
        end
      end,
    _ => eval_expr(else_expr, context, gen_stmts)
  }

fn gen_if_expr(
  condition: Shared<SExpr>,
  then_expr: Shared<SExpr>,
  else_expr: Shared<SExpr>,
  if_semantic_type: Shared<Type>,
  context: CodegenContext,
  gen_stmts: ([Shared<SStmt>], CodegenContext) -> string
) -> string = do
  const cond_code = eval_expr(condition, context, gen_stmts)
  const then_code = eval_expr(then_expr, context, gen_stmts)
  const else_code = gen_if_else_code(else_expr, if_semantic_type, then_expr, context, gen_stmts)
  match if_semantic_type {
    TNamed(type_name) => do
      const type_cpp = context_resolve(context, type_name)
      if type_cpp == "auto" then
        expression_output.ternary_conditional(cond_code, then_code, else_code)
      else
        "[&]() -> " + type_cpp + " {\nif (" + cond_code + ") {\nreturn " + then_code + ";\n} else {\nreturn " + else_code + ";\n}\n}()"
      end
    end,
    _ => expression_output.ternary_conditional(cond_code, then_code, else_code)
  }
end

fn gen_block_expr(statements: [Shared<SStmt>], result_expr: Shared<SExpr>, context: CodegenContext, gen_stmts: ([Shared<SStmt>], CodegenContext) -> string) -> string =
  if statements.length() == 0 then
    eval_expr(result_expr, context, gen_stmts)
  else
    const body =
      gen_stmts(statements, context) +
      expression_output.block_immediate_function_return_fragment(
        eval_expr(result_expr, stmts_final_ctx(statements, context), gen_stmts))
    expression_output.block_as_immediate_invoked_function_expression(body)
  end

fn gen_while_expr(condition: Shared<SExpr>, statements: [Shared<SStmt>], context: CodegenContext, gen_stmts: ([Shared<SStmt>], CodegenContext) -> string) -> string =
  expression_output.while_loop_immediate_invoked_function_expression(
    eval_expr(condition, context, gen_stmts),
    gen_stmts(statements, context))

fn gen_for_expr(variable: string, iterator: Shared<SExpr>, statements: [Shared<SStmt>], context: CodegenContext, gen_stmts: ([Shared<SStmt>], CodegenContext) -> string) -> string =
  expression_output.for_loop_immediate_invoked_function_expression(
    cpp_safe(variable),
    eval_expr(iterator, context, gen_stmts),
    gen_stmts(statements, context))

fn gen_array_expr(
  elements: [Shared<SExpr>],
  element_container_semantic_type: Shared<Type>,
  context: CodegenContext,
  gen_stmts: ([Shared<SStmt>], CodegenContext) -> string
) -> string =
  match element_container_semantic_type {
    TArray(inner_type) => do
      const element_cpp = sem_type_to_cpp(context, inner_type)
      if elements.length() == 0 then expression_output.typed_array_empty_or_untyped_empty(element_cpp)
      else if element_cpp == "auto" then expression_output.array_literal(eval_argument_list(elements, context, gen_stmts))
      else
        expression_output.typed_array_braced_initializer(
          element_cpp,
          eval_argument_list(elements, context, gen_stmts))
      end
    end,
    _ => expression_output.array_literal(eval_argument_list(elements, context, gen_stmts))
  }

fn gen_question_expr(inner_expr: Shared<SExpr>, context: CodegenContext, gen_stmts: ([Shared<SStmt>], CodegenContext) -> string) -> string = do
  const inner_code = eval_expr(inner_expr, context, gen_stmts)
  expression_output.question_try_result(inner_code)
end

fn gen_lambda_expr(parameters: [string], body_expr: Shared<SExpr>, context: CodegenContext, gen_stmts: ([Shared<SStmt>], CodegenContext) -> string) -> string =
  expression_output.lambda_with_return(cpp_lambda_header_prefix(parameters), eval_expr(body_expr, context, gen_stmts))

// --- Dispatcher --------------------------------------------------------------

export fn eval_expr(expr: Shared<SExpr>, context: CodegenContext, gen_stmts: ([Shared<SStmt>], CodegenContext) -> string) -> string =
  match expr {
    SExprInt(integer_value, _, _)                          => gen_integer_literal(integer_value),
    SExprStr(string_value, _, _)                           => gen_string_literal(string_value),
    SExprBool(boolean_value, _, _)                         => gen_boolean_literal(boolean_value),
    SExprUnit(_, _)                                        => gen_unit_literal(),
    SExprExtern(_, _)                                      => gen_extern_placeholder(),
    SExprFloat(v, _, _)                                    => gen_float_literal(v),
    SExprI64(v, _, _)                                      => gen_i64_literal(v),
    SExprU8(v, _, _)                                       => gen_u8_literal(v),
    SExprUsize(v, _, _)                                    => gen_usize_literal(v),
    SExprChar(v, _, _)                                     => gen_char_literal(v),
    SExprIdent(name, _, _)                                 => gen_identifier(name, context),
    SExprBin(operation, left_expr, right_expr, _, _)       => gen_binary_expr(operation, left_expr, right_expr, context, gen_stmts),
    SExprUn(operation, inner_expr, _, _)                   => gen_unary_expr(operation, inner_expr, context, gen_stmts),
    SExprCall(function_expr, arguments, _, _)              => gen_call_expr(function_expr, arguments, context, gen_stmts),
    SExprMethod(object, method_name, arguments, _, _)      => gen_method_expr(object, method_name, arguments, context, gen_stmts, eval_expr),
    SExprField(object, field_name, _, _)                   => gen_field_expr(object, field_name, context, gen_stmts),
    SExprIndex(object, index_expr, _, _)                   => gen_index_expr(object, index_expr, context, gen_stmts),
    SExprIf(condition, then_expr, else_expr, if_semantic_type, _) =>
      gen_if_expr(condition, then_expr, else_expr, if_semantic_type, context, gen_stmts),
    SExprBlock(statements, result_expr, _, _)              => gen_block_expr(statements, result_expr, context, gen_stmts),
    SExprWhile(condition, statements, _, _)                => gen_while_expr(condition, statements, context, gen_stmts),
    SExprFor(variable, iterator, statements, _, _)         => gen_for_expr(variable, iterator, statements, context, gen_stmts),
    SExprMatch(subject, arms, match_semantic_type, _) =>
      gen_match(subject, arms, match_semantic_type, context, gen_stmts, eval_expr),
    SExprRecord(type_name, field_values, expr_type, _)      => gen_record_expr(type_name, field_values, expr_type, context, gen_stmts, eval_expr),
    SExprRecordUpdate(type_name, base_expr, overrides, _, _) => gen_record_update_expr(type_name, base_expr, overrides, context, gen_stmts, eval_expr),
    SExprArray(elements, container_semantic_type, _) =>
      gen_array_expr(elements, container_semantic_type, context, gen_stmts),
    SExprTuple(elements, _, _) => do
      let mut parts: [string] = []
      let mut ki = 0
      while ki < elements.length() do
        parts.push(eval_expr(elements[ki], context, gen_stmts))
        ki = ki + 1
      end
      "std::make_tuple(" + parts.join(", ") + ")"
    end,
    SExprQuestion(inner_expr, _, _)                        => gen_question_expr(inner_expr, context, gen_stmts),
    SExprLambda(parameters, body_expr, _, _)               => gen_lambda_expr(parameters, body_expr, context, gen_stmts),
    SExprWith(resource, binder, stmts, _, _) => do
      const resource_code = eval_expr(resource, context, gen_stmts)
      const body_code = gen_stmts(stmts, context)
      expression_output.with_block_statement(resource_code, binder, body_code)
    end
  }
