// Pre-rendered C++ substrings for expressions and related statement fragments.
// Mutual recursion (gen_expr <-> gen_stmts_str) stays in eval.mlc; this module has no SExpr traversal.
// Export names must not collide with other compiler modules (single global symbol namespace).

export fn parenthesized_binary(left_code: string, operation: string, right_code: string) -> string =
  "(" + left_code + " " + operation + " " + right_code + ")"

export fn parenthesized_unary(operation: string, inner_code: string) -> string =
  "(" + operation + inner_code + ")"

export fn ternary_conditional(condition_code: string, then_code: string, else_code: string) -> string =
  "(" + condition_code + " ? " + then_code + " : " + else_code + ")"

export fn index_subscript(object_code: string, index_code: string) -> string =
  object_code + "[" + index_code + "]"

export fn array_literal(argument_list: string) -> string =
  if argument_list.length() == 0 then "\{\}" else "mlc::Array\{" + argument_list + "\}" end

export fn question_try_result(inner_code: string) -> string =
  "(\{ auto __q = " + inner_code + "; if (std::get_if<1>(&__q)) return *std::get_if<1>(&__q); std::get<0>(__q).field0; \})"

export fn block_as_immediate_invoked_function_expression(body_statements_and_return: string) -> string =
  "[&]() \{\n" + body_statements_and_return + "\}()"

export fn while_loop_immediate_invoked_function_expression(condition_code: string, body_statements: string) -> string =
  "[&]() \{\nwhile (" + condition_code + ") \{\n" + body_statements + "\}\n\}()"

export fn for_loop_immediate_invoked_function_expression(
  variable_cpp_safe: string,
  iterator_code: string,
  body_statements: string
) -> string =
  "[&]() \{\nfor (auto " + variable_cpp_safe + " : " + iterator_code + ") \{\n" + body_statements + "\}\n\}()"

export fn std_visit_match_expression(arm_lambdas: string, visit_subject: string) -> string =
  "std::visit(overloaded\{" + arm_lambdas + "\n\}, " + visit_subject + ")"

export fn match_arm_wild_or_unit_return(return_expression_code: string) -> string =
  "[&](const auto& __v) \{ return " + return_expression_code + "; \}"

export fn match_arm_binding_identifier(parameter_cpp_safe: string, return_expression_code: string) -> string =
  "[&](const auto& " + parameter_cpp_safe + ") \{ return " + return_expression_code + "; \}"

export fn match_arm_constructed_value(
  const_reference_parameter: string,
  binding_prefix: string,
  return_expression_code: string
) -> string =
  "[&](" + const_reference_parameter + ") \{ " + binding_prefix + "return " + return_expression_code + "; \}"

export fn record_initializer(type_resolved: string, values_comma_separated: string) -> string =
  type_resolved + "\{" + values_comma_separated + "\}"

export fn record_update_lazy_closure(initializer_and_assignments: string) -> string =
  "[&]() \{ " + initializer_and_assignments + "return __upd; \}()"

export fn function_call_parentheses(callee_code: string, argument_list: string) -> string =
  callee_code + "(" + argument_list + ")"

export fn constructor_call_braces(constructor_code: string, argument_list: string) -> string =
  constructor_code + "\{" + argument_list + "\}"

export fn field_access(object_code: string, access_operator: string, field_cpp_safe: string) -> string =
  object_code + access_operator + field_cpp_safe

export fn lambda_with_return(header_code: string, return_expression_code: string) -> string =
  header_code + " { return " + return_expression_code + "; }"

export fn assignment_statement(left_code: string, right_code: string) -> string =
  left_code + " = " + right_code + ";\n"

export fn expression_operation_statement(operation: string, left_code: string, right_code: string) -> string =
  "(" + left_code + " " + operation + " " + right_code + ");\n"

export fn suffix_semicolon_newline(expression_code: string) -> string =
  expression_code + ";\n"

export fn try_unwrap_result_block(result_variable: string, inner_code: string, success_line: string) -> string =
  "auto " + result_variable + " = " + inner_code + ";\n" +
  "if (std::get_if<1>(&" + result_variable + ")) return *std::get_if<1>(&" + result_variable + ");\n" +
  success_line

export fn auto_binding_statement(binding_cpp_safe: string, value_code: string) -> string =
  "auto " + binding_cpp_safe + " = " + value_code + ";\n"

export fn constexpr_auto_binding_statement(binding_cpp_safe: string, value_code: string) -> string =
  "constexpr auto " + binding_cpp_safe + " = " + value_code + ";\n"

export fn return_line(expression_code: string) -> string =
  "return " + expression_code + ";\n"

export fn if_brace_block(condition_code: string, inner_statements: string) -> string =
  "if (" + condition_code + ") \{\n" + inner_statements + "\}"

export fn else_brace_block(inner_statements: string) -> string =
  " else \{\n" + inner_statements + "\}"

export fn else_fragment_raw(raw_else_suffix: string) -> string =
  " else " + raw_else_suffix

export fn while_loop_statement(condition_code: string, body_statements: string) -> string =
  "while (" + condition_code + ") \{\n" + body_statements + "\}\n"

export fn for_loop_statement(variable_cpp_safe: string, iterator_code: string, body_statements: string) -> string =
  "for (auto " + variable_cpp_safe + " : " + iterator_code + ") \{\n" + body_statements + "\}\n"

export fn break_line() -> string =
  "break;\n"

export fn continue_line() -> string =
  "continue;\n"

export fn let_from_try_ok_field0(binding_cpp_safe: string, try_variable: string) -> string =
  "auto " + binding_cpp_safe + " = std::get<0>(" + try_variable + ").field0;\n"

export fn discard_try_ok_field0_statement(try_variable: string) -> string =
  "/* discard */ (void)std::get<0>(" + try_variable + ").field0;\n"

export fn return_try_ok_field0_statement(try_variable: string) -> string =
  "return std::get<0>(" + try_variable + ").field0;\n"

export fn if_always_true_block(inner_statements: string) -> string =
  "if (true) \{\n" + inner_statements + "\}\n"

export fn fragment_with_newline(fragment: string) -> string =
  fragment + "\n"

export fn tuple_destructure_binding(binding_names_csv: string, source_name: string) -> string =
  "auto [" + binding_names_csv + "] = " + source_name + "; "

export fn record_pattern_field_binding(field_cpp_safe: string, variant_lower_name: string) -> string =
  "const auto& " + field_cpp_safe + " = " + variant_lower_name + "." + field_cpp_safe + "; "

export fn record_update_base_prefix(expression_code: string) -> string =
  "auto __upd = " + expression_code + "; "

export fn mutable_member_assignment(receiver: string, member_cpp_safe: string, value_code: string) -> string =
  receiver + "." + member_cpp_safe + " = " + value_code + "; "

export fn pointer_dereference_parenthesized(expression_code: string) -> string =
  "(*" + expression_code + ")"

export fn visit_subject_for_match(expression_code: string, needs_dereference: bool) -> string =
  if needs_dereference then pointer_dereference_parenthesized(expression_code) else expression_code end

export fn make_shared_call(element_type: string, argument_code: string) -> string =
  "std::make_shared<" + element_type + ">(" + argument_code + ")"

export fn runtime_to_string_call(expression_code: string) -> string =
  "mlc::to_string(" + expression_code + ")"

export fn empty_map_initializer() -> string =
  "\{\}"

export fn block_immediate_function_return_fragment(return_expression_code: string) -> string =
  "return " + return_expression_code + ";\n"

export fn append_trailing_expression_statement(statements_code: string, expression_code: string) -> string =
  statements_code + expression_code + ";\n"

export fn hash_map_empty_instantiation(key_type_cpp: string, value_type_cpp: string) -> string =
  "mlc::HashMap<" + key_type_cpp + ", " + value_type_cpp + ">()"

export fn typed_array_empty(element_type_cpp: string) -> string =
  "mlc::Array<" + element_type_cpp + ">\{\}"

export fn array_string_fallback_empty() -> string =
  "mlc::Array<mlc::String>\{\}"

export fn match_lambda_const_reference_parameter(
  resolved_type_name: string,
  generic_angle_bracket_argument: string,
  binding_name_cpp_safe: string
) -> string =
  "const " + resolved_type_name + generic_angle_bracket_argument + "& " + binding_name_cpp_safe

export fn dot_member_access(receiver_code: string, member_code: string) -> string =
  receiver_code + "." + member_code

export fn comma_separated_pair(first_code: string, second_code: string) -> string =
  first_code + ", " + second_code

export fn prefix_with_optional_suffix(prefix: string, optional_suffix: string) -> string =
  if optional_suffix.length() > 0 then prefix + optional_suffix else prefix end

export fn main_program_parameter_list() -> string =
  "int argc, char** argv"

export fn noexcept_function_prototype(return_type_cpp: string, name_cpp: string, parameter_list: string) -> string =
  return_type_cpp + " " + name_cpp + "(" + parameter_list + ") noexcept;\n"

export fn noexcept_function_body_open(return_type_cpp: string, name_cpp: string, parameter_list: string) -> string =
  return_type_cpp + " " + name_cpp + "(" + parameter_list + ") noexcept\{\n"

export fn inline_noexcept_forwarding_call(
  return_type_cpp: string,
  method_name_cpp: string,
  parameter_list: string,
  callee_code: string,
  call_argument_list: string
) -> string =
  "inline " + return_type_cpp + " " + method_name_cpp + "(" + parameter_list +
  ") noexcept { return " + callee_code + "(" + call_argument_list + "); }\n"

export fn noexcept_one_line_returning_function(
  return_type_cpp: string,
  name_cpp: string,
  parameter_list: string,
  return_expression_code: string
) -> string =
  return_type_cpp + " " + name_cpp + "(" + parameter_list + ") noexcept { return " + return_expression_code + "; }\n"

export fn parameter_declaration_item(type_expression_cpp: string, binding_name_cpp: string) -> string =
  type_expression_cpp + " " + binding_name_cpp

export fn block_close_newline() -> string =
  "\}\n"
