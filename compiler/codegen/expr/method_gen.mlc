// Method call code generation.
// eval_expr_fn injected to break the import cycle with eval.mlc.

import { SemanticExpression, SemanticStatement, SemanticExpressionIdent, sexpr_type } from '../../ir/semantic_ir'
import { Type, TI32, TString, TBool, TNamed, TShared, TGeneric } from '../../checker/registry'
import { CppExpression, CppCall, CppMember, CppInitList } from '../../cpp/cpp_ast'
import * as emit_helpers from '../../cpp/emit_helpers'
import { CodegenContext } from '../context'
import { map_method } from '../cpp_naming'
import { infer_shared_new_type_name,
         cpp_function_name_for_file_method,
         cpp_function_name_for_profile_method } from './expression_support'
import * as mut_actual_argument from './mut_actual_argument'
import * as expression_output from './expr'

fn gen_method_file_using_trailing_argument_fragments(
  method_name: string,
  trailing_arguments_joined: string
) -> string =
  if trailing_arguments_joined.length() == 0 then
    expression_output.function_call_parentheses(
      cpp_function_name_for_file_method(method_name),
      '')
  else
    expression_output.function_call_parentheses(
      cpp_function_name_for_file_method(method_name),
      trailing_arguments_joined)
  end

fn gen_method_profile_using_trailing_argument_fragments(
  method_name: string,
  trailing_arguments_joined: string
) -> string =
  if trailing_arguments_joined.length() == 0 then
    expression_output.function_call_parentheses(
      cpp_function_name_for_profile_method(method_name),
      '')
  else
    expression_output.function_call_parentheses(
      cpp_function_name_for_profile_method(method_name),
      trailing_arguments_joined)
  end

fn gen_method_shared_new(
  argument: Shared<SemanticExpression>,
  context: CodegenContext,
  gen_stmts: ([Shared<SemanticStatement>], CodegenContext) -> string,
  eval_expr_fn: (Shared<SemanticExpression>, CodegenContext, ([Shared<SemanticStatement>], CodegenContext) -> string) -> string
) -> string = do
  const argument_code = eval_expr_fn(argument, context, gen_stmts)
  const type_name = infer_shared_new_type_name(argument, context)
  expression_output.make_shared_call(type_name, argument_code)
end

fn type_method_owner_key(type_name: string, method_name: string) -> string =
  type_name + "_" + method_name

fn resolve_method_owner_mangled(method_name: string, type_name: string, context: CodegenContext) -> string =
  if type_name != '' && context.method_owners.has(type_method_owner_key(type_name, method_name)) then
    context.method_owners.get(type_method_owner_key(type_name, method_name))
  else
    context.method_owners.get(method_name)
  end

fn gen_method_owner_call_using_fragments(
  receiver_fragment: string,
  type_name: string,
  method_name: string,
  trailing_arguments_joined: string,
  context: CodegenContext
) -> string = do
  const mangled_name = resolve_method_owner_mangled(method_name, type_name, context)
  const function_name = context.resolve(mangled_name)
  if trailing_arguments_joined.length() == 0 then
    expression_output.function_call_parentheses(function_name, receiver_fragment)
  else
    expression_output.function_call_parentheses(
      function_name,
      expression_output.comma_separated_pair(receiver_fragment, trailing_arguments_joined))
  end
end

fn gen_method_builtin_using_fragments(
  receiver_fragment: string,
  method_name: string,
  trailing_arguments_joined: string
) -> string = do
  const call_base = expression_output.dot_member_access(receiver_fragment, map_method(method_name))
  if trailing_arguments_joined.length() == 0 then expression_output.function_call_parentheses(call_base, '')
  else expression_output.function_call_parentheses(call_base, trailing_arguments_joined)
  end
end

fn gen_method_namespace_alias_using_fragments(
  static_prefix: string,
  method_name: string,
  trailing_arguments_joined: string
) -> string = do
  const call_base = `${static_prefix}${map_method(method_name)}`
  if trailing_arguments_joined.length() == 0 then expression_output.function_call_parentheses(call_base, '')
  else expression_output.function_call_parentheses(call_base, trailing_arguments_joined)
  end
end

fn object_type_name_for_dispatch(type_value: Shared<Type>) -> string =
  match type_value {
    TI32    => 'i32',
    TString => 'string',
    TBool   => 'bool',
    TNamed(name) => name,
    TShared(inner) => match inner { TNamed(name) => name, _ => '' },
    _ => ''
  }

fn is_user_defined_method_for_type(method_name: string, type_name: string, context: CodegenContext) -> bool =
  if type_name != '' && context.method_owners.has(type_method_owner_key(type_name, method_name)) then true
  else
    context.method_owners.has(method_name) &&
    type_name != '' &&
    context.method_owners.get(method_name) == type_method_owner_key(type_name, method_name)
  end

fn trailing_argument_fragments_join(fragments: [string]) -> string = fragments.join(', ')

fn result_option_method_cpp_name(is_option: bool, method_name: string) -> string =
  match method_name
  | 'ok' => if is_option then method_name else 'ok_into_optional' end
  | _    => method_name
  end

fn gen_method_expr_fallback_using_fragments(
  receiver_fragment: string,
  object_type_name: string,
  method_name: string,
  trailing_arguments_joined: string,
  argument_count: i32,
  context: CodegenContext
) -> string =
  if is_user_defined_method_for_type(method_name, object_type_name, context) then
    gen_method_owner_call_using_fragments(receiver_fragment, object_type_name, method_name, trailing_arguments_joined, context)
  else
    match method_name
    | 'to_string' =>
      if argument_count == 0 then expression_output.runtime_to_string_call(receiver_fragment)
      else gen_method_builtin_using_fragments(receiver_fragment, method_name, trailing_arguments_joined)
      end
    | _ => gen_method_builtin_using_fragments(receiver_fragment, method_name, trailing_arguments_joined)
    end
  end

fn gen_method_expr_fallback_cpp(
  receiver_expression: Shared<CppExpression>,
  object_type_name: string,
  method_name: string,
  trailing_arguments: [Shared<CppExpression>],
  argument_count: i32,
  context: CodegenContext
) -> Shared<CppExpression> =
  if is_user_defined_method_for_type(method_name, object_type_name, context) then
    gen_method_owner_call_cpp(receiver_expression, object_type_name, method_name, trailing_arguments, context)
  else
    match method_name
    | 'to_string' =>
      if argument_count == 0 then make_callee_call_cpp('mlc::to_string', [receiver_expression])
      else gen_method_builtin_cpp(receiver_expression, method_name, trailing_arguments)
      end
    | _ => gen_method_builtin_cpp(receiver_expression, method_name, trailing_arguments)
    end
  end

fn gen_method_expr_after_object_using_fragments(
  receiver_fragment: string,
  object_type_name: string,
  method_name: string,
  trailing_arguments_joined: string,
  argument_count: i32,
  context: CodegenContext,
  original_object_expression: Shared<SemanticExpression>,
  original_trailing_arguments: [Shared<SemanticExpression>],
  gen_stmts: ([Shared<SemanticStatement>], CodegenContext) -> string,
  eval_expr_fn: (Shared<SemanticExpression>, CodegenContext, ([Shared<SemanticStatement>], CodegenContext) -> string) -> string
) -> string = do
  const static_receiver_name = match original_object_expression {
    SemanticExpressionIdent(name, _, _) => name,
    _ => receiver_fragment
  }
  match static_receiver_name
  | 'File' => gen_method_file_using_trailing_argument_fragments(method_name, trailing_arguments_joined)
  | 'Profile' => gen_method_profile_using_trailing_argument_fragments(method_name, trailing_arguments_joined)
  | 'Map' =>
    match method_name
    | 'new' => expression_output.empty_map_initializer()
    | _ => gen_method_expr_fallback_using_fragments(
        receiver_fragment, object_type_name, method_name, trailing_arguments_joined, argument_count, context)
    end
  | 'Shared' =>
    match method_name
    | 'new' =>
      if argument_count == 1 then
        gen_method_shared_new(original_trailing_arguments[0], context, gen_stmts, eval_expr_fn)
      else
        gen_method_expr_fallback_using_fragments(
          receiver_fragment, object_type_name, method_name, trailing_arguments_joined, argument_count, context)
      end
    | _ => gen_method_expr_fallback_using_fragments(
        receiver_fragment, object_type_name, method_name, trailing_arguments_joined, argument_count, context)
    end
  | _ => gen_method_expr_fallback_using_fragments(
      receiver_fragment, object_type_name, method_name, trailing_arguments_joined, argument_count, context)
  end
end

fn gen_result_option_combinator_call_using_fragments(
  is_option: bool,
  receiver_fragment: string,
  method_name: string,
  trailing_arguments_joined: string
) -> string = do
  const base = if is_option then 'mlc::opt::' else 'mlc::result::' end
  const cpp_name = result_option_method_cpp_name(is_option, method_name)
  const callee = `${base}${cpp_name}`
  if trailing_arguments_joined.length() == 0 then
    expression_output.function_call_parentheses(callee, receiver_fragment)
  else
    expression_output.function_call_parentheses(
      callee,
      expression_output.comma_separated_pair(receiver_fragment, trailing_arguments_joined))
  end
end

fn build_positional_receiver_and_arguments(object: Shared<SemanticExpression>, trailing_arguments: [Shared<SemanticExpression>]) -> [Shared<SemanticExpression>] = do
  let positional: [Shared<SemanticExpression>] = []
  positional.push(object)
  let mut argument_walk_index = 0
  while argument_walk_index < trailing_arguments.length() do
    positional.push(trailing_arguments[argument_walk_index])
    argument_walk_index = argument_walk_index + 1
  end
  positional
end

export fn gen_method_expr(
  object: Shared<SemanticExpression>,
  method_name: string,
  arguments: [Shared<SemanticExpression>],
  receiver_and_method_parameter_mutability_flags: [i32],
  context: CodegenContext,
  gen_stmts: ([Shared<SemanticStatement>], CodegenContext) -> string,
  eval_expr_fn: (Shared<SemanticExpression>, CodegenContext, ([Shared<SemanticStatement>], CodegenContext) -> string) -> string
) -> string = do
  const object_type = sexpr_type(object)
  const object_type_name = object_type_name_for_dispatch(object_type)
  const positional_argument_expressions = build_positional_receiver_and_arguments(object, arguments)
  const materialization_outcome =
    mut_actual_argument.materialize_positional_actual_arguments_maybe_holding_mut_references(
      positional_argument_expressions,
      receiver_and_method_parameter_mutability_flags,
      context,
      gen_stmts,
      eval_expr_fn)
  const receiver_fragment = materialization_outcome.materialized_argument_fragments[0]
  let trailing_argument_fragments: [string] = []
  let mut tail_fragment_index = 1
  while tail_fragment_index < materialization_outcome.materialized_argument_fragments.length() do
    trailing_argument_fragments.push(materialization_outcome.materialized_argument_fragments[tail_fragment_index])
    tail_fragment_index = tail_fragment_index + 1
  end
  const trailing_arguments_joined = trailing_argument_fragments_join(trailing_argument_fragments)
  const ro_code = match object_type {
    TGeneric(generic_name, _) =>
      match generic_name
      | 'Result' => gen_result_option_combinator_call_using_fragments(false, receiver_fragment, method_name, trailing_arguments_joined)
      | 'Option' => gen_result_option_combinator_call_using_fragments(true, receiver_fragment, method_name, trailing_arguments_joined)
      | _ => ''
      end,
    TNamed(receiver_named) =>
      match receiver_named
      | 'Result' => gen_result_option_combinator_call_using_fragments(false, receiver_fragment, method_name, trailing_arguments_joined)
      | 'Option' => gen_result_option_combinator_call_using_fragments(true, receiver_fragment, method_name, trailing_arguments_joined)
      | _ => ''
      end,
    _ => '',
  }
  const invoke_expression =
    if ro_code != '' then ro_code
    else match object {
      SemanticExpressionIdent(namespace_object_name, _, _) =>
        if context.namespace_alias_prefixes.has(namespace_object_name) then
          gen_method_namespace_alias_using_fragments(
            context.namespace_alias_prefixes.get(namespace_object_name),
            method_name,
            trailing_arguments_joined)
        else
          gen_method_expr_after_object_using_fragments(
            receiver_fragment,
            object_type_name,
            method_name,
            trailing_arguments_joined,
            arguments.length(),
            context,
            object,
            arguments,
            gen_stmts,
            eval_expr_fn)
        end,
      _ =>
        gen_method_expr_after_object_using_fragments(
          receiver_fragment,
          object_type_name,
          method_name,
          trailing_arguments_joined,
          arguments.length(),
          context,
          object,
          arguments,
          gen_stmts,
          eval_expr_fn),
    }
    end
  mut_actual_argument.wrap_invoke_with_mut_actual_argument_holder_prelude_if_any(
    materialization_outcome.prelude_block,
    invoke_expression)
end

fn make_callee_call_cpp(callee_name: string, arguments: [Shared<CppExpression>]) -> Shared<CppExpression> =
  Shared.new(CppCall(emit_helpers.make_identifier_cpp_expression(callee_name), arguments))

fn prepend_expression_to_argument_list(
  leading_expression: Shared<CppExpression>,
  trailing_expressions: [Shared<CppExpression>]
) -> [Shared<CppExpression>] = do
  let arguments: [Shared<CppExpression>] = [leading_expression]
  let mut index = 0
  while index < trailing_expressions.length() do
    arguments.push(trailing_expressions[index])
    index = index + 1
  end
  arguments
end

fn gen_method_file_cpp(method_name: string, trailing_arguments: [Shared<CppExpression>]) -> Shared<CppExpression> =
  make_callee_call_cpp(cpp_function_name_for_file_method(method_name), trailing_arguments)

fn gen_method_profile_cpp(method_name: string, trailing_arguments: [Shared<CppExpression>]) -> Shared<CppExpression> =
  make_callee_call_cpp(cpp_function_name_for_profile_method(method_name), trailing_arguments)

fn gen_method_shared_new_cpp(
  argument: Shared<SemanticExpression>,
  context: CodegenContext,
  gen_stmts: ([Shared<SemanticStatement>], CodegenContext) -> string,
  evaluate_expression: (Shared<SemanticExpression>, CodegenContext, ([Shared<SemanticStatement>], CodegenContext) -> string) -> Shared<CppExpression>
) -> Shared<CppExpression> = do
  const argument_expression = evaluate_expression(argument, context, gen_stmts)
  const element_type = infer_shared_new_type_name(argument, context)
  make_callee_call_cpp(`std::make_shared<${element_type}>`, [argument_expression])
end

fn gen_method_owner_call_cpp(
  receiver_expression: Shared<CppExpression>,
  type_name: string,
  method_name: string,
  trailing_arguments: [Shared<CppExpression>],
  context: CodegenContext
) -> Shared<CppExpression> = do
  const mangled_name = resolve_method_owner_mangled(method_name, type_name, context)
  make_callee_call_cpp(
    context.resolve(mangled_name),
    prepend_expression_to_argument_list(receiver_expression, trailing_arguments))
end

fn gen_method_builtin_cpp(
  receiver_expression: Shared<CppExpression>,
  method_name: string,
  trailing_arguments: [Shared<CppExpression>]
) -> Shared<CppExpression> =
  Shared.new(CppCall(
    Shared.new(CppMember(receiver_expression, map_method(method_name), false)),
    trailing_arguments))

fn gen_method_namespace_alias_cpp(
  static_prefix: string,
  method_name: string,
  trailing_arguments: [Shared<CppExpression>]
) -> Shared<CppExpression> =
  make_callee_call_cpp(`${static_prefix}${map_method(method_name)}`, trailing_arguments)

fn gen_method_expr_after_object_cpp(
  receiver_expression: Shared<CppExpression>,
  object_type_name: string,
  method_name: string,
  trailing_arguments: [Shared<CppExpression>],
  argument_count: i32,
  context: CodegenContext,
  original_object_expression: Shared<SemanticExpression>,
  original_trailing_arguments: [Shared<SemanticExpression>],
  gen_stmts: ([Shared<SemanticStatement>], CodegenContext) -> string,
  evaluate_expression: (Shared<SemanticExpression>, CodegenContext, ([Shared<SemanticStatement>], CodegenContext) -> string) -> Shared<CppExpression>
) -> Shared<CppExpression> = do
  const static_receiver_name = match original_object_expression {
    SemanticExpressionIdent(name, _, _) => name,
    _ => ''
  }
  match static_receiver_name
  | 'File' => gen_method_file_cpp(method_name, trailing_arguments)
  | 'Profile' => gen_method_profile_cpp(method_name, trailing_arguments)
  | 'Map' =>
    match method_name
    | 'new' => Shared.new(CppInitList([]))
    | _ => gen_method_expr_fallback_cpp(
        receiver_expression, object_type_name, method_name, trailing_arguments, argument_count, context)
    end
  | 'Shared' =>
    match method_name
    | 'new' =>
      if argument_count == 1 then
        gen_method_shared_new_cpp(original_trailing_arguments[0], context, gen_stmts, evaluate_expression)
      else
        gen_method_expr_fallback_cpp(
          receiver_expression, object_type_name, method_name, trailing_arguments, argument_count, context)
      end
    | _ => gen_method_expr_fallback_cpp(
        receiver_expression, object_type_name, method_name, trailing_arguments, argument_count, context)
    end
  | _ => gen_method_expr_fallback_cpp(
      receiver_expression, object_type_name, method_name, trailing_arguments, argument_count, context)
  end
end

fn gen_result_option_combinator_call_cpp(
  is_option: bool,
  receiver_expression: Shared<CppExpression>,
  method_name: string,
  trailing_arguments: [Shared<CppExpression>]
) -> Shared<CppExpression> = do
  const namespace_prefix = if is_option then 'mlc::opt::' else 'mlc::result::' end
  const combinator_name = result_option_method_cpp_name(is_option, method_name)
  make_callee_call_cpp(
    `${namespace_prefix}${combinator_name}`,
    prepend_expression_to_argument_list(receiver_expression, trailing_arguments))
end

fn gen_method_dispatch_cpp(
  object: Shared<SemanticExpression>,
  object_type_name: string,
  method_name: string,
  receiver_expression: Shared<CppExpression>,
  trailing_argument_expressions: [Shared<CppExpression>],
  arguments: [Shared<SemanticExpression>],
  context: CodegenContext,
  gen_stmts: ([Shared<SemanticStatement>], CodegenContext) -> string,
  evaluate_expression: (Shared<SemanticExpression>, CodegenContext, ([Shared<SemanticStatement>], CodegenContext) -> string) -> Shared<CppExpression>
) -> Shared<CppExpression> =
  match object {
    SemanticExpressionIdent(namespace_object_name, _, _) =>
      if context.namespace_alias_prefixes.has(namespace_object_name) then
        gen_method_namespace_alias_cpp(
          context.namespace_alias_prefixes.get(namespace_object_name),
          method_name,
          trailing_argument_expressions)
      else
        gen_method_expr_after_object_cpp(
          receiver_expression,
          object_type_name,
          method_name,
          trailing_argument_expressions,
          arguments.length(),
          context,
          object,
          arguments,
          gen_stmts,
          evaluate_expression)
      end,
    _ =>
      gen_method_expr_after_object_cpp(
        receiver_expression,
        object_type_name,
        method_name,
        trailing_argument_expressions,
        arguments.length(),
        context,
        object,
        arguments,
        gen_stmts,
        evaluate_expression),
  }

export fn gen_method_expr_cpp(
  object: Shared<SemanticExpression>,
  method_name: string,
  arguments: [Shared<SemanticExpression>],
  receiver_and_method_parameter_mutability_flags: [i32],
  context: CodegenContext,
  gen_stmts: ([Shared<SemanticStatement>], CodegenContext) -> string,
  evaluate_expression: (Shared<SemanticExpression>, CodegenContext, ([Shared<SemanticStatement>], CodegenContext) -> string) -> Shared<CppExpression>
) -> Shared<CppExpression> = do
  const object_type = sexpr_type(object)
  const object_type_name = object_type_name_for_dispatch(object_type)
  const positional_argument_expressions = build_positional_receiver_and_arguments(object, arguments)
  const materialization_outcome =
    mut_actual_argument.materialize_positional_actual_arguments_cpp(
      positional_argument_expressions,
      receiver_and_method_parameter_mutability_flags,
      context,
      gen_stmts,
      evaluate_expression)
  const receiver_expression = materialization_outcome.materialized_argument_expressions[0]
  let trailing_argument_expressions: [Shared<CppExpression>] = []
  let mut tail_index = 1
  while tail_index < materialization_outcome.materialized_argument_expressions.length() do
    trailing_argument_expressions.push(materialization_outcome.materialized_argument_expressions[tail_index])
    tail_index = tail_index + 1
  end
  const result_or_option_code = match object_type {
    TGeneric(generic_name, _) =>
      match generic_name
      | 'Result' => gen_result_option_combinator_call_cpp(false, receiver_expression, method_name, trailing_argument_expressions)
      | 'Option' => gen_result_option_combinator_call_cpp(true, receiver_expression, method_name, trailing_argument_expressions)
      | _ =>
        gen_method_dispatch_cpp(
          object, object_type_name, method_name, receiver_expression, trailing_argument_expressions,
          arguments, context, gen_stmts, evaluate_expression)
      end,
    TNamed(receiver_named) =>
      match receiver_named
      | 'Result' => gen_result_option_combinator_call_cpp(false, receiver_expression, method_name, trailing_argument_expressions)
      | 'Option' => gen_result_option_combinator_call_cpp(true, receiver_expression, method_name, trailing_argument_expressions)
      | _ =>
        gen_method_dispatch_cpp(
          object, object_type_name, method_name, receiver_expression, trailing_argument_expressions,
          arguments, context, gen_stmts, evaluate_expression)
      end,
    _ =>
      gen_method_dispatch_cpp(
        object, object_type_name, method_name, receiver_expression, trailing_argument_expressions,
        arguments, context, gen_stmts, evaluate_expression),
  }
  mut_actual_argument.wrap_invoke_with_mut_prelude_cpp(
    materialization_outcome.prelude_statements,
    result_or_option_code)
end
