// ExprVisitor<string> wired into expr_eval for literals, identifiers, bin/unary ops.

import { Type } from '../checker/registry'
import { SExpr, SStmt, sexpr_type, SExprArray, SMatchArm, SFieldVal } from '../ir/semantic_ir'
import { TNamed, TArray, TFn } from '../checker/registry'
import { operator_method_for, array_element_type_from_array_type, type_is_unknown } from '../checker/semantic_type_structure'
import { ExprVisitor } from '../expr_visitor'
import { CodegenContext, qualify_function_callee } from './context'
import { gen_integer_literal, gen_string_literal, gen_boolean_literal, gen_unit_literal, gen_float_literal, gen_i64_literal, gen_u8_literal, gen_usize_literal, gen_char_literal, gen_extern_placeholder } from './literals'
import { gen_identifier } from './identifiers'
import { cpp_safe, map_builtin } from './cpp_naming'
import { is_constructor_call, field_access_operator, cpp_lambda_header_prefix } from './expression_support'
import * as mut_actual_argument from './mut_actual_argument'
import { gen_method_expr } from './method_gen'
import { gen_match } from './match_gen'
import { gen_record_expr, gen_record_update_expr } from './record_gen'
import { sem_type_to_cpp } from './type_gen'
import { stmts_final_ctx } from './statement_context'
import * as expression_output from './expr'

type StringExprVisitor = StringExprVisitor {
  context: CodegenContext,
  gen_stmts: ([Shared<SStmt>], CodegenContext) -> string,
  evaluate_expression: (Shared<SExpr>, CodegenContext, ([Shared<SStmt>], CodegenContext) -> string) -> string
}

fn evaluate_via_string_visitor(
  expression: Shared<SExpr>,
  context: CodegenContext,
  _gen_stmts: ([Shared<SStmt>], CodegenContext) -> string
) -> string =
  gen_expr_via_string_visitor(expression, context)

fn ignored_gen_stmts(_statements: [Shared<SStmt>], _context: CodegenContext) -> string = ''

export fn gen_binary_via_visitor(
  operation: string,
  left_expression: Shared<SExpr>,
  right_expression: Shared<SExpr>,
  context: CodegenContext,
  gen_stmts: ([Shared<SStmt>], CodegenContext) -> string,
  evaluate_expression: (Shared<SExpr>, CodegenContext, ([Shared<SStmt>], CodegenContext) -> string) -> string
) -> string = do
  const method = operator_method_for(operation)
  const left_type = sexpr_type(left_expression)
  const type_name = match left_type { TNamed(name) => name, _ => '' }
  if method != '' && type_name != '' then
    `${type_name}_${method}(${evaluate_expression(left_expression, context, gen_stmts)}, ${evaluate_expression(right_expression, context, gen_stmts)})`
  else
    expression_output.parenthesized_binary(
      evaluate_expression(left_expression, context, gen_stmts),
      operation,
      evaluate_expression(right_expression, context, gen_stmts))
  end
end

export fn gen_unary_via_visitor(
  operation: string,
  inner_expression: Shared<SExpr>,
  context: CodegenContext,
  gen_stmts: ([Shared<SStmt>], CodegenContext) -> string,
  evaluate_expression: (Shared<SExpr>, CodegenContext, ([Shared<SStmt>], CodegenContext) -> string) -> string
) -> string =
  expression_output.parenthesized_unary(operation, evaluate_expression(inner_expression, context, gen_stmts))

fn gen_call_function_code(
  function_expression: Shared<SExpr>,
  context: CodegenContext,
  gen_stmts: ([Shared<SStmt>], CodegenContext) -> string,
  evaluate_expression: (Shared<SExpr>, CodegenContext, ([Shared<SStmt>], CodegenContext) -> string) -> string
) -> string =
  match function_expression {
    SExprIdent(name, _, _) => qualify_function_callee(map_builtin(name), context),
    _ => evaluate_expression(function_expression, context, gen_stmts)
  }

export fn gen_call_via_visitor(
  function_expression: Shared<SExpr>,
  arguments: [Shared<SExpr>],
  call_parameter_mutability_flags: [i32],
  context: CodegenContext,
  gen_stmts: ([Shared<SStmt>], CodegenContext) -> string,
  evaluate_expression: (Shared<SExpr>, CodegenContext, ([Shared<SStmt>], CodegenContext) -> string) -> string
) -> string = do
  const function_code = gen_call_function_code(function_expression, context, gen_stmts, evaluate_expression)
  const materialization_outcome =
    mut_actual_argument.materialize_positional_actual_arguments_maybe_holding_mut_references(
      arguments,
      call_parameter_mutability_flags,
      context,
      gen_stmts,
      evaluate_expression)
  const argument_list = materialization_outcome.materialized_argument_fragments.join(', ')
  const invoke_expression =
    if is_constructor_call(function_expression) then expression_output.constructor_call_braces(function_code, argument_list)
    else expression_output.function_call_parentheses(function_code, argument_list)
    end
  mut_actual_argument.wrap_invoke_with_mut_actual_argument_holder_prelude_if_any(
    materialization_outcome.prelude_block,
    invoke_expression)
end

export fn gen_method_via_visitor(
  object: Shared<SExpr>,
  method_name: string,
  arguments: [Shared<SExpr>],
  receiver_and_parameter_mutability_flags: [i32],
  context: CodegenContext,
  gen_stmts: ([Shared<SStmt>], CodegenContext) -> string,
  evaluate_expression: (Shared<SExpr>, CodegenContext, ([Shared<SStmt>], CodegenContext) -> string) -> string
) -> string =
  gen_method_expr(
    object,
    method_name,
    arguments,
    receiver_and_parameter_mutability_flags,
    context,
    gen_stmts,
    evaluate_expression)

fn gen_if_else_code(
  else_expression: Shared<SExpr>,
  if_semantic_type: Shared<Type>,
  then_expression: Shared<SExpr>,
  context: CodegenContext,
  gen_stmts: ([Shared<SStmt>], CodegenContext) -> string,
  evaluate_expression: (Shared<SExpr>, CodegenContext, ([Shared<SStmt>], CodegenContext) -> string) -> string
) -> string =
  match else_expression {
    SExprArray(elements, _, array_span) =>
      if elements.length() > 0 then evaluate_expression(else_expression, context, gen_stmts)
      else do
        const inner_preferred = array_element_type_from_array_type(if_semantic_type)
        const inner_from_then_branch = array_element_type_from_array_type(sexpr_type(then_expression))
        const inner_for_empty_array =
          if !type_is_unknown(inner_preferred) then inner_preferred
          else inner_from_then_branch
          end
        if type_is_unknown(inner_for_empty_array) then evaluate_expression(else_expression, context, gen_stmts)
        else
          evaluate_expression(
            Shared.new(SExprArray(elements, Shared.new(TArray(inner_for_empty_array)), array_span)),
            context,
            gen_stmts)
        end
      end,
    _ => evaluate_expression(else_expression, context, gen_stmts)
  }

export fn gen_if_via_visitor(
  condition: Shared<SExpr>,
  then_expression: Shared<SExpr>,
  else_expression: Shared<SExpr>,
  if_semantic_type: Shared<Type>,
  context: CodegenContext,
  gen_stmts: ([Shared<SStmt>], CodegenContext) -> string,
  evaluate_expression: (Shared<SExpr>, CodegenContext, ([Shared<SStmt>], CodegenContext) -> string) -> string
) -> string = do
  const condition_code = evaluate_expression(condition, context, gen_stmts)
  const then_code = evaluate_expression(then_expression, context, gen_stmts)
  const else_code = gen_if_else_code(else_expression, if_semantic_type, then_expression, context, gen_stmts, evaluate_expression)
  match if_semantic_type {
    TNamed(type_name) => do
      const type_cpp = context.resolve(type_name)
      if type_cpp == 'auto' then
        expression_output.ternary_conditional(condition_code, then_code, else_code)
      else
        `[&]() -> ${type_cpp} {\nif (${condition_code}) {\nreturn ${then_code};\n} else {\nreturn ${else_code};\n}\n}()`
      end
    end,
    _ => expression_output.ternary_conditional(condition_code, then_code, else_code)
  }
end

export fn gen_block_via_visitor(
  statements: [Shared<SStmt>],
  result_expression: Shared<SExpr>,
  context: CodegenContext,
  gen_stmts: ([Shared<SStmt>], CodegenContext) -> string,
  evaluate_expression: (Shared<SExpr>, CodegenContext, ([Shared<SStmt>], CodegenContext) -> string) -> string
) -> string =
  if statements.length() == 0 then
    evaluate_expression(result_expression, context, gen_stmts)
  else
    const body =
      `${gen_stmts(statements, context)}${expression_output.block_immediate_function_return_fragment(
        evaluate_expression(result_expression, stmts_final_ctx(statements, context), gen_stmts))}`
    expression_output.block_as_immediate_invoked_function_expression(body)
  end

export fn gen_match_via_visitor(
  subject: Shared<SExpr>,
  arms: [Shared<SMatchArm>],
  match_semantic_type: Shared<Type>,
  context: CodegenContext,
  gen_stmts: ([Shared<SStmt>], CodegenContext) -> string,
  evaluate_expression: (Shared<SExpr>, CodegenContext, ([Shared<SStmt>], CodegenContext) -> string) -> string
) -> string =
  gen_match(subject, arms, match_semantic_type, context, gen_stmts, evaluate_expression)

export fn gen_extern_via_visitor(_semantic_type: Shared<Type>) -> string =
  gen_extern_placeholder()

fn argument_list_via_visitor(
  expressions: [Shared<SExpr>],
  context: CodegenContext,
  gen_stmts: ([Shared<SStmt>], CodegenContext) -> string,
  evaluate_expression: (Shared<SExpr>, CodegenContext, ([Shared<SStmt>], CodegenContext) -> string) -> string
) -> string =
  expressions.map(expression => evaluate_expression(expression, context, gen_stmts)).join(', ')

export fn gen_field_via_visitor(
  object: Shared<SExpr>,
  field_name: string,
  context: CodegenContext,
  gen_stmts: ([Shared<SStmt>], CodegenContext) -> string,
  evaluate_expression: (Shared<SExpr>, CodegenContext, ([Shared<SStmt>], CodegenContext) -> string) -> string
) -> string = do
  const object_code = evaluate_expression(object, context, gen_stmts)
  const operator = field_access_operator(object, context)
  expression_output.field_access(object_code, operator, cpp_safe(field_name))
end

export fn gen_index_via_visitor(
  object: Shared<SExpr>,
  index_expression: Shared<SExpr>,
  context: CodegenContext,
  gen_stmts: ([Shared<SStmt>], CodegenContext) -> string,
  evaluate_expression: (Shared<SExpr>, CodegenContext, ([Shared<SStmt>], CodegenContext) -> string) -> string
) -> string =
  expression_output.index_subscript(
    evaluate_expression(object, context, gen_stmts),
    evaluate_expression(index_expression, context, gen_stmts))

export fn gen_while_via_visitor(
  condition: Shared<SExpr>,
  statements: [Shared<SStmt>],
  context: CodegenContext,
  gen_stmts: ([Shared<SStmt>], CodegenContext) -> string,
  evaluate_expression: (Shared<SExpr>, CodegenContext, ([Shared<SStmt>], CodegenContext) -> string) -> string
) -> string =
  expression_output.while_loop_immediate_invoked_function_expression(
    evaluate_expression(condition, context, gen_stmts),
    gen_stmts(statements, context))

export fn gen_for_via_visitor(
  variable: string,
  iterator: Shared<SExpr>,
  statements: [Shared<SStmt>],
  context: CodegenContext,
  gen_stmts: ([Shared<SStmt>], CodegenContext) -> string,
  evaluate_expression: (Shared<SExpr>, CodegenContext, ([Shared<SStmt>], CodegenContext) -> string) -> string
) -> string =
  expression_output.for_loop_immediate_invoked_function_expression(
    cpp_safe(variable),
    evaluate_expression(iterator, context, gen_stmts),
    gen_stmts(statements, context))

export fn gen_record_via_visitor(
  type_name: string,
  field_values: [Shared<SFieldVal>],
  expression_type: Shared<Type>,
  context: CodegenContext,
  gen_stmts: ([Shared<SStmt>], CodegenContext) -> string,
  evaluate_expression: (Shared<SExpr>, CodegenContext, ([Shared<SStmt>], CodegenContext) -> string) -> string
) -> string =
  gen_record_expr(type_name, field_values, expression_type, context, gen_stmts, evaluate_expression)

export fn gen_record_update_via_visitor(
  type_name: string,
  base_expression: Shared<SExpr>,
  overrides: [Shared<SFieldVal>],
  context: CodegenContext,
  gen_stmts: ([Shared<SStmt>], CodegenContext) -> string,
  evaluate_expression: (Shared<SExpr>, CodegenContext, ([Shared<SStmt>], CodegenContext) -> string) -> string
) -> string =
  gen_record_update_expr(type_name, base_expression, overrides, context, gen_stmts, evaluate_expression)

export fn gen_array_via_visitor(
  elements: [Shared<SExpr>],
  element_container_semantic_type: Shared<Type>,
  context: CodegenContext,
  gen_stmts: ([Shared<SStmt>], CodegenContext) -> string,
  evaluate_expression: (Shared<SExpr>, CodegenContext, ([Shared<SStmt>], CodegenContext) -> string) -> string
) -> string =
  match element_container_semantic_type {
    TArray(inner_type) => do
      const element_cpp = sem_type_to_cpp(context, inner_type)
      if elements.length() == 0 then expression_output.typed_array_empty_or_untyped_empty(element_cpp)
      else if element_cpp == 'auto' then expression_output.array_literal(argument_list_via_visitor(elements, context, gen_stmts, evaluate_expression))
      else
        expression_output.typed_array_braced_initializer(
          element_cpp,
          argument_list_via_visitor(elements, context, gen_stmts, evaluate_expression))
      end
    end,
    _ => expression_output.array_literal(argument_list_via_visitor(elements, context, gen_stmts, evaluate_expression))
  }

export fn gen_tuple_via_visitor(
  elements: [Shared<SExpr>],
  context: CodegenContext,
  gen_stmts: ([Shared<SStmt>], CodegenContext) -> string,
  evaluate_expression: (Shared<SExpr>, CodegenContext, ([Shared<SStmt>], CodegenContext) -> string) -> string
) -> string =
  `std::make_tuple(${elements.map(element => evaluate_expression(element, context, gen_stmts)).join(', ')})`

export fn gen_question_via_visitor(
  inner_expression: Shared<SExpr>,
  context: CodegenContext,
  gen_stmts: ([Shared<SStmt>], CodegenContext) -> string,
  evaluate_expression: (Shared<SExpr>, CodegenContext, ([Shared<SStmt>], CodegenContext) -> string) -> string
) -> string =
  expression_output.question_try_result(evaluate_expression(inner_expression, context, gen_stmts))

fn cpp_lambda_header_from_semantic_function_type(
  parameter_binding_names: [string],
  semantic_function_type_for_lambda: Shared<Type>,
  context: CodegenContext
) -> string = do
  const capture_clause =
    if parameter_binding_names.length() == 0 then '[]' else '[&]' end
  match semantic_function_type_for_lambda {
    TFn(lambda_parameter_semantic_types, _) =>
      if lambda_parameter_semantic_types.length() != parameter_binding_names.length() then
        cpp_lambda_header_prefix(parameter_binding_names)
      else do
        let formatted_parameter_declarations: [string] = []
        let mut lambda_parameter_index = 0
        while lambda_parameter_index < parameter_binding_names.length() do
          const raw_param_type = sem_type_to_cpp(context, lambda_parameter_semantic_types[lambda_parameter_index])
          const param_type_cpp = if raw_param_type == 'void' then 'std::tuple<>' else raw_param_type end
          formatted_parameter_declarations.push(
            expression_output.parameter_declaration_item(
              param_type_cpp,
              cpp_safe(parameter_binding_names[lambda_parameter_index])))
          lambda_parameter_index = lambda_parameter_index + 1
        end
        `${capture_clause}(${formatted_parameter_declarations.join(', ')}) mutable`
      end,
    _ =>
      cpp_lambda_header_prefix(parameter_binding_names)
  }
end

export fn gen_lambda_via_visitor(
  parameter_binding_names: [string],
  body_expression_under_lambda: Shared<SExpr>,
  semantic_function_type_for_lambda_expression: Shared<Type>,
  context: CodegenContext,
  gen_stmts: ([Shared<SStmt>], CodegenContext) -> string,
  evaluate_expression: (Shared<SExpr>, CodegenContext, ([Shared<SStmt>], CodegenContext) -> string) -> string
) -> string =
  expression_output.lambda_with_return(
    cpp_lambda_header_from_semantic_function_type(
      parameter_binding_names,
      semantic_function_type_for_lambda_expression,
      context),
    evaluate_expression(body_expression_under_lambda, context, gen_stmts))

export fn gen_with_via_visitor(
  resource: Shared<SExpr>,
  binder: string,
  statements: [Shared<SStmt>],
  context: CodegenContext,
  gen_stmts: ([Shared<SStmt>], CodegenContext) -> string,
  evaluate_expression: (Shared<SExpr>, CodegenContext, ([Shared<SStmt>], CodegenContext) -> string) -> string
) -> string = do
  const resource_code = evaluate_expression(resource, context, gen_stmts)
  const body_code = gen_stmts(statements, context)
  expression_output.with_block_statement(resource_code, binder, body_code)
end

extend StringExprVisitor : ExprVisitor<string> {
  fn visit_int(self: StringExprVisitor, value: i32, _semantic_type: Shared<Type>) -> string =
    gen_integer_literal(value)
  fn visit_str(self: StringExprVisitor, value: string, _semantic_type: Shared<Type>) -> string =
    gen_string_literal(value)
  fn visit_bool(self: StringExprVisitor, value: bool, _semantic_type: Shared<Type>) -> string =
    gen_boolean_literal(value)
  fn visit_unit(self: StringExprVisitor, _semantic_type: Shared<Type>) -> string =
    gen_unit_literal()
  fn visit_float(self: StringExprVisitor, value: string, _semantic_type: Shared<Type>) -> string =
    gen_float_literal(value)
  fn visit_i64(self: StringExprVisitor, value: string, _semantic_type: Shared<Type>) -> string =
    gen_i64_literal(value)
  fn visit_u8(self: StringExprVisitor, value: string, _semantic_type: Shared<Type>) -> string =
    gen_u8_literal(value)
  fn visit_usize(self: StringExprVisitor, value: string, _semantic_type: Shared<Type>) -> string =
    gen_usize_literal(value)
  fn visit_char(self: StringExprVisitor, value: string, _semantic_type: Shared<Type>) -> string =
    gen_char_literal(value)
  fn visit_extern(self: StringExprVisitor, _semantic_type: Shared<Type>) -> string =
    gen_extern_via_visitor(_semantic_type)
  fn visit_ident(self: StringExprVisitor, name: string, _semantic_type: Shared<Type>) -> string =
    gen_identifier(name, self.context)
  fn visit_bin(self: StringExprVisitor, operation: string, left_expression: Shared<SExpr>, right_expression: Shared<SExpr>, _semantic_type: Shared<Type>) -> string =
    gen_binary_via_visitor(operation, left_expression, right_expression, self.context, self.gen_stmts, self.evaluate_expression)
  fn visit_un(self: StringExprVisitor, operation: string, inner_expression: Shared<SExpr>, _semantic_type: Shared<Type>) -> string =
    gen_unary_via_visitor(operation, inner_expression, self.context, self.gen_stmts, self.evaluate_expression)
  fn visit_call(self: StringExprVisitor, function_expression: Shared<SExpr>, arguments: [Shared<SExpr>], mutability_flags: [i32], _semantic_type: Shared<Type>) -> string =
    gen_call_via_visitor(function_expression, arguments, mutability_flags, self.context, self.gen_stmts, self.evaluate_expression)
  fn visit_method(self: StringExprVisitor, object: Shared<SExpr>, method_name: string, arguments: [Shared<SExpr>], mutability_flags: [i32], _semantic_type: Shared<Type>) -> string =
    gen_method_via_visitor(object, method_name, arguments, mutability_flags, self.context, self.gen_stmts, self.evaluate_expression)
  fn visit_field(self: StringExprVisitor, object: Shared<SExpr>, field_name: string, _semantic_type: Shared<Type>) -> string =
    gen_field_via_visitor(object, field_name, self.context, self.gen_stmts, self.evaluate_expression)
  fn visit_index(self: StringExprVisitor, object: Shared<SExpr>, index_expression: Shared<SExpr>, _semantic_type: Shared<Type>) -> string =
    gen_index_via_visitor(object, index_expression, self.context, self.gen_stmts, self.evaluate_expression)
  fn visit_if(self: StringExprVisitor, condition: Shared<SExpr>, then_expression: Shared<SExpr>, else_expression: Shared<SExpr>, semantic_type: Shared<Type>) -> string =
    gen_if_via_visitor(condition, then_expression, else_expression, semantic_type, self.context, self.gen_stmts, self.evaluate_expression)
  fn visit_block(self: StringExprVisitor, statements: [Shared<SStmt>], result_expression: Shared<SExpr>, _semantic_type: Shared<Type>) -> string =
    gen_block_via_visitor(statements, result_expression, self.context, self.gen_stmts, self.evaluate_expression)
  fn visit_while(self: StringExprVisitor, condition: Shared<SExpr>, statements: [Shared<SStmt>], _semantic_type: Shared<Type>) -> string =
    gen_while_via_visitor(condition, statements, self.context, self.gen_stmts, self.evaluate_expression)
  fn visit_for(self: StringExprVisitor, variable: string, iterator: Shared<SExpr>, statements: [Shared<SStmt>], _semantic_type: Shared<Type>) -> string =
    gen_for_via_visitor(variable, iterator, statements, self.context, self.gen_stmts, self.evaluate_expression)
  fn visit_match(self: StringExprVisitor, subject: Shared<SExpr>, arms: [Shared<SMatchArm>], semantic_type: Shared<Type>) -> string =
    gen_match_via_visitor(subject, arms, semantic_type, self.context, self.gen_stmts, self.evaluate_expression)
  fn visit_record(self: StringExprVisitor, type_name: string, field_values: [Shared<SFieldVal>], semantic_type: Shared<Type>) -> string =
    gen_record_via_visitor(type_name, field_values, semantic_type, self.context, self.gen_stmts, self.evaluate_expression)
  fn visit_record_update(self: StringExprVisitor, type_name: string, base_expression: Shared<SExpr>, overrides: [Shared<SFieldVal>], _semantic_type: Shared<Type>) -> string =
    gen_record_update_via_visitor(type_name, base_expression, overrides, self.context, self.gen_stmts, self.evaluate_expression)
  fn visit_array(self: StringExprVisitor, elements: [Shared<SExpr>], semantic_type: Shared<Type>) -> string =
    gen_array_via_visitor(elements, semantic_type, self.context, self.gen_stmts, self.evaluate_expression)
  fn visit_tuple(self: StringExprVisitor, elements: [Shared<SExpr>], _semantic_type: Shared<Type>) -> string =
    gen_tuple_via_visitor(elements, self.context, self.gen_stmts, self.evaluate_expression)
  fn visit_question(self: StringExprVisitor, inner_expression: Shared<SExpr>, _semantic_type: Shared<Type>) -> string =
    gen_question_via_visitor(inner_expression, self.context, self.gen_stmts, self.evaluate_expression)
  fn visit_lambda(self: StringExprVisitor, parameter_names: [string], body_expression: Shared<SExpr>, semantic_type: Shared<Type>) -> string =
    gen_lambda_via_visitor(parameter_names, body_expression, semantic_type, self.context, self.gen_stmts, self.evaluate_expression)
  fn visit_with(self: StringExprVisitor, resource: Shared<SExpr>, binder: string, statements: [Shared<SStmt>], _semantic_type: Shared<Type>) -> string =
    gen_with_via_visitor(resource, binder, statements, self.context, self.gen_stmts, self.evaluate_expression)
  fn visit_unsupported(self: StringExprVisitor, _expression: Shared<SExpr>) -> string =
    '/* unsupported expr */'
}

export fn eval_expr_with_visitor(
  expression: Shared<SExpr>,
  context: CodegenContext,
  gen_stmts: ([Shared<SStmt>], CodegenContext) -> string,
  evaluate_expression: (Shared<SExpr>, CodegenContext, ([Shared<SStmt>], CodegenContext) -> string) -> string
) -> string = do
  const expression_visitor = StringExprVisitor { context: context, gen_stmts: gen_stmts, evaluate_expression: evaluate_expression }
  match expression {
    SExprInt(integer_value, type_value, _) => expression_visitor.visit_int(integer_value, type_value),
    SExprStr(string_value, type_value, _) => expression_visitor.visit_str(string_value, type_value),
    SExprBool(boolean_value, type_value, _) => expression_visitor.visit_bool(boolean_value, type_value),
    SExprUnit(type_value, _) => expression_visitor.visit_unit(type_value),
    SExprFloat(float_value, type_value, _) => expression_visitor.visit_float(float_value, type_value),
    SExprI64(integer_value, type_value, _) => expression_visitor.visit_i64(integer_value, type_value),
    SExprU8(byte_value, type_value, _) => expression_visitor.visit_u8(byte_value, type_value),
    SExprUsize(size_value, type_value, _) => expression_visitor.visit_usize(size_value, type_value),
    SExprChar(character_value, type_value, _) => expression_visitor.visit_char(character_value, type_value),
    SExprExtern(type_value, _) => expression_visitor.visit_extern(type_value),
    SExprIdent(name_value, type_value, _) => expression_visitor.visit_ident(name_value, type_value),
    SExprBin(operation, left_expression, right_expression, type_value, _) =>
      expression_visitor.visit_bin(operation, left_expression, right_expression, type_value),
    SExprUn(operation, inner_expression, type_value, _) =>
      expression_visitor.visit_un(operation, inner_expression, type_value),
    SExprCall(function_expression, arguments, mutability_flags, type_value, _) =>
      expression_visitor.visit_call(function_expression, arguments, mutability_flags, type_value),
    SExprMethod(object, method_name, arguments, mutability_flags, type_value, _) =>
      expression_visitor.visit_method(object, method_name, arguments, mutability_flags, type_value),
    SExprField(object, field_name, type_value, _) =>
      expression_visitor.visit_field(object, field_name, type_value),
    SExprIndex(object, index_expression, type_value, _) =>
      expression_visitor.visit_index(object, index_expression, type_value),
    SExprIf(condition, then_expression, else_expression, type_value, _) =>
      expression_visitor.visit_if(condition, then_expression, else_expression, type_value),
    SExprBlock(statements, result_expression, type_value, _) =>
      expression_visitor.visit_block(statements, result_expression, type_value),
    SExprWhile(condition, statements, type_value, _) =>
      expression_visitor.visit_while(condition, statements, type_value),
    SExprFor(variable, iterator, statements, type_value, _) =>
      expression_visitor.visit_for(variable, iterator, statements, type_value),
    SExprMatch(subject, arms, type_value, _) =>
      expression_visitor.visit_match(subject, arms, type_value),
    SExprRecord(type_name, field_values, type_value, _) =>
      expression_visitor.visit_record(type_name, field_values, type_value),
    SExprRecordUpdate(type_name, base_expression, overrides, type_value, _) =>
      expression_visitor.visit_record_update(type_name, base_expression, overrides, type_value),
    SExprArray(elements, type_value, _) =>
      expression_visitor.visit_array(elements, type_value),
    SExprTuple(elements, type_value, _) =>
      expression_visitor.visit_tuple(elements, type_value),
    SExprQuestion(inner_expression, type_value, _) =>
      expression_visitor.visit_question(inner_expression, type_value),
    SExprLambda(parameter_names, body_expression, type_value, _) =>
      expression_visitor.visit_lambda(parameter_names, body_expression, type_value),
    SExprWith(resource, binder, statements, type_value, _) =>
      expression_visitor.visit_with(resource, binder, statements, type_value),
  }
end

export fn gen_expr_via_string_visitor(expression: Shared<SExpr>, context: CodegenContext) -> string =
  eval_expr_with_visitor(expression, context, ignored_gen_stmts, evaluate_via_string_visitor)
