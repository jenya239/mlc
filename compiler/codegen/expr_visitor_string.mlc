// ExprVisitor<string> wired into expr_eval for literals, identifiers, bin/unary ops.

import { Type } from '../checker/registry'
import { SExpr, SStmt, sexpr_type } from '../semantic_ir'
import { TNamed } from '../checker/registry'
import { operator_method_for } from '../checker/semantic_type_structure'
import { ExprVisitor } from '../expr_visitor'
import { CodegenContext } from './context'
import { gen_integer_literal, gen_string_literal, gen_boolean_literal, gen_unit_literal, gen_float_literal, gen_i64_literal, gen_u8_literal, gen_usize_literal, gen_char_literal } from './literals'
import { gen_identifier } from './identifiers'
import { cpp_safe, map_builtin } from './cpp_naming'
import { is_constructor_call } from './expression_support'
import * as mut_actual_argument from './mut_actual_argument'
import { gen_method_expr } from './method_gen'
import * as expression_output from './expr'

type StringExprVisitor = StringExprVisitor { context: CodegenContext }

fn evaluate_via_string_visitor(
  expression: Shared<SExpr>,
  context: CodegenContext,
  _gen_stmts: ([Shared<SStmt>], CodegenContext) -> string
) -> string =
  gen_expr_via_string_visitor(expression, context)

fn ignored_gen_stmts(_statements: [Shared<SStmt>], _context: CodegenContext) -> string = ''

export fn gen_binary_via_visitor(
  operation: string,
  left_expression: Shared<SExpr>,
  right_expression: Shared<SExpr>,
  context: CodegenContext,
  gen_stmts: ([Shared<SStmt>], CodegenContext) -> string,
  evaluate_expression: (Shared<SExpr>, CodegenContext, ([Shared<SStmt>], CodegenContext) -> string) -> string
) -> string = do
  const method = operator_method_for(operation)
  const left_type = sexpr_type(left_expression)
  const type_name = match left_type { TNamed(name) => name, _ => '' }
  if method != '' && type_name != '' then
    `${type_name}_${method}(${evaluate_expression(left_expression, context, gen_stmts)}, ${evaluate_expression(right_expression, context, gen_stmts)})`
  else
    expression_output.parenthesized_binary(
      evaluate_expression(left_expression, context, gen_stmts),
      operation,
      evaluate_expression(right_expression, context, gen_stmts))
  end
end

export fn gen_unary_via_visitor(
  operation: string,
  inner_expression: Shared<SExpr>,
  context: CodegenContext,
  gen_stmts: ([Shared<SStmt>], CodegenContext) -> string,
  evaluate_expression: (Shared<SExpr>, CodegenContext, ([Shared<SStmt>], CodegenContext) -> string) -> string
) -> string =
  expression_output.parenthesized_unary(operation, evaluate_expression(inner_expression, context, gen_stmts))

fn gen_call_function_code(
  function_expression: Shared<SExpr>,
  context: CodegenContext,
  gen_stmts: ([Shared<SStmt>], CodegenContext) -> string,
  evaluate_expression: (Shared<SExpr>, CodegenContext, ([Shared<SStmt>], CodegenContext) -> string) -> string
) -> string =
  match function_expression {
    SExprIdent(name, _, _) => context.resolve(map_builtin(name)),
    _ => evaluate_expression(function_expression, context, gen_stmts)
  }

export fn gen_call_via_visitor(
  function_expression: Shared<SExpr>,
  arguments: [Shared<SExpr>],
  call_parameter_mutability_flags: [i32],
  context: CodegenContext,
  gen_stmts: ([Shared<SStmt>], CodegenContext) -> string,
  evaluate_expression: (Shared<SExpr>, CodegenContext, ([Shared<SStmt>], CodegenContext) -> string) -> string
) -> string = do
  const function_code = gen_call_function_code(function_expression, context, gen_stmts, evaluate_expression)
  const materialization_outcome =
    mut_actual_argument.materialize_positional_actual_arguments_maybe_holding_mut_references(
      arguments,
      call_parameter_mutability_flags,
      context,
      gen_stmts,
      evaluate_expression)
  const argument_list = materialization_outcome.materialized_argument_fragments.join(', ')
  const invoke_expression =
    if is_constructor_call(function_expression) then expression_output.constructor_call_braces(function_code, argument_list)
    else expression_output.function_call_parentheses(function_code, argument_list)
    end
  mut_actual_argument.wrap_invoke_with_mut_actual_argument_holder_prelude_if_any(
    materialization_outcome.prelude_block,
    invoke_expression)
end

export fn gen_method_via_visitor(
  object: Shared<SExpr>,
  method_name: string,
  arguments: [Shared<SExpr>],
  receiver_and_parameter_mutability_flags: [i32],
  context: CodegenContext,
  gen_stmts: ([Shared<SStmt>], CodegenContext) -> string,
  evaluate_expression: (Shared<SExpr>, CodegenContext, ([Shared<SStmt>], CodegenContext) -> string) -> string
) -> string =
  gen_method_expr(
    object,
    method_name,
    arguments,
    receiver_and_parameter_mutability_flags,
    context,
    gen_stmts,
    evaluate_expression)

extend StringExprVisitor : ExprVisitor<string> {
  fn visit_int(self: StringExprVisitor, value: i32, _semantic_type: Shared<Type>) -> string =
    gen_integer_literal(value)
  fn visit_str(self: StringExprVisitor, value: string, _semantic_type: Shared<Type>) -> string =
    gen_string_literal(value)
  fn visit_bool(self: StringExprVisitor, value: bool, _semantic_type: Shared<Type>) -> string =
    gen_boolean_literal(value)
  fn visit_unit(self: StringExprVisitor, _semantic_type: Shared<Type>) -> string =
    gen_unit_literal()
  fn visit_float(self: StringExprVisitor, value: string, _semantic_type: Shared<Type>) -> string =
    gen_float_literal(value)
  fn visit_i64(self: StringExprVisitor, value: string, _semantic_type: Shared<Type>) -> string =
    gen_i64_literal(value)
  fn visit_u8(self: StringExprVisitor, value: string, _semantic_type: Shared<Type>) -> string =
    gen_u8_literal(value)
  fn visit_usize(self: StringExprVisitor, value: string, _semantic_type: Shared<Type>) -> string =
    gen_usize_literal(value)
  fn visit_char(self: StringExprVisitor, value: string, _semantic_type: Shared<Type>) -> string =
    gen_char_literal(value)
  fn visit_ident(self: StringExprVisitor, name: string, _semantic_type: Shared<Type>) -> string =
    gen_identifier(name, self.context)
  fn visit_bin(self: StringExprVisitor, operation: string, left_expression: Shared<SExpr>, right_expression: Shared<SExpr>, _semantic_type: Shared<Type>) -> string =
    gen_binary_via_visitor(operation, left_expression, right_expression, self.context, ignored_gen_stmts, evaluate_via_string_visitor)
  fn visit_un(self: StringExprVisitor, operation: string, inner_expression: Shared<SExpr>, _semantic_type: Shared<Type>) -> string =
    gen_unary_via_visitor(operation, inner_expression, self.context, ignored_gen_stmts, evaluate_via_string_visitor)
  fn visit_call(self: StringExprVisitor, function_expression: Shared<SExpr>, arguments: [Shared<SExpr>], mutability_flags: [i32], _semantic_type: Shared<Type>) -> string =
    gen_call_via_visitor(function_expression, arguments, mutability_flags, self.context, ignored_gen_stmts, evaluate_via_string_visitor)
  fn visit_method(self: StringExprVisitor, object: Shared<SExpr>, method_name: string, arguments: [Shared<SExpr>], mutability_flags: [i32], _semantic_type: Shared<Type>) -> string =
    gen_method_via_visitor(object, method_name, arguments, mutability_flags, self.context, ignored_gen_stmts, evaluate_via_string_visitor)
  fn visit_unsupported(self: StringExprVisitor, _expression: Shared<SExpr>) -> string =
    '/* unsupported expr */'
}

export fn gen_expr_via_string_visitor(expression: Shared<SExpr>, context: CodegenContext) -> string = do
  const expression_visitor = StringExprVisitor { context: context }
  match expression {
    SExprInt(integer_value, type_value, _) => expression_visitor.visit_int(integer_value, type_value),
    SExprStr(string_value, type_value, _) => expression_visitor.visit_str(string_value, type_value),
    SExprBool(boolean_value, type_value, _) => expression_visitor.visit_bool(boolean_value, type_value),
    SExprUnit(type_value, _) => expression_visitor.visit_unit(type_value),
    SExprFloat(float_value, type_value, _) => expression_visitor.visit_float(float_value, type_value),
    SExprI64(integer_value, type_value, _) => expression_visitor.visit_i64(integer_value, type_value),
    SExprU8(byte_value, type_value, _) => expression_visitor.visit_u8(byte_value, type_value),
    SExprUsize(size_value, type_value, _) => expression_visitor.visit_usize(size_value, type_value),
    SExprChar(character_value, type_value, _) => expression_visitor.visit_char(character_value, type_value),
    SExprIdent(name_value, type_value, _) => expression_visitor.visit_ident(name_value, type_value),
    SExprBin(operation, left_expression, right_expression, type_value, _) =>
      expression_visitor.visit_bin(operation, left_expression, right_expression, type_value),
    SExprUn(operation, inner_expression, type_value, _) =>
      expression_visitor.visit_un(operation, inner_expression, type_value),
    SExprCall(function_expression, arguments, mutability_flags, type_value, _) =>
      expression_visitor.visit_call(function_expression, arguments, mutability_flags, type_value),
    SExprMethod(object, method_name, arguments, mutability_flags, type_value, _) =>
      expression_visitor.visit_method(object, method_name, arguments, mutability_flags, type_value),
    _ => expression_visitor.visit_unsupported(expression)
  }
end
