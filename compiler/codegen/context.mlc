// Context types and mutation for the code generator.

import { Program, Pattern, TypeExpr } from '../frontend/ast'
import { build_registry } from '../checker/registry'
import { SemanticStatement } from '../ir/semantic_ir'
import { Type, TShared, TArray, TUnknown, trait_base_name } from '../checker/registry'
import { cpp_safe } from './cpp_naming'
import * as decl_index from './decl/decl_index'
import { FieldOrder } from './decl/decl_index'
import { LoadItem, NamespaceImportAlias } from '../ir/load_item'
import { build_field_orders, build_method_owners_from_decls, build_variant_types_from_decls, build_generic_variants_from_decls, build_sum_type_parameter_names_from_decls, build_variant_used_type_parameter_names_from_decls, add_method_owners_from_decls } from './decl/type_index'
import { CtorTypeInfo, build_ctor_type_infos_from_decls, build_ctor_type_info_index, lookup_ctor_type_info, lookup_ctor_type_info_indexed } from './decl/ctor_info'
import { is_shared_type, is_shared_array_type, is_shared_map_type, array_elem_name, collect_shared_params, collect_shared_array_params, collect_array_elem_types, collect_shared_map_params, collect_value_params } from './decl/param_analysis'

export type StructUsingEntry = StructUsingEntry { alias: string, type_cpp: string }

export type StructUsingData = StructUsingData {
  entries: Map<string, [StructUsingEntry]>,
  lines: Map<string, [string]>
}

export type CodegenContext = CodegenContext {
  field_orders: [Shared<FieldOrder>],
  field_order_index: Map<string, [string]>,
  namespace_prefix: string,
  qualified: Map<string, string>,
  namespace_alias_prefixes: Map<string, string>,
  self_type: string,
  method_owners: Map<string, string>,
  shared_params: [string],
  shared_array_params: [string],
  array_elem_types: Map<string, string>,
  shared_map_params: [string],
  ctor_type_infos: [Shared<CtorTypeInfo>],
  ctor_type_info_index: Map<string, Shared<CtorTypeInfo> >,
  variant_types: Map<string, string>,
  sum_type_parameter_names: Map<string, [string]>,
  variant_used_type_parameter_names: Map<string, [string]>,
  value_params: [string],
  match_deref_params: [string],
  generic_variants: [string],
  struct_using_entries: Map<string, [StructUsingEntry]>,
  struct_using_lines: Map<string, [string]>,
  type_alias_annotations: Map<string, Shared<TypeExpr>>,
  trait_associated_type_names: Map<string, [string]>,
  temp_name_counter: i32,
  enclosing_function_return_type: Shared<Type>
}

export fn new_temp_name_counter() -> i32 = 0

export type TempNameResult = TempNameResult { name: string, codegen_context: CodegenContext }

export fn take_temp_name(context: CodegenContext) -> TempNameResult = do
  TempNameResult {
    name: '__tmp_' + context.temp_name_counter.to_string(),
    codegen_context: CodegenContext { ...context, temp_name_counter: context.temp_name_counter + 1 }
  }
end

export type GenStmtsResult = GenStmtsResult { parts: [string], next_try: i32 }
export type GenStmtsWithContext = GenStmtsWithContext { statements_parsed: GenStmtsResult, codegen_context: CodegenContext }
export type GenStmtResult  = GenStmtResult  { output: string, next_try: i32, codegen_context: CodegenContext }

extend GenStmtsResult {
  fn append_stmt(self, statement_parsed: GenStmtResult) -> GenStmtsResult = do
    let parts = self.parts
    parts.push(statement_parsed.output)
    GenStmtsResult { parts: parts, next_try: statement_parsed.next_try }
  end

  fn joined_code(self) -> string = self.parts.join('')
}

export type GenModuleOut   = GenModuleOut   { header: string, source: string }
export type PrecomputedCtx = PrecomputedCtx {
  field_orders: [Shared<FieldOrder>],
  variant_types: Map<string, string>,
  sum_type_parameter_names: Map<string, [string]>,
  variant_used_type_parameter_names: Map<string, [string]>,
  item_index: Map<string, Shared<LoadItem>>,
  ctor_type_infos: [Shared<CtorTypeInfo>],
  generic_variants: [string],
  method_owners: Map<string, string>,
  field_order_index: Map<string, [string]>,
  ctor_type_info_index: Map<string, Shared<CtorTypeInfo> >,
  type_alias_annotations: Map<string, Shared<TypeExpr>>,
  trait_associated_type_names: Map<string, [string]>
}

export fn context_resolve(context: CodegenContext, name: string) -> string =
  if context.method_owners.has(name) then cpp_safe(name)
  else if context.qualified.has(name) then context.qualified.get(name) + cpp_safe(name)
  else if context.namespace_prefix.length() > 0 then context.namespace_prefix + cpp_safe(name)
  else cpp_safe(name)
  end

fn type_method_namespace_prefix(mangled_name: string, context: CodegenContext) -> string = do
  if context.method_owners.has(mangled_name) then ''
  else
    let mut underscore = -1
    let mut index = 0
    while index < mangled_name.length() && underscore < 0 do
      if mangled_name.char_at(index) == "_" then underscore = index end
      index = index + 1
    end
    if underscore <= 0 then ''
    else if context.qualified.has(mangled_name.substring(0, underscore)) then context.qualified.get(mangled_name.substring(0, underscore))
    else ''
    end
  end
end

export fn qualify_function_callee(name: string, context: CodegenContext) -> string =
  if context.method_owners.has(name) then cpp_safe(name)
  else if context.qualified.has(name) then context.qualified.get(name) + cpp_safe(name)
  else type_method_namespace_prefix(name, context) + cpp_safe(name)
  end

fn collect_pattern_bind_names_for_context(pattern: Shared<Pattern>, mut accumulator: [string]) -> [string] = do
  match pattern {
    PatternIdent(binding_name, _) => do accumulator.push(binding_name); accumulator end,
    PatternCtor(_, sub_patterns, _) => do
      let mut index = 0
      while index < sub_patterns.length() do
        accumulator = collect_pattern_bind_names_for_context(sub_patterns[index], accumulator); index = index + 1
      end
      accumulator
    end,
    PatternRecord(_, field_patterns, _) => do
      let mut index = 0
      while index < field_patterns.length() do
        accumulator = collect_pattern_bind_names_for_context(field_patterns[index], accumulator); index = index + 1
      end
      accumulator
    end,
    PatternTuple(sub_patterns, _) => do
      let mut index = 0
      while index < sub_patterns.length() do
        accumulator = collect_pattern_bind_names_for_context(sub_patterns[index], accumulator); index = index + 1
      end
      accumulator
    end,
    PatternArray(sub_patterns, rest, _) => do
      let mut index = 0
      while index < sub_patterns.length() do
        accumulator = collect_pattern_bind_names_for_context(sub_patterns[index], accumulator); index = index + 1
      end
      if rest != '' && rest != "_" then accumulator.push(rest) end
      accumulator
    end,
    _ => accumulator
  }
end

export fn struct_using_line_from_entry(entry: StructUsingEntry) -> string =
  'using ' + entry.alias + ' = ' + entry.type_cpp + ';\n'

extend CodegenContext {
  fn resolve(self: CodegenContext, name: string) -> string = context_resolve(self, name)

  fn for_type_body(self: CodegenContext, type_name: string) -> CodegenContext =
    CodegenContext { ...self, shared_params: [], shared_array_params: [], array_elem_types: Map.new(), shared_map_params: [], self_type: type_name, value_params: [], match_deref_params: [] }

  fn add_shared(self: CodegenContext, name: string) -> CodegenContext = do
    let new_shared_params = self.shared_params; new_shared_params.push(name)
    CodegenContext { ...self, shared_params: new_shared_params }
  end

  fn add_shared_array(self: CodegenContext, name: string) -> CodegenContext = do
    let new_shared_array_params = self.shared_array_params; new_shared_array_params.push(name)
    CodegenContext { ...self, shared_array_params: new_shared_array_params }
  end

  fn add_value(self: CodegenContext, name: string) -> CodegenContext = do
    let new_value_params = self.value_params; new_value_params.push(name)
    CodegenContext { ...self, value_params: new_value_params }
  end

  fn add_match_deref(self: CodegenContext, name: string) -> CodegenContext = do
    let new_match_deref_params = self.match_deref_params; new_match_deref_params.push(name)
    CodegenContext { ...self, match_deref_params: new_match_deref_params }
  end

  fn with_struct_using_data(self: CodegenContext, data: StructUsingData) -> CodegenContext =
    CodegenContext { ...self, struct_using_entries: data.entries, struct_using_lines: data.lines }

  fn with_struct_using_lines(self: CodegenContext, lines: Map<string, [string]>) -> CodegenContext =
    CodegenContext { ...self, struct_using_lines: lines }

  fn with_namespace_alias_prefixes(self: CodegenContext, prefixes: Map<string, string>) -> CodegenContext =
    CodegenContext { ...self, namespace_alias_prefixes: prefixes }

  fn with_enclosing_function_return_type(self: CodegenContext, return_type: Shared<Type>) -> CodegenContext =
    CodegenContext { ...self, enclosing_function_return_type: return_type }

  fn update_from_statement(self: CodegenContext, statement: Shared<SemanticStatement>) -> CodegenContext =
    match statement {
      SemanticStatementLetConst(binding_name, _, _, _) => self.add_value(binding_name),
      SemanticStatementLet(binding_name, _, _, value_type, _) =>
        match value_type {
          TShared(_)      => self.add_shared(binding_name),
          TArray(inner)   => match inner { TShared(_) => self.add_shared_array(binding_name), _ => self.add_value(binding_name) },
          _               => self.add_value(binding_name)
        },
      SemanticStatementLetPattern(pattern, _, _, _, _, _, _) => do
        const names = collect_pattern_bind_names_for_context(pattern, [])
        let mut codegen_context = self; let mut name_index = 0
        while name_index < names.length() do
          codegen_context = codegen_context.add_value(names[name_index]); name_index = name_index + 1
        end
        codegen_context
      end,
      _ => self
    }
}

export fn trait_has_associated_types(context: CodegenContext, trait_name: string) -> bool = do
  const bare_trait_name = trait_base_name(trait_name)
  if context.trait_associated_type_names.has(bare_trait_name) then
    context.trait_associated_type_names.get(bare_trait_name).length() > 0
  else
    false
  end
end

export fn make_body_context(base: CodegenContext, shared_params: [string], shared_array_params: [string], array_elem_types: Map<string, string>, shared_map_params: [string], self_type: string, value_params: [string], match_deref_params: [string]) -> CodegenContext =
  CodegenContext { ...base, shared_params: shared_params, shared_array_params: shared_array_params, array_elem_types: array_elem_types, shared_map_params: shared_map_params, self_type: self_type, value_params: value_params, match_deref_params: match_deref_params }

export fn context_add_shared(context: CodegenContext, name: string) -> CodegenContext = context.add_shared(name)

export fn context_add_shared_array(context: CodegenContext, name: string) -> CodegenContext = context.add_shared_array(name)

export fn context_add_value(context: CodegenContext, name: string) -> CodegenContext = context.add_value(name)

export fn context_add_match_deref(context: CodegenContext, name: string) -> CodegenContext = context.add_match_deref(name)

export fn update_context_from_statement(statement: Shared<SemanticStatement>, context: CodegenContext) -> CodegenContext =
  context.update_from_statement(statement)

fn push_pattern_bind_names_to_value_params(pattern: Shared<Pattern>, context: ref mut CodegenContext) -> unit = do
  const names = collect_pattern_bind_names_for_context(pattern, [])
  let mut name_index = 0
  while name_index < names.length() do
    context.value_params.push(names[name_index])
    name_index = name_index + 1
  end
end

fn mutate_context_for_let_const(binding_name: string, context: ref mut CodegenContext) -> unit = do
  context.value_params.push(binding_name)
end

fn mutate_context_for_let(binding_name: string, value_type: Shared<Type>, context: ref mut CodegenContext) -> unit = do
  match value_type {
    TShared(_) => context.shared_params.push(binding_name),
    TArray(inner) => match inner {
      TShared(_) => context.shared_array_params.push(binding_name),
      _ => context.value_params.push(binding_name)
    },
    _ => context.value_params.push(binding_name)
  }
end

fn mutate_context_noop() -> unit = do end

export fn mutate_context_from_statement(statement: Shared<SemanticStatement>, context: ref mut CodegenContext) -> unit = do
  match statement {
    SemanticStatementLetConst(binding_name, _, _, _) =>
      mutate_context_for_let_const(binding_name, context),
    SemanticStatementLet(binding_name, _, _, value_type, _) =>
      mutate_context_for_let(binding_name, value_type, context),
    SemanticStatementLetPattern(pattern, _, _, _, _, _, _) =>
      push_pattern_bind_names_to_value_params(pattern, context),
    SemanticStatementExpr(_, _) => mutate_context_noop(),
    SemanticStatementReturn(_, _) => mutate_context_noop(),
    SemanticStatementBreak(_) => mutate_context_noop(),
    SemanticStatementContinue(_) => mutate_context_noop()
  }
end

export fn lookup_fields_for_context(context: CodegenContext, name: string) -> [string] =
  if context.field_order_index.has(name) then context.field_order_index.get(name)
  else decl_index.lookup_fields(context.field_orders, name) end

export fn lookup_ctor_type_info_for_context(context: CodegenContext, constructor_name: string) -> Shared<CtorTypeInfo> =
  lookup_ctor_type_info_indexed(context.ctor_type_info_index, context.ctor_type_infos, constructor_name)

export fn create_codegen_context(program: Program) -> CodegenContext = do
  const field_orders = build_field_orders(program)
  const ctor_type_infos = build_ctor_type_infos_from_decls(program.decls)
  const registry = build_registry(program)
  CodegenContext {
    field_orders: field_orders,
    field_order_index: decl_index.build_field_order_index(field_orders),
    namespace_prefix: '',
    qualified: Map.new(),
    namespace_alias_prefixes: Map.new(),
    self_type: '',
    method_owners: build_method_owners_from_decls(program.decls),
    shared_params: [],
    shared_array_params: [],
    array_elem_types: Map.new(),
    shared_map_params: [],
    ctor_type_infos: ctor_type_infos,
    ctor_type_info_index: build_ctor_type_info_index(ctor_type_infos),
    variant_types: build_variant_types_from_decls(program.decls),
    sum_type_parameter_names: build_sum_type_parameter_names_from_decls(program.decls),
    variant_used_type_parameter_names: build_variant_used_type_parameter_names_from_decls(program.decls),
    value_params: [],
    match_deref_params: [],
    generic_variants: build_generic_variants_from_decls(program.decls),
    struct_using_entries: Map.new(),
    struct_using_lines: Map.new(),
    type_alias_annotations: registry.type_alias_annotations,
    trait_associated_type_names: registry.adt_index.trait_assoc_types,
    temp_name_counter: new_temp_name_counter(),
    enclosing_function_return_type: Shared.new(TUnknown)
  }
end

export fn context_with_struct_using_data(
  base: CodegenContext,
  data: StructUsingData
) -> CodegenContext =
  base.with_struct_using_data(data)

export fn context_with_struct_using_lines(
  base: CodegenContext,
  struct_using_lines: Map<string, [string]>
) -> CodegenContext =
  base.with_struct_using_lines(struct_using_lines)

export fn context_with_namespace_alias_prefixes(
  base: CodegenContext,
  namespace_alias_prefixes: Map<string, string>
) -> CodegenContext =
  base.with_namespace_alias_prefixes(namespace_alias_prefixes)
