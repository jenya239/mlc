// Expression and statement code generation (mutually recursive evaluation core).
// gen_expr dispatches per SExpr form; C++ text fragments live in expr.mlc (acyclic import).

import { Pat, span_unknown } from "../ast"
import { SExpr, SStmt, SFieldVal, SMatchArm, SExprUnit, sexpr_type } from "../semantic_ir"
import { Type } from "../checker/registry"
import { CodegenContext, CtorTypeInfo, GenStmtsResult, GenStmtResult,
         context_resolve, lookup_fields, list_contains, lookup_ctor_type_info,
         context_add_shared, context_add_shared_array,
         update_context_from_statement } from "./context"
import { cpp_safe, lower_first, map_method, map_builtin } from "./cpp_naming"
import { sem_type_to_cpp } from "./type_gen"
import { gen_integer_literal, gen_string_literal, gen_boolean_literal, gen_unit_literal, gen_extern_placeholder } from "./literals"
import { gen_identifier } from "./identifiers"
import { first_arm_needs_deref, pat_bind_names } from "./match_analysis"
import { find_field_value, is_constructor_call, resolve_object_code_in_self_context, infer_shared_new_type_name, field_access_operator, cpp_function_name_for_file_method, cpp_lambda_header_prefix } from "./expression_support"
import { stmts_final_ctx } from "./statement_context"
import * as expression_output from "./expr"

// Wrappers: match arm helpers use parameter name `context`, which shadows the C++
// namespace `context`, so do not call context::CodegenContext_with_* from extend here.
fn codegen_context_with_shared_binding(arm_context: CodegenContext, binding_name: string) -> CodegenContext =
  context_add_shared(arm_context, binding_name)

fn codegen_context_with_shared_array_binding(arm_context: CodegenContext, binding_name: string) -> CodegenContext =
  context_add_shared_array(arm_context, binding_name)

// --- Argument list helper ----------------------------------------------------

export fn gen_argument_list(expressions: [Shared<SExpr>], context: CodegenContext) -> string = do
  let parts: [string] = []; let mut index = 0
  while index < expressions.length() do
    parts.push(gen_expr(expressions[index], context)); index = index + 1
  end
  parts.join(", ")
end

// --- Record helpers ----------------------------------------------------------

fn gen_record_ordered(field_values: [Shared<SFieldVal>], field_order: [string], context: CodegenContext) -> string = do
  let parts: [string] = []; let mut index = 0
  while index < field_order.length() do
    let value = find_field_value(field_values, field_order[index])
    parts.push(gen_expr(value, context)); index = index + 1
  end
  parts.join(", ")
end

fn gen_record_unordered(field_values: [Shared<SFieldVal>], context: CodegenContext) -> string = do
  let parts: [string] = []; let mut index = 0
  while index < field_values.length() do
    parts.push(gen_expr(field_values[index].val, context)); index = index + 1
  end
  parts.join(", ")
end

fn gen_record_update_ordered(base_expr: Shared<SExpr>, overrides: [Shared<SFieldVal>], field_order: [string], context: CodegenContext) -> string = do
  let parts: [string] = []; let mut index = 0
  while index < field_order.length() do
    const field_name = field_order[index]
    let mut value_string = ""
    let mut override_found = false
    let mut override_index = 0
    while override_index < overrides.length() do
      if overrides[override_index].name == field_name then
        value_string = gen_expr(overrides[override_index].val, context)
        override_found = true
      end
      override_index = override_index + 1
    end
    if !override_found then
      value_string = gen_expr(Shared.new(SExprField(base_expr, field_name, Shared.new(TUnknown), span_unknown())), context)
    end
    parts.push(value_string); index = index + 1
  end
  parts.join(", ")
end

fn gen_record_update_lazy(base_expr: Shared<SExpr>, overrides: [Shared<SFieldVal>], context: CodegenContext) -> string = do
  let parts: [string] = ["auto __upd = " + gen_expr(base_expr, context) + "; "]
  let mut index = 0
  while index < overrides.length() do
    parts.push("__upd." + cpp_safe(overrides[index].name) + " = " + gen_expr(overrides[index].val, context) + "; ")
    index = index + 1
  end
  expression_output.record_update_lazy_closure(parts.join(""))
end

// --- Match arm generation rule ----------------------------------------------

fn gen_arm_ctor(ctor_name: string, sub_patterns: [Shared<Pat>], arm_body: Shared<SExpr>, context: CodegenContext) -> string = do
  const qualified_name = context_resolve(context, ctor_name)
  const lower_name = cpp_safe(lower_first(ctor_name))
  const binding =
    if sub_patterns.length() == 0 then ""
    else "auto [" + pat_bind_names(sub_patterns) + "] = " + lower_name + "; "
    end
  const ctor_type_info: Shared<CtorTypeInfo> = lookup_ctor_type_info(context.ctor_type_infos, ctor_name)
  const is_generic = list_contains(context.generic_variants, ctor_name)
  const type_argument = if is_generic then "<auto>" else "" end
  let mut arm_context = context; let mut index = 0
  while index < sub_patterns.length() do
    match sub_patterns[index] {
      PatIdent(pattern_name, _) => do
        if ctor_type_info.shared_pos.contains(index) then
          arm_context = codegen_context_with_shared_binding(arm_context, pattern_name)
        end
        if ctor_type_info.shared_arr_pos.contains(index) then
          arm_context = codegen_context_with_shared_array_binding(arm_context, pattern_name)
        end
      end,
      _ => do end
    }
    index = index + 1
  end
  expression_output.match_arm_constructed_value(
    "const " + qualified_name + type_argument + "& " + lower_name,
    binding,
    gen_expr(arm_body, arm_context))
end

fn gen_arm_record_pattern(record_name: string, field_patterns: [Shared<Pat>], arm_body: Shared<SExpr>, context: CodegenContext) -> string = do
  const qualified_name = context_resolve(context, record_name)
  const lower_name = cpp_safe(lower_first(record_name))
  const is_generic = list_contains(context.generic_variants, record_name)
  const type_argument = if is_generic then "<auto>" else "" end
  let mut field_bindings = ""; let mut field_index = 0
  while field_index < field_patterns.length() do
    match field_patterns[field_index] {
      PatIdent(field_name, _) => do
        field_bindings = field_bindings + "const auto& " + cpp_safe(field_name) + " = " + lower_name + "." + cpp_safe(field_name) + "; "
      end,
      _ => do end
    }
    field_index = field_index + 1
  end
  expression_output.match_arm_constructed_value(
    "const " + qualified_name + type_argument + "& " + lower_name,
    field_bindings,
    gen_expr(arm_body, context))
end

fn gen_arm(arm: Shared<SMatchArm>, context: CodegenContext) -> string =
  match arm.pat {
    PatWild(_)        => expression_output.match_arm_wild_or_unit_return(gen_expr(arm.body, context)),
    PatUnit(_)        => expression_output.match_arm_wild_or_unit_return(gen_expr(arm.body, context)),
    PatBool(_, _)     => expression_output.match_arm_wild_or_unit_return(gen_expr(arm.body, context)),
    PatInt(_, _)      => expression_output.match_arm_wild_or_unit_return(gen_expr(arm.body, context)),
    PatStr(_, _)      => expression_output.match_arm_wild_or_unit_return(gen_expr(arm.body, context)),
    PatIdent(name, _) => expression_output.match_arm_binding_identifier(cpp_safe(name), gen_expr(arm.body, context)),
    PatCtor(name, sub_patterns, _)     => gen_arm_ctor(name, sub_patterns, arm.body, context),
    PatRecord(name, field_patterns, _) => gen_arm_record_pattern(name, field_patterns, arm.body, context)
  }

fn gen_match(subject: Shared<SExpr>, arms: [Shared<SMatchArm>], context: CodegenContext) -> string = do
  let parts: [string] = []; let mut index = 0
  while index < arms.length() do parts.push(gen_arm(arms[index], context)); index = index + 1 end
  const subject_code = gen_expr(subject, context)
  const needs_deref = if arms.length() > 0 then first_arm_needs_deref(arms[0], subject, context) else true end
  const visit_subject = if needs_deref then "(*" + subject_code + ")" else subject_code end
  expression_output.std_visit_match_expression(parts.join(",\n"), visit_subject)
end

// --- Expression rules (one function per expression form) --------------------

fn gen_binary_expr(operation: string, left_expr: Shared<SExpr>, right_expr: Shared<SExpr>, context: CodegenContext) -> string =
  expression_output.parenthesized_binary(gen_expr(left_expr, context), operation, gen_expr(right_expr, context))

fn gen_unary_expr(operation: string, inner_expr: Shared<SExpr>, context: CodegenContext) -> string =
  expression_output.parenthesized_unary(operation, gen_expr(inner_expr, context))

fn gen_call_function_code(function_expr: Shared<SExpr>, context: CodegenContext) -> string =
  match function_expr {
    SExprIdent(name, _, _) => context_resolve(context, map_builtin(name)),
    _ => gen_expr(function_expr, context)
  }

fn gen_call_expr(function_expr: Shared<SExpr>, arguments: [Shared<SExpr>], context: CodegenContext) -> string = do
  const function_code = gen_call_function_code(function_expr, context)
  const argument_list = gen_argument_list(arguments, context)
  if is_constructor_call(function_expr) then expression_output.constructor_call_braces(function_code, argument_list)
  else expression_output.function_call_parentheses(function_code, argument_list)
  end
end

fn gen_object_code(object: Shared<SExpr>, context: CodegenContext) -> string =
  match object {
    SExprIdent(name, _, _) =>
      if context.self_type.length() > 0 then resolve_object_code_in_self_context(name, context)
      else context_resolve(context, map_builtin(name))
      end,
    _ => gen_expr(object, context)
  }

fn gen_method_file(method_name: string, arguments: [Shared<SExpr>], context: CodegenContext) -> string =
  expression_output.function_call_parentheses(
    cpp_function_name_for_file_method(method_name),
    gen_argument_list(arguments, context))

fn gen_method_shared_new(argument: Shared<SExpr>, context: CodegenContext) -> string = do
  const argument_code = gen_expr(argument, context)
  const type_name = infer_shared_new_type_name(argument, context)
  "std::make_shared<" + type_name + ">(" + argument_code + ")"
end

fn gen_method_owner_call(object_code: string, method_name: string, arguments: [Shared<SExpr>], context: CodegenContext) -> string = do
  const mangled_name = context.method_owners.get(method_name)
  const function_name = context_resolve(context, mangled_name)
  if arguments.length() == 0 then expression_output.function_call_parentheses(function_name, object_code)
  else expression_output.function_call_parentheses(function_name, object_code + ", " + gen_argument_list(arguments, context))
  end
end

fn gen_method_builtin(object_code: string, method_name: string, arguments: [Shared<SExpr>], context: CodegenContext) -> string = do
  const call_base = object_code + "." + map_method(method_name)
  if arguments.length() == 0 then expression_output.function_call_parentheses(call_base, "")
  else expression_output.function_call_parentheses(call_base, gen_argument_list(arguments, context))
  end
end

fn gen_method_namespace_alias(static_prefix: string, method_name: string, arguments: [Shared<SExpr>], context: CodegenContext) -> string = do
  const call_base = static_prefix + map_method(method_name)
  if arguments.length() == 0 then expression_output.function_call_parentheses(call_base, "")
  else expression_output.function_call_parentheses(call_base, gen_argument_list(arguments, context))
  end
end

fn gen_method_expr_after_object(object_code: string, method_name: string, arguments: [Shared<SExpr>], context: CodegenContext) -> string =
  if object_code == "File" then
    gen_method_file(method_name, arguments, context)
  else if object_code == "Map" && method_name == "new" then
    "\{\}"
  else if object_code == "Shared" && method_name == "new" && arguments.length() == 1 then
    gen_method_shared_new(arguments[0], context)
  else if method_name == "to_string" && arguments.length() == 0 then
    "mlc::to_string(" + object_code + ")"
  else if context.method_owners.has(method_name) then
    gen_method_owner_call(object_code, method_name, arguments, context)
  else
    gen_method_builtin(object_code, method_name, arguments, context)
  end

fn gen_method_expr(object: Shared<SExpr>, method_name: string, arguments: [Shared<SExpr>], context: CodegenContext) -> string =
  match object {
    SExprIdent(object_name, _, _) =>
      if context.namespace_alias_prefixes.has(object_name) then
        gen_method_namespace_alias(context.namespace_alias_prefixes.get(object_name), method_name, arguments, context)
      else
        gen_method_expr_after_object(gen_object_code(object, context), method_name, arguments, context)
      end,
    _ => gen_method_expr_after_object(gen_object_code(object, context), method_name, arguments, context)
  }

fn gen_field_expr(object: Shared<SExpr>, field_name: string, context: CodegenContext) -> string = do
  const object_code = gen_expr(object, context)
  const operator = field_access_operator(object, context)
  expression_output.field_access(object_code, operator, cpp_safe(field_name))
end

fn gen_index_expr(object: Shared<SExpr>, index_expr: Shared<SExpr>, context: CodegenContext) -> string =
  expression_output.index_subscript(gen_expr(object, context), gen_expr(index_expr, context))

fn gen_if_expr(condition: Shared<SExpr>, then_expr: Shared<SExpr>, else_expr: Shared<SExpr>, context: CodegenContext) -> string =
  expression_output.ternary_conditional(
    gen_expr(condition, context),
    gen_expr(then_expr, context),
    gen_expr(else_expr, context))

fn gen_block_expr(statements: [Shared<SStmt>], result_expr: Shared<SExpr>, context: CodegenContext) -> string =
  if statements.length() == 0 then
    gen_expr(result_expr, context)
  else
    const body = gen_stmts_str(statements, context) + "return " + gen_expr(result_expr, stmts_final_ctx(statements, context)) + ";\n"
    expression_output.block_as_immediate_invoked_function_expression(body)
  end

fn gen_while_expr(condition: Shared<SExpr>, statements: [Shared<SStmt>], context: CodegenContext) -> string =
  expression_output.while_loop_immediate_invoked_function_expression(
    gen_expr(condition, context),
    gen_stmts_str(statements, context))

fn gen_for_expr(variable: string, iterator: Shared<SExpr>, statements: [Shared<SStmt>], context: CodegenContext) -> string =
  expression_output.for_loop_immediate_invoked_function_expression(
    cpp_safe(variable),
    gen_expr(iterator, context),
    gen_stmts_str(statements, context))

fn gen_record_expr(type_name: string, field_values: [Shared<SFieldVal>], context: CodegenContext) -> string = do
  const field_order = lookup_fields(context.field_orders, type_name)
  const values_code = if field_order.length() > 0
                      then gen_record_ordered(field_values, field_order, context)
                      else gen_record_unordered(field_values, context)
                      end
  expression_output.record_initializer(context_resolve(context, type_name), values_code)
end

fn gen_record_update_expr(type_name: string, base_expr: Shared<SExpr>, overrides: [Shared<SFieldVal>], context: CodegenContext) -> string = do
  const field_order = lookup_fields(context.field_orders, type_name)
  if field_order.length() > 0 then
    expression_output.record_initializer(
      context_resolve(context, type_name),
      gen_record_update_ordered(base_expr, overrides, field_order, context))
  else
    gen_record_update_lazy(base_expr, overrides, context)
  end
end

fn gen_array_expr(elements: [Shared<SExpr>], context: CodegenContext) -> string =
  expression_output.array_literal(gen_argument_list(elements, context))

fn gen_question_expr(inner_expr: Shared<SExpr>, context: CodegenContext) -> string = do
  const inner_code = gen_expr(inner_expr, context)
  expression_output.question_try_result(inner_code)
end

fn gen_lambda_expr(parameters: [string], body_expr: Shared<SExpr>, context: CodegenContext) -> string =
  expression_output.lambda_with_return(cpp_lambda_header_prefix(parameters), gen_expr(body_expr, context))

// --- Dispatcher --------------------------------------------------------------

export fn gen_expr(expr: Shared<SExpr>, context: CodegenContext) -> string =
  match expr {
    SExprInt(integer_value, _, _)                          => gen_integer_literal(integer_value),
    SExprStr(string_value, _, _)                           => gen_string_literal(string_value),
    SExprBool(boolean_value, _, _)                         => gen_boolean_literal(boolean_value),
    SExprUnit(_, _)                                        => gen_unit_literal(),
    SExprExtern(_, _)                                      => gen_extern_placeholder(),
    SExprIdent(name, _, _)                                 => gen_identifier(name, context),
    SExprBin(operation, left_expr, right_expr, _, _)       => gen_binary_expr(operation, left_expr, right_expr, context),
    SExprUn(operation, inner_expr, _, _)                   => gen_unary_expr(operation, inner_expr, context),
    SExprCall(function_expr, arguments, _, _)              => gen_call_expr(function_expr, arguments, context),
    SExprMethod(object, method_name, arguments, _, _)      => gen_method_expr(object, method_name, arguments, context),
    SExprField(object, field_name, _, _)                   => gen_field_expr(object, field_name, context),
    SExprIndex(object, index_expr, _, _)                   => gen_index_expr(object, index_expr, context),
    SExprIf(condition, then_expr, else_expr, _, _)         => gen_if_expr(condition, then_expr, else_expr, context),
    SExprBlock(statements, result_expr, _, _)              => gen_block_expr(statements, result_expr, context),
    SExprWhile(condition, statements, _, _)                => gen_while_expr(condition, statements, context),
    SExprFor(variable, iterator, statements, _, _)         => gen_for_expr(variable, iterator, statements, context),
    SExprMatch(subject, arms, _, _)                        => gen_match(subject, arms, context),
    SExprRecord(type_name, field_values, _, _)             => gen_record_expr(type_name, field_values, context),
    SExprRecordUpdate(type_name, base_expr, overrides, _, _) => gen_record_update_expr(type_name, base_expr, overrides, context),
    SExprArray(elements, _, _)                             => gen_array_expr(elements, context),
    SExprQuestion(inner_expr, _, _)                        => gen_question_expr(inner_expr, context),
    SExprLambda(parameters, body_expr, _, _)               => gen_lambda_expr(parameters, body_expr, context)
  }

// --- Statement generation ----------------------------------------------------

fn gen_try_unwrap(inner_expr: Shared<SExpr>, context: CodegenContext, try_identifier: string, success_line: string) -> string = do
  const inner_code = gen_expr(inner_expr, context)
  expression_output.try_unwrap_result_block(try_identifier, inner_code, success_line)
end

export fn gen_stmt_with_try(stmt: Shared<SStmt>, context: CodegenContext, try_counter: i32) -> GenStmtResult =
  match stmt {
    SStmtLet(name, _, value, value_type, _) => do
      const try_identifier = "__try_" + try_counter.to_string()
      const next_counter = try_counter + 1
      const result = match value {
        SExprQuestion(inner_expr, _, _) =>
          GenStmtResult {
            output: gen_try_unwrap(
              inner_expr,
              context,
              try_identifier,
              expression_output.let_from_try_ok_field0(cpp_safe(name), try_identifier)),
            next_try: next_counter
          },
        SExprArray(elements, array_type, _) => do
          const value_code = if elements.length() == 0 then
            match array_type {
              TArray(inner_type) => "mlc::Array<" + sem_type_to_cpp(context, inner_type) + ">\{\}",
              _                  => "mlc::Array<mlc::String>\{\}"
            }
          else expression_output.constructor_call_braces("mlc::Array", gen_argument_list(elements, context))
          end
          GenStmtResult {
            output: expression_output.auto_binding_statement(cpp_safe(name), value_code),
            next_try: try_counter
          }
        end,
        SExprMethod(map_object, method_name, _, _, _) => do
          const value_code = if method_name == "new" then
            match map_object {
              SExprIdent(object_name, _, _) =>
                if object_name == "Map" then
                  match value_type {
                    TGeneric(type_name, type_args) =>
                      if type_name == "Map" && type_args.length() == 2 then
                        "mlc::HashMap<" + sem_type_to_cpp(context, type_args[0]) + ", " + sem_type_to_cpp(context, type_args[1]) + ">()"
                      else gen_expr(value, context)
                      end,
                    _ => gen_expr(value, context)
                  }
                else gen_expr(value, context)
                end,
              _ => gen_expr(value, context)
            }
          else gen_expr(value, context)
          end
          GenStmtResult {
            output: expression_output.auto_binding_statement(cpp_safe(name), value_code),
            next_try: try_counter
          }
        end,
        _ => GenStmtResult {
          output: expression_output.auto_binding_statement(cpp_safe(name), gen_expr(value, context)),
          next_try: try_counter
        }
      }
      result
    end,
    SStmtLetConst(name, value, _, _) =>
      GenStmtResult {
        output: expression_output.constexpr_auto_binding_statement(cpp_safe(name), gen_expr(value, context)),
        next_try: try_counter
      },
    SStmtExpr(expression, _) => match expression {
      SExprQuestion(inner_expr, _, _) => do
        const try_identifier = "__try_" + try_counter.to_string()
        GenStmtResult {
          output: gen_try_unwrap(
            inner_expr,
            context,
            try_identifier,
            expression_output.discard_try_ok_field0_statement(try_identifier)),
          next_try: try_counter + 1
        }
      end,
      _ => GenStmtResult { output: gen_stmt_expr(expression, context), next_try: try_counter }
    },
    SStmtBreak(_)    => GenStmtResult { output: expression_output.break_line(), next_try: try_counter },
    SStmtContinue(_) => GenStmtResult { output: expression_output.continue_line(), next_try: try_counter },
    SStmtReturn(expression, _) => match expression {
      SExprQuestion(inner_expr, _, _) => do
        const try_identifier = "__try_ret_" + try_counter.to_string()
        GenStmtResult {
          output: gen_try_unwrap(
            inner_expr,
            context,
            try_identifier,
            expression_output.return_try_ok_field0_statement(try_identifier)),
          next_try: try_counter + 1
        }
      end,
      _ => GenStmtResult {
        output: expression_output.return_line(gen_expr(expression, context)),
        next_try: try_counter
      }
    }
  }

fn gen_stmt_expr(expression: Shared<SExpr>, context: CodegenContext) -> string =
  match expression {
    SExprBin(operation, left_expr, right_expr, _, _) =>
      if operation == "=" then
        expression_output.assignment_statement(gen_expr(left_expr, context), gen_expr(right_expr, context))
      else
        expression_output.expression_operation_statement(
          operation,
          gen_expr(left_expr, context),
          gen_expr(right_expr, context))
      end,
    SExprIf(condition, then_expr, else_expr, _, _) => do
      let mut output = expression_output.if_brace_block(
        gen_expr(condition, context),
        gen_block_body(then_expr, context))
      const else_string = match else_expr {
        SExprUnit(_, _)                             => "",
        SExprBlock(statements, result_expr, _, _) =>
          if statements.length() == 0 then
            match result_expr {
              SExprUnit(_, _) => "",
              _ => expression_output.else_brace_block(gen_block_body(else_expr, context))
            }
          else expression_output.else_brace_block(gen_block_body(else_expr, context))
          end,
        SExprIf(_, _, _, _, _) =>
          expression_output.else_fragment_raw(gen_stmt_expr(else_expr, context)),
        _ => expression_output.else_brace_block(gen_block_body(else_expr, context))
      }
      if else_string.length() > 0 then output = output + else_string end
      expression_output.fragment_with_newline(output)
    end,
    SExprWhile(condition, statements, _, _) =>
      expression_output.while_loop_statement(
        gen_expr(condition, context),
        gen_stmts_str(statements, context)),
    SExprFor(variable, iterator, statements, _, _) =>
      expression_output.for_loop_statement(
        cpp_safe(variable),
        gen_expr(iterator, context),
        gen_stmts_str(statements, context)),
    SExprBlock(statements, result_expr, _, _) => do
      const statements_code = gen_stmts_str(statements, context)
      const result_code = gen_expr(result_expr, stmts_final_ctx(statements, context))
      if result_code == "/* unit */" then statements_code else statements_code + result_code + ";\n" end
    end,
    _ => expression_output.suffix_semicolon_newline(gen_expr(expression, context))
  }

fn gen_block_body(expr: Shared<SExpr>, context: CodegenContext) -> string =
  match expr {
    SExprBlock(statements, result_expr, _, _) => do
      const statements_code = gen_stmts_str(statements, context)
      const final_context   = stmts_final_ctx(statements, context)
      match result_expr {
        SExprIf(_, _, _, _, _) => statements_code + gen_stmt_expr(result_expr, final_context),
        SExprUnit(_, _)        => statements_code,
        _ => do
          const result_code = gen_expr(result_expr, final_context)
          if result_code == "/* unit */" then statements_code else statements_code + result_code + ";\n" end
        end
      }
    end,
    SExprIf(_, _, _, _, _) => gen_stmt_expr(expr, context),
    _ => expression_output.suffix_semicolon_newline(gen_expr(expr, context))
  }

export fn gen_stmts_str_with_try(statements: [Shared<SStmt>], context: CodegenContext, try_counter: i32) -> GenStmtsResult = do
  let parts: [string] = []; let mut index = 0
  let mut current_context = context; let mut counter = try_counter
  while index < statements.length() do
    const result = gen_stmt_with_try(statements[index], current_context, counter)
    parts.push(result.output)
    counter = result.next_try
    current_context = update_context_from_statement(statements[index], current_context)
    index = index + 1
  end
  GenStmtsResult { code: parts.join(""), next_try: counter }
end

export fn gen_stmts_str(statements: [Shared<SStmt>], context: CodegenContext) -> string = do
  const result = gen_stmts_str_with_try(statements, context, 0)
  result.code
end

// --- Return body generation --------------------------------------------------

fn gen_return_if_stmt(expr: Shared<SExpr>, context: CodegenContext) -> string =
  match expr {
    SExprIf(condition, then_expr, else_expr, _, _) => do
      let mut output = expression_output.if_brace_block(
        gen_expr(condition, context),
        gen_return_body(then_expr, context))
      const else_string = match else_expr {
        SExprUnit(_, _)        => "",
        SExprIf(_, _, _, _, _) => expression_output.else_fragment_raw(gen_return_if_stmt(else_expr, context)),
        _                      => expression_output.else_brace_block(gen_return_body(else_expr, context))
      }
      if else_string.length() > 0 then output = output + else_string end
      expression_output.fragment_with_newline(output)
    end,
    _ => expression_output.if_always_true_block(gen_return_body(expr, context))
  }

export fn gen_return_body(expr: Shared<SExpr>, context: CodegenContext) -> string =
  match expr {
    SExprBlock(statements, result_expr, _, _) => do
      const final_context   = stmts_final_ctx(statements, context)
      const statements_code = gen_stmts_str(statements, context)
      match result_expr {
        SExprQuestion(inner_expr, _, _) => do
          const try_identifier = "__try_ret"
          statements_code + gen_try_unwrap(
            inner_expr,
            final_context,
            try_identifier,
            expression_output.return_try_ok_field0_statement(try_identifier))
        end,
        SExprUnit(_, _)        => statements_code,
        SExprIf(_, _, _, _, _) => statements_code + gen_return_body(result_expr, final_context),
        SExprMatch(_, _, _, _) => statements_code + gen_return_body(result_expr, final_context),
        SExprBlock(_, _, _, _) => statements_code + gen_return_body(result_expr, final_context),
        _ =>
          statements_code + expression_output.return_line(gen_expr(result_expr, final_context))
      }
    end,
    SExprIf(condition, then_expr, else_expr, _, _) => do
      let mut output = expression_output.if_brace_block(
        gen_expr(condition, context),
        gen_return_body(then_expr, context))
      const else_string = match else_expr {
        SExprUnit(_, _)        => "",
        SExprIf(_, _, _, _, _) => expression_output.else_fragment_raw(gen_return_if_stmt(else_expr, context)),
        _                      => expression_output.else_brace_block(gen_return_body(else_expr, context))
      }
      if else_string.length() > 0 then output = output + else_string end
      expression_output.fragment_with_newline(output)
    end,
    SExprQuestion(inner_expr, _, _) => do
      const try_identifier = "__try_ret"
      gen_try_unwrap(
        inner_expr,
        context,
        try_identifier,
        expression_output.return_try_ok_field0_statement(try_identifier))
    end,
    _ => expression_output.return_line(gen_expr(expr, context))
  }

export fn gen_fn_body(body_expr: Shared<SExpr>, context: CodegenContext) -> string =
  gen_return_body(body_expr, context)
