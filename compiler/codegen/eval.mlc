// Binding layer: threads gen_expr <-> gen_stmts_str via closures.
// CodegenPass : ExprVisitor<Shared<CppExpression>> lives in expr_visitor_cpp.mlc.

import { SemanticExpression, SemanticStatement } from '../ir/semantic_ir'
import { CodegenContext, GenStmtsWithContext, GenStmtResult } from './context'
import { print_expr } from '../cpp/cpp_ast'
import * as stmt_eval from './stmt/stmt_eval'
import * as expr_visitor_cpp from '../expr_visitor_cpp'
import { gen_stmts_cpp, print_cpp_statements } from './stmt_cpp'

fn eval_expr_gen_stmts_callback(
  statements: [Shared<SemanticStatement>],
  codegen_context: CodegenContext
) -> string =
  gen_stmts_str(statements, codegen_context)

extend CodegenContext {
  fn gen_stmts_str(self: CodegenContext, statements: [Shared<SemanticStatement>]) -> string =
    print_cpp_statements(gen_stmts_cpp(statements, self))

  fn gen_expr(self: CodegenContext, expression: Shared<SemanticExpression>) -> string =
    print_expr(expr_visitor_cpp.eval_expr_cpp(expression, self, eval_expr_gen_stmts_callback))

  fn gen_argument_list(self: CodegenContext, expressions: [Shared<SemanticExpression>]) -> string =
    expressions.map(expression => gen_expr(expression, self)).join(', ')

  fn gen_try_unwrap(
    self: CodegenContext,
    inner_expression: Shared<SemanticExpression>,
    try_identifier: string,
    success_line: string
  ) -> string =
    stmt_eval.eval_try_unwrap(
      inner_expression,
      self,
      try_identifier,
      success_line,
      (expression: Shared<SemanticExpression>, codegen_context: CodegenContext) =>
        gen_expr(expression, codegen_context))

  fn gen_stmt_with_try(
    self: CodegenContext,
    statement: Shared<SemanticStatement>,
    try_counter: i32
  ) -> GenStmtResult =
    stmt_eval.eval_stmt_with_try(
      statement,
      self,
      try_counter,
      (expression: Shared<SemanticExpression>, codegen_context: CodegenContext) =>
        gen_expr(expression, codegen_context))

  fn gen_stmts_str_with_try(
    self: CodegenContext,
    statements: [Shared<SemanticStatement>],
    try_counter: i32
  ) -> GenStmtsWithContext =
    stmt_eval.eval_stmts_str_with_try(
      statements,
      self,
      try_counter,
      (expression: Shared<SemanticExpression>, codegen_context: CodegenContext) =>
        gen_expr(expression, codegen_context))
}

export fn gen_expr(expression: Shared<SemanticExpression>, context: CodegenContext) -> string =
  context.gen_expr(expression)

export fn gen_stmts_str(statements: [Shared<SemanticStatement>], context: CodegenContext) -> string =
  context.gen_stmts_str(statements)

export fn gen_argument_list(expressions: [Shared<SemanticExpression>], context: CodegenContext) -> string =
  context.gen_argument_list(expressions)

export fn gen_try_unwrap(inner_expression: Shared<SemanticExpression>, context: CodegenContext, try_identifier: string, success_line: string) -> string =
  context.gen_try_unwrap(inner_expression, try_identifier, success_line)

export fn gen_stmt_with_try(statement: Shared<SemanticStatement>, context: CodegenContext, try_counter: i32) -> GenStmtResult =
  context.gen_stmt_with_try(statement, try_counter)

export fn gen_stmts_str_with_try(statements: [Shared<SemanticStatement>], context: CodegenContext, try_counter: i32) -> GenStmtsWithContext =
  context.gen_stmts_str_with_try(statements, try_counter)
