// Binding layer: threads gen_expr <-> gen_stmts_str via closures.
// Public API has no extra parameters; the cross-module dependency is injected here.

import { SExpr, SStmt } from "../semantic_ir"
import { CodegenContext, GenStmtsResult, GenStmtResult } from "./context"
import * as expr_eval from "./expr_eval"
import * as stmt_eval from "./stmt_eval"

export fn gen_expr(expr: Shared<SExpr>, context: CodegenContext) -> string =
  expr_eval.eval_expr(expr, context, (statements: [Shared<SStmt>], ctx: CodegenContext) => gen_stmts_str(statements, ctx))

export fn gen_stmts_str(statements: [Shared<SStmt>], context: CodegenContext) -> string =
  stmt_eval.eval_stmts_str(statements, context, (expression: Shared<SExpr>, ctx: CodegenContext) => gen_expr(expression, ctx))

export fn gen_argument_list(expressions: [Shared<SExpr>], context: CodegenContext) -> string =
  expr_eval.eval_argument_list(expressions, context, (statements: [Shared<SStmt>], ctx: CodegenContext) => gen_stmts_str(statements, ctx))

export fn gen_try_unwrap(inner_expr: Shared<SExpr>, context: CodegenContext, try_identifier: string, success_line: string) -> string =
  stmt_eval.eval_try_unwrap(inner_expr, context, try_identifier, success_line, (expression: Shared<SExpr>, ctx: CodegenContext) => gen_expr(expression, ctx))

export fn gen_stmt_with_try(stmt: Shared<SStmt>, context: CodegenContext, try_counter: i32) -> GenStmtResult =
  stmt_eval.eval_stmt_with_try(stmt, context, try_counter, (expression: Shared<SExpr>, ctx: CodegenContext) => gen_expr(expression, ctx))

export fn gen_stmts_str_with_try(statements: [Shared<SStmt>], context: CodegenContext, try_counter: i32) -> GenStmtsResult =
  stmt_eval.eval_stmts_str_with_try(statements, context, try_counter, (expression: Shared<SExpr>, ctx: CodegenContext) => gen_expr(expression, ctx))
