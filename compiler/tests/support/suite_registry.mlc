import { spawn_tests } from '../test_spawn'
import { channel_syntax_tests } from '../test_channel_syntax'
import { arc_syntax_tests } from '../test_arc_syntax'
import { mutex_syntax_tests } from '../test_mutex_syntax'
import { compiler_db_tests } from '../test_compiler_db'
