// TRACK_CONCURRENCY_FFI_METADATA STEP=2 —
// TaskScope.spawn also rejects thread_affine extern fn (E094).
extern fn gui_paint() -> unit = "gui_paint" from "<stdio.h>" thread_affine(MainThread)

fn main() -> i32 = do
  scope |task_scope| do
    task_scope.spawn do
      gui_paint()
      0
    end
  end
  0
end
