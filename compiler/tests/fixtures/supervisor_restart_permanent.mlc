// TRACK_CONCURRENCY_SUPERVISOR_MLC_SURFACE —
// Permanent restarts; Temporary sibling runs once (mirror C++ test_supervisor).
extern fn test_sleep_ms(milliseconds: i32) -> i32
  = "mlc::concurrency::test_sleep_ms" from "mlc/concurrency/test_sleep.hpp" blocking

fn main() -> i32 = do
  let runs = AtomicI32.new(0)
  let sibling = AtomicI32.new(0)
  let supervisor = Supervisor.new()
  supervisor.add("loop", RestartPolicy.Permanent, (token: StopToken) => do
    let _ignored = runs.fetch_add(1)
    let _slept = test_sleep_ms(5)
    ()
  end)
  supervisor.add("once", RestartPolicy.Temporary, (token: StopToken) => do
    let _ignored = sibling.fetch_add(1)
    ()
  end)
  supervisor.start()
  let _waited = test_sleep_ms(40)
  supervisor.stop()
  if runs.load() >= 3 && sibling.load() == 1 then 0 else 1 end
end
