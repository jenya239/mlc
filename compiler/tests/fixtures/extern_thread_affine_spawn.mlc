// TRACK_CONCURRENCY_FFI_METADATA STEP=1 —
// Desired: thread_affine(MainThread) extern fn inside spawn → error[E094].
// Red today: check-only succeeds (no affinity call-site check).
extern fn gui_paint() -> unit = "gui_paint" from "<stdio.h>" thread_affine(MainThread)

fn main() -> unit = do
  let _task = spawn do
    gui_paint()
    return ()
  end
  ()
end
