import { TestResult, assert_true } from './test_runner'
import { module_path_is_safe, program_to_semantic_load_item } from '../checker/transform/program_to_semantic'
import { parse_program } from '../frontend/parser/decls'
import { tokenize } from '../frontend/lexer'

export fn program_to_semantic_tests() -> [TestResult] = do
  let results: [TestResult] = []

  results.push(assert_true('module_path_is_safe accepts test_main', module_path_is_safe('test_main')))
  results.push(assert_true('module_path_is_safe rejects empty', !module_path_is_safe('')))
  results.push(assert_true('module_path_is_safe rejects semicolon', !module_path_is_safe('foo;bar')))

  const source = 'fn main() -> i32 = 0'
  const program = parse_program(tokenize(source).tokens)
  const converted = program_to_semantic_load_item(program, 'test_main')
  results.push(assert_true('program_to_semantic_load_item ok for minimal program',
    match converted { Ok(_) => true, Err(_) => false }))

  const rejected = program_to_semantic_load_item(program, '../escape')
  results.push(assert_true('program_to_semantic_load_item rejects unsafe path',
    match rejected { Err(_) => true, Ok(_) => false }))

  results
end