import { TestResult, assert_eq_int } from './test_runner'
import { assert_code_contains, assert_type_generates } from './codegen_test_helpers'
import { tokenize } from '../frontend/lexer'
import { parse_program } from '../frontend/parser/decls'
import { check } from '../checker/check/check'
import { gen_expr } from '../codegen/eval'
import { create_codegen_context } from '../codegen/context'
import { empty_program } from './ast_builders'
import {
  SemanticExpressionCall, SemanticExpressionIdent, SemanticExpressionLambda,
  SemanticExpressionBlock, SemanticExpressionInt
} from '../ir/semantic_ir'
import { span_unknown, TyI32, TyGeneric } from '../frontend/ast'
import { TI32, TUnit, TFn, TGeneric } from '../checker/registry'
import { diagnostic_code_e087, diagnostic_code_e088 } from '../checker/diagnostic_codes'

fn check_error_count(source: string) -> i32 =
  match check(parse_program(tokenize(source).tokens)) {
    Ok(_) => 0,
    Err(errors) => errors.length()
  }

fn first_error_line(source: string) -> string =
  match check(parse_program(tokenize(source).tokens)) {
    Ok(_) => '',
    Err(errors) => if errors.length() > 0 then errors[0] else '' end
  }

fn integer_type() -> Shared<Type> = Shared.new(TI32)

export fn spawn_tests() -> [TestResult] = do
  let results: [TestResult] = []

  results.push(assert_eq_int('spawn do return checks',
    check_error_count('fn main() -> Task<i32> = spawn do return 7 end'), 0))

  results.push(assert_eq_int('spawn captures immutable binding',
    check_error_count(
      'fn main() -> Task<i32> = do\n  let x = 7\n  spawn do return x end\nend'),
    0))

  results.push(assert_eq_int('spawn rejects mutable capture E087',
    check_error_count(
      'fn main() -> Task<i32> = do\n  let mut x = 7\n  spawn do return x end\nend'),
    1))

  results.push(assert_eq_int('spawn mutable capture diagnostic code',
    if first_error_line(
      'fn main() -> Task<i32> = do\n  let mut x = 7\n  spawn do return x end\nend'
    ).contains('error[' + diagnostic_code_e087() + ']') then 1 else 0 end,
    1))

  results.push(assert_eq_int('spawn local mut inside body ok',
    check_error_count(
      'fn main() -> Task<i32> = spawn do\n  let mut x = 7\n  return x\nend'),
    0))

  results.push(assert_eq_int('spawn move mut binding ok',
    check_error_count(
      'fn main() -> Task<i32> = do\n  let mut x = 7\n  spawn do return move x end\nend'),
    0))

  results.push(assert_eq_int('use after move E088',
    check_error_count(
      'fn main() -> i32 = do\n  let x = 7\n  let y = move x\n  x\nend'),
    1))

  results.push(assert_eq_int('use after move diagnostic code',
    if first_error_line(
      'fn main() -> i32 = do\n  let x = 7\n  let y = move x\n  x\nend'
    ).contains('error[' + diagnostic_code_e088() + ']') then 1 else 0 end,
    1))

  results.push(assert_eq_int('use after move into spawn E088',
    check_error_count(
      'fn main() -> i32 = do\n  let mut x = 7\n  let t = spawn do return move x end\n  x\nend'),
    1))

  const return_value = Shared.new(SemanticExpressionInt(7, integer_type(), span_unknown()))
  const block = Shared.new(SemanticExpressionBlock([], return_value, integer_type(), span_unknown()))
  const lambda = Shared.new(SemanticExpressionLambda(
    [], block, Shared.new(TFn([], integer_type())), span_unknown()))
  const spawn_call = Shared.new(SemanticExpressionCall(
    Shared.new(SemanticExpressionIdent('spawn_task', Shared.new(TUnit), span_unknown())),
    [lambda],
    [0],
    Shared.new(TGeneric('Task', [integer_type()])),
    span_unknown()))
  const context = create_codegen_context(empty_program())
  const generated = gen_expr(spawn_call, context)
  results.push(assert_code_contains('spawn_task in cpp', generated.to_string(), 'spawn_task'))
  results.push(assert_type_generates(
    'Task type in cpp', context,
    Shared.new(TyGeneric('Task', [Shared.new(TyI32)])),
    'mlc::Task<int>'))

  results
end
