  const with_src = 'type Res = { v: i32 } fn make(x: i32) -> Res = Res { v: x } extend Res { fn drop(self: Res) -> i32 = 0 fn read(self: Res) -> i32 = self.v } fn f(x: i32) -> i32 = do with make(x) as r do r.read() end 0 end'
