  const codegen_invariant_tail_after_else_if_chain =
    'export fn tail_after_chain(kind: string, extra: i32) -> i32 = do\n  let mut accumulator = 0\n  if kind == "a" then\n    accumulator = 1\n  else if kind == "b" then\n    accumulator = 2\n  else\n    accumulator = 3\n  end\n  accumulator + extra\nend\n\nexport fn main() -> i32 = tail_after_chain("a", 100)'
  results.push(assert_eq_int('codegen invariant: do-block tail after else-if chain — 0 errors',
    check_error_count(codegen_invariant_tail_after_else_if_chain), 0))

  const codegen_invariant_twin_if_zip_join_style =
    'export fn twin_branch(kind: string, has_arg: bool) -> i32 = do\n  let mut diagnostics_weight = 0\n  if has_arg then\n    if kind == "zip" then\n      diagnostics_weight = 1\n    end\n    if kind == "join" then\n      diagnostics_weight = diagnostics_weight + 2\n    end\n  end\n  diagnostics_weight + 50\nend\n\nexport fn main() -> i32 = twin_branch("zip", true)'
  results.push(assert_eq_int('codegen invariant: sequential if branches (zip/join shape) — 0 errors',
    check_error_count(codegen_invariant_twin_if_zip_join_style), 0))

  const codegen_invariant_if_else_flattened =
    'fn merge_unknown_inner(then_inner: i32, else_errors: i32) -> i32 = do\n  if then_inner == 0 then else_errors + 10\n  else then_inner + else_errors\n  end\nend\n\nexport fn conditional_flat(use_merge: bool, then_inner: i32, else_errors: i32) -> i32 = do\n  if !use_merge then else_errors\n  else merge_unknown_inner(then_inner, else_errors)\n  end\nend\n\nexport fn main() -> i32 = conditional_flat(true, 0, 5)'
  results.push(assert_eq_int('codegen invariant: if + else calls helper (flattened match shape) — 0 errors',
    check_error_count(codegen_invariant_if_else_flattened), 0))

  results.push(assert_eq_int('E6 partial application: let-bound thunk call — 0 errors',
    check_error_count(
      'fn add_numbers(left: i32, right: i32) -> i32 = left + right\nfn main() -> i32 = do\n  let bound = add_numbers(10, _)\n  bound(3)\nend'
    ), 0))

  results.push(assert_true('E6 bare underscore expression — error',
    check_error_count('fn main() -> i32 = _') > 0))

  const shared_node_decl = 'type Node = { name: string, value: i32 }\n'

  results.push(assert_eq_int('infer: flat_map on Shared<T> with member access — 0 errors',
    check_error_count(shared_node_decl +
      'fn f(nodes: [Shared<Node>]) -> [string] = nodes.flat_map(node => [node.name])'), 0))

  results.push(assert_eq_int('infer: any on Shared<T> with member access — 0 errors',
    check_error_count(shared_node_decl +
      'fn f(nodes: [Shared<Node>]) -> bool = nodes.any(node => node.value > 0)'), 0))

  results.push(assert_eq_int('infer: all on Shared<T> with member access — 0 errors',
    check_error_count(shared_node_decl +
      'fn f(nodes: [Shared<Node>]) -> bool = nodes.all(node => node.value > 0)'), 0))

  results.push(assert_eq_int('infer: none on Shared<T> with member access — 0 errors',
    check_error_count(shared_node_decl +
      'fn f(nodes: [Shared<Node>]) -> bool = nodes.none(node => node.value > 0)'), 0))

  results.push(assert_eq_int('infer: find on Shared<T> with member access — 0 errors',
    check_error_count(shared_node_decl +
      'type Option<T> = Some(T) | None\n' +
      'fn f(nodes: [Shared<Node>]) -> Option<Shared<Node>> = nodes.find(node => node.value > 0)'), 0))

  results.push(assert_eq_int('infer: sort_by on Shared<T> with member access — 0 errors',
    check_error_count(shared_node_decl +
      'fn f(nodes: [Shared<Node>]) -> [Shared<Node>] = nodes.sort_by(node => node.value)'), 0))

  results.push(assert_eq_int('infer: filter on Shared<T> with member access — 0 errors',
    check_error_count(shared_node_decl +
      'fn f(nodes: [Shared<Node>]) -> [Shared<Node>] = nodes.filter(node => node.value > 0)'), 0))

  results
end
