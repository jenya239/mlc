    check_error_count('type Unvalidated\ntype Validated\ntype Ast<Phase> = Ast { value: i32 }\nfn expect(ast: Ast<Validated>) -> i32 = 0\nfn make() -> Ast<Unvalidated> = do\n  let ast: Ast<Unvalidated> = Ast { value: 1 }\n  ast\nend\nfn wrong() -> i32 = expect(make())'), 1))

