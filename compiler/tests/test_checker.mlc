    check_error_count("fn f(x: i32, y: i32) -> string = `\${x}+\${y}`"), 0))
  results.push(assert_true('template: undefined var in interpolation - error',
    check_error_count("fn f() -> string = `\${undefined_var}`") > 0))

  results.push(assert_eq_int('let-else: PatCtor without else - 1 error',
