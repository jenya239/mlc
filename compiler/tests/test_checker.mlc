// Unit tests for the checker (check function).

import { TestResult, assert_eq_int, assert_eq_str, assert_true, assert_diagnostic_at } from "./test_runner"
import { tokenize } from "../lexer"
import { parse_program, parse_program_with_source_path } from "../parser/decls"
import { check, check_with_context } from "../checker/check"

fn check_error_count(source: string) -> i32 =
  match check(parse_program(tokenize(source).tokens)) {
    Ok(_)    => 0,
    Err(errs) => errs.length()
  }

fn check_with_context_error_count(entry_source: string, full_source: string) -> i32 =
  match check_with_context(parse_program(tokenize(entry_source).tokens), parse_program(tokenize(full_source).tokens)) {
    Ok(_) => 0,
    Err(error_list) => error_list.length()
  }

fn first_checker_error_line(source: string) -> string =
  match check(parse_program(tokenize(source).tokens)) {
    Err(error_lines) => if error_lines.length() > 0 then error_lines[0] else "" end,
    Ok(_) => ""
  }

fn first_checker_error_line_with_path(source: string, source_path: string) -> string =
  match check(parse_program_with_source_path(tokenize(source).tokens, source_path)) {
    Err(error_lines) => if error_lines.length() > 0 then error_lines[0] else "" end,
    Ok(_) => ""
  }

fn checker_first_error_contains_nonfunction_i32(program_source: string) -> bool = do
  const line = first_checker_error_line(program_source)
  line.contains("called value is not a function") && line.contains("(got i32)")
end

export fn checker_tests() -> [TestResult] = do
  let results: [TestResult] = []

  results.push(assert_eq_int("empty program - 0 errors",
    check_error_count(""), 0))

  results.push(assert_eq_int("fn returning literal - 0 errors",
    check_error_count("fn f() -> i32 = 42"), 0))

  results.push(assert_true("fn return type mismatch — error",
    first_checker_error_line("fn f() -> i32 = \"hello\"").contains("return type: expected i32, got string")))

  results.push(assert_eq_int("fn return type matches — 0 errors",
    check_error_count("fn f() -> string = \"hello\""), 0))

  results.push(assert_eq_int("fn generic return T — 0 errors",
    check_error_count("fn id<T>(x: T) -> T = x"), 0))

  results.push(assert_true("integer literal called like function - diagnostic names type",
    checker_first_error_contains_nonfunction_i32("fn f() -> i32 = 42()")))

  results.push(assert_eq_int("fn using its own param - 0 errors",
    check_error_count("fn f(x: i32) -> i32 = x"), 0))

  results.push(assert_eq_int("fn calling another fn - 0 errors",
    check_error_count("fn add(x: i32, y: i32) -> i32 = x + y\nfn main() -> i32 = add(1, 2)"), 0))

  results.push(assert_true("undefined name - at least 1 error",
    check_error_count("fn f() -> i32 = undefined_name") > 0))

  results.push(assert_diagnostic_at(
    "undefined ident: line and column (single line body)",
    first_checker_error_line("fn f() -> i32 = badident"),
    1,
    17,
    "undefined: badident"))

  results.push(assert_diagnostic_at(
    "undefined ident: line and column (next line, indented)",
    first_checker_error_line("fn f() -> i32 =\n  badident"),
    2,
    3,
    "undefined: badident"))

  results.push(assert_eq_str(
    "undefined ident: diagnostic includes source path",
    first_checker_error_line_with_path("fn f() -> i32 = badident", "unit.mlc"),
    "unit.mlc:1:17: error: undefined: badident"))

  results.push(assert_eq_int("type decl with variants - 0 errors",
    check_error_count("type Color = Red | Green | Blue"), 0))

  results.push(assert_eq_int("fn returning bool - 0 errors",
    check_error_count("fn f() -> bool = true"), 0))

  results.push(assert_eq_int("fn with const binding - 0 errors",
    check_error_count("fn f() -> i32 = do\n  const x = 1\n  x\nend"), 0))

  results.push(assert_eq_int("let const compile-time binding - 0 errors",
    check_error_count("fn f() -> i32 = do\n  let const c = 42\n  c\nend"), 0))

  results.push(assert_eq_int("nested generic in array type annotation - 0 errors",
    check_error_count("type Result<T, E> = Ok(T) | Err(E)\nfn f() -> i32 = do\n  let items: [Result<i32, string>] = []\n  0\nend"), 0))

  results.push(assert_eq_int("record update expression - 0 errors",
    check_error_count("type Point = { x: i32, y: i32 }\nfn f(p: Point) -> Point = Point { ...p, x: 10 }"), 0))

  results.push(assert_eq_int("trait bound: param method call - 0 errors",
    check_error_count("type Display { fn to_string(self: Self) -> string }\nfn show<T: Display>(x: T) -> string = x.to_string()"), 0))

  results.push(assert_eq_int("trait bound: call with implementing type — 0 errors",
    check_error_count("type Display { fn show(self: Self) -> string }\nextend i32 : Display { fn show(self: i32) -> string = self.to_string() }\nfn print_it<T: Display>(x: T) -> string = x.show()\nfn main() -> string = print_it(42)"), 0))

  results.push(assert_true("trait bound: call with non-implementing type — error",
    first_checker_error_line("type Display { fn show(self: Self) -> string }\nfn print_it<T: Display>(x: T) -> string = x.show()\nfn main() -> string = print_it(42)").contains("does not implement Display")))

  results.push(assert_diagnostic_at(
    "record update: unknown field — position on field value",
    first_checker_error_line("type Point = { x: i32, y: i32 }\nfn f(p: Point) -> Point = Point { ...p, z: 1 }"),
    2,
    44,
    "undefined field: z on Point"))

  results.push(assert_diagnostic_at(
    "record constructor: unknown field — position on field value",
    first_checker_error_line("type Point = { x: i32, y: i32 }\nfn f() -> Point = Point { x: 1, z: 1 }"),
    2,
    36,
    "undefined field: z on Point"))

  results.push(assert_diagnostic_at(
    "record constructor: field type mismatch — position on field value",
    first_checker_error_line("type Point = { x: i32, y: i32 }\nfn f() -> Point = Point { x: \"wrong\", y: 0 }"),
    2,
    30,
    "field x: expected i32, got string"))

  results.push(assert_eq_int("record constructor: correct field types — 0 errors",
    check_error_count("type Point = { x: i32, y: i32 }\nfn f() -> Point = Point { x: 1, y: 2 }"), 0))

  results.push(assert_eq_int("multiline string literal in source — 0 checker errors",
    check_error_count("fn f() -> string = \"hello\nworld\""), 0))

  results.push(assert_eq_int("string with escaped newline in source — 0 checker errors",
    check_error_count("fn f() -> string = \"a\\nb\""), 0))

  results.push(assert_true("two undefined names - at least 1 error",
    check_error_count("fn f() -> i32 = foo + bar") > 0))

  results.push(assert_eq_int("builtin print - 0 errors",
    check_error_count("fn f() -> i32 = do\n  print(\"hi\")\n  0\nend"), 0))

  results.push(assert_true("builtin print wrong arity - error",
    check_error_count("fn f() -> i32 = do\n  print()\n  0\nend") > 0))

  results.push(assert_true("builtin print wrong argument type - error",
    check_error_count("fn f() -> i32 = do\n  print(42)\n  0\nend") > 0))

  results.push(assert_true("monomorphic call wrong argument type - error",
    check_error_count("fn g(x: i32) -> i32 = x\nfn f() -> i32 = g(\"a\")") > 0))

  results.push(assert_true("tuple variant constructor wrong payload type - error",
    check_error_count("type Msg = Num(i32) | Empty\nfn f() -> Msg = Num(\"x\")") > 0))

  results.push(assert_eq_int("fn with type param - 0 errors",
    check_error_count("fn id<T>(x: T) -> T = x"), 0))

  results.push(assert_eq_int("fn with type param and bound - 0 errors",
    check_error_count("type Display { fn to_string(self: Self) -> string }\nfn id<T: Display>(x: T) -> T = x"), 0))

  results.push(assert_eq_int("call generic fn - 0 errors",
    check_error_count("fn id<T>(x: T) -> T = x\nfn f() -> i32 = id(42)"), 0))

  results.push(assert_true("generic fn two params same T - conflicting args error",
    check_error_count("fn pair<T>(a: T, b: T) -> T = a\nfn f() -> i32 = pair(1, \"x\")") > 0))

  results.push(assert_eq_int("trait decl + extend impl - 0 errors",
    check_error_count("type Display { fn to_string(self: Self) -> string }\ntype Color = Red | Green\nextend Color : Display { fn to_string(self: Color) -> string = \"Red\" }"), 0))

  results.push(assert_eq_int("method call on param - 0 errors",
    check_error_count("fn f(c: string) -> string = c.to_string()"), 0))

  results.push(assert_eq_int("lambda expr - 0 errors",
    check_error_count("fn f() -> i32 = do\n  const g = x => x + 1\n  g(41)\nend"), 0))

  results.push(assert_eq_int("typed lambda param — 0 errors",
    check_error_count("fn f() -> i32 = do\n  const g = (x: i32) => x + 1\n  g(41)\nend"), 0))

  results.push(assert_eq_int("typed lambda two params — 0 errors",
    check_error_count("fn f() -> i32 = do\n  const g = (x: i32, y: i32) => x + y\n  g(1, 2)\nend"), 0))

  results.push(assert_eq_int("Ok/Err/Result as known globals - 0 errors",
    check_error_count("fn f() -> i32 = do\n  const r = Ok(42)\n  0\nend"), 0))

  results.push(assert_eq_int("Err constructor - 0 errors",
    check_error_count("fn f() -> i32 = do\n  const e = Err(\"oops\")\n  0\nend"), 0))

  results.push(assert_eq_int("Result return type annotation - 0 errors",
    check_error_count("type Result<T, E> = Ok(T) | Err(E)\nfn f() -> Result<i32, string> = Ok(42)"), 0))

  results.push(assert_eq_int("block: let then use binding - 0 errors",
    check_error_count("fn f() -> i32 = do\n  let x = 10\n  x + 1\nend"), 0))

  results.push(assert_eq_int("for-in: loop variable visible in body - 0 errors",
    check_error_count("fn sum(items: [i32]) -> i32 = do\n  let mut total = 0\n  for element in items do\n    total = total + element\n  end\n  total\nend"), 0))

  results.push(assert_eq_int("A3: let (a, b) = (1, 2) - 0 errors",
    check_error_count("fn f() -> i32 = do\n  let (a, b) = (1, 2)\n  a + b\nend"), 0))

  results.push(assert_eq_int("A3: let (a, b, c) = (1, 2, 3) - 0 errors",
    check_error_count("fn f() -> i32 = do\n  let (a, b, c) = (1, 2, 3)\n  a + b + c\nend"), 0))

  results.push(assert_eq_int("A3: let {x, y} = record - 0 errors",
    check_error_count("type Point = { x: i32, y: i32 }\nfn f() -> i32 = do\n  let p = Point { x: 1, y: 2 }\n  let { x, y } = p\n  x + y\nend"), 0))

  results.push(assert_eq_int("A3: let [a, ...b] = array - 0 errors",
    check_error_count("fn f() -> i32 = do\n  let a: [i32] = [1, 2, 3]\n  let [u, ...v] = a\n  u\nend"), 0))

  results.push(assert_eq_int("A3: let Ok(x) = Ok - 0 errors",
    check_error_count("type Result<T, E> = Ok(T) | Err(E)\nfn f() -> i32 = do\n  let o: Result<i32, string> = Ok(1)\n  let Ok(n) = o else return 0 end\n  n\nend"), 0))

  results.push(assert_eq_int("A4: default param call with omitted args - 0 errors",
    check_error_count("fn f(a: i32 = 1) -> i32 = a\nfn g() -> i32 = f()"), 0))

  results.push(assert_eq_int("A4: two defaults call with one arg - 0 errors",
    check_error_count("fn f(a: i32, b: i32 = 2, c: i32 = 3) -> i32 = a + b + c\nfn g() -> i32 = f(0)"), 0))

  results.push(assert_true("A4: default not before required",
    first_checker_error_line("fn f(a: i32 = 1, b: i32) -> i32 = b").contains("parameter defaults must be trailing")))

  results.push(assert_true("A4: generic function default rejected",
    first_checker_error_line("fn f<T>(a: T = 1) -> T = a").contains("default parameters are not allowed on generic")))

  results.push(assert_true("A4: non-literal default rejected",
    first_checker_error_line("fn f(a: i32 = 1 + 1) -> i32 = a").contains("literal")))

  results.push(assert_true("A4: too many call arguments with defaults",
    first_checker_error_line("fn f(a: i32 = 1) -> i32 = a\nfn g() -> i32 = f(1, 2)").contains("expected between")))

  results.push(assert_true("A4: extern with default rejected",
    first_checker_error_line("extern fn f(a: i32 = 1) -> i32").contains("extern")))

  results.push(assert_true("for-in: iterator must be an array",
    first_checker_error_line("fn g() -> i32 = do\n  for x in 42 do\n    0\n  end\n  0\nend").contains("for loop range must be an array")))

  results.push(assert_true("index: subscript must be i32",
    first_checker_error_line("fn f(items: [i32]) -> i32 = items[\"0\"]").contains("array index must be i32")))

  results.push(assert_eq_int("check_with_context: entry sees helper from full program - 0 errors",
    check_with_context_error_count("fn main() -> i32 = helper()", "fn helper() -> i32 = 1\nfn main() -> i32 = helper()"), 0))

  results.push(assert_eq_int("match: constructor arm binds payload - 0 errors",
    check_error_count("type Answer = Yes(i32) | No\nfn value(answer: Answer) -> i32 = match answer | Yes(n) => n | No => 0\n"), 0))

  results.push(assert_true("match: arm result type must match first arm",
    first_checker_error_line("fn f(flag: bool) -> i32 = match flag | true => 1 | false => \"no\"").contains("match arm result type")))

  results.push(assert_true("if: then and else branch types must match",
    first_checker_error_line("fn f(flag: bool) -> i32 = if flag then 1 else \"no\" end").contains("if branch types differ")))

  results.push(assert_diagnostic_at(
    "undefined record field: line and column on field access",
    first_checker_error_line("type Point = { x: i32, y: i32 }\nfn f(p: Point) -> i32 = p.z"),
    2,
    26,
    "undefined field: z on Point"))

  results.push(assert_eq_str(
    "undefined record field: message text",
    first_checker_error_line("type R = { a: i32 }\nfn f(x: R) -> i32 = x.missing"),
    "2:22: error: undefined field: missing on R"))

  results.push(assert_true("infer: string + i32 is an error",
    check_error_count("fn f() -> i32 = \"a\" + 1") > 0))

  results.push(assert_true("infer: i32 + string is an error",
    check_error_count("fn f() -> i32 = 1 + \"a\"") > 0))

  results.push(assert_true("infer: string with - is an error",
    check_error_count("fn f() -> string = \"a\" - \"b\"") > 0))

  results.push(assert_eq_int("infer: string + string still ok",
    check_error_count("fn f() -> string = \"a\" + \"b\""), 0))

  results.push(assert_true("infer: ! on i32 is an error",
    check_error_count("fn f() -> bool = !42") > 0))

  results.push(assert_eq_int("infer: ! on bool ok",
    check_error_count("fn f() -> bool = !false"), 0))

  results.push(assert_true("infer: i32 == bool is an error",
    check_error_count("fn f() -> bool = 1 == true") > 0))

  results.push(assert_true("infer: i32 < string is an error",
    check_error_count("fn f() -> bool = 1 < \"a\"") > 0))

  results.push(assert_true("infer: bool && i32 is an error",
    check_error_count("fn f() -> bool = true && 1") > 0))

  results.push(assert_eq_int("infer: i32 ordering ok",
    check_error_count("fn f() -> bool = 1 < 2"), 0))

  results.push(assert_eq_int("infer: string ordering ok",
    check_error_count("fn f() -> bool = \"a\" <= \"b\""), 0))

  results.push(assert_eq_int("infer: bool && ok",
    check_error_count("fn f() -> bool = true && false"), 0))

  results.push(assert_diagnostic_at(
    "infer: unary minus on string",
    first_checker_error_line("fn f() -> i32 = -\"x\""),
    1,
    17,
    "unary - expects i32"))

  results.push(assert_diagnostic_at(
    "infer: to_i on non-string receiver",
    first_checker_error_line("fn f() -> i32 = 1.to_i()"),
    1,
    18,
    "method to_i expects a string receiver"))

  results.push(assert_diagnostic_at(
    "infer: join on non-array receiver",
    first_checker_error_line("fn f() -> string = \"a\".join(\",\")"),
    1,
    23,
    "method join expects an array receiver"))

  results.push(assert_diagnostic_at(
    "infer: push on string receiver",
    first_checker_error_line("fn f() -> i32 = \"a\".push(1)"),
    1,
    20,
    "method push expects an array receiver"))

  results.push(assert_diagnostic_at(
    "infer: set on string receiver",
    first_checker_error_line("fn f() -> i32 = \"a\".set(0, 1)"),
    1,
    20,
    "method set expects an array or Map receiver"))

  results.push(assert_diagnostic_at(
    "infer: get on non-Map receiver",
    first_checker_error_line("fn f() -> i32 = 1.get(\"k\")"),
    1,
    18,
    "method get expects a Map receiver"))

  results.push(assert_eq_int("infer: get and set on Map ok",
    check_error_count("fn f(m: Map<string, i32>) -> i32 = do\n  m.set(\"k\", 1)\n  m.get(\"k\")\nend"), 0))

  results.push(assert_diagnostic_at(
    "infer: builtin map get wrong arity",
    first_checker_error_line("fn f(m: Map<string, i32>) -> i32 = m.get()"),
    1,
    37,
    "expected 1 arguments, got 0"))

  results.push(assert_diagnostic_at(
    "infer: builtin map set wrong arity",
    first_checker_error_line("fn f(m: Map<string, i32>) -> i32 = m.set(\"k\")"),
    1,
    37,
    "expected 2 arguments, got 1"))

  results.push(assert_diagnostic_at(
    "infer: builtin array push wrong arity",
    first_checker_error_line("fn f(a: [i32]) -> i32 = a.push()"),
    1,
    26,
    "expected 1 arguments, got 0"))

  results.push(assert_diagnostic_at(
    "infer: user function call too few arguments — position on ( of call",
    first_checker_error_line("fn f(x: i32) -> i32 = x\nfn g() -> i32 = f()"),
    2,
    18,
    "expected 1 arguments, got 0"))

  results.push(assert_diagnostic_at(
    "infer: user function call too many arguments — position on ( of call",
    first_checker_error_line("fn f(x: i32) -> i32 = x\nfn g() -> i32 = f(1, 2)"),
    2,
    18,
    "expected 1 arguments, got 2"))

  results.push(assert_diagnostic_at(
    "infer: user function call argument type mismatch — position on argument",
    first_checker_error_line("fn f(x: i32) -> i32 = x\nfn g() -> i32 = f(\"str\")"),
    2,
    19,
    "argument expects i32, got string"))

  results.push(assert_diagnostic_at(
    "infer: called value is not a function — position on ( of call",
    first_checker_error_line("fn f() -> i32 = 42()"),
    1,
    19,
    "called value is not a function (got i32)"))

  results.push(assert_diagnostic_at(
    "infer: field access on i32 — position on dot",
    first_checker_error_line("type P = { x: i32 }\nfn f(p: i32) -> i32 = p.x"),
    2,
    24,
    "field access on value without record fields: i32"))

  results.push(assert_diagnostic_at(
    "infer: has on non-Map receiver (i32)",
    first_checker_error_line("fn f() -> bool = 1.has(\"k\")"),
    1,
    19,
    "method has expects a Map receiver"))

  results.push(assert_diagnostic_at(
    "infer: has on sum type is an error",
    first_checker_error_line("type Hue = Red | Green\nfn f(x: Hue) -> bool = x.has(\"k\")"),
    2,
    25,
    "method has expects a Map receiver"))

  results.push(assert_eq_int("infer: has on Map ok",
    check_error_count("fn f(m: Map<string, i32>) -> bool = m.has(\"k\")"), 0))

  results.push(assert_eq_int("infer: ref mut Map uses inner type for builtins",
    check_error_count("fn f(cache: ref mut Map<string, i32>) -> bool = cache.has(\"k\")"), 0))

  // --- if branch type mismatch -----------------------------------------------

  results.push(assert_diagnostic_at(
    "infer: if branch type mismatch — position on else expression",
    first_checker_error_line("fn f() -> i32 = if true then 1 else \"x\" end"),
    1,
    37,
    "if branch types differ"))

  results.push(assert_eq_int("infer: if branch same type — 0 errors",
    check_error_count("fn f() -> i32 = if true then 1 else 2 end"), 0))

  // --- match arm type mismatch -----------------------------------------------

  results.push(assert_diagnostic_at(
    "infer: match arm type mismatch — position on mismatched arm body",
    first_checker_error_line("fn f() -> i32 = match 1 { _ => 0, _ => \"x\" }"),
    1,
    40,
    "match arm result type"))

  results.push(assert_eq_int("infer: match arms same type — 0 errors",
    check_error_count("fn f() -> i32 = match 1 { _ => 0, _ => 1 }"), 0))

  // --- for loop range type ---------------------------------------------------

  results.push(assert_diagnostic_at(
    "infer: for loop range not array — position on iterator",
    first_checker_error_line("fn f() -> i32 = do for x in 42 do end; 0 end"),
    1,
    29,
    "for loop range must be an array"))

  results.push(assert_eq_int("infer: for loop range array — 0 errors",
    check_error_count("fn f(a: [i32]) -> i32 = do for x in a do end; 0 end"), 0))

  // --- index diagnostics -----------------------------------------------------

  results.push(assert_diagnostic_at(
    "infer: index on non-array — position on bracket",
    first_checker_error_line("fn f() -> i32 = 42[0]"),
    1,
    19,
    "indexing requires an array"))

  results.push(assert_diagnostic_at(
    "infer: index with non-i32 — position on bracket",
    first_checker_error_line("fn f(a: [i32]) -> i32 = a[\"key\"]"),
    1,
    26,
    "array index must be i32"))

  results.push(assert_eq_int("infer: valid array index — 0 errors",
    check_error_count("fn f(a: [i32]) -> i32 = a[0]"), 0))

  // --- binary operator type mismatch -----------------------------------------

  results.push(assert_true("infer: binary + type mismatch produces error",
    first_checker_error_line("fn f() -> i32 = 1 + true").contains("incompatible operand types for +")))

  results.push(assert_true("infer: binary == type mismatch produces error",
    first_checker_error_line("fn f() -> bool = 1 == \"x\"").contains("incompatible types for ==")))

  results.push(assert_true("infer: binary < on bool produces error",
    first_checker_error_line("fn f() -> bool = true < false").contains("ordering requires i32 or string")))

  results.push(assert_eq_int("infer: binary + string concat — 0 errors",
    check_error_count("fn f() -> string = \"a\" + \"b\""), 0))

  results.push(assert_true("mutation: assign to immutable binding produces error",
    first_checker_error_line("fn f() -> i32 = do let x = 1; x = 2; x end").contains("cannot assign to immutable binding: x")))

  results.push(assert_eq_int("mutation: assign to let mut binding — 0 errors",
    check_error_count("fn f() -> i32 = do let mut x = 1; x = 2; x end"), 0))

  results.push(assert_true("question: ? on non-Result produces error",
    first_checker_error_line("fn f() -> i32 = do let x: i32 = 42; x? end").contains("? operator requires a Result type")))

  // --- Result / Option combinators (A2) --------------------------------------

  results.push(assert_eq_int("infer: Result map — 0 errors",
    check_error_count("type Result<T, E> = Ok(T) | Err(E)\nfn f() -> Result<i32, string> = Ok(1).map(x => x + 1)"), 0))

  results.push(assert_eq_int("infer: Option map — 0 errors",
    check_error_count("type Option<T> = Some(T) | None\nfn f() -> Option<i32> = Some(1).map(x => x * 2)"), 0))

  // --- array higher-order methods --------------------------------------------

  results.push(assert_eq_int("infer: array map — 0 errors",
    check_error_count("fn f(a: [i32]) -> [i32] = a.map(x => x + 1)"), 0))

  results.push(assert_eq_int("infer: array filter — 0 errors",
    check_error_count("fn f(a: [i32]) -> [i32] = a.filter(x => x > 0)"), 0))

  results.push(assert_eq_int("infer: array fold — 0 errors",
    check_error_count("fn f(a: [i32]) -> i32 = a.fold(0, (s, x) => s + x)"), 0))

  results.push(assert_eq_int("infer: array flat_map — 0 errors",
    check_error_count("fn f(a: [i32]) -> [i32] = a.flat_map(x => [x])"), 0))

  results.push(assert_eq_int("infer: array any — 0 errors",
    check_error_count("fn f(a: [i32]) -> bool = a.any(x => x > 0)"), 0))

  results.push(assert_true("infer: array map on non-array receiver",
    first_checker_error_line("fn f() -> [i32] = 42.map(x => x)").contains("expects an array receiver")))

  results.push(assert_true("infer: array map wrong arity",
    first_checker_error_line("fn f(a: [i32]) -> [i32] = a.map()").contains("expected 1 arguments")))

  results.push(assert_true("infer: filter predicate must return bool",
    first_checker_error_line("fn f(a: [i32]) -> [i32] = a.filter(x => x)").contains("expects a predicate returning bool")))

  results.push(assert_true("infer: fold step return must match accumulator",
    first_checker_error_line("fn f(a: [i32]) -> i32 = a.fold(0, (s, x) => \"bad\")").contains("fold step function must return")))

  results.push(assert_eq_int("infer: array find — 0 errors",
    check_error_count(
      "type Option<T> = Some(T) | None\nfn f(a: [i32]) -> Option<i32> = a.find(x => x > 0)"), 0))

  results.push(assert_true("infer: find Option element must match declared return",
    first_checker_error_line(
      "type Option<T> = Some(T) | None\nfn f(a: [string]) -> Option<i32> = a.find(x => false)").contains(
      "return type: expected")))

  results.push(assert_eq_int("infer: array zip — 0 errors",
    check_error_count("fn f(a: [i32], b: [string]) -> i32 = a.zip(b).length()"), 0))

  results.push(assert_eq_int("infer: array enumerate — 0 errors",
    check_error_count("fn f(a: [i32]) -> i32 = a.enumerate().length()"), 0))

  results.push(assert_eq_int("infer: array join strings — 0 errors",
    check_error_count("fn f(a: [string]) -> string = a.join(\",\")"), 0))

  results.push(assert_eq_int("infer: array sum — 0 errors",
    check_error_count("fn f(a: [i32]) -> i32 = a.sum()"), 0))

  results.push(assert_eq_int("infer: array flat — 0 errors",
    check_error_count("fn f(a: [[i32]]) -> [i32] = a.flat()"), 0))

  results.push(assert_eq_int("infer: array group_by — 0 errors",
    check_error_count("fn f(a: [i32]) -> i32 = a.group_by(x => x % 2).length()"), 0))

  results.push(assert_true("infer: sum on non-i32 array",
    first_checker_error_line("fn f(a: [string]) -> i32 = a.sum()").contains("sum expects i32 array")))

  results.push(assert_true("infer: flat on non-nested array",
    first_checker_error_line("fn f(a: [i32]) -> [i32] = a.flat()").contains("flat expects an array of arrays")))

  results.push(assert_eq_int("derive Display: to_string on record — 0 errors",
    check_error_count("type Point = { x: i32, y: i32 } derive { Display }\nfn f(p: Point) -> string = p.to_string()"), 0))

  results.push(assert_eq_int("derive Eq: == on record — 0 errors",
    check_error_count("type Point = { x: i32, y: i32 } derive { Eq }\nfn f(a: Point, b: Point) -> bool = a == b"), 0))

  results.push(assert_eq_int("derive Display on sum type — 0 errors",
    check_error_count("type Color = Red | Green | Blue derive { Display }\nfn f(c: Color) -> string = c.to_string()"), 0))

  results.push(assert_true("infer: zip expects array argument",
    first_checker_error_line("fn f(a: [i32]) -> i32 = a.zip(1).length()").contains("expects an array argument")))

  // Template literal checker tests
  results.push(assert_eq_int("template: plain string - 0 errors",
    check_error_count("fn f() -> string = `hello`"), 0))
  results.push(assert_eq_int("template: i32 interpolation - 0 errors",
    check_error_count("fn f(x: i32) -> string = `val \${x}`"), 0))
  results.push(assert_eq_int("template: string interpolation - 0 errors",
    check_error_count("fn f(s: string) -> string = `hello \${s}`"), 0))
  results.push(assert_eq_int("template: bool interpolation - 0 errors",
    check_error_count("fn f(b: bool) -> string = `\${b}`"), 0))
  results.push(assert_eq_int("template: multi interpolation - 0 errors",
    check_error_count("fn f(x: i32, y: i32) -> string = `\${x}+\${y}`"), 0))
  results.push(assert_true("template: undefined var in interpolation - error",
    check_error_count("fn f() -> string = `\${undefined_var}`") > 0))

  results.push(assert_eq_int("let-else: PatCtor without else - 1 error",
    check_error_count("type Opt = Some(i32) | None\nfn f(o: Opt) -> i32 = do\n  let Some(v) = o\n  v\nend"), 1))

  results.push(assert_eq_int("let-else: PatCtor with else - 0 errors",
    check_error_count("type Opt = Some(i32) | None\nfn f(o: Opt) -> i32 = do\n  let Some(v) = o else return 0 end\n  v\nend"), 0))

  results.push(assert_eq_int("phantom type: declaration — 0 errors",
    check_error_count("type Unvalidated\ntype Ast<Phase> = Ast { value: i32 }"), 0))

  results.push(assert_eq_int("phantom type: fn with phantom param annotation — 0 errors",
    check_error_count("type Unvalidated\ntype Ast<Phase> = Ast { value: i32 }\nfn use_ast(ast: Ast<Unvalidated>) -> i32 = ast.value"), 0))

  results.push(assert_eq_int("phantom type: wrong phantom arg at call site — 1 error",
    check_error_count("type Unvalidated\ntype Validated\ntype Ast<Phase> = Ast { value: i32 }\nfn expect(ast: Ast<Validated>) -> i32 = 0\nfn make() -> Ast<Unvalidated> = do\n  let ast: Ast<Unvalidated> = Ast { value: 1 }\n  ast\nend\nfn wrong() -> i32 = expect(make())"), 1))

  results.push(assert_eq_int("private ctor: declaration — 0 errors",
    check_error_count("type Email = private Email { raw: string }"), 0))

  results.push(assert_eq_int("private ctor: construction outside extend — 1 error",
    check_error_count("type Email = private Email { raw: string }\nfn f() -> Email = Email { raw: \"x\" }"), 1))

  results.push(assert_eq_int("private ctor: construction inside extend — 0 errors",
    check_error_count("type Email = private Email { raw: string }\nextend Email { fn make(s: string) -> Email = Email { raw: s } }"), 0))

  results.push(assert_eq_int("private ctor: matching outside extend allowed — 0 errors",
    check_error_count("type Email = private Email { raw: string }\nfn get_raw(e: Email) -> string = match e { Email { raw } => raw }"), 0))

  results.push(assert_eq_int("named args: all-named call — 0 errors",
    check_error_count("fn f(x: i32, y: i32) -> i32 = x + y\nfn g() -> i32 = f(x: 1, y: 2)"), 0))

  results.push(assert_eq_int("named args: reverse order — 0 errors",
    check_error_count("fn f(x: i32, y: i32) -> i32 = x + y\nfn g() -> i32 = f(y: 2, x: 1)"), 0))

  results.push(assert_eq_int("named args: mixed positional + named — 0 errors",
    check_error_count("fn f(x: i32, y: i32, z: i32) -> i32 = x\nfn g() -> i32 = f(1, y: 2, z: 3)"), 0))

  results.push(assert_true("named args: unknown param name — at least 1 error",
    check_error_count("fn f(x: i32) -> i32 = x\nfn g() -> i32 = f(bad: 1)") > 0))

  results.push(assert_true("named args: type mismatch in named arg",
    check_error_count("fn f(x: i32) -> i32 = x\nfn g() -> i32 = f(x: \"str\")") > 0))

  results.push(assert_eq_int("c4: i64 annotation - 0 errors",
    check_error_count("fn f(x: i64) -> i64 = x"), 0))

  results.push(assert_eq_int("c4: f64 annotation - 0 errors",
    check_error_count("fn f(x: f64) -> f64 = x"), 0))

  results.push(assert_eq_int("c4: u8 annotation - 0 errors",
    check_error_count("fn f(x: u8) -> u8 = x"), 0))

  results.push(assert_eq_int("c4: usize annotation - 0 errors",
    check_error_count("fn f(x: usize) -> usize = x"), 0))

  results.push(assert_eq_int("c4: char annotation - 0 errors",
    check_error_count("fn f(x: char) -> char = x"), 0))

  results.push(assert_eq_int("c4: i64 literal - 0 errors",
    check_error_count("fn f() -> i64 = 42i64"), 0))

  results.push(assert_eq_int("c4: char literal - 0 errors",
    check_error_count("fn f() -> char = 'a'"), 0))

  results.push(assert_eq_int("c4: i64 arithmetic - 0 errors",
    check_error_count("fn f(x: i64, y: i64) -> i64 = x + y"), 0))

  results.push(assert_eq_int("c4: char arithmetic - 0 errors",
    check_error_count("fn f(x: char, y: char) -> char = x + y"), 0))

  results.push(assert_eq_int("c4: f64 arithmetic - 0 errors",
    check_error_count("fn f(x: f64, y: f64) -> f64 = x + y"), 0))

  results.push(assert_true("c4: type mismatch i64 vs i32 - 1+ errors",
    check_error_count("fn f(x: i32) -> i64 = x") > 0))

  results
end
