    19,
    'called value is not a function (got i32)',
    'E002'))

  results.push(assert_diagnostic_at(
    'infer: field access on i32 — position on dot',
    first_checker_error_line('type P = { x: i32 }\nfn f(p: i32) -> i32 = p.x'),
    2,
    24,
    'field access on value without record fields: i32'))

  results.push(assert_checker_diagnostic(
    'negative E027: has on i32 exact',
    'fn f() -> bool = 1.has("k")',
    'error[E027]: method has expects a Map receiver, got i32\n  --> 1:19'))

  results.push(assert_checker_diagnostic(
    'negative E021: push on i32 exact',
    'fn f() -> unit = do let mut xs: i32 = 1; xs.push(2) end',
    'error[E021]: method push expects an array receiver, got i32\n  --> 1:44'))

  results.push(assert_diagnostic_at_with_code(
    'infer: has on sum type is an error',
    first_checker_error_line('type Hue = Red | Green\nfn f(x: Hue) -> bool = x.has("k")'),
    2,
    25,
    'method has expects a Map receiver',
    'E027'))

  results.push(assert_eq_int('infer: has on Map ok',
    check_error_count('fn f(m: Map<string, i32>) -> bool = m.has("k")'), 0))

  results.push(assert_eq_int('infer: ref mut Map uses inner type for builtins',
    check_error_count('fn f(cache: ref mut Map<string, i32>) -> bool = cache.has("k")'), 0))

  // --- if branch type mismatch -----------------------------------------------

  results.push(assert_diagnostic_at(
