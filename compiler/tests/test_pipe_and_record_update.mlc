// Tests for pipe operator desugaring and record update codegen.

import { TestResult, assert_eq_int, assert_eq_str } from "./test_runner"
import { gen_expr } from "../codegen/eval"
import { create_codegen_context } from "../codegen/context"
import { pipe_desugar } from "../parser/exprs"
import { tokenize } from "../lexer"
import { Program, DeclType, VarRecord, FieldDef, TyI32, Expr, ExprIdent, ExprCall, ExprRecordUpdate, FieldVal, ExprInt, span_unknown } from "../ast"

export fn pipe_and_record_update_tests() -> [TestResult] = do
  let results: [TestResult] = []
  const empty_prog = Program { decls: [] }
  const ctx = create_codegen_context(empty_prog)

  // -- Pipe operator desugaring ---------------------------------------------

  const left_expr = Shared.new(ExprIdent("x", span_unknown()))
  const right_fn   = Shared.new(ExprIdent("double", span_unknown()))

  const plain_pipe = pipe_desugar(left_expr, right_fn)
  results.push(assert_eq_str("pipe x |> double - double_(x)",
    gen_expr(plain_pipe, ctx),
    "double_(x)"))

  const right_call_args: [Shared<Expr>] = [Shared.new(ExprInt(5, span_unknown()))]
  const right_call = Shared.new(ExprCall(Shared.new(ExprIdent("add", span_unknown())), right_call_args, span_unknown()))
  const partial_pipe = pipe_desugar(left_expr, right_call)
  results.push(assert_eq_str("pipe x |> add(5) - add(x, 5)",
    gen_expr(partial_pipe, ctx),
    "add(x, 5)"))

  const right_multi_args: [Shared<Expr>] = [Shared.new(ExprInt(3, span_unknown())), Shared.new(ExprInt(4, span_unknown()))]
  const right_multi_call = Shared.new(ExprCall(Shared.new(ExprIdent("clamp", span_unknown())), right_multi_args, span_unknown()))
  const multi_partial_pipe = pipe_desugar(left_expr, right_multi_call)
  results.push(assert_eq_str("pipe x |> clamp(3, 4) - clamp(x, 3, 4)",
    gen_expr(multi_partial_pipe, ctx),
    "clamp(x, 3, 4)"))

  // -- Record update codegen ------------------------------------------------

  const point_decl = Shared.new(DeclType("Point", [], [Shared.new(VarRecord("Point", [
    Shared.new(FieldDef { name: "x", typ: Shared.new(TyI32) }),
    Shared.new(FieldDef { name: "y", typ: Shared.new(TyI32) })
  ]))]))
  const point_prog = Program { decls: [point_decl] }
  const ctx_point = create_codegen_context(point_prog)

  const override_fields: [Shared<FieldVal>] = [
    Shared.new(FieldVal { name: "x", val: Shared.new(ExprInt(10, span_unknown())) })
  ]
  const base_expr = Shared.new(ExprIdent("p", span_unknown()))
  const update_expr = Shared.new(ExprRecordUpdate("Point", base_expr, override_fields, span_unknown()))
  results.push(assert_eq_str("Point { ...p, x: 10 } - Point{10, p.y}",
    gen_expr(update_expr, ctx_point),
    "Point{10, p.y}"))

  const two_overrides: [Shared<FieldVal>] = [
    Shared.new(FieldVal { name: "x", val: Shared.new(ExprInt(0, span_unknown())) }),
    Shared.new(FieldVal { name: "y", val: Shared.new(ExprInt(0, span_unknown())) })
  ]
  const all_overrides_expr = Shared.new(ExprRecordUpdate("Point", base_expr, two_overrides, span_unknown()))
  results.push(assert_eq_str("Point { ...p, x: 0, y: 0 } - Point{0, 0}",
    gen_expr(all_overrides_expr, ctx_point),
    "Point{0, 0}"))

  // -- Lexer tokenizes ... as Spread ----------------------------------------

  const spread_tokens = tokenize("...")
  results.push(assert_eq_int("'...' - 2 tokens (Spread + Eof)",
    spread_tokens.tokens.length(), 2))

  const first_token_is_spread = match spread_tokens.tokens[0].kind { Spread => 1, _ => 0 }
  results.push(assert_eq_int("first token of '...' is Spread",
    first_token_is_spread, 1))

  results
end
