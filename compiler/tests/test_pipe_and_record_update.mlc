// Tests for pipe operator desugaring and record update codegen.

import { TestResult, assert_eq_int, assert_eq_str, assert_true } from './test_runner'
import { gen_expr } from '../codegen/eval'
import {print_expr} from '../cpp_emit/print'
import { create_codegen_context } from '../codegen/context'
import { pipe_desugar } from '../frontend/parser/exprs'
import { tokenize } from '../frontend/lexer'
import { Program, Expr, Stmt, DeclType, VarRecord, FieldDef, TyI32, ExprIdent, ExprCall, ExprInt, ExprUnit, span_unknown } from '../frontend/ast'
import { SemanticExpression, SemanticFieldVal, SemanticExpressionInt, SemanticExpressionIdent, SemanticExpressionRecordUpdate } from '../ir/semantic_ir'
import { Type, TNamed, TI32, TUnknown } from '../checker/registry'
import { transform_expr, empty_transform_context, TransformContext, TransformStmtsResult } from '../checker/transform/transform'
import { transform_stmts } from '../checker/transform/transform_stmts'

fn sid(name: string) -> Shared<SemanticExpression> = Shared.new(SemanticExpressionIdent(name, Shared.new(TUnknown), span_unknown()))
fn si(v: i32) -> Shared<SemanticExpression> = Shared.new(SemanticExpressionInt(v, Shared.new(TI32), span_unknown()))

export fn pipe_and_record_update_tests() -> [TestResult] = do
  let results: [TestResult] = []
  const empty_program = Program { decls: [] }
  const context = create_codegen_context(empty_program)
  const transform_context = empty_transform_context()

  // -- Pipe operator desugaring ---------------------------------------------

  const left_expr  = Shared.new(ExprIdent("x", span_unknown()))
  const right_fn   = Shared.new(ExprIdent('double', span_unknown()))
  const plain_pipe = pipe_desugar(left_expr, right_fn)
  results.push(assert_eq_str('pipe x |> double - double_(x)',
    print_expr(gen_expr(transform_expr(plain_pipe, transform_context, (statements: [Shared<Stmt>], nested_transform_context: TransformContext) => transform_stmts(statements, nested_transform_context)), context)),
    'double_(x)'))

  const right_call_args: [Shared<Expr>] = [Shared.new(ExprInt(5, span_unknown()))]
  const right_call   = Shared.new(ExprCall(Shared.new(ExprIdent('add', span_unknown())), right_call_args, span_unknown()))
  const partial_pipe = pipe_desugar(left_expr, right_call)
  results.push(assert_eq_str('pipe x |> add(5) - add(x, 5)',
    print_expr(gen_expr(transform_expr(partial_pipe, transform_context, (statements: [Shared<Stmt>], nested_transform_context: TransformContext) => transform_stmts(statements, nested_transform_context)), context)),
    'add(x, 5)'))

  const right_multi_args: [Shared<Expr>] = [Shared.new(ExprInt(3, span_unknown())), Shared.new(ExprInt(4, span_unknown()))]
  const right_multi_call  = Shared.new(ExprCall(Shared.new(ExprIdent('clamp', span_unknown())), right_multi_args, span_unknown()))
  const multi_partial_pipe = pipe_desugar(left_expr, right_multi_call)
  results.push(assert_eq_str('pipe x |> clamp(3, 4) - clamp(x, 3, 4)',
    print_expr(gen_expr(transform_expr(multi_partial_pipe, transform_context, (statements: [Shared<Stmt>], nested_transform_context: TransformContext) => transform_stmts(statements, nested_transform_context)), context)),
    'clamp(x, 3, 4)'))

  // -- Record update codegen ------------------------------------------------

  const point_decl = Shared.new(DeclType('Point', [], [Shared.new(VarRecord('Point', [
    Shared.new(FieldDef {
      name: "x",
      type_value: Shared.new(TyI32),
      has_default_expression: false,
      default_expression: Shared.new(ExprUnit(span_unknown()))
    }),
    Shared.new(FieldDef {
      name: "y",
      type_value: Shared.new(TyI32),
      has_default_expression: false,
      default_expression: Shared.new(ExprUnit(span_unknown()))
    })
  ], false))], [], span_unknown()))
  const point_program  = Program { decls: [point_decl] }
  const point_context   = create_codegen_context(point_program)

  const point_type = Shared.new(TNamed('Point'))
  const override_fields: [Shared<SemanticFieldVal>] = [
    Shared.new(SemanticFieldVal { name: "x", value: si(10) })
  ]
  const base_expr   = sid("p")
  const update_expr = Shared.new(SemanticExpressionRecordUpdate('Point', base_expr, override_fields, point_type, span_unknown()))
  results.push(assert_eq_str('Point { ...p, x: 10 } - Point{10, p.y}',
    print_expr(gen_expr(update_expr, point_context)),
    'Point{10, p.y}'))

  const two_overrides: [Shared<SemanticFieldVal>] = [
    Shared.new(SemanticFieldVal { name: "x", value: si(0) }),
    Shared.new(SemanticFieldVal { name: "y", value: si(0) })
  ]
  const all_overrides_expr = Shared.new(SemanticExpressionRecordUpdate('Point', base_expr, two_overrides, point_type, span_unknown()))
  results.push(assert_eq_str('Point { ...p, x: 0, y: 0 } - Point{0, 0}',
    print_expr(gen_expr(all_overrides_expr, point_context)),
    'Point{0, 0}'))

  const lazy_update = Shared.new(SemanticExpressionRecordUpdate('Point', base_expr, override_fields, point_type, span_unknown()))
  results.push(assert_true('record update without field order registry uses lazy block',
    print_expr(gen_expr(lazy_update, context)).contains('__upd')))

  // -- Lexer tokenizes ... as Spread ----------------------------------------

  const spread_tokens = tokenize('...')
  results.push(assert_eq_int('\'...\' - 2 tokens (Spread + Eof)',
    spread_tokens.tokens.length(), 2))

  const first_token_is_spread = match spread_tokens.tokens[0].kind { Spread => 1, _ => 0 }
  results.push(assert_eq_int('first token of \'...\' is Spread',
    first_token_is_spread, 1))

  results
end