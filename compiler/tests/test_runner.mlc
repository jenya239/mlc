// Minimal test framework.

export type TestResult = Pass { name: string } | Fail { name: string, message: string }

export fn assert_true(test_name: string, condition: bool) -> TestResult = do
  const pass_variant: TestResult = Pass { name: test_name }
  const fail_variant: TestResult =
    Fail { name: test_name, message: 'expected true, got false' }
  if condition then pass_variant else fail_variant end
end

export fn assert_eq_int(test_name: string, actual: i32, expected: i32) -> TestResult = do
  const pass_variant: TestResult = Pass { name: test_name }
  const fail_variant: TestResult =
    Fail {
      name: test_name,
      message: 'expected ' + expected.to_string() + ', got ' + actual.to_string(),
    }
  if actual == expected then pass_variant else fail_variant end
end

export fn assert_eq_str(test_name: string, actual: string, expected: string) -> TestResult = do
  const pass_variant: TestResult = Pass { name: test_name }
  const fail_variant: TestResult =
    Fail { name: test_name, message: `expected '${expected}', got '${actual}'` }
  if actual == expected then pass_variant else fail_variant end
end

// `formatted_diagnostic` matches rustc-style `diagnostic_format`: "severity: message" + optional "  --> file:line:col".
export fn assert_diagnostic_at(
  test_name: string,
  formatted_diagnostic: string,
  expected_line: i32,
  expected_column: i32,
  message_needle: string
) -> TestResult = do
  const line_column = expected_line.to_string() + ":" + expected_column.to_string()
  const has_message = formatted_diagnostic.contains(message_needle)
  const has_position =
    formatted_diagnostic.contains("  --> " + line_column)
    || (formatted_diagnostic.contains("  --> ") && formatted_diagnostic.contains(":" + line_column))
  if has_message && has_position then Pass { name: test_name }
  else Fail {
    name: test_name,
    message: `expected needle '${message_needle}' and location '  --> …${line_column}', got '${formatted_diagnostic}'`
  }
  end
end

export fn run_all(results: [TestResult]) -> string = do
  let mut passed = 0; let mut failed = 0; let mut output = ''; let mut i = 0
  while i < results.length() do
    match results[i] {
      Pass(_)            => do passed = passed + 1 end,
      Fail(name, message) => do
        failed = failed + 1
        output = output + 'FAIL: ' + name + ' - ' + message + "\n"
      end
    }
    i = i + 1
  end
  output + passed.to_string() + ' passed, ' + failed.to_string() + ' failed\n'
end
