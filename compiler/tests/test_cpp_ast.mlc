// Unit tests for C++ AST types.

import { TestResult, assert_eq_int, assert_true } from './test_runner'
import { CppProgram, CppInclude, CppStruct, CppField, CppType, CppTypeName, CppTypeTemplate, CppTypeRef,
         CppExpression, CppBool, CppTernary, CppInitList, CppCast, CppCastStatic, CppInt, CppIdent } from '../cpp/cpp_ast'

export fn cpp_ast_tests() -> [TestResult] = do
  let results: [TestResult] = []

  const inc = Shared.new(CppInclude(true, 'string'))
  const prog = CppProgram { declarations: [inc] }
  results.push(assert_eq_int('CppProgram with 1 decl',
    prog.declarations.length(), 1))

  const field = Shared.new(CppField { type_value: 'int', name: "x" })
  const st = Shared.new(CppStruct('', 'Point', [field], false))
  const prog2 = CppProgram { declarations: [st] }
  results.push(assert_true('CppStruct in program',
    match prog2.declarations[0] { CppStruct(_, _, _, _) => true, _ => false }))

  const vector_type = Shared.new(CppTypeName('std::vector'))
  const int_type = Shared.new(CppTypeName('int'))
  const vector_int = Shared.new(CppTypeTemplate('std::vector', [int_type]))
  const int_ref = Shared.new(CppTypeRef(int_type))
  results.push(assert_true('CppTypeName',
    match vector_type { CppTypeName(name) => name == 'std::vector', _ => false }))
  results.push(assert_true('CppTypeTemplate',
    match vector_int { CppTypeTemplate(name, args) => name == 'std::vector' && args.length() == 1, _ => false }))
  results.push(assert_true('CppTypeRef',
    match int_ref { CppTypeRef(inner) => match inner { CppTypeName(name) => name == 'int', _ => false }, _ => false }))

  const flag = Shared.new(CppBool(true))
  results.push(assert_true('CppBool',
    match flag { CppBool(value) => value, _ => false }))

  const condition = Shared.new(CppIdent('ready'))
  const then_branch = Shared.new(CppInt(1))
  const else_branch = Shared.new(CppInt(0))
  const ternary = Shared.new(CppTernary(condition, then_branch, else_branch))
  results.push(assert_true('CppTernary',
    match ternary {
      CppTernary(condition_expression, then_expression, else_expression) =>
        match condition_expression { CppIdent(name) => name == 'ready', _ => false }
        && match then_expression { CppInt(value) => value == 1, _ => false }
        && match else_expression { CppInt(value) => value == 0, _ => false },
      _ => false
    }))

  const element = Shared.new(CppInt(42))
  const init_list = Shared.new(CppInitList([element]))
  results.push(assert_true('CppInitList',
    match init_list { CppInitList(elements) => elements.length() == 1, _ => false }))

  const cast_target = Shared.new(CppTypeName('int'))
  const cast_operand = Shared.new(CppIdent('value'))
  const cast_expression = Shared.new(CppCast(CppCastStatic, cast_target, cast_operand))
  results.push(assert_true('CppCast',
    match cast_expression {
      CppCast(kind, target_type, operand) =>
        match kind { CppCastStatic => true, _ => false }
        && match target_type { CppTypeName(name) => name == 'int', _ => false }
        && match operand { CppIdent(name) => name == 'value', _ => false },
      _ => false
    }))

  results
end
