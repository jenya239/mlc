// Test entry point. Runs all test suites.
// Uses import for modular build (build_tests.sh).

import { lexer_tests } from './test_lexer'
import { parser_tests } from './test_parser'
import { checker_tests } from './test_checker'
import { codegen_tests } from './test_codegen'
import { pipe_and_record_update_tests } from './test_pipe_and_record_update'
import { decl_gen_tests } from './test_decl_gen'
import { partial_application_tests } from './test_partial_application'
import { merge_import_tests } from './test_merge_imports'
import { pass_type_tests } from './test_pass'
import { expr_visitor_tests } from './test_expr_visitor'
import { cpp_printer_tests } from './test_cpp_printer'
import { fuzz_tests } from './test_fuzz'
import { TestResult, run_all } from './test_runner'

fn all_tests() -> [TestResult] = do
  let mut all: [TestResult] = []
  let mut index = 0

  const suite_lex = lexer_tests()
  index = 0; while index < suite_lex.length() do all.push(suite_lex[index]); index = index + 1 end

  const suite_parse = parser_tests()
  index = 0; while index < suite_parse.length() do all.push(suite_parse[index]); index = index + 1 end

  const suite_check = checker_tests()
  index = 0; while index < suite_check.length() do all.push(suite_check[index]); index = index + 1 end

  const suite_gen = codegen_tests()
  index = 0; while index < suite_gen.length() do all.push(suite_gen[index]); index = index + 1 end

  const suite_pipe = pipe_and_record_update_tests()
  index = 0; while index < suite_pipe.length() do all.push(suite_pipe[index]); index = index + 1 end

  const suite_decl = decl_gen_tests()
  index = 0; while index < suite_decl.length() do all.push(suite_decl[index]); index = index + 1 end

  const suite_partial = partial_application_tests()
  index = 0; while index < suite_partial.length() do all.push(suite_partial[index]); index = index + 1 end

  const suite_merge = merge_import_tests()
  index = 0; while index < suite_merge.length() do all.push(suite_merge[index]); index = index + 1 end

  const suite_pass = pass_type_tests()
  index = 0; while index < suite_pass.length() do all.push(suite_pass[index]); index = index + 1 end

  const suite_expr_visitor = expr_visitor_tests()
  index = 0; while index < suite_expr_visitor.length() do all.push(suite_expr_visitor[index]); index = index + 1 end

  const suite_cpp_printer = cpp_printer_tests()
  index = 0; while index < suite_cpp_printer.length() do all.push(suite_cpp_printer[index]); index = index + 1 end

  const suite_fuzz = fuzz_tests()
  index = 0; while index < suite_fuzz.length() do all.push(suite_fuzz[index]); index = index + 1 end

  all
end

fn main() -> i32 = do
  print(run_all(all_tests()))
  0
end
