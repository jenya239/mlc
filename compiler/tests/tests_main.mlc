// Test entry point. Runs all test suites.
// Uses import for modular build (build_tests.sh).

import { lexer_tests } from "./test_lexer"
import { parser_tests } from "./test_parser"
import { checker_tests } from "./test_checker"
import { codegen_tests } from "./test_codegen"
import { pipe_and_record_update_tests } from "./test_pipe_and_record_update"
import { TestResult, run_all } from "./test_runner"

fn all_tests() -> [TestResult] = do
  const all: [TestResult] = []
  let mut i = 0

  const lex_results = lexer_tests()
  while i < lex_results.length() do all.push(lex_results[i]); i = i + 1 end

  const parse_results = parser_tests()
  i = 0
  while i < parse_results.length() do all.push(parse_results[i]); i = i + 1 end

  const check_results = checker_tests()
  i = 0
  while i < check_results.length() do all.push(check_results[i]); i = i + 1 end

  const gen_results = codegen_tests()
  i = 0
  while i < gen_results.length() do all.push(gen_results[i]); i = i + 1 end

  const pipe_record_results = pipe_and_record_update_tests()
  i = 0
  while i < pipe_record_results.length() do all.push(pipe_record_results[i]); i = i + 1 end

  all
end

fn main() -> i32 = do
  print(run_all(all_tests()))
  0
end
