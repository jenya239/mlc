// Unit tests for declaration code generation.

import { TestResult, assert_eq_str, assert_eq_int, assert_true } from './test_runner'
import { Program, TypeVariant, Param, FieldDef, TyI32, TyBool, TyString, TyUnit, TyNamed, TyArray, span_unknown, Span, ExprUnit, ExprInt, PatternUnit, PatternStringLit, PatternWild, WhereClauseBound } from '../frontend/ast'
import { tokenize } from '../frontend/lexer'
import { parse_program } from '../frontend/parser/decls'
import { check } from '../checker/check/check'
import { transform_program } from '../checker/transform/transform_decl'
import { create_codegen_context, StructUsingEntry, StructUsingData, context_with_struct_using_data } from '../codegen/context'
import { build_struct_using_data } from '../codegen/module'
import { gen_extend_wrapper_protos, gen_decl_extend, gen_decl_extend_trait_suffix, gen_extend_extern_method } from '../codegen/decl/decl_extend'
import { gen_fn_proto, gen_fn_decl, gen_trait_decl, gen_trait_struct, gen_decl, gen_proto, decls_have_main, extend_method_forward_segments, extend_cpp_forward_segment, collect_all_decl_parts, extend_helper_protos_for_exported_types } from '../codegen/decl/decl'
import { gen_derive_display_cpp, gen_derive_eq_cpp, gen_derive_ord_cpp, gen_derive_hash_cpp, gen_derive_json_cpp, gen_derive_methods_cpp } from '../codegen/decl/derive_methods_cpp'
import { trait_method_field_cpp, gen_trait_struct_cpp } from '../codegen/decl/trait_struct_cpp'
import { CppDeclaration, CppStruct, CppDeclarationSequence, CppDeclarationEmpty, CppUsing, CppStdHashSpecialization, CppDeclarationFragment, CppStatement, CppStatementFragment, CppStatementSequence, CppBlock, CppIf, CppWhile, CppFor } from '../cpp_ir/cpp_ast'
import { gen_fn_proto_cpp, gen_fn_decl_cpp, gen_decl_cpp, gen_proto_cpp, print_cpp_declaration, print_cpp_declarations, extend_method_forward_segments_cpp, gen_extend_wrapper_protos_cpp, extend_cpp_forward_segment_cpp, collect_fn_defs_cpp, collect_decl_parts_cpp, collect_all_decl_parts_cpp, extend_helper_protos_for_exported_types_cpp, main_program_parameter_items_cpp, main_set_args_preamble_cpp, gen_type_decl_fwd_cpp, gen_type_decl_body_cpp, gen_trait_decl_cpp, decl_segment_cpp, gen_decl_extend_cpp, gen_decl_extend_trait_suffix_cpp, gen_extend_extern_method_cpp } from '../codegen/decl_cpp'
import { gen_type_decl_fwd_only, gen_type_decl_body_only, gen_derive_methods } from '../codegen/decl/type_gen'
import { static_assert_concept_for_type_line, static_assert_concept_for_result_and_implementor_line } from '../codegen/expr/expr'
import { empty_program, record_variant, tuple_variant, unit_variant, field_definition } from './ast_builders'
import { assert_code_contains, assert_code_not_contains, empty_codegen_context } from './codegen_test_helpers'
import { SemanticDeclaration, SemanticExpression, SemanticExpressionUnit, SemanticExpressionIdent, SemanticExpressionStr, SemanticExpressionBin, SemanticExpressionInt, SemanticExpressionBool, SemanticExpressionQuestion, SemanticExpressionBlock, SemanticExpressionIf, SemanticExpressionMatch, SemanticExpressionWhile, SemanticExpressionExtern, SemanticMatchArm, SemanticStatementLet, SemanticStatementExpr, SemanticDeclarationFn, SemanticDeclarationType, SemanticDeclarationTrait, SemanticDeclarationExported, SemanticDeclarationExtend, SemanticDeclarationAssocBind, SemanticDeclarationImport, sdecl_span, empty_fn_escape_info } from '../ir/semantic_ir'
import { Type, TypeRegistry, TI32, TString, TBool, TUnit, TUnknown, TNamed, TGeneric } from '../checker/registry'
import { gen_return_body, gen_return_body_cpp } from '../codegen/stmt/return_body'
import { print_cpp_statements } from '../codegen/stmt_cpp'

fn ti32()  -> Shared<Type> = Shared.new(TI32)
fn tstr()  -> Shared<Type> = Shared.new(TString)
fn tunit() -> Shared<Type> = Shared.new(TUnit)
fn tbool() -> Shared<Type> = Shared.new(TBool)
fn unk()   -> Shared<Type> = Shared.new(TUnknown)

fn make_ident(name: string) -> Shared<SemanticExpression> = Shared.new(SemanticExpressionIdent(name, unk(), span_unknown()))
fn make_bin(op: string, left: Shared<SemanticExpression>, right: Shared<SemanticExpression>) -> Shared<SemanticExpression> = Shared.new(SemanticExpressionBin(op, left, right, unk(), span_unknown()))
fn make_unit_expr() -> Shared<SemanticExpression> = Shared.new(SemanticExpressionUnit(tunit(), span_unknown()))
fn make_int(value: i32) -> Shared<SemanticExpression> = Shared.new(SemanticExpressionInt(value, ti32(), span_unknown()))
fn make_bool(value: bool) -> Shared<SemanticExpression> = Shared.new(SemanticExpressionBool(value, tbool(), span_unknown()))
fn make_question(inner: Shared<SemanticExpression>) -> Shared<SemanticExpression> =
  Shared.new(SemanticExpressionQuestion(inner, unk(), span_unknown()))

fn iparam(name: string) -> Shared<Param> = Shared.new(Param { name: name, is_mut: false, type_value: Shared.new(TyI32), has_default: false, default: Shared.new(ExprUnit(span_unknown())), param_pattern: Shared.new(PatternUnit(span_unknown())) })
fn fn_decl(name: string, params: [Shared<Param>], return_type: Shared<Type>, body: Shared<SemanticExpression>) -> Shared<SemanticDeclaration> = do
  const where_clause_bounds: [WhereClauseBound] = []
  Shared.new(SemanticDeclarationFn(name, [], [], params, return_type, body, where_clause_bounds, empty_fn_escape_info(), span_unknown()))
end

fn generic_param(name: string) -> Shared<Param> =
  Shared.new(Param {
    name: name,
    is_mut: false,
    type_value: Shared.new(TyNamed("T")),
    has_default: false,
    default: Shared.new(ExprUnit(span_unknown())),
    param_pattern: Shared.new(PatternUnit(span_unknown()))
  })

fn type_decl(name: string, type_params: [string], variants: [Shared<TypeVariant>], derive_traits: [string]) -> Shared<SemanticDeclaration> =
  Shared.new(SemanticDeclarationType(name, type_params, variants, derive_traits, span_unknown()))

fn trait_decl(name: string, type_params: [string], methods: [Shared<SemanticDeclaration>]) -> Shared<SemanticDeclaration> =
  Shared.new(SemanticDeclarationTrait(name, type_params, methods, span_unknown()))

fn extend_decl(type_name: string, trait_name: string, methods: [Shared<SemanticDeclaration>]) -> Shared<SemanticDeclaration> =
  Shared.new(SemanticDeclarationExtend(type_name, trait_name, methods, span_unknown()))

fn first_transformed_decl_span(program: Program, registry: TypeRegistry) -> Span = do
  const transformed = transform_program(program, registry)
  if transformed.decls.length() == 0 then span_unknown() else sdecl_span(transformed.decls[0]) end
end

fn transformed_decl_span(source: string) -> Span = do
  const program = parse_program(tokenize(source).tokens)
  match check(program) {
    Ok(checked) => first_transformed_decl_span(program, checked.registry),
    Err(_) => span_unknown()
  }
end

fn transformed_fn_decl_span(source: string) -> Span = transformed_decl_span(source)
fn transformed_type_decl_span(source: string) -> Span = transformed_decl_span(source)
fn transformed_trait_decl_span(source: string) -> Span = transformed_decl_span(source)
fn transformed_extend_decl_span(source: string) -> Span = transformed_decl_span(source)

fn cpp_decl_sequence_children(declaration: Shared<CppDeclaration>) -> [Shared<CppDeclaration>] =
  match declaration {
    CppDeclarationSequence(declarations) => declarations,
    _ => []
  }

fn is_cpp_decl_empty(declaration: Shared<CppDeclaration>) -> bool =
  match declaration {
    CppDeclarationEmpty => true,
    _ => false
  }

fn cpp_decl_is_using(declaration: Shared<CppDeclaration>, alias: string, type_cpp: string) -> bool =
  match declaration {
    CppUsing(decl_alias, decl_type) => decl_alias == alias && decl_type == type_cpp,
    _ => false
  }

fn cpp_decl_list_contains_using(
  declarations: [Shared<CppDeclaration>],
  alias: string,
  type_cpp: string
) -> bool = do
  let mut index = 0
  let mut found = false
  while index < declarations.length() && !found do
    found = cpp_decl_is_using(declarations[index], alias, type_cpp)
    index = index + 1
  end
  found
end

fn cpp_decl_is_std_hash_specialization(declaration: Shared<CppDeclaration>, type_name: string) -> bool =
  match declaration {
    CppStdHashSpecialization(specialized_type_name, _) =>
      specialized_type_name == type_name,
    _ => false
  }

fn cpp_decl_is_fragment(declaration: Shared<CppDeclaration>) -> bool =
  match declaration {
    CppDeclarationFragment(_) => true,
    _ => false
  }

fn cpp_stmt_is_fragment(statement: Shared<CppStatement>) -> bool =
  match statement {
    CppStatementFragment(_) => true,
    _ => false
  }

fn cpp_stmt_tree_contains_fragment(statement: Shared<CppStatement>) -> bool =
  if cpp_stmt_is_fragment(statement) then
    true
  else
    match statement {
      CppBlock(statements) => cpp_stmt_list_contains_fragment(statements),
      CppStatementSequence(statements) => cpp_stmt_list_contains_fragment(statements),
      CppIf(_, then_branch, else_branch) =>
        cpp_stmt_tree_contains_fragment(then_branch) ||
        cpp_stmt_tree_contains_fragment(else_branch),
      CppWhile(_, body) => cpp_stmt_tree_contains_fragment(body),
      CppFor(_, _, body) => cpp_stmt_list_contains_fragment(body),
      _ => false
    }
  end

fn cpp_stmt_list_contains_fragment(statements: [Shared<CppStatement>]) -> bool = do
  let mut index = 0
  let mut found = false
  while index < statements.length() && !found do
    found = cpp_stmt_tree_contains_fragment(statements[index])
    index = index + 1
  end
  found
end

fn cpp_std_hash_body_statements(declaration: Shared<CppDeclaration>) -> [Shared<CppStatement>] =
  match declaration {
    CppStdHashSpecialization(_, body) => body,
    _ => []
  }

fn cpp_decl_list_hash_body_contains_fragment(declarations: [Shared<CppDeclaration>]) -> bool = do
  let mut index = 0
  let mut found = false
  while index < declarations.length() && !found do
    const body = cpp_std_hash_body_statements(declarations[index])
    if body.length() > 0 then
      found = cpp_stmt_list_contains_fragment(body)
    end
    index = index + 1
  end
  found
end

fn cpp_decl_list_contains_std_hash_specialization(
  declarations: [Shared<CppDeclaration>],
  type_name: string
) -> bool = do
  let mut index = 0
  let mut found = false
  while index < declarations.length() && !found do
    found = cpp_decl_is_std_hash_specialization(declarations[index], type_name)
    index = index + 1
  end
  found
end

fn make_str_expr(text: string) -> Shared<SemanticExpression> = Shared.new(SemanticExpressionStr(text, tstr(), span_unknown()))

export fn decl_gen_tests() -> [TestResult] = do
  let results: [TestResult] = []
  const context = empty_codegen_context()

  // --- gen_fn_proto -----------------------------------------------------------

  results.push(assert_eq_str('gen_fn_proto: zero params',
    gen_fn_proto('compute', [], [], [], tunit(), context),
    'void compute() noexcept;\n'))

  results.push(assert_eq_str('gen_fn_proto: single i32 param',
    gen_fn_proto('double_it', [], [], [iparam('value')], ti32(), context),
    'int double_it(int value) noexcept;\n'))

  results.push(assert_eq_str('gen_fn_proto: two params',
    gen_fn_proto('add', [], [], [iparam('left'), iparam('right')], ti32(), context),
    'int add(int left, int right) noexcept;\n'))

  results.push(assert_eq_str('gen_fn_proto: mut array param by reference',
    gen_fn_proto('push_token', [], [], [Shared.new(Param {
      name: 'tokens',
      is_mut: true,
      type_value: Shared.new(TyArray(Shared.new(TyNamed('Token')))),
      has_default: false,
      default: Shared.new(ExprUnit(span_unknown())),
      param_pattern: Shared.new(PatternUnit(span_unknown()))
    })], tunit(), context),
    'void push_token(mlc::Array<Token>& tokens) noexcept;\n'))

  results.push(assert_eq_str('gen_fn_proto: string return type',
    gen_fn_proto('greet', [], [], [Shared.new(Param { name: 'name', is_mut: false, type_value: Shared.new(TyString), has_default: false, default: Shared.new(ExprUnit(span_unknown())), param_pattern: Shared.new(PatternUnit(span_unknown())) })], tstr(), context),
    'mlc::String greet(mlc::String name) noexcept;\n'))

  results.push(assert_eq_str('gen_fn_proto: default param literal',
    gen_fn_proto("f", [], [], [Shared.new(Param { name: "a", is_mut: false, type_value: Shared.new(TyI32), has_default: true, default: Shared.new(ExprInt(2, span_unknown())), param_pattern: Shared.new(PatternUnit(span_unknown())) })], ti32(), context),
    'int f(int a = 2) noexcept;\n'))

  results.push(assert_eq_str('gen_fn_decl: body omits default value',
    gen_fn_decl("f", [], [], [Shared.new(Param { name: "a", is_mut: false, type_value: Shared.new(TyI32), has_default: true, default: Shared.new(ExprInt(2, span_unknown())), param_pattern: Shared.new(PatternUnit(span_unknown())) })], ti32(), make_ident("a"), context),
    'int f(int a) noexcept{\nreturn a;\n}\n'))

  // --- gen_fn_decl ------------------------------------------------------------

  results.push(assert_eq_str('gen_fn_decl: identity function',
    gen_fn_decl('identity', [], [], [iparam('value')], ti32(), make_ident('value'), context),
    'int identity(int value) noexcept{\nreturn value;\n}\n'))

  results.push(assert_eq_str('gen_fn_decl: addition',
    gen_fn_decl('add', [], [], [iparam('left'), iparam('right')], ti32(),
      make_bin("+", make_ident('left'), make_ident('right')), context),
    'int add(int left, int right) noexcept{\nreturn mlc::arith::checked_add(left, right);\n}\n'))

  results.push(assert_eq_str('gen_fn_decl: unit return',
    gen_fn_decl('nothing', [], [], [], tunit(), make_unit_expr(), context),
    'void nothing() noexcept{\n}\n'))

  // --- gen_decl with SemanticDeclarationFn ---------------------------------------------------

  const add_decl = fn_decl('add', [iparam('left'), iparam('right')], ti32(),
    make_bin("+", make_ident('left'), make_ident('right')))

  results.push(assert_code_contains('gen_decl DeclFn: contains return type',
    gen_decl(add_decl, context), 'int add'))

  results.push(assert_code_contains('gen_decl DeclFn: contains body',
    gen_decl(add_decl, context), 'return mlc::arith::checked_add(left, right)'))

  // --- gen_decl with SemanticDeclarationType -------------------------------------------------

  const point_type = type_decl('Point', [],
    [record_variant('Point', [field_definition("x", Shared.new(TyI32)), field_definition("y", Shared.new(TyI32))])], [])

  results.push(assert_code_contains('gen_decl DeclType: record struct',
    gen_decl(point_type, context), 'Point'))

  const color_type = type_decl('Color', [],
    [unit_variant('Red'), unit_variant('Green'), unit_variant('Blue')], [])

  results.push(assert_code_contains('gen_decl DeclType: unit variants',
    gen_decl(color_type, context), 'Red'))

  // --- derive method generation ------------------------------------------------

  const point_display = type_decl('Point', [],
    [record_variant('Point', [field_definition("x", Shared.new(TyI32)), field_definition("y", Shared.new(TyI32))])], ['Display'])

  results.push(assert_code_contains('derive Display record: generates to_string function',
    gen_decl(point_display, context), 'Point_to_string'))

  results.push(assert_code_contains('derive Display record: uses mlc::to_string for i32 field',
    gen_decl(point_display, context), 'mlc::to_string(self.x)'))

  const point_eq = type_decl('Point', [],
    [record_variant('Point', [field_definition("x", Shared.new(TyI32)), field_definition("y", Shared.new(TyI32))])], ['Eq'])

  results.push(assert_code_contains('derive Eq record: generates operator==',
    gen_decl(point_eq, context), 'operator=='))

  results.push(assert_code_contains('derive Eq record: compares fields',
    gen_decl(point_eq, context), 'a.x == b.x'))

  const color_display = type_decl('Color', [],
    [unit_variant('Red'), unit_variant('Green'), unit_variant('Blue')], ['Display'])

  results.push(assert_code_contains('derive Display sum type: generates to_string',
    gen_decl(color_display, context), 'Color_to_string'))

  results.push(assert_code_contains('derive Display sum type: handles Red variant',
    gen_decl(color_display, context), '"Red"'))

  const point_hash = type_decl('Point', [],
    [record_variant('Point', [
      field_definition('tag', Shared.new(TyI32)),
      field_definition('flag', Shared.new(TyBool)),
      field_definition('label', Shared.new(TyString))
    ])], ['Hash'])

  results.push(assert_code_contains('derive Hash record: namespace std and struct hash',
    gen_decl(point_hash, context), 'namespace std'))
  results.push(assert_code_contains('derive Hash record: struct hash<Point>',
    gen_decl(point_hash, context), 'struct hash<Point>'))
  results.push(assert_code_contains('derive Hash record: combines i32 field',
    gen_decl(point_hash, context), 'std::hash<int>{}(self.tag)'))
  results.push(assert_code_contains('derive Hash record: combines bool field',
    gen_decl(point_hash, context), 'std::hash<bool>{}(self.flag)'))
  results.push(assert_code_contains('derive Hash record: combines string field',
    gen_decl(point_hash, context), 'std::hash<mlc::String>{}(self.label)'))
  results.push(assert_code_contains('derive Hash record: boost-style combine constant',
    gen_decl(point_hash, context), '0x9e3779b97f4a7c15ULL'))

  const empty_hash = type_decl('Empty', [],
    [record_variant('Empty', [])], ['Hash'])
  results.push(assert_code_contains('derive Hash empty record: fnv offset basis seed',
    gen_decl(empty_hash, context), '1469598103934665603ULL'))

  const hue_hash = type_decl('Hue', [],
    [unit_variant('North'), unit_variant('South')], ['Hash'])
  results.push(assert_code_contains('derive Hash sum: holds_alternative first variant',
    gen_decl(hue_hash, context), 'std::holds_alternative<North>'))
  results.push(assert_code_contains('derive Hash sum: holds_alternative second variant',
    gen_decl(hue_hash, context), 'std::holds_alternative<South>'))

  const shape_hash = type_decl('Shape', [],
    [tuple_variant('Circle', [Shared.new(TyI32)]), unit_variant('Empty')], ['Hash'])
  results.push(assert_code_contains('derive Hash sum tuple variant: std get and field0',
    gen_decl(shape_hash, context), 'std::get<Circle>(self._).field0'))

  // --- gen_trait_decl + SemanticDeclarationExtend --------------------------------------------

  const display_self = Shared.new(Param { name: 'self', is_mut: false, type_value: Shared.new(TyNamed('Display')), has_default: false, default: Shared.new(ExprUnit(span_unknown())), param_pattern: Shared.new(PatternUnit(span_unknown())) })
  const display_method = fn_decl('Display_to_string', [display_self], tstr(), make_unit_expr())
  results.push(assert_code_contains('gen_trait_decl: concept keyword',
    gen_trait_decl(context, 'Display', [], [display_method]), 'concept'))
  results.push(assert_code_contains('gen_trait_decl: trait identifier',
    gen_trait_decl(context, 'Display', [], [display_method]), 'Display'))

  results.push(assert_eq_str('gen_trait_decl_cpp matches string',
    print_cpp_declaration(gen_trait_decl_cpp(context, 'Display', [], [display_method])),
    gen_trait_decl(context, 'Display', [], [display_method])))

  results.push(assert_code_contains('gen_trait_struct: std::function field',
    gen_trait_struct(context, 'Display', [], [display_method]), 'std::function'))
  results.push(assert_code_contains('gen_trait_struct: vtable struct name',
    gen_trait_struct(context, 'Display', [], [display_method]), 'struct Display_vtable'))
  results.push(assert_code_contains('gen_trait_struct: method name',
    gen_trait_struct(context, 'Display', [], [display_method]), 'to_string'))

  const trait_context = context.for_type_body('Display')
  const display_field = trait_method_field_cpp(trait_context, 'to_string', [display_self], tstr())
  results.push(assert_code_contains('trait_method_field_cpp: std::function',
    print_cpp_declaration(Shared.new(CppStruct('', 'Display_vtable', [display_field], false))), 'std::function'))
  results.push(assert_code_contains('trait_method_field_cpp: method name',
    print_cpp_declaration(Shared.new(CppStruct('', 'Display_vtable', [display_field], false))), 'to_string'))
  results.push(assert_eq_str('trait_method_field_cpp struct matches string gen_trait_struct',
    print_cpp_declaration(Shared.new(CppStruct('', 'Display_vtable', [display_field], false))),
    gen_trait_struct(context, 'Display', [], [display_method])))

  results.push(assert_eq_str('gen_trait_struct_cpp matches string',
    print_cpp_declaration(gen_trait_struct_cpp(context, 'Display', [], [display_method])),
    gen_trait_struct(context, 'Display', [], [display_method])))

  const color_self = Shared.new(Param { name: 'self', is_mut: false, type_value: Shared.new(TyNamed('Color')), has_default: false, default: Shared.new(ExprUnit(span_unknown())), param_pattern: Shared.new(PatternUnit(span_unknown())) })
  const color_to_string = fn_decl('Color_to_string', [color_self], tstr(), make_str_expr('red'))
  const extend_display_for_color = extend_decl('Color', 'Display', [color_to_string])
  results.push(assert_code_contains('gen_decl SemanticDeclarationExtend: static_assert implements trait',
    gen_decl(extend_display_for_color, context), 'static_assert'))
  results.push(assert_code_contains('gen_decl SemanticDeclarationExtend: trait name in assert',
    gen_decl(extend_display_for_color, context), 'Display'))

  results.push(assert_eq_str('extend_method_forward_segments_cpp matches string',
    print_cpp_declarations(extend_method_forward_segments_cpp([extend_display_for_color], context)),
    extend_method_forward_segments([extend_display_for_color], context).join('')))

  results.push(assert_eq_str('gen_extend_wrapper_protos_cpp matches string',
    print_cpp_declarations(gen_extend_wrapper_protos_cpp('Color', 'Display', [color_to_string], context)),
    gen_extend_wrapper_protos('Color', 'Display', [color_to_string], context)))

  results.push(assert_eq_str('extend_cpp_forward_segment_cpp matches string',
    print_cpp_declarations(extend_cpp_forward_segment_cpp(extend_display_for_color, context)),
    extend_cpp_forward_segment(extend_display_for_color, context)))

  results.push(assert_eq_str('collect_fn_defs_cpp extend decl matches string fn_defs',
    print_cpp_declarations(collect_fn_defs_cpp([extend_display_for_color], context)),
    collect_all_decl_parts([extend_display_for_color], context).fn_defs.join('')))

  const extend_context_resolve = (codegen_context: CodegenContext, name: string) => codegen_context.resolve(name)
  const extend_gen_decl = (declaration: Shared<SemanticDeclaration>, codegen_context: CodegenContext) => gen_decl(declaration, codegen_context)
  const extend_string = gen_decl_extend('Color', 'Display', [color_to_string], context, extend_context_resolve, extend_gen_decl)

  results.push(assert_eq_str('gen_decl_extend_cpp matches string gen_decl_extend',
    print_cpp_declarations(gen_decl_extend_cpp('Color', 'Display', [color_to_string], context)),
    extend_string))

  const trait_suffix_string = gen_decl_extend_trait_suffix(
    'Color', 'Display', [color_to_string], context, extend_context_resolve)
  results.push(assert_eq_str('gen_decl_extend_trait_suffix_cpp matches string',
    print_cpp_declarations(gen_decl_extend_trait_suffix_cpp(
      'Color', 'Display', [color_to_string], context, extend_context_resolve)),
    trait_suffix_string))
  const trait_suffix_native = gen_decl_extend_trait_suffix_cpp(
    'Color', 'Display', [color_to_string], context, extend_context_resolve)
  const trait_static_assert_index = trait_suffix_native.length() - 1
  results.push(assert_eq_str('extend_trait_static_assert_decl_cpp: Display generic trait',
    print_cpp_declaration(trait_suffix_native[trait_static_assert_index]),
    static_assert_concept_for_type_line('Display', 'Color', 'Color does not implement Display')))
  const color_visit = fn_decl('Color_visit', [color_self], tstr(), make_str_expr('red'))
  const expr_visitor_suffix = gen_decl_extend_trait_suffix_cpp(
    'Color', 'ExprVisitor', [color_visit], context, extend_context_resolve)
  const expr_visitor_static_assert_index = expr_visitor_suffix.length() - 1
  results.push(assert_eq_str('extend_trait_static_assert_decl_cpp: ExprVisitor two-arg',
    print_cpp_declaration(expr_visitor_suffix[expr_visitor_static_assert_index]),
    static_assert_concept_for_result_and_implementor_line(
      'expr_visitor::ExprVisitor', 'mlc::String', 'Color', 'Color does not implement ExprVisitor')))
  results.push(assert_code_contains('gen_decl_extend_trait_suffix_cpp: trait wrapper forward',
    print_cpp_declarations(gen_decl_extend_trait_suffix_cpp(
      'Color', 'Display', [color_to_string], context, extend_context_resolve)),
    'inline mlc::String to_string'))

  results.push(assert_eq_str('gen_decl_cpp SemanticDeclarationExtend matches string gen_decl',
    print_cpp_declaration(gen_decl_cpp(extend_display_for_color, context)),
