// Unit tests for declaration code generation.

import { TestResult, assert_eq_str, assert_true } from "./test_runner"
import { Program, TypeVariant, Param, FieldDef, TyI32, TyString, TyUnit, TyNamed, span_unknown } from "../ast"
import { create_codegen_context } from "../codegen/context"
import { gen_fn_proto, gen_fn_decl, gen_trait_decl, gen_decl, gen_proto, decls_have_main } from "../codegen/decl"
import { empty_program, record_variant, tuple_variant, unit_variant, field_definition } from "./ast_builders"
import { assert_code_contains, empty_codegen_context } from "./codegen_test_helpers"
import { SDecl, SExpr, SExprUnit, SExprIdent, SExprStr, SExprBin, SDeclFn, SDeclType, SDeclExported, SDeclExtend } from "../semantic_ir"
import { Type, TI32, TString, TUnit, TUnknown } from "../checker/registry"

fn ti32()  -> Shared<Type> = Shared.new(TI32)
fn tstr()  -> Shared<Type> = Shared.new(TString)
fn tunit() -> Shared<Type> = Shared.new(TUnit)
fn unk()   -> Shared<Type> = Shared.new(TUnknown)

fn make_ident(name: string) -> Shared<SExpr> = Shared.new(SExprIdent(name, unk(), span_unknown()))
fn make_bin(op: string, left: Shared<SExpr>, right: Shared<SExpr>) -> Shared<SExpr> = Shared.new(SExprBin(op, left, right, unk(), span_unknown()))
fn make_unit_expr() -> Shared<SExpr> = Shared.new(SExprUnit(tunit(), span_unknown()))

fn iparam(name: string) -> Shared<Param> = Shared.new(Param { name: name, is_mut: false, typ: Shared.new(TyI32) })
fn fn_decl(name: string, params: [Shared<Param>], return_type: Shared<Type>, body: Shared<SExpr>) -> Shared<SDecl> =
  Shared.new(SDeclFn(name, [], [], params, return_type, body))

fn make_str_expr(text: string) -> Shared<SExpr> = Shared.new(SExprStr(text, tstr(), span_unknown()))

export fn decl_gen_tests() -> [TestResult] = do
  let results: [TestResult] = []
  const context = empty_codegen_context()

  // --- gen_fn_proto -----------------------------------------------------------

  results.push(assert_eq_str("gen_fn_proto: zero params",
    gen_fn_proto("compute", [], [], [], tunit(), context),
    "void compute() noexcept;\n"))

  results.push(assert_eq_str("gen_fn_proto: single i32 param",
    gen_fn_proto("double_it", [], [], [iparam("value")], ti32(), context),
    "int double_it(int value) noexcept;\n"))

  results.push(assert_eq_str("gen_fn_proto: two params",
    gen_fn_proto("add", [], [], [iparam("left"), iparam("right")], ti32(), context),
    "int add(int left, int right) noexcept;\n"))

  results.push(assert_eq_str("gen_fn_proto: string return type",
    gen_fn_proto("greet", [], [], [Shared.new(Param { name: "name", is_mut: false, typ: Shared.new(TyString) })], tstr(), context),
    "mlc::String greet(mlc::String name) noexcept;\n"))

  // --- gen_fn_decl ------------------------------------------------------------

  results.push(assert_eq_str("gen_fn_decl: identity function",
    gen_fn_decl("identity", [], [], [iparam("value")], ti32(), make_ident("value"), context),
    "int identity(int value) noexcept{\nreturn value;\n}\n"))

  results.push(assert_eq_str("gen_fn_decl: addition",
    gen_fn_decl("add", [], [], [iparam("left"), iparam("right")], ti32(),
      make_bin("+", make_ident("left"), make_ident("right")), context),
    "int add(int left, int right) noexcept{\nreturn (left + right);\n}\n"))

  results.push(assert_eq_str("gen_fn_decl: unit return",
    gen_fn_decl("nothing", [], [], [], tunit(), make_unit_expr(), context),
    "void nothing() noexcept{\nreturn /* unit */;\n}\n"))

  // --- gen_decl with SDeclFn ---------------------------------------------------

  const add_decl = fn_decl("add", [iparam("left"), iparam("right")], ti32(),
    make_bin("+", make_ident("left"), make_ident("right")))

  results.push(assert_code_contains("gen_decl DeclFn: contains return type",
    gen_decl(add_decl, context), "int add"))

  results.push(assert_code_contains("gen_decl DeclFn: contains body",
    gen_decl(add_decl, context), "return (left + right)"))

  // --- gen_decl with SDeclType -------------------------------------------------

  const point_type = Shared.new(SDeclType("Point", [],
    [record_variant("Point", [field_definition("x", Shared.new(TyI32)), field_definition("y", Shared.new(TyI32))])]))

  results.push(assert_code_contains("gen_decl DeclType: record struct",
    gen_decl(point_type, context), "Point"))

  const color_type = Shared.new(SDeclType("Color", [],
    [unit_variant("Red"), unit_variant("Green"), unit_variant("Blue")]))

  results.push(assert_code_contains("gen_decl DeclType: unit variants",
    gen_decl(color_type, context), "Red"))

  // --- gen_trait_decl + SDeclExtend --------------------------------------------

  const display_self = Shared.new(Param { name: "self", is_mut: false, typ: Shared.new(TyNamed("Display")) })
  const display_method = fn_decl("Display_to_string", [display_self], tstr(), make_unit_expr())
  results.push(assert_code_contains("gen_trait_decl: concept keyword",
    gen_trait_decl(context, "Display", [], [display_method]), "concept"))
  results.push(assert_code_contains("gen_trait_decl: trait identifier",
    gen_trait_decl(context, "Display", [], [display_method]), "Display"))

  const color_self = Shared.new(Param { name: "self", is_mut: false, typ: Shared.new(TyNamed("Color")) })
  const color_to_string = fn_decl("Color_to_string", [color_self], tstr(), make_str_expr("red"))
  const extend_display_for_color = Shared.new(SDeclExtend("Color", "Display", [color_to_string]))
  results.push(assert_code_contains("gen_decl SDeclExtend: static_assert implements trait",
    gen_decl(extend_display_for_color, context), "static_assert"))
  results.push(assert_code_contains("gen_decl SDeclExtend: trait name in assert",
    gen_decl(extend_display_for_color, context), "Display"))

  // --- gen_decl with SDeclExported ---------------------------------------------

  const exported_fn = Shared.new(SDeclExported(fn_decl("square",
    [iparam("value")], ti32(),
    make_bin("*", make_ident("value"), make_ident("value")))))

  results.push(assert_code_contains("gen_decl SDeclExported: generates body",
    gen_decl(exported_fn, context), "int square"))

  results.push(assert_code_contains("gen_decl SDeclExported: contains multiplication",
    gen_decl(exported_fn, context), "value * value"))

  // --- gen_proto --------------------------------------------------------------

  results.push(assert_eq_str("gen_proto SDeclFn: produces prototype",
    gen_proto(add_decl, context),
    "int add(int left, int right) noexcept;\n"))

  results.push(assert_eq_str("gen_proto SDeclType: empty string",
    gen_proto(point_type, context), ""))

  // --- decls_have_main --------------------------------------------------------

  const main_decl  = fn_decl("main",  [], tunit(), make_unit_expr())
  const other_decl = fn_decl("other", [], tunit(), make_unit_expr())

  results.push(assert_true("decls_have_main: finds main",
    decls_have_main([main_decl, other_decl])))

  results.push(assert_true("decls_have_main: no main",
    !decls_have_main([other_decl])))

  results.push(assert_true("decls_have_main: empty list",
    !decls_have_main([])))

  results
end
