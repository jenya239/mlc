// Unit tests for declaration code generation.

import { TestResult, assert_eq_str, assert_true } from './test_runner'
import { Program, TypeVariant, Param, FieldDef, TyI32, TyString, TyUnit, TyNamed, span_unknown, Span, ExprUnit, ExprInt, PatUnit, WhereClauseBound } from '../frontend/ast'
import { tokenize } from '../frontend/lexer'
import { parse_program } from '../frontend/parser/decls'
import { check } from '../checker/check/check'
import { transform_program } from '../checker/transform/transform_decl'
import { create_codegen_context } from '../codegen/context'
import { gen_extend_wrapper_protos } from '../codegen/decl/decl_extend'
import { gen_fn_proto, gen_fn_decl, gen_trait_decl, gen_trait_struct, gen_decl, gen_proto, decls_have_main, extend_method_forward_segments, extend_cpp_forward_segment, collect_all_decl_parts } from '../codegen/decl/decl'
import { gen_fn_proto_cpp, gen_fn_decl_cpp, gen_decl_cpp, gen_proto_cpp, print_cpp_declaration, print_cpp_declarations, extend_method_forward_segments_cpp, gen_extend_wrapper_protos_cpp, extend_cpp_forward_segment_cpp, collect_fn_defs_cpp, main_program_parameter_items_cpp, main_set_args_preamble_cpp } from '../codegen/decl_cpp'
import { main_program_parameter_list } from '../codegen/expr/expr'
import { empty_program, record_variant, tuple_variant, unit_variant, field_definition } from './ast_builders'
import { assert_code_contains, empty_codegen_context } from './codegen_test_helpers'
import { SDecl, SExpr, SExprUnit, SExprIdent, SExprStr, SExprBin, SExprInt, SExprBool, SExprQuestion, SExprBlock, SExprIf, SExprMatch, SExprWhile, SMatchArm, SStmtLet, SStmtExpr, SDeclFn, SDeclType, SDeclExported, SDeclExtend, sdecl_span } from '../ir/semantic_ir'
import { Type, TypeRegistry, TI32, TString, TBool, TUnit, TUnknown } from '../checker/registry'
import { gen_return_body, gen_return_body_cpp } from '../codegen/stmt/return_body'
import { print_cpp_statements } from '../codegen/stmt_cpp'

fn ti32()  -> Shared<Type> = Shared.new(TI32)
fn tstr()  -> Shared<Type> = Shared.new(TString)
fn tunit() -> Shared<Type> = Shared.new(TUnit)
fn tbool() -> Shared<Type> = Shared.new(TBool)
fn unk()   -> Shared<Type> = Shared.new(TUnknown)

fn make_ident(name: string) -> Shared<SExpr> = Shared.new(SExprIdent(name, unk(), span_unknown()))
fn make_bin(op: string, left: Shared<SExpr>, right: Shared<SExpr>) -> Shared<SExpr> = Shared.new(SExprBin(op, left, right, unk(), span_unknown()))
fn make_unit_expr() -> Shared<SExpr> = Shared.new(SExprUnit(tunit(), span_unknown()))
fn make_int(value: i32) -> Shared<SExpr> = Shared.new(SExprInt(value, ti32(), span_unknown()))
fn make_bool(value: bool) -> Shared<SExpr> = Shared.new(SExprBool(value, tbool(), span_unknown()))
fn make_question(inner: Shared<SExpr>) -> Shared<SExpr> =
  Shared.new(SExprQuestion(inner, unk(), span_unknown()))

fn iparam(name: string) -> Shared<Param> = Shared.new(Param { name: name, is_mut: false, typ: Shared.new(TyI32), has_default: false, default: Shared.new(ExprUnit(span_unknown())), param_pattern: Shared.new(PatUnit(span_unknown())) })
fn fn_decl(name: string, params: [Shared<Param>], return_type: Shared<Type>, body: Shared<SExpr>) -> Shared<SDecl> = do
  const where_clause_bounds: [WhereClauseBound] = []
  Shared.new(SDeclFn(name, [], [], params, return_type, body, where_clause_bounds, span_unknown()))
end

fn generic_param(name: string) -> Shared<Param> =
  Shared.new(Param {
    name: name,
    is_mut: false,
    typ: Shared.new(TyNamed("T")),
    has_default: false,
    default: Shared.new(ExprUnit(span_unknown())),
    param_pattern: Shared.new(PatUnit(span_unknown()))
  })

fn type_decl(name: string, type_params: [string], variants: [Shared<TypeVariant>], derive_traits: [string]) -> Shared<SDecl> =
  Shared.new(SDeclType(name, type_params, variants, derive_traits, span_unknown()))

fn extend_decl(type_name: string, trait_name: string, methods: [Shared<SDecl>]) -> Shared<SDecl> =
  Shared.new(SDeclExtend(type_name, trait_name, methods, span_unknown()))

fn first_transformed_decl_span(program: Program, registry: TypeRegistry) -> Span = do
  const transformed = transform_program(program, registry)
  if transformed.decls.length() == 0 then span_unknown() else sdecl_span(transformed.decls[0]) end
end

fn transformed_decl_span(source: string) -> Span = do
  const program = parse_program(tokenize(source).tokens)
  match check(program) {
    Ok(checked) => first_transformed_decl_span(program, checked.registry),
    Err(_) => span_unknown()
  }
end

fn transformed_fn_decl_span(source: string) -> Span = transformed_decl_span(source)
fn transformed_type_decl_span(source: string) -> Span = transformed_decl_span(source)
fn transformed_trait_decl_span(source: string) -> Span = transformed_decl_span(source)
fn transformed_extend_decl_span(source: string) -> Span = transformed_decl_span(source)

fn make_str_expr(text: string) -> Shared<SExpr> = Shared.new(SExprStr(text, tstr(), span_unknown()))

export fn decl_gen_tests() -> [TestResult] = do
  let results: [TestResult] = []
  const context = empty_codegen_context()

  // --- gen_fn_proto -----------------------------------------------------------

  results.push(assert_eq_str('gen_fn_proto: zero params',
    gen_fn_proto('compute', [], [], [], tunit(), context),
    'void compute() noexcept;\n'))

  results.push(assert_eq_str('gen_fn_proto: single i32 param',
    gen_fn_proto('double_it', [], [], [iparam('value')], ti32(), context),
    'int double_it(int value) noexcept;\n'))

  results.push(assert_eq_str('gen_fn_proto: two params',
    gen_fn_proto('add', [], [], [iparam('left'), iparam('right')], ti32(), context),
    'int add(int left, int right) noexcept;\n'))

  results.push(assert_eq_str('gen_fn_proto: string return type',
    gen_fn_proto('greet', [], [], [Shared.new(Param { name: 'name', is_mut: false, typ: Shared.new(TyString), has_default: false, default: Shared.new(ExprUnit(span_unknown())), param_pattern: Shared.new(PatUnit(span_unknown())) })], tstr(), context),
    'mlc::String greet(mlc::String name) noexcept;\n'))

  results.push(assert_eq_str('gen_fn_proto: default param literal',
    gen_fn_proto("f", [], [], [Shared.new(Param { name: "a", is_mut: false, typ: Shared.new(TyI32), has_default: true, default: Shared.new(ExprInt(2, span_unknown())), param_pattern: Shared.new(PatUnit(span_unknown())) })], ti32(), context),
    'int f(int a = 2) noexcept;\n'))

  results.push(assert_eq_str('gen_fn_decl: body omits default value',
    gen_fn_decl("f", [], [], [Shared.new(Param { name: "a", is_mut: false, typ: Shared.new(TyI32), has_default: true, default: Shared.new(ExprInt(2, span_unknown())), param_pattern: Shared.new(PatUnit(span_unknown())) })], ti32(), make_ident("a"), context),
    'int f(int a) noexcept{\nreturn a;\n}\n'))

  // --- gen_fn_decl ------------------------------------------------------------

  results.push(assert_eq_str('gen_fn_decl: identity function',
    gen_fn_decl('identity', [], [], [iparam('value')], ti32(), make_ident('value'), context),
    'int identity(int value) noexcept{\nreturn value;\n}\n'))

  results.push(assert_eq_str('gen_fn_decl: addition',
    gen_fn_decl('add', [], [], [iparam('left'), iparam('right')], ti32(),
      make_bin("+", make_ident('left'), make_ident('right')), context),
    'int add(int left, int right) noexcept{\nreturn (left + right);\n}\n'))

  results.push(assert_eq_str('gen_fn_decl: unit return',
    gen_fn_decl('nothing', [], [], [], tunit(), make_unit_expr(), context),
    'void nothing() noexcept{\n}\n'))

  // --- gen_decl with SDeclFn ---------------------------------------------------

  const add_decl = fn_decl('add', [iparam('left'), iparam('right')], ti32(),
    make_bin("+", make_ident('left'), make_ident('right')))

  results.push(assert_code_contains('gen_decl DeclFn: contains return type',
    gen_decl(add_decl, context), 'int add'))

  results.push(assert_code_contains('gen_decl DeclFn: contains body',
    gen_decl(add_decl, context), 'return (left + right)'))

  // --- gen_decl with SDeclType -------------------------------------------------

  const point_type = type_decl('Point', [],
    [record_variant('Point', [field_definition("x", Shared.new(TyI32)), field_definition("y", Shared.new(TyI32))])], [])

  results.push(assert_code_contains('gen_decl DeclType: record struct',
    gen_decl(point_type, context), 'Point'))

  const color_type = type_decl('Color', [],
    [unit_variant('Red'), unit_variant('Green'), unit_variant('Blue')], [])

  results.push(assert_code_contains('gen_decl DeclType: unit variants',
    gen_decl(color_type, context), 'Red'))

  // --- derive method generation ------------------------------------------------

  const point_display = type_decl('Point', [],
    [record_variant('Point', [field_definition("x", Shared.new(TyI32)), field_definition("y", Shared.new(TyI32))])], ['Display'])

  results.push(assert_code_contains('derive Display record: generates to_string function',
    gen_decl(point_display, context), 'Point_to_string'))

  results.push(assert_code_contains('derive Display record: uses mlc::to_string for i32 field',
    gen_decl(point_display, context), 'mlc::to_string(self.x)'))

  const point_eq = type_decl('Point', [],
    [record_variant('Point', [field_definition("x", Shared.new(TyI32)), field_definition("y", Shared.new(TyI32))])], ['Eq'])

  results.push(assert_code_contains('derive Eq record: generates operator==',
    gen_decl(point_eq, context), 'operator=='))

  results.push(assert_code_contains('derive Eq record: compares fields',
    gen_decl(point_eq, context), 'a.x == b.x'))

  const color_display = type_decl('Color', [],
    [unit_variant('Red'), unit_variant('Green'), unit_variant('Blue')], ['Display'])

  results.push(assert_code_contains('derive Display sum type: generates to_string',
    gen_decl(color_display, context), 'Color_to_string'))

  results.push(assert_code_contains('derive Display sum type: handles Red variant',
    gen_decl(color_display, context), '"Red"'))

  const point_hash = type_decl('Point', [],
    [record_variant('Point', [
      field_definition('tag', Shared.new(TyI32)),
      field_definition('flag', Shared.new(TyBool)),
      field_definition('label', Shared.new(TyString))
    ])], ['Hash'])

  results.push(assert_code_contains('derive Hash record: namespace std and struct hash',
    gen_decl(point_hash, context), 'namespace std'))
  results.push(assert_code_contains('derive Hash record: struct hash<Point>',
    gen_decl(point_hash, context), 'struct hash<Point>'))
  results.push(assert_code_contains('derive Hash record: combines i32 field',
    gen_decl(point_hash, context), 'std::hash<int>{}(self.tag)'))
  results.push(assert_code_contains('derive Hash record: combines bool field',
    gen_decl(point_hash, context), 'std::hash<bool>{}(self.flag)'))
  results.push(assert_code_contains('derive Hash record: combines string field',
    gen_decl(point_hash, context), 'std::hash<mlc::String>{}(self.label)'))
  results.push(assert_code_contains('derive Hash record: boost-style combine constant',
    gen_decl(point_hash, context), '0x9e3779b97f4a7c15ULL'))

  const empty_hash = type_decl('Empty', [],
    [record_variant('Empty', [])], ['Hash'])
  results.push(assert_code_contains('derive Hash empty record: fnv offset basis seed',
    gen_decl(empty_hash, context), '1469598103934665603ULL'))

  const hue_hash = type_decl('Hue', [],
    [unit_variant('North'), unit_variant('South')], ['Hash'])
  results.push(assert_code_contains('derive Hash sum: holds_alternative first variant',
    gen_decl(hue_hash, context), 'std::holds_alternative<North>'))
  results.push(assert_code_contains('derive Hash sum: holds_alternative second variant',
    gen_decl(hue_hash, context), 'std::holds_alternative<South>'))

  const shape_hash = type_decl('Shape', [],
    [tuple_variant('Circle', [Shared.new(TyI32)]), unit_variant('Empty')], ['Hash'])
  results.push(assert_code_contains('derive Hash sum tuple variant: std get and field0',
    gen_decl(shape_hash, context), 'std::get<Circle>(self._).field0'))

  // --- gen_trait_decl + SDeclExtend --------------------------------------------

  const display_self = Shared.new(Param { name: 'self', is_mut: false, typ: Shared.new(TyNamed('Display')), has_default: false, default: Shared.new(ExprUnit(span_unknown())), param_pattern: Shared.new(PatUnit(span_unknown())) })
  const display_method = fn_decl('Display_to_string', [display_self], tstr(), make_unit_expr())
  results.push(assert_code_contains('gen_trait_decl: concept keyword',
    gen_trait_decl(context, 'Display', [], [display_method]), 'concept'))
  results.push(assert_code_contains('gen_trait_decl: trait identifier',
    gen_trait_decl(context, 'Display', [], [display_method]), 'Display'))

  results.push(assert_code_contains('gen_trait_struct: std::function field',
    gen_trait_struct(context, 'Display', [], [display_method]), 'std::function'))
  results.push(assert_code_contains('gen_trait_struct: vtable struct name',
    gen_trait_struct(context, 'Display', [], [display_method]), 'struct Display_vtable'))
  results.push(assert_code_contains('gen_trait_struct: method name',
    gen_trait_struct(context, 'Display', [], [display_method]), 'to_string'))

  const color_self = Shared.new(Param { name: 'self', is_mut: false, typ: Shared.new(TyNamed('Color')), has_default: false, default: Shared.new(ExprUnit(span_unknown())), param_pattern: Shared.new(PatUnit(span_unknown())) })
  const color_to_string = fn_decl('Color_to_string', [color_self], tstr(), make_str_expr('red'))
  const extend_display_for_color = extend_decl('Color', 'Display', [color_to_string])
  results.push(assert_code_contains('gen_decl SDeclExtend: static_assert implements trait',
    gen_decl(extend_display_for_color, context), 'static_assert'))
  results.push(assert_code_contains('gen_decl SDeclExtend: trait name in assert',
    gen_decl(extend_display_for_color, context), 'Display'))

  results.push(assert_eq_str('extend_method_forward_segments_cpp matches string',
    print_cpp_declarations(extend_method_forward_segments_cpp([extend_display_for_color], context)),
    extend_method_forward_segments([extend_display_for_color], context).join('')))

  results.push(assert_eq_str('gen_extend_wrapper_protos_cpp matches string',
    print_cpp_declarations(gen_extend_wrapper_protos_cpp('Color', 'Display', [color_to_string], context)),
    gen_extend_wrapper_protos('Color', 'Display', [color_to_string], context)))

  results.push(assert_eq_str('extend_cpp_forward_segment_cpp matches string',
    print_cpp_declarations(extend_cpp_forward_segment_cpp(extend_display_for_color, context)),
    extend_cpp_forward_segment(extend_display_for_color, context)))

  results.push(assert_eq_str('collect_fn_defs_cpp extend decl matches string fn_defs',
    print_cpp_declarations(collect_fn_defs_cpp([extend_display_for_color], context)),
    collect_all_decl_parts([extend_display_for_color], context).fn_defs.join('')))

  // --- gen_decl with SDeclExported ---------------------------------------------

  const exported_fn = Shared.new(SDeclExported(fn_decl('square',
    [iparam('value')], ti32(),
    make_bin("*", make_ident('value'), make_ident('value')))))

  results.push(assert_code_contains('gen_decl SDeclExported: generates body',
    gen_decl(exported_fn, context), 'int square'))

  results.push(assert_code_contains('gen_decl SDeclExported: contains multiplication',
    gen_decl(exported_fn, context), 'value * value'))

  // --- gen_proto --------------------------------------------------------------

  results.push(assert_eq_str('gen_proto SDeclFn: produces prototype',
    gen_proto(add_decl, context),
    'int add(int left, int right) noexcept;\n'))

  results.push(assert_true('transform_decl SDeclFn span from body',
    transformed_fn_decl_span('fn probe() -> i32 = 42').line > 0))

  results.push(assert_true('transform_decl SDeclType span from name',
    transformed_type_decl_span('type Box = { value: i32 }').line > 0))

  results.push(assert_true('transform_decl SDeclTrait span from name',
    transformed_trait_decl_span('trait Display { fn to_string(self: Display) -> string = "" }').line > 0))

  results.push(assert_true('transform_decl SDeclExtend span from name',
    transformed_extend_decl_span('extend Color : Display { fn to_string(self: Color) -> string = "red" }').line > 0))

  results.push(assert_eq_str('gen_proto SDeclType: empty string',
    gen_proto(point_type, context), ''))

  // --- decls_have_main --------------------------------------------------------

  const main_decl  = fn_decl('main',  [], tunit(), make_unit_expr())
  const other_decl = fn_decl('other', [], tunit(), make_unit_expr())

  results.push(assert_true('decls_have_main: finds main',
    decls_have_main([main_decl, other_decl])))

  results.push(assert_true('decls_have_main: no main',
    !decls_have_main([other_decl])))

  results.push(assert_true('decls_have_main: empty list',
    !decls_have_main([])))

  results.push(assert_eq_str('gen_fn_proto_cpp matches string',
    print_cpp_declaration(gen_fn_proto_cpp('add', [], [], [iparam('left'), iparam('right')], ti32(), context)),
    gen_fn_proto('add', [], [], [iparam('left'), iparam('right')], ti32(), context)))

  results.push(assert_eq_str('gen_fn_proto_cpp: template matches string',
    print_cpp_declaration(gen_fn_proto_cpp('identity', ["T"], [[]], [generic_param('value')], unk(), context)),
    gen_fn_proto('identity', ["T"], [[]], [generic_param('value')], unk(), context)))

  results.push(assert_eq_str('gen_return_body_cpp: unit body empty',
    print_cpp_statements(gen_return_body_cpp(make_unit_expr(), context)), ''))

  results.push(assert_eq_str('gen_return_body_cpp: ident return matches string',
    print_cpp_statements(gen_return_body_cpp(make_ident('value'), context)),
    gen_return_body(make_ident('value'), context)))

  const question_body = make_question(make_int(7))
  results.push(assert_code_contains('gen_return_body_cpp: question native get_if unwrap',
    print_cpp_statements(gen_return_body_cpp(question_body, context)),
    'std::get_if<1>'))
  results.push(assert_code_contains('gen_return_body_cpp: question native ok return',
    print_cpp_statements(gen_return_body_cpp(question_body, context)),
    'std::get<0>(__try_ret).field0'))

  const block_return_body = Shared.new(SExprBlock(
    [Shared.new(SStmtLet('counter', false, make_int(1), ti32(), span_unknown()))],
    make_ident('counter'),
    ti32(),
    span_unknown()))
  results.push(assert_eq_str('gen_return_body_cpp: block let and return matches string',
    print_cpp_statements(gen_return_body_cpp(block_return_body, context)),
    gen_return_body(block_return_body, context)))

  const block_unit_body = Shared.new(SExprBlock(
    [Shared.new(SStmtLet('counter', false, make_int(1), ti32(), span_unknown()))],
    make_unit_expr(),
    tunit(),
    span_unknown()))
  results.push(assert_eq_str('gen_return_body_cpp: block unit tail matches string',
    print_cpp_statements(gen_return_body_cpp(block_unit_body, context)),
    gen_return_body(block_unit_body, context)))

  const if_return_body = Shared.new(SExprIf(
    make_bool(true),
    make_int(1),
    make_int(0),
    ti32(),
    span_unknown()))
  results.push(assert_eq_str('gen_return_body_cpp: if else return native',
    print_cpp_statements(gen_return_body_cpp(if_return_body, context)),
    'if (true) {\n  return 1;\n} else {\n  return 0;\n}\n'))

  const else_if_return_body = Shared.new(SExprIf(
    make_bool(true),
    make_int(1),
    Shared.new(SExprIf(make_bool(false), make_int(2), make_int(3), ti32(), span_unknown())),
    ti32(),
    span_unknown()))
  results.push(assert_eq_str('gen_return_body_cpp: else-if return native',
    print_cpp_statements(gen_return_body_cpp(else_if_return_body, context)),
    'if (true) {\n  return 1;\n} else if (false) {\n  return 2;\n} else {\n  return 3;\n}\n'))

  const if_then_block_body = Shared.new(SExprIf(
    make_bool(true),
    Shared.new(SExprBlock(
      [Shared.new(SStmtLet('temporary', false, make_int(1), ti32(), span_unknown()))],
      make_ident('temporary'),
      ti32(),
      span_unknown())),
    make_int(0),
    ti32(),
    span_unknown()))
  results.push(assert_eq_str('gen_return_body_cpp: if then block prefix native',
    print_cpp_statements(gen_return_body_cpp(if_then_block_body, context)),
    'if (true) {\n  auto temporary = 1;\n  return temporary;\n} else {\n  return 0;\n}\n'))

  const match_arm_block_body = Shared.new(SExprMatch(
    make_int(1),
    [Shared.new(SMatchArm {
      pat: Shared.new(PatUnit(span_unknown())),
      has_guard: false,
      when_condition: make_unit_expr(),
      body: Shared.new(SExprBlock(
        [Shared.new(SStmtLet('temporary', false, make_int(2), ti32(), span_unknown()))],
        make_ident('temporary'),
        ti32(),
        span_unknown()))
    })],
    ti32(),
    span_unknown()))
  results.push(assert_code_contains('gen_return_body_cpp: match arm block prefix native',
    print_cpp_statements(gen_return_body_cpp(match_arm_block_body, context)),
    'auto temporary = 2'))

  const while_return_body = Shared.new(SExprWhile(
    make_bool(true),
    [Shared.new(SStmtExpr(make_int(0), span_unknown()))],
    tunit(),
    span_unknown()))
  results.push(assert_code_contains('gen_fn_decl_cpp: while return body native',
    print_cpp_declaration(gen_fn_decl_cpp('spin', [], [], [], tunit(), while_return_body, context)),
    'while (true)'))

  results.push(assert_eq_str('gen_fn_decl_cpp: identity native return',
    print_cpp_declaration(gen_fn_decl_cpp('identity', [], [], [iparam('value')], ti32(), make_ident('value'), context)),
    'int identity(int value) noexcept{\n  return value;\n}\n'))

  results.push(assert_code_contains('gen_fn_decl_cpp: template native prefix',
    print_cpp_declaration(gen_fn_decl_cpp('identity', ["T"], [[]], [generic_param('value')], unk(), make_ident('value'), context)),
    'template<typename T>'))
  results.push(assert_code_contains('gen_fn_decl_cpp: template native return',
    print_cpp_declaration(gen_fn_decl_cpp('identity', ["T"], [[]], [generic_param('value')], unk(), make_ident('value'), context)),
    'return value'))

  results.push(assert_eq_str('gen_fn_proto_cpp: main native proto',
    print_cpp_declaration(gen_fn_proto_cpp('main', [], [], [], ti32(), context)),
    gen_fn_proto('main', [], [], [], ti32(), context)))

  results.push(assert_code_contains('gen_fn_decl_cpp: main string bridge argc argv',
    print_cpp_declaration(gen_fn_decl_cpp('main', [], [], [], ti32(), make_int(0), context)),
    'int argc, char** argv'))

  results.push(assert_eq_str('main_program_parameter_items_cpp matches string',
    main_program_parameter_items_cpp().join(', '),
    main_program_parameter_list()))

  results.push(assert_eq_str('main_set_args_preamble_cpp native prelude',
    print_cpp_statements(main_set_args_preamble_cpp()),
    'mlc::io::set_args(std::vector<mlc::String>((argv + 1), (argv + argc)));\n'))

  results.push(assert_eq_str('gen_decl_cpp DeclFn native return',
    print_cpp_declaration(gen_decl_cpp(fn_decl('add', [iparam('left'), iparam('right')], ti32(),
      make_bin("+", make_ident('left'), make_ident('right'))), context)),
    'int add(int left, int right) noexcept{\n  return (left + right);\n}\n'))

  results.push(assert_eq_str('gen_proto_cpp DeclFn matches string',
    print_cpp_declaration(gen_proto_cpp(fn_decl('add', [iparam('left'), iparam('right')], ti32(),
      make_bin("+", make_ident('left'), make_ident('right'))), context)),
    gen_proto(fn_decl('add', [iparam('left'), iparam('right')], ti32(),
      make_bin("+", make_ident('left'), make_ident('right'))), context)))

  results
end
