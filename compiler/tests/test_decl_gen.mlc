    print_cpp_declarations(gen_derive_display_cpp('Color', color_variants)), 'Color_to_string'))

  results.push(assert_code_contains('gen_derive_display_cpp sum: Red variant',
    print_cpp_declarations(gen_derive_display_cpp('Color', color_variants)), 'holds_alternative<Red>'))

  results.push(assert_code_contains('gen_derive_eq_cpp record: operator==',
    print_cpp_declarations(gen_derive_eq_cpp('Point', point_variants)), 'operator=='))

  results.push(assert_code_contains('gen_derive_eq_cpp record: field compare',
    print_cpp_declarations(gen_derive_eq_cpp('Point', point_variants)), 'a.x == b.x'))

  results.push(assert_code_contains('gen_derive_eq_cpp sum: operator==',
    print_cpp_declarations(gen_derive_eq_cpp('Color', color_variants)), 'operator=='))

  results.push(assert_code_contains('gen_derive_eq_cpp sum: discriminant compare',
    print_cpp_declarations(gen_derive_eq_cpp('Color', color_variants)), 'a._ == b._'))

  results.push(assert_code_contains('gen_derive_ord_cpp record: operator<',
    print_cpp_declarations(gen_derive_ord_cpp('Point', point_variants)), 'operator<'))

  results.push(assert_code_contains('gen_derive_ord_cpp record: field compare',
    print_cpp_declarations(gen_derive_ord_cpp('Point', point_variants)), 'a.x < b.x'))

  results.push(assert_code_contains('gen_derive_ord_cpp sum: operator<',
    print_cpp_declarations(gen_derive_ord_cpp('Color', color_variants)), 'operator<'))

  results.push(assert_code_contains('gen_derive_ord_cpp sum: discriminant compare',
    print_cpp_declarations(gen_derive_ord_cpp('Color', color_variants)), 'a._ < b._'))

  results.push(assert_code_contains('gen_derive_hash_cpp record: struct hash',
    print_cpp_declarations(gen_derive_hash_cpp('Point', point_hash_variants)), 'struct hash<Point>'))

  results.push(assert_code_contains('gen_derive_hash_cpp record: combines i32',
    print_cpp_declarations(gen_derive_hash_cpp('Point', point_hash_variants)), 'std::hash<int>{}(self.tag)'))

  results.push(assert_code_contains('gen_derive_hash_cpp sum: holds_alternative',
    print_cpp_declarations(gen_derive_hash_cpp('Hue', hue_hash_variants)), 'std::holds_alternative<North>'))

  const hash_record_native = gen_derive_hash_cpp('Point', point_hash_variants)
  results.push(assert_true('gen_derive_hash_cpp record: CppStdHashSpecialization',
    cpp_decl_is_std_hash_specialization(hash_record_native[0], 'Point')))
  results.push(assert_true('gen_derive_hash_cpp record: not CppDeclarationFragment',
    !cpp_decl_is_fragment(hash_record_native[0])))

  const hash_sum_native = gen_derive_hash_cpp('Hue', hue_hash_variants)
  results.push(assert_true('gen_derive_hash_cpp sum: CppStdHashSpecialization',
    cpp_decl_is_std_hash_specialization(hash_sum_native[0], 'Hue')))
  results.push(assert_true('gen_derive_hash_cpp sum: not CppDeclarationFragment',
    !cpp_decl_is_fragment(hash_sum_native[0])))

  results.push(assert_true('gen_derive_hash_cpp record: body no CppStatementFragment',
    !cpp_stmt_list_contains_fragment(cpp_std_hash_body_statements(hash_record_native[0]))))

  results.push(assert_true('gen_derive_hash_cpp sum: body no CppStatementFragment',
    !cpp_stmt_list_contains_fragment(cpp_std_hash_body_statements(hash_sum_native[0]))))

  const empty_hash_native = gen_derive_hash_cpp('Empty', empty_hash_variants)
  results.push(assert_true('gen_derive_hash_cpp empty record: body no CppStatementFragment',
    !cpp_stmt_list_contains_fragment(cpp_std_hash_body_statements(empty_hash_native[0]))))

  const point_hash_body = gen_type_decl_body_cpp(context, 'Point', [], point_hash_variants, ['Hash'])
  results.push(assert_true('gen_type_decl_body_cpp record Hash: CppStdHashSpecialization',
    cpp_decl_list_contains_std_hash_specialization(point_hash_body, 'Point')))

  const hue_hash_body = gen_type_decl_body_cpp(context, 'Hue', [], hue_hash_variants, ['Hash'])
  results.push(assert_true('gen_type_decl_body_cpp sum Hash: CppStdHashSpecialization',
    cpp_decl_list_contains_std_hash_specialization(hue_hash_body, 'Hue')))

  results.push(assert_true('gen_type_decl_body_cpp record Hash: body no CppStatementFragment',
    !cpp_decl_list_hash_body_contains_fragment(point_hash_body)))

  results.push(assert_true('gen_type_decl_body_cpp sum Hash: body no CppStatementFragment',
    !cpp_decl_list_hash_body_contains_fragment(hue_hash_body)))

  results.push(assert_code_contains('gen_derive_methods_cpp: Display and Eq',
    print_cpp_declarations(gen_derive_methods_cpp('Point', point_variants, ['Display', 'Eq'])),
    'Point_to_string'))

  results.push(assert_code_contains('gen_derive_methods_cpp: Display and Eq operator',
    print_cpp_declarations(gen_derive_methods_cpp('Point', point_variants, ['Display', 'Eq'])),
    'operator=='))

  results.push(assert_code_contains('gen_derive_json_cpp record: Point_to_json',
    print_cpp_declarations(gen_derive_json_cpp('Point', point_variants)), 'Point_to_json'))

  results.push(assert_code_contains('gen_derive_json_cpp record: Point_from_json',
    print_cpp_declarations(gen_derive_json_cpp('Point', point_variants)), 'Point_from_json'))

  results.push(assert_code_contains('gen_derive_json_cpp record: json_set x',
    print_cpp_declarations(gen_derive_json_cpp('Point', point_variants)), 'mlc::String("x")'))

  results.push(assert_code_contains('gen_derive_json_cpp sum: Color_to_json',
    print_cpp_declarations(gen_derive_json_cpp('Color', color_variants)), 'Color_to_json'))

  results.push(assert_code_contains('gen_derive_json_cpp sum: unit tag string',
    print_cpp_declarations(gen_derive_json_cpp('Color', color_variants)), 'mlc::String("Red")'))

  results.push(assert_code_contains('gen_derive_methods_cpp: Json wired',
    print_cpp_declarations(gen_derive_methods_cpp('Point', point_variants, ['Json'])),
    'Point_to_json'))

  results.push(assert_code_contains('gen_type_decl_body_cpp: native Hash wired',
    print_cpp_declarations(gen_type_decl_body_cpp(context, 'Hue', [], hue_hash_variants, ['Hash'])),
    'struct hash<Hue>'))

  results.push(assert_eq_str('gen_decl_cpp DeclFn native return',
    print_cpp_declaration(gen_decl_cpp(fn_decl('add', [iparam('left'), iparam('right')], ti32(),
      make_bin("+", make_ident('left'), make_ident('right'))), context)),
    'int add(int left, int right) noexcept{\n  return mlc::arith::checked_add(left, right);\n}\n'))

  results.push(assert_eq_str('gen_proto_cpp DeclFn matches string',
    print_cpp_declaration(gen_proto_cpp(fn_decl('add', [iparam('left'), iparam('right')], ti32(),
      make_bin("+", make_ident('left'), make_ident('right'))), context)),
    gen_proto(fn_decl('add', [iparam('left'), iparam('right')], ti32(),
      make_bin("+", make_ident('left'), make_ident('right'))), context)))

  results.push(assert_eq_str('decl_segment_cpp phase 2 SemanticDeclarationFn matches string',
    print_cpp_declarations(decl_segment_cpp(add_decl, context, 2)),
    collect_decl_parts([add_decl], context, 2).join('')))

  results.push(assert_eq_str('decl_segment_cpp phase 2 SemanticDeclarationExported fn matches string',
    print_cpp_declarations(decl_segment_cpp(exported_fn, context, 2)),
    collect_decl_parts([exported_fn], context, 2).join('')))

  results.push(assert_eq_str('gen_decl_cpp SemanticDeclarationType record matches native body print',
    print_cpp_declaration(gen_decl_cpp(point_type, context)),
    print_cpp_declarations(gen_type_decl_body_cpp(context, 'Point', [], point_variants, []))))

  results.push(assert_eq_str('gen_decl_cpp SemanticDeclarationType sum matches string gen_decl',
    print_cpp_declaration(gen_decl_cpp(color_type, context)),
    gen_decl(color_type, context)))

  const color_sum_native = gen_decl_cpp(color_type, context)
  const color_sum_children = cpp_decl_sequence_children(color_sum_native)
  results.push(assert_eq_int('gen_decl_cpp SemanticDeclarationType sum: CppDeclarationSequence child count',
    color_sum_children.length(), 7))
  results.push(assert_eq_str('gen_decl_cpp SemanticDeclarationType sum: CppDeclarationSequence print parity',
    print_cpp_declaration(color_sum_native),
    print_cpp_declarations(color_sum_children)))

  results.push(assert_eq_str('gen_decl_cpp SemanticDeclarationTrait matches string gen_decl',
    print_cpp_declaration(gen_decl_cpp(display_trait, context)),
    gen_decl(display_trait, context)))

  const square_decl = fn_decl('square', [iparam('value')], ti32(),
    make_bin("*", make_ident('value'), make_ident('value')))

  results.push(assert_eq_str('gen_decl_cpp SemanticDeclarationExported matches unwrapped SemanticDeclarationFn',
    print_cpp_declaration(gen_decl_cpp(exported_fn, context)),
    print_cpp_declaration(gen_decl_cpp(square_decl, context))))

  results.push(assert_code_contains('gen_decl_cpp SemanticDeclarationExported matches string gen_decl signature',
    print_cpp_declaration(gen_decl_cpp(exported_fn, context)),
    'int square(int value)'))

  results.push(assert_eq_str('gen_decl_cpp SemanticDeclarationImport empty',
    print_cpp_declaration(gen_decl_cpp(Shared.new(SemanticDeclarationImport('', [])), context)), ''))

  results.push(assert_eq_str('gen_decl_cpp SemanticDeclarationAssocBind empty',
    print_cpp_declaration(gen_decl_cpp(Shared.new(SemanticDeclarationAssocBind('Item', ti32(), span_unknown())), context)), ''))

  results.push(assert_eq_str('gen_proto_cpp SemanticDeclarationType empty',
    print_cpp_declaration(gen_proto_cpp(point_type, context)), ''))

  results.push(assert_eq_str('gen_proto_cpp SemanticDeclarationTrait empty',
    print_cpp_declaration(gen_proto_cpp(display_trait, context)), ''))

  results.push(assert_eq_str('gen_proto_cpp SemanticDeclarationExtend matches string gen_proto',
    print_cpp_declaration(gen_proto_cpp(extend_display_for_color, context)),
    gen_proto(extend_display_for_color, context)))

  results.push(assert_eq_str('gen_proto_cpp SemanticDeclarationExported matches unwrapped SemanticDeclarationFn',
    print_cpp_declaration(gen_proto_cpp(exported_fn, context)),
    print_cpp_declaration(gen_proto_cpp(square_decl, context))))

  results.push(assert_code_contains('gen_proto_cpp SemanticDeclarationExported matches string gen_proto signature',
    print_cpp_declaration(gen_proto_cpp(exported_fn, context)),
    'int square(int value)'))

  results.push(assert_eq_str('gen_proto_cpp SemanticDeclarationImport empty',
    print_cpp_declaration(gen_proto_cpp(Shared.new(SemanticDeclarationImport('', [])), context)), ''))

  results.push(assert_eq_str('gen_proto_cpp SemanticDeclarationAssocBind empty',
    print_cpp_declaration(gen_proto_cpp(Shared.new(SemanticDeclarationAssocBind('Item', ti32(), span_unknown())), context)), ''))

  const extern_fn = fn_decl('external_helper', [], tunit(), Shared.new(SemanticExpressionExtern(tunit(), "", "", [], span_unknown())))
  const extern_decl_native = gen_decl_cpp(extern_fn, context)
  results.push(assert_true('gen_decl_cpp SemanticDeclarationFn extern: native CppDeclarationEmpty',
    is_cpp_decl_empty(extern_decl_native)))
  results.push(assert_eq_str('gen_decl_cpp SemanticDeclarationFn extern empty print',
    print_cpp_declaration(extern_decl_native), ''))

  const extern_proto_native = gen_proto_cpp(extern_fn, context)
  results.push(assert_true('gen_proto_cpp SemanticDeclarationFn extern: native CppDeclarationEmpty',
    is_cpp_decl_empty(extern_proto_native)))
  results.push(assert_eq_str('gen_proto_cpp SemanticDeclarationFn extern empty print',
    print_cpp_declaration(extern_proto_native), ''))

  const extend_proto_extern_native = gen_proto_cpp(extend_display_extern, context)
  results.push(assert_true('gen_proto_cpp SemanticDeclarationExtend all-extern: native CppDeclarationEmpty',
    is_cpp_decl_empty(extend_proto_extern_native)))
  results.push(assert_eq_str('gen_proto_cpp SemanticDeclarationExtend all-extern empty print',
    print_cpp_declaration(extend_proto_extern_native), ''))

  results.push(assert_true('gen_decl_cpp SemanticDeclarationImport: native CppDeclarationEmpty',
    is_cpp_decl_empty(gen_decl_cpp(Shared.new(SemanticDeclarationImport('', [])), context))))

  results.push(assert_true('gen_decl_cpp SemanticDeclarationAssocBind: native CppDeclarationEmpty',
    is_cpp_decl_empty(gen_decl_cpp(Shared.new(SemanticDeclarationAssocBind('Item', ti32(), span_unknown())), context))))

  results
end