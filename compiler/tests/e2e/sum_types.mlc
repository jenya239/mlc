type Shape = Circle(i32) | Rect(i32, i32)

fn area(s: Shape) -> i32 =
  match s {
    Circle(r) => r * r * 3,
    Rect(w, h) => w * h
  }

fn describe(s: Shape) -> string =
  match s {
    Circle(_) => "circle",
    Rect(_, _) => "rect"
  }

fn main() -> i32 = do
  const c = Circle(5)
  const r = Rect(3, 4)
  println(describe(c) + ": " + area(c).to_string())
  println(describe(r) + ": " + area(r).to_string())
  0
end
