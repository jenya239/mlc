// Unit tests for the lexer (tokenize function).

import { TestResult, assert_eq_int, assert_eq_str, assert_true } from "./test_runner"
import { tokenize } from "../lexer"
import { TKind, LStr, LTemplate } from "../ast_tokens"

fn lex_token_count(source: string) -> i32 =
  tokenize(source).tokens.length()

fn lex_first_kind(source: string) -> TKind =
  tokenize(source).tokens[0].kind

fn lex_first_string(source: string) -> string =
  match tokenize(source).tokens[0].kind {
    LStr(text) => text,
    _ => ""
  }

fn lex_template_parts(source: string) -> [string] =
  match tokenize(source).tokens[0].kind {
    LTemplate(parts) => parts,
    _ => do let r: [string] = []; r end
  }

fn lex_error_count(source: string) -> i32 =
  tokenize(source).errors.length()

export fn lexer_tests() -> [TestResult] = do
  let results: [TestResult] = []

  results.push(assert_eq_int("empty source - 1 token (Eof)",       lex_token_count(""),   1))
  results.push(assert_eq_int("whitespace only - 1 token (Eof)",    lex_token_count("   "), 1))
  results.push(assert_eq_int("comment only - 1 token (Eof)",       lex_token_count("// hi"), 1))

  results.push(assert_eq_int("'fn' - 2 tokens",                    lex_token_count("fn"),      2))
  results.push(assert_eq_int("'type' - 2 tokens",                  lex_token_count("type"),    2))
  results.push(assert_eq_int("'let' - 2 tokens",                   lex_token_count("let"),     2))
  results.push(assert_eq_int("'if' - 2 tokens",                    lex_token_count("if"),      2))
  results.push(assert_eq_int("'match' - 2 tokens",                 lex_token_count("match"),   2))
  results.push(assert_eq_int("'end' - 2 tokens",                   lex_token_count("end"),     2))

  results.push(assert_eq_int("integer literal - 2 tokens",         lex_token_count("42"),      2))
  results.push(assert_eq_int("string literal - 2 tokens",          lex_token_count("\"hi\""),  2))
  results.push(assert_eq_str("string literal decodes escaped newline",
    lex_first_string("\"a\\nb\""), "a\nb"))
  results.push(assert_eq_str("string literal decodes escaped quote",
    lex_first_string("\"say \\\"hi\\\"\""), "say \"hi\""))
  results.push(assert_eq_int("multiline double-quoted string - 2 tokens (LStr + Eof)",
    lex_token_count("\"a\nb\""), 2))
  results.push(assert_eq_str("multiline double-quoted string literal preserves embedded newline",
    lex_first_string("\"a\nb\""), "a\nb"))
  results.push(assert_true("unterminated double-quoted string yields lex error",
    lex_error_count("\"no closing quote") > 0))
  results.push(assert_eq_int("identifier - 2 tokens",              lex_token_count("foo"),     2))

  results.push(assert_eq_int("no lex errors on valid source",       lex_error_count("fn f() -> i32 = 42"), 0))

  results.push(assert_eq_int("fn decl - correct token count",
    lex_token_count("fn f() -> i32 = 42"), 9))

  // Template literal tests
  results.push(assert_eq_int("plain template - 2 tokens (LTemplate + Eof)",
    lex_token_count("`hello`"), 2))
  results.push(assert_eq_int("plain template parts count",
    lex_template_parts("`hello`").length(), 1))
  results.push(assert_eq_str("plain template content",
    lex_template_parts("`hello`")[0], "hello"))
  results.push(assert_eq_int("template with interpolation parts count",
    lex_template_parts("`a \${x} b`").length(), 3))
  results.push(assert_eq_str("template interp part[0]",
    lex_template_parts("`a \${x} b`")[0], "a "))
  results.push(assert_eq_str("template interp part[1] (expr)",
    lex_template_parts("`a \${x} b`")[1], "x"))
  results.push(assert_eq_str("template interp part[2]",
    lex_template_parts("`a \${x} b`")[2], " b"))
  results.push(assert_true("unterminated template yields lex error",
    lex_error_count("`no closing") > 0))
  results.push(assert_true("unterminated interpolation yields lex error",
    lex_error_count("`a \${b") > 0))

  results
end
