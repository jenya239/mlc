import { TestResult, assert_eq_int, assert_true } from './test_runner'
import { tokenize } from '../frontend/lexer'
import { parse_program, parse_program_with_errors } from '../frontend/parser/decls'
import { check } from '../checker/check/check'

fn parse_error_count(source: string) -> i32 =
  parse_program_with_errors(tokenize(source).tokens, '').errors.length()

fn check_error_count(source: string) -> i32 =
  match check(parse_program(tokenize(source).tokens)) {
    Ok(_) => 0,
    Err(errors) => errors.length()
  }

export fn region_tests() -> [TestResult] = do
  let results: [TestResult] = []

  results.push(assert_eq_int('region r do parses',
    parse_error_count('fn main() -> () = region r do\n  0\nend'),
    0))

  results.push(assert_eq_int('region binder arena parses',
    parse_error_count('fn main() -> () = region arena do\n  0\nend'),
    0))

  results.push(assert_eq_int('region without do is parse error',
    if parse_error_count('fn main() -> () = region r\n  0\nend') > 0 then 1 else 0 end,
    1))

  results.push(assert_eq_int('region empty body typechecks',
    check_error_count('fn main() -> () = region r do\n  0\nend'),
    0))

  results.push(assert_eq_int('region r.alloc typechecks',
    check_error_count('fn main() -> () = region r do\n  r.alloc(0)\nend'),
    0))

  results.push(assert_eq_int('region r.alloc bind typechecks',
    check_error_count(
      'fn main() -> () = region r do\n  let x = r.alloc(0)\n  0\nend'),
    0))

  results.push(assert_true('region unknown method is error',
    check_error_count(
      'fn main() -> () = region r do\n  r.nope()\nend') > 0))

  results
end
