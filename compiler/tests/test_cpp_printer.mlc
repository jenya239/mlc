// Golden tests for Cpp AST printer (compiler/cpp/cpp_ast.mlc).

import { TestResult, assert_eq_str } from './test_runner'
import { print_expr, print_statement, print_decl, print_file } from '../cpp/cpp_ast'
import * as module_tu_helpers from '../cpp/module_tu_helpers'
import * as expression_output from '../codegen/expr/expr'
import { CppInt, CppStr, CppBool, CppIdent, CppCall, CppMember, CppIndex, CppBinary, CppUnary,
         CppTernary, CppInitList, CppAggregateInit, CppStdVisit, CppVisitArmWild, CppVisitArmBinding,
         CppVisitArmConstructed, CppVisitArmConstructedGeneric, CppCast, CppCastStatic, CppLambda, CppMutableLambda,
         CppReturn, CppExpressionStatement, CppAutoDecl, CppVarDecl, CppConstDecl, CppConstexprAutoDecl, CppStructuredBinding, CppStatementFragment, CppBlock, CppIf, CppWhile, CppFor,
         CppInvokedWhile, CppInvokedFor, CppInvokedBlock, CppInvokedBlockWithReturn, CppQuestionTry, CppWithBlock,
         CppDeclaration, CppInclude, CppIfndef, CppDefineMacro, CppEndif, CppNamespaceBegin, CppNamespaceEnd, CppUsing, CppUsingNamespace, CppHostEntryMain, CppStruct, CppForwardDecl, CppField, CppFnProto, CppFnDef, CppNamespace, CppVariant, CppVariantArm, CppStaticAssert, CppStdHashSpecialization, CppDeclarationSequence, CppDeclarationEmpty, CppBlankLine,
         CppFile, CppType, CppTypeName, CppTypeConst, CppTypePtr, CppTypeRef, CppCapture, CppParam } from '../cpp/cpp_ast'

fn print_declarations(declarations: [Shared<CppDeclaration>]) -> string =
  declarations.map(declaration => print_decl(declaration)).join('')

fn integer_type() -> Shared<CppType> =
  Shared.new(CppTypeName('int'))

export fn cpp_printer_tests() -> [TestResult] = do
  let results: [TestResult] = []
  const int_type = integer_type()

  results.push(assert_eq_str('print_expr CppInt',
    print_expr(Shared.new(CppInt(42))), '42'))

  results.push(assert_eq_str('print_expr CppStr',
    print_expr(Shared.new(CppStr('hello'))), '"hello"'))

  results.push(assert_eq_str('print_expr CppBool',
    print_expr(Shared.new(CppBool(false))), 'false'))

  results.push(assert_eq_str('print_expr CppCall',
    print_expr(Shared.new(CppCall(Shared.new(CppIdent('foo')), [Shared.new(CppInt(1)), Shared.new(CppInt(2))]))),
    'foo(1, 2)'))

  results.push(assert_eq_str('print_expr CppMember value',
    print_expr(Shared.new(CppMember(Shared.new(CppIdent('object')), 'field', false))),
    'object.field'))

  results.push(assert_eq_str('print_expr CppMember pointer',
    print_expr(Shared.new(CppMember(Shared.new(CppIdent('pointer')), 'field', true))),
    'pointer->field'))

  results.push(assert_eq_str('print_expr CppIndex',
    print_expr(Shared.new(CppIndex(Shared.new(CppIdent('items')), Shared.new(CppInt(0))))),
    'items[0]'))

  results.push(assert_eq_str('print_expr CppBinary',
    print_expr(Shared.new(CppBinary("+", Shared.new(CppInt(1)), Shared.new(CppInt(2))))),
    '(1 + 2)'))

  results.push(assert_eq_str('print_expr CppUnary',
    print_expr(Shared.new(CppUnary("-", Shared.new(CppInt(5))))),
    '(-5)'))

  results.push(assert_eq_str('print_expr CppTernary',
    print_expr(Shared.new(CppTernary(Shared.new(CppIdent('ready')), Shared.new(CppInt(1)), Shared.new(CppInt(0))))),
    '(ready ? (1) : (0))'))

  results.push(assert_eq_str('print_expr CppInitList empty',
    print_expr(Shared.new(CppInitList([]))), '{}'))

  results.push(assert_eq_str('print_expr CppInitList elements',
    print_expr(Shared.new(CppInitList([Shared.new(CppInt(1)), Shared.new(CppInt(2))]))),
    '{1, 2}'))

  results.push(assert_eq_str('print_expr CppAggregateInit',
    print_expr(Shared.new(CppAggregateInit('Point', [Shared.new(CppInt(1)), Shared.new(CppInt(2))]))),
    'Point{1, 2}'))

  const match_handler = Shared.new(CppVisitArmWild(false, Shared.new(CppInt(1))))
  results.push(assert_eq_str('print_expr CppStdVisit',
    print_expr(Shared.new(CppStdVisit(Shared.new(CppInt(0)), [match_handler]))),
    'std::visit(overloaded{[&](const auto& __v) { return 1; }\n}, 0)'))

  results.push(assert_eq_str('print_expr CppVisitArmBinding',
    print_expr(Shared.new(CppVisitArmBinding('value', false, Shared.new(CppInt(2))))),
    '[&](const auto& value) { return 2; }'))

  results.push(assert_eq_str('print_expr CppVisitArmConstructed',
    print_expr(Shared.new(CppVisitArmConstructed(
      'const Point& point', 'const auto& x = point.x; ', false, Shared.new(CppIdent("x"))))),
    '[&](const Point& point) { const auto& x = point.x; return x; }'))

  results.push(assert_eq_str('print_expr CppVisitArmConstructedGeneric',
    print_expr(Shared.new(CppVisitArmConstructedGeneric(
      'Shape', 'shape', '', false, Shared.new(CppInt(3))))),
    '[&]<typename __mlcT>(const Shape<__mlcT>& shape) { return 3; }'))

  results.push(assert_eq_str('print_expr CppCast',
    print_expr(Shared.new(CppCast(CppCastStatic, int_type, Shared.new(CppIdent('value'))))),
    'static_cast<int>(value)'))

  const capture = Shared.new(CppCapture { name: 'counter', by_reference: true })
  const parameter = Shared.new(CppParam { name: 'input', parameter_type: int_type })
  const lambda_body = [Shared.new(CppReturn(Shared.new(CppIdent('input'))))]
  results.push(assert_eq_str('print_expr CppLambda',
    print_expr(Shared.new(CppLambda([capture], [parameter], int_type, lambda_body))),
    '[&counter](int input) -> int {\n  return input;\n}'))

  const mutable_lambda_body =
    Shared.new(CppBinary("+", Shared.new(CppIdent('value')), Shared.new(CppInt(1))))
  results.push(assert_eq_str('print_expr CppMutableLambda',
    print_expr(Shared.new(CppMutableLambda(
      [Shared.new(CppCapture { name: '', by_reference: true })],
      [Shared.new(CppParam { name: 'value', parameter_type: int_type })],
      mutable_lambda_body))),
    '[&](int value) mutable { return (value + 1); }'))

  const loop_body = 'step();\n'
  results.push(assert_eq_str('print_expr CppInvokedWhile',
    print_expr(Shared.new(CppInvokedWhile(Shared.new(CppBool(true)), loop_body))),
    '[&]() {\nwhile (true) {\nstep();\n}\n}()'))

  results.push(assert_eq_str('print_expr CppInvokedFor',
    print_expr(Shared.new(CppInvokedFor('item', Shared.new(CppIdent('items')), loop_body))),
    '[&]() {\nfor (auto item : items) {\nstep();\n}\n}()'))

  results.push(assert_eq_str('print_expr CppInvokedBlock',
    print_expr(Shared.new(CppInvokedBlock('auto x = 1;\nreturn x;\n'))),
    '[&]() {\nauto x = 1;\nreturn x;\n}()'))

  results.push(assert_eq_str('print_expr CppInvokedBlockWithReturn',
    print_expr(Shared.new(CppInvokedBlockWithReturn('int', 'auto x = 1;\nreturn x;\n'))),
    '[&]() -> int {\nauto x = 1;\nreturn x;\n}()'))

  results.push(assert_eq_str('print_expr CppQuestionTry',
    print_expr(Shared.new(CppQuestionTry(Shared.new(CppInt(7))))),
    '({ auto __q = 7; if (std::get_if<1>(&__q)) return *std::get_if<1>(&__q); std::get<0>(__q).field0; })'))

  results.push(assert_eq_str('print_expr CppWithBlock',
    print_expr(Shared.new(CppWithBlock(Shared.new(CppIdent('resource')), 'handle', 'handle.use();\n'))),
    '{\nauto handle = (resource);\nhandle.use();\nhandle.drop();\n}\n'))

  results.push(assert_eq_str('print_statement CppReturn',
    print_statement(Shared.new(CppReturn(Shared.new(CppInt(0))))),
    'return 0;'))

  results.push(assert_eq_str('print_statement CppAutoDecl',
    print_statement(Shared.new(CppAutoDecl('counter', Shared.new(CppInt(0))))),
    'auto counter = 0;'))

  results.push(assert_eq_str('print_statement CppConstDecl',
    print_statement(Shared.new(CppConstDecl('limit', int_type, Shared.new(CppInt(10))))),
    'const int limit = 10;'))

  results.push(assert_eq_str('print_statement CppVarDecl size_t seed',
    print_statement(Shared.new(CppVarDecl("h", Shared.new(CppTypeName("size_t")),
      Shared.new(CppIdent("1469598103934665603ULL"))))),
    "size_t h = 1469598103934665603ULL;"))

  results.push(assert_eq_str('print_statement hash empty return cast',
    print_statement(Shared.new(CppReturn(Shared.new(CppCast(
      CppCastStatic,
      Shared.new(CppTypeName("size_t")),
      Shared.new(CppIdent("1469598103934665603ULL"))))))),
    "return static_cast<size_t>(1469598103934665603ULL);"))

  const hash_access = Shared.new(CppMember(Shared.new(CppIdent("self")), "tag", false))
  const hash_identifier = Shared.new(CppIdent("h"))
  const hash_call = Shared.new(CppCall(
    Shared.new(CppAggregateInit("std::hash<int>", [])),
    [hash_access]))
  const hash_plus_constant = Shared.new(CppBinary(
    "+",
    hash_call,
    Shared.new(CppIdent("0x9e3779b97f4a7c15ULL"))))
  const hash_plus_shift = Shared.new(CppBinary(
    "+",
    hash_plus_constant,
    Shared.new(CppBinary("<<", hash_identifier, Shared.new(CppInt(6))))))
  const hash_rhs = Shared.new(CppBinary(
    "+",
    hash_plus_shift,
    Shared.new(CppBinary(">>", hash_identifier, Shared.new(CppInt(2))))))
  const hash_combine = Shared.new(CppBinary("^=", hash_identifier, hash_rhs))
  results.push(assert_eq_str('print_statement hash combine expr',
    print_statement(Shared.new(CppExpressionStatement(hash_combine))),
    "(h ^= (((std::hash<int>{}(self.tag) + 0x9e3779b97f4a7c15ULL) + (h << 6)) + (h >> 2)));"))

  results.push(assert_eq_str('print_statement CppConstexprAutoDecl',
    print_statement(Shared.new(CppConstexprAutoDecl('limit', Shared.new(CppInt(42))))),
    'constexpr auto limit = 42;'))

  results.push(assert_eq_str('print_statement CppStructuredBinding',
    print_statement(Shared.new(CppStructuredBinding(
      ['first', 'second'],
      Shared.new(CppIdent('__lt'))))),
    'auto [first, second] = __lt;'))

  results.push(assert_eq_str('print_statement CppStatementFragment',
    print_statement(Shared.new(CppStatementFragment('if (ready) { step(); }'))),
    'if (ready) { step(); }'))

  results.push(assert_eq_str('print_statement CppIf',
    print_statement(Shared.new(CppIf(
      Shared.new(CppIdent('flag')),
      Shared.new(CppBlock([Shared.new(CppReturn(Shared.new(CppInt(1))))])),
      Shared.new(CppBlock([Shared.new(CppReturn(Shared.new(CppInt(0))))]))
    ))),
    'if (flag) {\n  return 1;\n} else {\n  return 0;\n}'))

  results.push(assert_eq_str('print_statement CppFor',
    print_statement(Shared.new(CppFor(
      'item',
      Shared.new(CppIdent('items')),
      [Shared.new(CppExpressionStatement(Shared.new(CppCall(Shared.new(CppIdent('process')), [Shared.new(CppIdent('item'))]))))]
    ))),
    'for (auto item : items) {\n  process(item);\n}'))

  results.push(assert_eq_str('print_decl CppInclude angle',
    print_decl(Shared.new(CppInclude(true, 'vector'))),
    '#include <vector>\n'))

  results.push(assert_eq_str('print_decl CppInclude quoted',
    print_decl(Shared.new(CppInclude(false, 'local.h'))),
    '#include "local.h"\n'))

  results.push(assert_eq_str('print_decl CppIfndef',
    print_decl(Shared.new(CppIfndef('FOO_HPP'))),
    '#ifndef FOO_HPP\n'))

  results.push(assert_eq_str('print_decl CppDefineMacro guard',
    print_decl(Shared.new(CppDefineMacro('FOO_HPP', ''))),
    '#define FOO_HPP\n'))

  results.push(assert_eq_str('print_decl CppDefineMacro main shim',
    print_decl(Shared.new(CppDefineMacro('main', 'mlc_user_main'))),
    '#define main mlc_user_main\n'))

  results.push(assert_eq_str('print_decl CppEndif',
    print_decl(Shared.new(CppEndif('FOO_HPP'))),
    '#endif // FOO_HPP\n'))

  results.push(assert_eq_str('print_decl CppNamespaceBegin',
    print_decl(Shared.new(CppNamespaceBegin('ast'))),
    'namespace ast {\n'))

  results.push(assert_eq_str('print_decl CppNamespaceEnd',
    print_decl(Shared.new(CppNamespaceEnd('ast'))),
    '} // namespace ast\n'))

  results.push(assert_eq_str('print_decl CppStruct',
    print_decl(Shared.new(CppStruct('', 'Point', [Shared.new(CppField { type_value: "int", name: "x" })], false))),
    "struct Point {\n  int x;\n};\n"))

  results.push(assert_eq_str('print_decl CppStruct forward',
    print_decl(Shared.new(CppStruct('', 'Red', [], true))),
    "struct Red;\n"))

  results.push(assert_eq_str('print_decl CppStruct empty definition',
    print_decl(Shared.new(CppStruct('', 'Red', [], false))),
    "struct Red {};\n"))

  results.push(assert_eq_str('print_decl CppForwardDecl class',
    print_decl(Shared.new(CppForwardDecl('class', 'Widget'))),
    "class Widget;\n"))

  results.push(assert_eq_str('print_decl CppForwardDecl enum',
    print_decl(Shared.new(CppForwardDecl('enum', 'Color'))),
    "enum Color;\n"))

  results.push(assert_eq_str('print_statement CppVarDecl const int pointer',
    print_statement(Shared.new(CppVarDecl(
      'value',
      Shared.new(CppTypePtr(Shared.new(CppTypeConst(int_type)))),
      Shared.new(CppInt(0))))),
    'const int* value = 0;'))

  results.push(assert_eq_str('print_decl CppFnProto',
    print_decl(Shared.new(CppFnProto('', 'int', 'add', ['int left', 'int right']))),
    'int add(int left, int right) noexcept;\n'))

  results.push(assert_eq_str('print_decl CppFnProto template',
    print_decl(Shared.new(CppFnProto(
      "template<typename T>\n",
      "T",
      'identity',
      ['T value']))),
    'template<typename T>\nT identity(T value) noexcept;\n'))

  results.push(assert_eq_str('print_decl CppFnDef',
    print_decl(Shared.new(CppFnDef('', 'int', 'answer', [], [Shared.new(CppReturn(Shared.new(CppInt(42))))], 1))),
    'int answer() noexcept{\n  return 42;\n}\n'))

  results.push(assert_eq_str('print_decl CppFnDef template',
    print_decl(Shared.new(CppFnDef(
      "template<typename T>\n",
      "T",
      'identity',
      ['T value'],
      [Shared.new(CppReturn(Shared.new(CppIdent('value'))))], 1))),
    'template<typename T>\nT identity(T value) noexcept{\n  return value;\n}\n'))

  results.push(assert_eq_str('print_decl CppNamespace',
    print_decl(Shared.new(CppNamespace('detail', [Shared.new(CppUsing('Byte', 'unsigned char'))]))),
    'namespace detail {\nusing Byte = unsigned char;\n}'))

  const variant_arm = Shared.new(CppVariantArm { name: 'Integer', types: [int_type] })
  results.push(assert_eq_str('print_decl CppVariant',
    print_decl(Shared.new(CppVariant('', 'Value', [variant_arm]))),
    'using Value = std::variant<int>;\n'))

  const color_arms = [
    Shared.new(CppVariantArm { name: 'Red', types: [] }),
    Shared.new(CppVariantArm { name: 'Green', types: [] }),
    Shared.new(CppVariantArm { name: 'Blue', types: [] })]
  results.push(assert_eq_str('print_decl CppVariant unit arms',
    print_decl(Shared.new(CppVariant('', 'Color', color_arms))),
    'using Color = std::variant<Red, Green, Blue>;\n'))

  results.push(assert_eq_str('print_decl CppStaticAssert one type argument',
    print_decl(Shared.new(CppStaticAssert('Display', ['Color'], 'Color does not implement Display'))),
    'static_assert(Display<Color>, "Color does not implement Display");\n'))

  results.push(assert_eq_str('print_decl CppStaticAssert two type arguments',
    print_decl(Shared.new(CppStaticAssert('ExprVisitor', ['mlc::String', 'Color'], 'Color does not implement ExprVisitor'))),
    'static_assert(ExprVisitor<mlc::String, Color>, "Color does not implement ExprVisitor");\n'))

  results.push(assert_eq_str('print_decl CppDeclarationSequence',
    print_decl(Shared.new(CppDeclarationSequence([
      Shared.new(CppUsing('Left', 'int')),
      Shared.new(CppUsing('Right', 'int'))]))),
    'using Left = int;using Right = int;'))

  results.push(assert_eq_str('print_decl CppDeclarationEmpty',
    print_decl(Shared.new(CppDeclarationEmpty)), ''))

  results.push(assert_eq_str('print_decl CppBlankLine',
    print_decl(Shared.new(CppBlankLine)), "\n"))

  results.push(assert_eq_str('print_decl CppUsingNamespace',
    print_decl(Shared.new(CppUsingNamespace('ast'))),
    "using namespace ast;\n"))

  results.push(assert_eq_str('print_decl CppHostEntryMain',
    print_decl(Shared.new(CppHostEntryMain('mlc_main'))),
    expression_output.bootstrap_host_main_calling_namespaced_user_main('mlc_main')))

  results.push(assert_eq_str('print_decl CppStdHashSpecialization',
    print_decl(Shared.new(CppStdHashSpecialization('Item', [Shared.new(CppReturn(Shared.new(CppInt(0))))]))),
    'namespace std {\n' +
    'template<>\n' +
    'struct hash<Item> {\n' +
    "  size_t operator()(const Item& self) const noexcept {\n" +
    '    return 0;\n' +
    '  }\n' +
    '};\n' +
    '}\n'))

  const header_include = Shared.new(CppInclude(true, 'vector'))
  const source_function = Shared.new(CppFnDef('', 'int', 'main', [], [Shared.new(CppReturn(Shared.new(CppInt(0))))], 1))
  const file = Shared.new(CppFile { header: [header_include], source: [source_function] })
  results.push(assert_eq_str('print_file header and source',
    print_file(file),
    "#include <vector>\n\n\nint main() noexcept{\n  return 0;\n}\n"))

  const guard_macro = "MODULE_HPP"
  let mut header_declarations = [
    module_tu_helpers.make_include_guard_ifndef_cpp_declaration(guard_macro),
    module_tu_helpers.make_include_guard_define_cpp_declaration(guard_macro),
    module_tu_helpers.make_blank_line_cpp_declaration(),
    module_tu_helpers.make_quoted_include_cpp_declaration("mlc.hpp")]
  header_declarations = module_tu_helpers.append_cpp_declarations_from_include_text(
    header_declarations,
    "#include <variant>\n#include \"peer.hpp\"\n")
  header_declarations.push(module_tu_helpers.make_namespace_open_cpp_declaration("ast"))
  header_declarations.push(module_tu_helpers.make_namespace_close_cpp_declaration("ast"))
  header_declarations.push(module_tu_helpers.make_include_guard_endif_cpp_declaration(guard_macro))
  results.push(assert_eq_str("module_tu_helpers header scaffolding",
    print_declarations(header_declarations),
    "#ifndef MODULE_HPP\n" +
    "#define MODULE_HPP\n" +
    "\n" +
    "#include \"mlc.hpp\"\n" +
    "#include <variant>\n" +
    "#include \"peer.hpp\"\n" +
    "namespace ast {\n" +
    "} // namespace ast\n" +
    "#endif // MODULE_HPP\n"))

  const source_declarations = [
    module_tu_helpers.make_define_main_as_user_main_cpp_declaration(),
    module_tu_helpers.make_quoted_include_cpp_declaration("mod.hpp"),
    module_tu_helpers.make_blank_line_cpp_declaration(),
    module_tu_helpers.make_namespace_open_cpp_declaration("ast")]
  results.push(assert_eq_str("module_tu_helpers source prologue",
    print_declarations(source_declarations),
    "#define main mlc_user_main\n" +
    "#include \"mod.hpp\"\n" +
    "\n" +
    "namespace ast {\n"))

  let mut source_with_imports = [
    module_tu_helpers.make_define_main_as_user_main_cpp_declaration(),
    module_tu_helpers.make_quoted_include_cpp_declaration("mod.hpp"),
    module_tu_helpers.make_blank_line_cpp_declaration()]
  source_with_imports = module_tu_helpers.append_cpp_declarations_from_include_text(
    source_with_imports, "#include \"peer.hpp\"\n")
  source_with_imports.push(module_tu_helpers.make_blank_line_cpp_declaration())
  source_with_imports.push(module_tu_helpers.make_namespace_open_cpp_declaration("ast"))
  source_with_imports.push(module_tu_helpers.make_blank_line_cpp_declaration())
  source_with_imports.push(module_tu_helpers.make_using_namespace_cpp_declaration("ast"))
  source_with_imports.push(module_tu_helpers.make_blank_line_cpp_declaration())
  source_with_imports.push(module_tu_helpers.make_namespace_close_cpp_declaration("ast"))
  results.push(assert_eq_str("module_tu_helpers source imports and using",
    print_declarations(source_with_imports),
    "#define main mlc_user_main\n" +
    "#include \"mod.hpp\"\n" +
    "\n" +
    "#include \"peer.hpp\"\n" +
    "\n" +
    "namespace ast {\n" +
    "\n" +
    "using namespace ast;\n" +
    "\n" +
    "} // namespace ast\n"))

  results
end
