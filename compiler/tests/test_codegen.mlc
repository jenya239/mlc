  results.push(assert_eq_str('gen_stmts_cpp: let record tuple fallback native structured binding',
    gen_stmts_str([let_record_tuple_fallback], context),
    'auto __tmp_0 = point;\nauto [first, second] = __tmp_0;\n'))

  const unknown_tuple_pat = Shared.new(PatternTuple(
