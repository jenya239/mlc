    'auto value = ({ auto __q = 7; if (std::get_if<1>(&__q)) return *std::get_if<1>(&__q); std::get<0>(__q).field0; });\n'))

  results.push(assert_eq_str('gen_stmts_cpp_as_string: let const if',
