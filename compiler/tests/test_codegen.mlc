  results.push(assert_eq_str('phantom multi-variant: template<typename Tag> on Active struct',
    if tagged_out.contains('template<typename Tag>\nstruct Active') then 'yes' else 'no' end, 'yes'))

  const phantom_rec_type = Shared.new(TGeneric('Ast', [Shared.new(TNamed('Unvalidated'))]))
  const phantom_rec_fvals: [Shared<SemanticFieldVal>] = []
  const phantom_rec_expr = Shared.new(SemanticExpressionRecord('Ast', phantom_rec_fvals, phantom_rec_type, span_unknown()))
  results.push(assert_eq_str('phantom record expr: Ast<Unvalidated>{}',
    gen_expr(phantom_rec_expr, context), 'Ast<Unvalidated>{}'))

  const h11_program_source = "type Opt<T> = Some(T) | None\nfn f() -> Opt<i64> = Some(42)\n"
  const h11_program = parse_program(tokenize(h11_program_source).tokens)
  const h11_context =
    create_codegen_context(h11_program).with_enclosing_function_return_type(
      Shared.new(TGeneric("Opt", [Shared.new(TI64)])))
  const h11_some_call = Shared.new(SemanticExpressionCall(
    Shared.new(SemanticExpressionIdent("Some", unk_t(), span_unknown())),
    [si(42)],
    empty_parameter_mutability_pattern(),
    Shared.new(TGeneric("Opt", [Shared.new(TI64)])),
    span_unknown()))
  results.push(assert_eq_str('generic sum ctor: parsed Opt decl emits Some<int64_t>',
    gen_expr(h11_some_call, h11_context), 'Some<int64_t>{42}'))

  results.push(assert_code_contains('generic sum ctor: f() emits Some<int64_t> via pipeline',
    gen_program(h11_program), 'Some<int64_t>{42}'))

  // C4: numeric tower
  const f64_t = Shared.new(TF64)
  const i64_t = Shared.new(TI64)
  const u8_t  = Shared.new(TU8)
  const usize_t = Shared.new(TUsize)
  const char_t = Shared.new(TChar)

  results.push(assert_eq_str('c4: f64 literal codegen',
    gen_expr(Shared.new(SemanticExpressionFloat('3.14', f64_t, span_unknown())), context), '3.14'))

  results.push(assert_eq_str('c4: i64 literal codegen',
