  const err_fields: [Shared<TypeExpr>] = [Shared.new(TyNamed("E"))]
  const result_variants: [Shared<TypeVariant>] = [
    Shared.new(VarTuple('Ok',  ok_fields, false)),
    Shared.new(VarTuple('Err', err_fields, false))
  ]
  const expected_fwd =
    'template<typename T>\nstruct Ok;\n' +
    'template<typename E>\nstruct Err;\n' +
    'template<typename T, typename E>\nusing Result = std::variant<Ok<T>, Err<E>>;\n'
  const expected_body =
    'template<typename T>\nstruct Ok {T field0;};\n' +
    'template<typename E>\nstruct Err {E field0;};\n'
  results.push(assert_eq_str('generic type Result<T,E> = Ok(T) | Err(E) codegen',
    gen_type_decl(context, 'Result', result_type_params, result_variants),
    expected_fwd + expected_body))

  // -- Multiline string literal codegen ------------------------------------

  results.push(assert_eq_str('string literal with embedded newline - escapes to \\n in C++',
    gen_expr(ss('hello\nworld'), context),
