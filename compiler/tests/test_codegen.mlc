  const let_unknown_tuple_fallback = Shared.new(SemanticStatementLetPattern(
    unknown_tuple_pat, false, sid('value'), unk_t(), false, letpat_else_body, span_unknown()))
  results.push(assert_eq_str('gen_stmts_cpp: let unknown type tuple fallback native structured binding',
    gen_stmts_str([let_unknown_tuple_fallback], context),
    'auto __tmp_0 = value;\nauto [alpha, __1] = __tmp_0;\n'))

  const letpat_ctor_pat = Shared.new(PatternCtor('Some', [Shared.new(PatternIdent("v", span_unknown()))], span_unknown()))
  const letpat_with_else = Shared.new(SemanticStatementLetPattern(letpat_ctor_pat, false, sid('opt'), Shared.new(TNamed('Opt')), true, letpat_else_body, span_unknown()))
  const letpat_no_else = Shared.new(SemanticStatementLetPattern(letpat_ctor_pat, false, sid('opt'), Shared.new(TNamed('Opt')), false, letpat_else_body, span_unknown()))
  const letpat_with_else_out = gen_stmts_str([letpat_with_else], context)
  const letpat_no_else_out = gen_stmts_str([letpat_no_else], context)
  results.push(assert_eq_str('let-else: with else no abort',
    if letpat_with_else_out.contains('abort') then 'abort' else 'no-abort' end, 'no-abort'))
  results.push(assert_eq_str('let-else: without else uses abort',
    if letpat_no_else_out.contains('abort') then 'abort' else 'no-abort' end, 'abort'))
  results.push(assert_code_contains('gen_stmts_cpp: let ctor native holds_alternative',
    letpat_no_else_out, 'std::holds_alternative'))
  results.push(assert_code_contains('gen_stmts_cpp: let ctor native std::get bind',
    letpat_no_else_out, 'std::get<0>(__tmp_1)'))

  const letpat_ctor_wild_pat = Shared.new(PatternCtor(
    'Some',
    [Shared.new(PatternIdent('head', span_unknown())), Shared.new(PatternWild(span_unknown()))],
    span_unknown()))
  const letpat_ctor_wild = Shared.new(SemanticStatementLetPattern(
    letpat_ctor_wild_pat, false, sid('opt'), Shared.new(TNamed('Opt')), false, letpat_else_body, span_unknown()))
  results.push(assert_code_contains('gen_stmts_cpp: let ctor wild native structured binding',
    gen_stmts_str([letpat_ctor_wild], context), 'auto [head, __1] = __tmp_1'))

  const array_pat = Shared.new(PatternArray(
