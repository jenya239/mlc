  const phantom_variants_1: [Shared<TypeVariant>] = [Shared.new(VarRecord('Ast', phantom_fds, false))]
  const phantom_type_out = gen_type_decl(context, 'Ast', ['Phase'], phantom_variants_1)
  results.push(assert_eq_str('phantom single-variant: template<typename Phase> in output',
    if phantom_type_out.contains('typename Phase') then 'yes' else 'no' end, 'yes'))

