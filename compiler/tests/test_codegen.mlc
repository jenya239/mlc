  results.push(assert_code_contains('gen_stmts_cpp: let record field native',
    gen_stmts_str([let_record], context), '__tmp_0.value'))

  // --- Phantom type codegen ---------------------------------------------------

  const phantom_fds: [Shared<FieldDef>] = [Shared.new(FieldDef {
    name: 'value',
    type_value: Shared.new(TyI32),
