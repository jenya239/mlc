  const let_array_out = gen_stmts_str([let_array_rest], context)
  results.push(assert_code_contains('gen_stmts_cpp: let array rest native slice',
    let_array_out, 'mlc::Array<int>'))
  results.push(assert_code_contains('gen_stmts_cpp: let array rest cbegin offset',
    let_array_out, 'cbegin() + 1'))

  const record_pat = Shared.new(PatternRecord('', [Shared.new(PatternIdent('value', span_unknown()))], span_unknown()))
  const let_record = Shared.new(SemanticStatementLetPattern(
