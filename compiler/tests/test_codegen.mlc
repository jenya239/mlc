  const with_body: [Shared<SemanticStatement>] = [Shared.new(SemanticStatementExpr(si(0), span_unknown()))]
  const with_out = gen_expr(Shared.new(SemanticExpressionWith(si(1), 'res', with_body, unit_t(), span_unknown())), context)
  results.push(assert_eq_str('c5: SemanticExpressionWith contains auto res =',
