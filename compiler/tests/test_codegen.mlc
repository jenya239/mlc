  const d4_where_trait_bounds_output = gen_program(parse_program(tokenize(d4_where_trait_bounds_source).tokens))
  results.push(assert_code_contains('D4 gen_program: requires Display', d4_where_trait_bounds_output, 'Display'))
  results.push(assert_code_contains('D4 gen_program: requires EqCompare', d4_where_trait_bounds_output, 'EqCompare'))
  const result_type_params: [string] = ["T", "E"]
