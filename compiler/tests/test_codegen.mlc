  results.push(assert_eq_str('string literal with tab - escapes to \\t',
    gen_expr(ss('a\tb'), context),
    'mlc::String("a\\tb", 3)'))

  results.push(assert_eq_str('string literal with backslash - escapes to \\\\',
    gen_expr(ss('a\\b'), context),
    'mlc::String("a\\\\b", 3)'))

  results.push(assert_eq_str('string literal with double quote - escapes to \\"',
    gen_expr(ss('say "hi"'), context),
    'mlc::String("say \\"hi\\"", 8)'))

  const letpat_else_body = Shared.new(SemanticExpressionInt(0, i32_t(), span_unknown()))
  const letpat_ident = Shared.new(SemanticStatementLetPattern(
    Shared.new(PatternIdent('value', span_unknown())), false, si(7), i32_t(), false, letpat_else_body, span_unknown()))
  results.push(assert_eq_str('gen_stmts_cpp_as_string: let pat ident',
    gen_stmts_str([letpat_ident], context), 'auto value = 7;\n'))

  const tuple_pat = Shared.new(PatternTuple(
    [Shared.new(PatternIdent('left', span_unknown())), Shared.new(PatternIdent('right', span_unknown()))],
    span_unknown()))
  const pair_type = Shared.new(TPair(Shared.new(TI32), Shared.new(TI32)))
  const let_tuple_pair = Shared.new(SemanticStatementLetPattern(
    tuple_pat, false, sid('pair'), pair_type, false, letpat_else_body, span_unknown()))
  results.push(assert_eq_str('gen_stmts_cpp_as_string: let tuple pair native std::get',
    gen_stmts_str([let_tuple_pair], context),
    'auto __tmp_0 = pair;\nauto left = std::get<0>(__tmp_0);\nauto right = std::get<1>(__tmp_0);\n'))
  results.push(assert_code_not_contains('gen_stmts_cpp_as_string: let tuple pair no structured binding fragment',
    gen_stmts_str([let_tuple_pair], context), 'auto ['))

  const tuple_wild_pat = Shared.new(PatternTuple(
    [Shared.new(PatternIdent('left', span_unknown())), Shared.new(PatternWild(span_unknown()))],
    span_unknown()))
  const let_tuple_wild = Shared.new(SemanticStatementLetPattern(
    tuple_wild_pat, false, sid('pair'), pair_type, false, letpat_else_body, span_unknown()))
  results.push(assert_eq_str('gen_stmts_cpp: let tuple pair wild native structured binding',
    gen_stmts_str([let_tuple_wild], context),
    'auto __tmp_0 = pair;\nauto [left, __1] = __tmp_0;\n'))

  const record_tuple_pat = Shared.new(PatternTuple(
    [Shared.new(PatternIdent('first', span_unknown())), Shared.new(PatternIdent('second', span_unknown()))],
    span_unknown()))
  const let_record_tuple_fallback = Shared.new(SemanticStatementLetPattern(
