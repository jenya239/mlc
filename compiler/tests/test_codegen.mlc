// Unit tests for the code generator.

import { TestResult, assert_eq_str, assert_eq_int } from './test_runner'
import { assert_code_contains, assert_code_not_contains } from './codegen_test_helpers'
import { gen_expr, gen_argument_list, gen_stmts_str } from '../codegen/eval'
import { cpp_lambda_header_prefix } from '../codegen/expr/expression_support'
import {
  match_arm_wild_or_unit_return,
  match_arm_binding_identifier,
  match_arm_constructed_value,
  match_arm_constructed_value_generic
} from '../codegen/expr/expr'
import { create_codegen_context, FieldOrder, map_builtin, map_method } from '../codegen/context'
import { type_to_cpp, gen_type_decl, sem_type_to_cpp } from '../codegen/decl/type_gen'
import { gen_program } from './codegen_harness'
import { tokenize } from '../frontend/lexer'
import { parse_program } from '../frontend/parser/decls'
import { Program, TypeExpr, TypeVariant, FieldDef, DeclType, DeclFn, DeclExported, Param, VarTuple, VarRecord, VarUnit, TyNamed, TyGeneric, TyI32, TyString, TyBool, TyUnit, TyArray, TyShared, ExprBin, ExprIdent, ExprInt, ExprUnit, PatternInt, PatternWild, PatternOr, PatternCtor, PatternIdent, PatternTuple, PatternArray, PatternRecord, PatternStringLit, span_unknown, PatternUnit } from '../frontend/ast'
import { SemanticExpression, SemanticStatement, SemanticMatchArm, SemanticFieldVal, SemanticExpressionInt, SemanticExpressionStr, SemanticExpressionBool, SemanticExpressionUnit, SemanticExpressionIdent, SemanticExpressionBin, SemanticExpressionUn, SemanticExpressionCall, SemanticExpressionMethod, SemanticExpressionField, SemanticExpressionIndex, SemanticExpressionIf, SemanticExpressionBlock, SemanticExpressionWhile, SemanticExpressionArray, SemanticExpressionMatch, SemanticExpressionRecord, SemanticExpressionLambda, SemanticExpressionQuestion, SemanticExpressionTuple, SemanticStatementLet, SemanticStatementLetConst, SemanticStatementExpr, SemanticStatementLetPattern, SemanticStatementBreak, SemanticStatementContinue, SemanticStatementReturn } from '../ir/semantic_ir'
import { SemanticExpressionFloat, SemanticExpressionI64, SemanticExpressionU8, SemanticExpressionUsize, SemanticExpressionChar } from '../ir/semantic_ir'
import { SemanticExpressionWith } from '../ir/semantic_ir'
import { Type, TI32, TString, TBool, TUnit, TUnknown, TArray, TNamed, TGeneric, TPair, TTuple, TFn } from '../checker/registry'
import { TF64, TI64, TU8, TUsize, TChar, TAssoc } from '../checker/registry'
import { build_ctor_type_infos_from_decls, lookup_ctor_type_info } from '../codegen/decl/ctor_info'

fn i32_t() -> Shared<Type> = Shared.new(TI32)
fn str_t() -> Shared<Type> = Shared.new(TString)
fn bool_t() -> Shared<Type> = Shared.new(TBool)
fn unit_t() -> Shared<Type> = Shared.new(TUnit)
fn unk_t() -> Shared<Type> = Shared.new(TUnknown)

fn si(v: i32) -> Shared<SemanticExpression> = Shared.new(SemanticExpressionInt(v, i32_t(), span_unknown()))
fn ss(v: string) -> Shared<SemanticExpression> = Shared.new(SemanticExpressionStr(v, str_t(), span_unknown()))
fn sb(v: bool) -> Shared<SemanticExpression> = Shared.new(SemanticExpressionBool(v, bool_t(), span_unknown()))
fn sid(name: string) -> Shared<SemanticExpression> = Shared.new(SemanticExpressionIdent(name, unk_t(), span_unknown()))
fn su() -> Shared<SemanticExpression> = Shared.new(SemanticExpressionUnit(unit_t(), span_unknown()))

fn empty_parameter_mutability_pattern() -> [i32] = do let pattern: [i32] = []; pattern end

fn smatch_arm(pattern: Shared<Pattern>, body_expression: Shared<SemanticExpression>) -> Shared<SemanticMatchArm> =
  Shared.new(SemanticMatchArm {
    pattern: pattern,
    has_guard: false,
    when_condition: Shared.new(SemanticExpressionBool(true, bool_t(), span_unknown())),
    body: body_expression
  })

fn smatch_arm_guarded(pattern: Shared<Pattern>, when_condition_expression: Shared<SemanticExpression>, body_expression: Shared<SemanticExpression>) -> Shared<SemanticMatchArm> =
  Shared.new(SemanticMatchArm {
    pattern: pattern,
    has_guard: true,
    when_condition: when_condition_expression,
    body: body_expression
  })

export fn codegen_tests() -> [TestResult] = do
  let results: [TestResult] = []

  const empty_program = Program { decls: [] }
  const context = create_codegen_context(empty_program)
  results.push(assert_eq_str('create_codegen_context: gen_expr with ctx',
    gen_expr(si(42), context), '42'))

  results.push(assert_eq_str('TyI32 - \'int\'',
    type_to_cpp(context, Shared.new(TyI32)), 'int'))

  results.push(assert_eq_str('TyString - \'mlc::String\'',
    type_to_cpp(context, Shared.new(TyString)), 'mlc::String'))

  results.push(assert_eq_str('TyBool - \'bool\'',
    type_to_cpp(context, Shared.new(TyBool)), 'bool'))

  results.push(assert_eq_str('TyUnit - \'void\'',
    type_to_cpp(context, Shared.new(TyUnit)), 'void'))

  results.push(assert_eq_str('TyArray(TyI32) - \'mlc::Array<int>\'',
    type_to_cpp(context, Shared.new(TyArray(Shared.new(TyI32)))), 'mlc::Array<int>'))

  results.push(assert_eq_str('TyShared(TyI32) - \'std::shared_ptr<int>\'',
    type_to_cpp(context, Shared.new(TyShared(Shared.new(TyI32)))), 'std::shared_ptr<int>'))

  results.push(assert_eq_str('sem_type TPair(i32, string)',
    sem_type_to_cpp(context, Shared.new(TPair(Shared.new(TI32), Shared.new(TString)))),
    'std::pair<int, mlc::String>'))

  results.push(assert_eq_str('sem_type TTuple(i32, string, bool)',
    sem_type_to_cpp(context, Shared.new(TTuple([Shared.new(TI32), Shared.new(TString), Shared.new(TBool)]))),
    'std::tuple<int, mlc::String, bool>'))

  results.push(assert_eq_str('sem_type Option<i32> -> std::optional',
    sem_type_to_cpp(context, Shared.new(TGeneric('Option', [Shared.new(TI32)]))),
    'std::optional<int>'))

  results.push(assert_eq_str('ExprInt(42) - \'42\'',
    gen_expr(si(42), context), '42'))

  results.push(assert_eq_str('ExprQuestion: gen_expr index-based unwrap',
    gen_expr(Shared.new(SemanticExpressionQuestion(si(7), unk_t(), span_unknown())), context),
    '({ auto __q = 7; if (std::get_if<1>(&__q)) return *std::get_if<1>(&__q); std::get<0>(__q).field0; })'))

  results.push(assert_eq_str('ExprBool(true) - \'true\'',
    gen_expr(sb(true), context), 'true'))

  results.push(assert_eq_str('ExprStr(\'hi\') - \'mlc::String("hi", 2)\'',
    gen_expr(ss('hi'), context), 'mlc::String("hi", 2)'))

  results.push(assert_eq_str('ExprUnit - \'std::make_tuple()\'',
    gen_expr(su(), context), 'std::make_tuple()'))

  results.push(assert_eq_str('ExprIdent(\'x\') - \'x\'',
    gen_expr(sid("x"), context), "x"))

  results.push(assert_eq_str('ExprIdent(\'print\') - \'mlc::io::print\'',
    gen_expr(sid('print'), context), 'mlc::io::print'))

  results.push(assert_eq_str('ExprIdent(\'println\') - \'mlc::io::println\'',
    gen_expr(sid('println'), context), 'mlc::io::println'))


  results.push(assert_eq_str('ExprBin add - \'(1 + 2)\'',
    gen_expr(Shared.new(SemanticExpressionBin("+", si(1), si(2), i32_t(), span_unknown())), context), '(1 + 2)'))

  results.push(assert_eq_str('ExprUn neg - \'(-42)\'',
    gen_expr(Shared.new(SemanticExpressionUn("-", si(42), i32_t(), span_unknown())), context), '(-42)'))

  results.push(assert_eq_str('map_builtin passthrough - \'foo\'',
    map_builtin('foo'), 'foo'))

  const single_params: [string] = ["x"]
  results.push(assert_eq_str('ExprLambda single param - \'[=](auto x) mutable { return ... }\'',
    gen_expr(Shared.new(SemanticExpressionLambda(single_params, Shared.new(SemanticExpressionBin("+", sid("x"), si(1), i32_t(), span_unknown())), unk_t(), span_unknown())), context),
    '[=](auto x) mutable { return (x + 1); }'))

  const lambda_typed_with_single_i32_parameter = Shared.new(TFn([Shared.new(TI32)], Shared.new(TI32)))
  results.push(assert_eq_str('ExprLambda annotated TFn([i32], i32) uses explicit int parameter',
    gen_expr(Shared.new(SemanticExpressionLambda(single_params, Shared.new(SemanticExpressionBin("+", sid("x"), si(1), i32_t(), span_unknown())), lambda_typed_with_single_i32_parameter, span_unknown())), context),
    '[=](int x) mutable { return (x + 1); }'))

  const two_params: [string] = ["a", "b"]
  results.push(assert_eq_str('ExprLambda two params - \'[=](auto a, auto b) mutable { return ... }\'',
    gen_expr(Shared.new(SemanticExpressionLambda(two_params, Shared.new(SemanticExpressionBin("+", sid("a"), sid("b"), i32_t(), span_unknown())), unk_t(), span_unknown())), context),
    '[=](auto a, auto b) mutable { return (a + b); }'))

  const zero_params: [string] = []
  results.push(assert_eq_str('ExprLambda zero params - \'[]() mutable { return ... }\'',
    gen_expr(Shared.new(SemanticExpressionLambda(zero_params, si(42), unk_t(), span_unknown())), context),
    '[]() mutable { return 42; }'))

  const stored_lambda_program =
    'fn make_checker(allowed: [string]) -> i32 = do\n  const checker = fn word => if allowed.contains(word) then 1 else 0 end\n  checker("fn")\nend\nfn main() -> i32 = make_checker(["fn"])\n'
  const stored_lambda_cpp = gen_program(parse_program(tokenize(stored_lambda_program).tokens))
  results.push(assert_code_contains('stored lambda make_checker uses value capture',
    stored_lambda_cpp, '[=](auto word)'))
  results.push(assert_code_not_contains('stored lambda make_checker avoids reference capture',
    stored_lambda_cpp, '[&](auto word)'))

  const three_lambda_parameters: [string] = ['first_parameter', 'second_parameter', 'third_parameter']
  results.push(assert_eq_str(
    'cpp_lambda_header_prefix — three identifiers',
    cpp_lambda_header_prefix(three_lambda_parameters),
    '[=](auto first_parameter, auto second_parameter, auto third_parameter) mutable'))

  const escaped_cpp_keyword_parameter: [string] = ['class']
  results.push(assert_eq_str(
    'cpp_lambda_header_prefix — cpp keyword parameter uses cpp_safe',
    cpp_lambda_header_prefix(escaped_cpp_keyword_parameter),
    '[=](auto class_) mutable'))

  results.push(assert_eq_str('map_method: length - length',
    map_method('length'), 'length'))

  results.push(assert_eq_str('map_method: len - length',
    map_method('len'), 'length'))

  results.push(assert_eq_str('map_method: push - push_back',
    map_method('push'), 'push_back'))

  results.push(assert_eq_str('map_method: upper - upper',
    map_method('upper'), 'upper'))

  results.push(assert_eq_str('map_method: to_upper - upper',
    map_method('to_upper'), 'upper'))

  results.push(assert_eq_str('map_method: to_lower - lower',
    map_method('to_lower'), 'lower'))

  results.push(assert_eq_str('map_method: trim passthrough',
    map_method('trim'), 'trim'))

  results.push(assert_eq_str('map_method: split passthrough',
    map_method('split'), 'split'))

  results.push(assert_eq_str('map_method: chars passthrough',
    map_method('chars'), 'chars'))

  results.push(assert_eq_str('map_method: lines passthrough',
    map_method('lines'), 'lines'))

  const call_lambda_args: [Shared<SemanticExpression>] = [si(5), Shared.new(SemanticExpressionLambda(single_params, Shared.new(SemanticExpressionBin("+", sid("x"), si(1), i32_t(), span_unknown())), unk_t(), span_unknown()))]
  results.push(assert_eq_str('ExprCall with lambda arg',
    gen_expr(Shared.new(SemanticExpressionCall(sid('apply'), call_lambda_args, empty_parameter_mutability_pattern(), unk_t(), span_unknown())), context),
    'apply(5, [=](auto x) mutable { return (x + 1); })'))

  const ok_args: [Shared<SemanticExpression>] = [si(42)]
  results.push(assert_eq_str('ExprCall ctor Ok(42) uses brace init',
    gen_expr(Shared.new(SemanticExpressionCall(sid('Ok'), ok_args, empty_parameter_mutability_pattern(), unk_t(), span_unknown())), context),
    'Ok{42}'))

  const err_args: [Shared<SemanticExpression>] = [ss('oops')]
  results.push(assert_eq_str('ExprCall ctor Err(str) uses brace init',
    gen_expr(Shared.new(SemanticExpressionCall(sid('Err'), err_args, empty_parameter_mutability_pattern(), unk_t(), span_unknown())), context),
    'Err{mlc::String("oops", 4)}'))

  const empty_arr: [Shared<SemanticExpression>] = []

  const mut_actual_first_parameter: [i32] = []
  mut_actual_first_parameter.push(1)
  const inner_call_under_mut_actual_test =
    Shared.new(SemanticExpressionCall(sid('spawn_inner'), empty_arr, empty_parameter_mutability_pattern(), unk_t(), span_unknown()))
  const outer_under_mut_actual_test_expression =
    Shared.new(SemanticExpressionCall(
      sid('consume_mut_first'),
      [inner_call_under_mut_actual_test],
      mut_actual_first_parameter,
      unk_t(),
      span_unknown()))
  results.push(assert_code_contains(
    'mutable first positional actual argument lowers with holder IIFE',
    gen_expr(outer_under_mut_actual_test_expression, context),
    '__mut_actual_argument_holder_0'))
  results.push(assert_code_contains(
    'mutable first positional actual argument lowers with return prelude',
    gen_expr(outer_under_mut_actual_test_expression, context),
    '[&]()'))
  results.push(assert_code_contains(
    'mutable first positional actual argument holder auto decl',
    gen_expr(outer_under_mut_actual_test_expression, context),
    'auto __mut_actual_argument_holder_0'))

  // --- ExprIf -------------------------------------------------------------------

  results.push(assert_eq_str('ExprIf',
    gen_expr(Shared.new(SemanticExpressionIf(sb(true), si(1), si(2), i32_t(), span_unknown())), context),
    '(true ? (1) : (2))'))

  // --- ExprArray ----------------------------------------------------------------

  const arr_elems: [Shared<SemanticExpression>] = [si(1), si(2), si(3)]
  results.push(assert_eq_str('ExprArray',
    gen_expr(Shared.new(SemanticExpressionArray(arr_elems, Shared.new(TArray(i32_t())), span_unknown())), context),
    'mlc::Array<int>{1, 2, 3}'))

  results.push(assert_eq_str('ExprArray empty',
    gen_expr(Shared.new(SemanticExpressionArray(empty_arr, Shared.new(TArray(i32_t())), span_unknown())), context),
    'mlc::Array<int>{}'))

  // --- ExprTuple ----------------------------------------------------------------

  const tuple_elements: [Shared<SemanticExpression>] = [si(1), si(2)]
  results.push(assert_eq_str('ExprTuple - std::make_tuple(1, 2)',
    gen_expr(Shared.new(SemanticExpressionTuple(tuple_elements, Shared.new(TTuple([Shared.new(TI32), Shared.new(TI32)])), span_unknown())), context),
    'std::make_tuple(1, 2)'))

  // --- ExprIndex ----------------------------------------------------------------

  results.push(assert_eq_str('ExprIndex',
    gen_expr(Shared.new(SemanticExpressionIndex(sid('arr'), si(0), i32_t(), span_unknown())), context),
    'arr[0]'))

  // --- ExprField ----------------------------------------------------------------

  results.push(assert_eq_str('ExprField on ident',
    gen_expr(Shared.new(SemanticExpressionField(sid('point'), "x", unk_t(), span_unknown())), context),
    'point.x'))

  // --- ExprMethod ---------------------------------------------------------------

  const method_args: [Shared<SemanticExpression>] = [si(1)]
  results.push(assert_eq_str('ExprMethod push',
    gen_expr(Shared.new(SemanticExpressionMethod(sid('arr'), 'push', method_args, empty_parameter_mutability_pattern(), unit_t(), span_unknown())), context),
    'arr.push_back(1)'))

  results.push(assert_eq_str('ExprMethod length',
    gen_expr(Shared.new(SemanticExpressionMethod(sid('arr'), 'length', empty_arr, empty_parameter_mutability_pattern(), i32_t(), span_unknown())), context),
    'arr.length()'))

  const result_r_t = Shared.new(TGeneric('Result', [i32_t(), str_t()]))
  const s_result = Shared.new(SemanticExpressionIdent("r", result_r_t, span_unknown()))
  const map_one: [Shared<SemanticExpression>] = [Shared.new(SemanticExpressionIdent("f", unk_t(), span_unknown()))]
  results.push(assert_eq_str('ExprMethod Result map',
    gen_expr(Shared.new(SemanticExpressionMethod(s_result, 'map', map_one, empty_parameter_mutability_pattern(), unk_t(), span_unknown())), context),
    'mlc::result::map(r, f)'))

  let namespace_alias_prefixes: Map<string, string> = Map.new()
  namespace_alias_prefixes.set('helpers', 'infer_literals::')
  const context_with_aliases = context.with_namespace_alias_prefixes(namespace_alias_prefixes)
  results.push(assert_eq_str('ExprMethod on import-as alias emits namespace::fn()',
    gen_expr(Shared.new(SemanticExpressionMethod(sid('helpers'), 'infer_expr_integer_literal', empty_arr, empty_parameter_mutability_pattern(), unk_t(), span_unknown())), context_with_aliases),
    'infer_literals::infer_expr_integer_literal()'))

  // --- ExprMatch ----------------------------------------------------------------

  const pattern_arms: [Shared<SemanticMatchArm>] = [
    smatch_arm(Shared.new(PatternInt(1, span_unknown())), ss('one')),
    smatch_arm(Shared.new(PatternWild(span_unknown())), ss('other'))
  ]
  const match_out = gen_expr(Shared.new(SemanticExpressionMatch(sid("n"), pattern_arms, str_t(), span_unknown())), context)
  results.push(assert_eq_str('ExprMatch wildcard avoids std::visit',
    if match_out.contains('std::visit') then 'visit' else 'guarded' end, 'guarded'))
  results.push(assert_eq_str('ExprMatch contains one',
    if match_out.contains('"one"') then 'yes' else 'no' end, 'yes'))
  results.push(assert_eq_str('ExprMatch contains other',
    if match_out.contains('"other"') then 'yes' else 'no' end, 'yes'))

  results.push(assert_eq_str('match_arm_wild_or_unit_return uses value capture',
    match_arm_wild_or_unit_return("1"), "[=](const auto& __v) { return 1; }"))
  results.push(assert_eq_str('match_arm_binding_identifier uses value capture',
    match_arm_binding_identifier("n", "n"), "[=](const auto& n) { return n; }"))
  results.push(assert_eq_str('match_arm_constructed_value uses value capture',
    match_arm_constructed_value("const Point& p", "", "p.x"),
    "[=](const Point& p) { return p.x; }"))
  results.push(assert_eq_str('match_arm_constructed_value_generic uses value capture',
    match_arm_constructed_value_generic("Shape", "shape", "", "1"),
    "[=]<typename __mlcT>(const Shape<__mlcT>& shape) { return 1; }"))

  const string_match_arms: [Shared<SemanticMatchArm>] = [
    smatch_arm(Shared.new(PatternStringLit('fn', span_unknown())), si(1)),
    smatch_arm(Shared.new(PatternStringLit('type', span_unknown())), si(2)),
    smatch_arm(Shared.new(PatternWild(span_unknown())), si(0))
  ]
  const word_subject = Shared.new(SemanticExpressionIdent('word', str_t(), span_unknown()))
  const string_match_out =
    gen_expr(Shared.new(SemanticExpressionMatch(word_subject, string_match_arms, i32_t(), span_unknown())), context)
  results.push(assert_eq_str('string match avoids std::visit',
    if string_match_out.contains('std::visit') then 'has_visit' else 'no_visit' end, 'no_visit'))
  results.push(assert_code_contains('string match emits if/else if chain', string_match_out, 'else if'))
  results.push(assert_code_contains('string match compares subject to literal', string_match_out, '__match_subject =='))

  const string_match_program =
    'fn f(word: string) -> i32 = match word | "fn" => 1 | "type" => 2 | _ => 0 end\nfn main() -> i32 = f("fn")\n'
  const string_match_program_cpp = gen_program(parse_program(tokenize(string_match_program).tokens))
  results.push(assert_eq_str('program string match avoids std::visit',
    if string_match_program_cpp.contains('std::visit') then 'has_visit' else 'no_visit' end, 'no_visit'))
  results.push(assert_code_contains('program string match has else if', string_match_program_cpp, 'else if'))

  // PatternOr: expand_or_arms produces two separate lambda arms
  const or_match_arms: [Shared<SemanticMatchArm>] = [
    smatch_arm(
      Shared.new(PatternOr([Shared.new(PatternCtor('Circle', [Shared.new(PatternWild(span_unknown()))], span_unknown())), Shared.new(PatternCtor('Square', [Shared.new(PatternWild(span_unknown()))], span_unknown()))], span_unknown())),
      ss("r"))
  ]
  const or_match_out = gen_expr(Shared.new(SemanticExpressionMatch(sid("s"), or_match_arms, str_t(), span_unknown())), context)
  results.push(assert_eq_str('PatternOr expanded: Circle lambda present',
    if or_match_out.contains('Circle') then 'yes' else 'no' end, 'yes'))
  results.push(assert_eq_str('PatternOr expanded: Square lambda present',
    if or_match_out.contains('Square') then 'yes' else 'no' end, 'yes'))

  const guarded_primitive_program =
    'fn main() -> i32 = match 5 { n if n > 0 => 1, else => 0 }\n'
  const guarded_primitive_cpp = gen_program(parse_program(tokenize(guarded_primitive_program).tokens))
  results.push(assert_eq_str('match guard on primitive avoids std::visit',
    if guarded_primitive_cpp.contains('std::visit') then 'has_visit' else 'no_visit' end, 'no_visit'))
  results.push(assert_code_contains('match guard emits typed IIFE', guarded_primitive_cpp, '[&]() -> int'))
  const plain_sum_program =
    'type T = A(i32) | B\nfn f(x: T) -> i32 = match x | A(n) => n | B => 0 end\nfn main() -> i32 = f(A(1))\n'
  const plain_sum_cpp = gen_program(parse_program(tokenize(plain_sum_program).tokens))
  results.push(assert_eq_str('match sum without guard keeps std::visit',
    if plain_sum_cpp.contains('std::visit') then 'yes' else 'no' end, 'yes'))
  const guarded_sum_program =
    'type U = A(i32) | B\nfn g(x: U) -> i32 = match x | A(n) if n > 0 => n | A(_) => 0 | B => -1 end\nfn main() -> i32 = g(A(3))\n'
  const guarded_sum_cpp = gen_program(parse_program(tokenize(guarded_sum_program).tokens))
  results.push(assert_eq_str('match sum with guard avoids std::visit',
    if guarded_sum_cpp.contains('std::visit') then 'has_visit' else 'no_visit' end, 'no_visit'))
  const mixed_guard_program =
    'type V = A(i32) | B\nfn h(x: V) -> i32 = match x | A(n) => n | B if true => 0 end\nfn main() -> i32 = h(B)\n'
  const mixed_guard_cpp = gen_program(parse_program(tokenize(mixed_guard_program).tokens))
  results.push(assert_eq_str('match mixed arms use guarded lowering when any guard present',
    if mixed_guard_cpp.contains('std::visit') then 'has_visit' else 'no_visit' end, 'no_visit'))
  // --- ExprWhile ----------------------------------------------------------------

  const while_body: [Shared<SemanticStatement>] = [Shared.new(SemanticStatementExpr(si(0), span_unknown()))]
  const while_out = gen_expr(Shared.new(SemanticExpressionWhile(sb(true), while_body, unit_t(), span_unknown())), context)
  results.push(assert_eq_str('ExprWhile contains while (true)',
    if while_out.contains('while (true)') then 'yes' else 'no' end, 'yes'))

  // --- ExprBlock ----------------------------------------------------------------

  const block_statements: [Shared<SemanticStatement>] = [Shared.new(SemanticStatementLet("x", false, si(1), i32_t(), span_unknown()))]
  results.push(assert_eq_str('ExprBlock',
    gen_expr(Shared.new(SemanticExpressionBlock(block_statements, sid("x"), i32_t(), span_unknown())), context),
    '[&]() {\nauto x = 1;\nreturn x;\n}()'))

  results.push(assert_eq_str('gen_stmts_str: let const emits constexpr',
    gen_stmts_str([Shared.new(SemanticStatementLetConst('limit', si(42), i32_t(), span_unknown()))], context),
    'constexpr auto limit = 42;\n'))

  results.push(assert_eq_str('gen_stmts_cpp_as_string: break',
    gen_stmts_str([Shared.new(SemanticStatementBreak(span_unknown()))], context),
    'break;\n'))

  results.push(assert_eq_str('gen_stmts_cpp_as_string: continue',
    gen_stmts_str([Shared.new(SemanticStatementContinue(span_unknown()))], context),
    'continue;\n'))

  results.push(assert_eq_str('gen_stmts_cpp_as_string: let',
    gen_stmts_str([Shared.new(SemanticStatementLet('counter', false, si(1), i32_t(), span_unknown()))], context),
    'auto counter = 1;\n'))

  const map_new_value = Shared.new(SemanticExpressionMethod(
    Shared.new(SemanticExpressionIdent('Map', unk_t(), span_unknown())),
    'new',
    [],
    empty_parameter_mutability_pattern(),
    unk_t(),
    span_unknown()))
  const map_new_type = Shared.new(TGeneric('Map', [Shared.new(TString), Shared.new(TString)]))
  results.push(assert_eq_str('gen_stmts_cpp_as_string: let Map.new typed',
    gen_stmts_str([Shared.new(SemanticStatementLet('table', false, map_new_value, map_new_type, span_unknown()))], context),
    'auto table = mlc::HashMap<mlc::String, mlc::String>();\n'))

  results.push(assert_eq_str('gen_stmts_cpp_as_string: let question',
