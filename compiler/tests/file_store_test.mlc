// Tests for SourceFileId and SourceFileStore intern/lookup round-trip.
import { TestResult, assert_eq_int, assert_eq_str, assert_true } from './test_runner'
import { SourceFileStore, SourceFileId, source_file_store_new, source_file_store_intern, source_file_store_path, source_file_store_source, source_file_id_index } from '../infrastructure/file_store'
export fn file_store_tests() -> [TestResult] = do
  let results: [TestResult] = []
  let mut store = source_file_store_new()
  const id_a = source_file_store_intern(store, 'a.mlc', 'source a')
  results.push(assert_eq_int('first intern index', source_file_id_index(id_a), 0))
  const id_a_again = source_file_store_intern(store, 'a.mlc', 'source a')
  results.push(assert_eq_int('dedup same path index', source_file_id_index(id_a_again), 0))
  results.push(assert_eq_int('store size after dedup', store.paths.length(), 1))
  const id_b = source_file_store_intern(store, 'b.mlc', 'source b')
  results.push(assert_eq_int('second intern index', source_file_id_index(id_b), 1))
  results.push(assert_true('distinct file ids', source_file_id_index(id_a) != source_file_id_index(id_b)))
  results.push(assert_eq_str('path a', source_file_store_path(store, id_a), 'a.mlc'))
  results.push(assert_eq_str('source a', source_file_store_source(store, id_a), 'source a'))
  results.push(assert_eq_str('path b', source_file_store_path(store, id_b), 'b.mlc'))
  results.push(assert_eq_str('source b', source_file_store_source(store, id_b), 'source b'))
  results
end
