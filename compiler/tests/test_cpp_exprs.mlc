// Unit tests for C++ expression parser.

import { TestResult, assert_eq_int, assert_true } from './test_runner'
import { cpp_tokenize } from '../cpp_parse/cpp_lexer'
import { parse_cpp_expression } from '../cpp_parse/parser/cpp_exprs'
import { CppExpression, CppInt, CppStr, CppCharLiteral, CppFloatLiteral, CppBool, CppIdent,
         CppBinary, CppUnary, CppCall, CppMember, CppIndex, CppTernary } from '../cpp_ir/cpp_ast'

fn cpp_expr_parse(source_text: string) -> Shared<CppExpression> =
  parse_cpp_expression(cpp_tokenize(source_text).tokens, 0).expression

fn cpp_expr_parse_error_count(source_text: string) -> i32 =
  if parse_cpp_expression(cpp_tokenize(source_text).tokens, 0).error_message != "" then 1 else 0

fn cpp_expr_is_int(expression: Shared<CppExpression>, expected: i32) -> bool =
  match expression { CppInt(value) => value == expected, _ => false }

fn cpp_expr_is_hex(expression: Shared<CppExpression>, expected: i32) -> bool =
  match expression { CppInt(value) => value == expected, _ => false }

fn cpp_expr_is_float(expression: Shared<CppExpression>, expected: string) -> bool =
  match expression { CppFloatLiteral(text) => text == expected, _ => false }

fn cpp_expr_is_char(expression: Shared<CppExpression>, expected: string) -> bool =
  match expression { CppCharLiteral(character) => character == expected, _ => false }

fn cpp_expr_is_string(expression: Shared<CppExpression>, expected: string) -> bool =
  match expression { CppStr(text) => text == expected, _ => false }

fn cpp_expr_is_ident(expression: Shared<CppExpression>, expected: string) -> bool =
  match expression { CppIdent(name) => name == expected, _ => false }

fn cpp_expr_is_addition(expression: Shared<CppExpression>) -> bool = do
  match expression {
    CppBinary(operation, left, right) =>
      operation == "+" && cpp_expr_is_int(left, 1) && cpp_expr_is_int(right, 2),
    _ => false
  }
end

fn cpp_expr_is_binary_mul(expression: Shared<CppExpression>) -> bool = do
  match expression {
    CppBinary(operation, _, _) => operation == "*",
    _ => false
  }
end

fn cpp_expr_is_mul_precedence(expression: Shared<CppExpression>) -> bool = do
  match expression {
    CppBinary(operation, left, right) =>
      operation == "+" && cpp_expr_is_int(left, 1) && cpp_expr_is_binary_mul(right),
    _ => false
  }
end

fn cpp_expr_is_unary_minus(expression: Shared<CppExpression>) -> bool = do
  match expression {
    CppUnary(operation, inner) => operation == "-" && cpp_expr_is_ident(inner, "x"),
    _ => false
  }
end

fn cpp_expr_is_call(expression: Shared<CppExpression>) -> bool = do
  match expression {
    CppCall(callee, arguments) =>
      cpp_expr_is_ident(callee, "foo") && arguments.length() == 2,
    _ => false
  }
end

fn cpp_expr_is_member(expression: Shared<CppExpression>) -> bool = do
  match expression {
    CppMember(object, member_name, is_pointer) =>
      cpp_expr_is_ident(object, "obj") && member_name == "field" && !is_pointer,
    _ => false
  }
end

fn cpp_expr_is_pointer_member(expression: Shared<CppExpression>) -> bool = do
  match expression {
    CppMember(object, member_name, is_pointer) =>
      cpp_expr_is_ident(object, "ptr") && member_name == "method" && is_pointer,
    _ => false
  }
end

fn cpp_expr_is_index(expression: Shared<CppExpression>) -> bool = do
  match expression {
    CppIndex(object, index) => cpp_expr_is_ident(object, "arr") && cpp_expr_is_int(index, 0),
    _ => false
  }
end

fn cpp_expr_is_ternary(expression: Shared<CppExpression>) -> bool = do
  match expression {
    CppTernary(condition, then_branch, else_branch) =>
      cpp_expr_is_ident(condition, "a")
      && cpp_expr_is_ident(then_branch, "b")
      && cpp_expr_is_ident(else_branch, "c"),
    _ => false
  }
end

fn cpp_expr_is_true(expression: Shared<CppExpression>) -> bool =
  match expression { CppBool(value) => value, _ => false }

fn cpp_expr_is_false(expression: Shared<CppExpression>) -> bool =
  match expression { CppBool(value) => !value, _ => false }

export fn cpp_expr_parser_tests() -> [TestResult] = do
  let results: [TestResult] = []

  results.push(assert_true('integer literal', cpp_expr_is_int(cpp_expr_parse("42"), 42)))
  results.push(assert_true('hex literal', cpp_expr_is_hex(cpp_expr_parse("0xFF"), 255)))
  results.push(assert_true('float literal', cpp_expr_is_float(cpp_expr_parse("3.14f"), "3.14f")))
  results.push(assert_true('char literal', cpp_expr_is_char(cpp_expr_parse("'a'"), "a")))
  results.push(assert_true('string literal', cpp_expr_is_string(cpp_expr_parse(`"hello"`), "hello")))
  results.push(assert_true('true keyword', cpp_expr_is_true(cpp_expr_parse("true"))))
  results.push(assert_true('false keyword', cpp_expr_is_false(cpp_expr_parse("false"))))
  results.push(assert_true('nullptr keyword', cpp_expr_is_ident(cpp_expr_parse("nullptr"), "nullptr")))
  results.push(assert_true('identifier', cpp_expr_is_ident(cpp_expr_parse("foo"), "foo")))
  results.push(assert_true('binary addition', cpp_expr_is_addition(cpp_expr_parse("1 + 2"))))
  results.push(assert_true('multiplication binds tighter than addition', cpp_expr_is_mul_precedence(cpp_expr_parse("1 + 2 * 3"))))
  results.push(assert_true('unary minus', cpp_expr_is_unary_minus(cpp_expr_parse("-x"))))
  results.push(assert_true('function call', cpp_expr_is_call(cpp_expr_parse("foo(1, 2)"))))
  results.push(assert_true('member access', cpp_expr_is_member(cpp_expr_parse("obj.field"))))
  results.push(assert_true('pointer member access', cpp_expr_is_pointer_member(cpp_expr_parse("ptr->method"))))
  results.push(assert_true('index access', cpp_expr_is_index(cpp_expr_parse("arr[0]"))))
  results.push(assert_true('ternary expression', cpp_expr_is_ternary(cpp_expr_parse("a ? b : c"))))
  results.push(assert_eq_int('parse error on garbage', cpp_expr_parse_error_count("@@@"), 1))

  results
end