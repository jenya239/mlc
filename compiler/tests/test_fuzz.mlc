import { TestResult, assert_eq_int, assert_eq_str, assert_true } from './test_runner'
import { fuzz_random_program, fuzz_mix, fuzz_variant_count, fuzz_program_kind } from './fuzz/random_program'
import { tokenize } from '../frontend/lexer'
import { parse_program } from '../frontend/parser/decls'
import { LoadItem } from '../ir/load_item'
import { ModularCompileInput, run_modular_compiler_pipeline } from '../pipeline'

fn fuzz_pipeline_input_for_source(source: string) -> ModularCompileInput = do
  const program = parse_program(tokenize(source).tokens)
  const load_item = LoadItem {
    path: 'fuzz_probe.mlc',
    decls: program.decls,
    imports: [],
    namespace_import_aliases: []
  }
  ModularCompileInput {
    load_items: [load_item],
    full_program: program,
    entry_program: program,
    output_directory: '',
    profile_enabled: false,
    check_only: true,
    emit_compile_commands: false,
    verify_each_pass: false,
    dump_ast: false,
    dump_sem: false,
    dump_mir: false,
    mir_bootstrap_report: false,
    time_passes: false,
    run_interpreter: false,
    trace_vm: false
  }
end

fn fuzz_pipeline_input(seed: i32) -> ModularCompileInput =
  fuzz_pipeline_input_for_source(fuzz_random_program(seed))

fn fuzz_differential_check_only_ok(source: string) -> bool =
  match run_modular_compiler_pipeline(fuzz_pipeline_input_for_source(source)) {
    Ok(_) => true,
    Err(_) => false
  }

fn fuzz_differential_check_only_error_count(source: string) -> i32 =
  match run_modular_compiler_pipeline(fuzz_pipeline_input_for_source(source)) {
    Ok(_) => 0,
    Err(errors) => errors.length()
  }

fn fuzz_pipeline_completes(seed: i32) -> bool =
  match run_modular_compiler_pipeline(fuzz_pipeline_input(seed)) {
    Ok(_) => true,
    Err(_) => true
  }

fn fuzz_lex_parse_completes(source: string) -> bool = do
  const lex = tokenize(source)
  if lex.has_errors() then true
  else do
    parse_program(lex.tokens)
    true
  end
  end
end

fn fuzz_deep_nesting_source(depth: i32) -> string = do
  let mut body = "0"
  let mut level = 0
  while level < depth do
    body = "do\n" + body + "\nend"
    level = level + 1
  end
  "fn fuzz_entry() -> i32 = " + body
end

export fn fuzz_tests() -> [TestResult] = do
  let results: [TestResult] = []

  results.push(assert_true('fuzz generator non-empty',
    fuzz_random_program(0).length() > 0))

  results.push(assert_eq_str('fuzz generator deterministic',
    fuzz_random_program(42), fuzz_random_program(42)))

  results.push(assert_true('fuzz mix varies with seed',
    fuzz_mix(0) != fuzz_mix(1)))

  results.push(assert_eq_str('fuzz variant count',
    fuzz_variant_count().to_string(), '12'))

  let mut seed = 0
  while seed < fuzz_variant_count() do
    results.push(assert_true('fuzz program variants seed ' + seed.to_string(),
      fuzz_random_program(seed).contains('fn ')))
    seed = seed + 1
  end

  results.push(assert_true('fuzz if variant',
    fuzz_random_program(7).contains('if true then')))

  results.push(assert_true('fuzz let variant',
    fuzz_random_program(0).contains('let x =')))

  results.push(assert_true('fuzz match variant',
    fuzz_random_program(5).contains('match ')))

  results.push(assert_true('fuzz type stub variant',
    fuzz_program_kind(10) == 9 && fuzz_random_program(10).contains('type FuzzStub_')))

  results.push(assert_true('fuzz record variant',
    fuzz_program_kind(3) == 10 && fuzz_random_program(3).contains('FuzzRecord_')))

  results.push(assert_true('fuzz nested block variant',
    fuzz_program_kind(8) == 11 && fuzz_random_program(8).contains('let outer = do')))

  results.push(assert_true('fuzz garbage lex parse completes',
    fuzz_lex_parse_completes('fn @@@')))

  results.push(assert_true('fuzz garbage unclosed string lex',
    fuzz_lex_parse_completes('fn f() -> string = "unclosed')))

  results.push(assert_true('fuzz garbage deep nesting lex parse',
    fuzz_lex_parse_completes(fuzz_deep_nesting_source(24))))

  let mut pipeline_seed = 0
  while pipeline_seed < 64 do
    const source = fuzz_random_program(pipeline_seed)
    results.push(assert_true('fuzz check_only pipeline seed ' + pipeline_seed.to_string(),
      fuzz_pipeline_completes(pipeline_seed)))
    results.push(assert_true('fuzz lex parse seed ' + pipeline_seed.to_string(),
      fuzz_lex_parse_completes(source)))
    pipeline_seed = pipeline_seed + 1
  end

  let mut differential_seed = 0
  while differential_seed < 8 do
    results.push(assert_true('fuzz differential seed ' + differential_seed.to_string() + ' check_only ok',
      fuzz_differential_check_only_ok(fuzz_random_program(differential_seed))))
    differential_seed = differential_seed + 1
  end

  const immutable_assign = 'fn f() -> i32 = do\n  let x = 1\n  x = 2\n  x\nend'
  const not_callable = 'fn f() -> i32 = 42()'
  const return_type_mismatch = 'fn f() -> i32 = "not an integer"'
  const undefined_ident = 'fn f() -> i32 = no_such_binding'
  const wrong_call_arity = 'fn pair_sum(first: i32, second: i32) -> i32 = first + second\nfn main() -> i32 = pair_sum(1)'

  results.push(assert_eq_int('fuzz differential checker-negative immutable assign',
    fuzz_differential_check_only_error_count(immutable_assign), 1))
  results.push(assert_eq_int('fuzz differential checker-negative not callable',
    fuzz_differential_check_only_error_count(not_callable), 1))
  results.push(assert_eq_int('fuzz differential checker-negative return type',
    fuzz_differential_check_only_error_count(return_type_mismatch), 1))
  results.push(assert_eq_int('fuzz differential checker-negative undefined ident',
    fuzz_differential_check_only_error_count(undefined_ident), 1))
  results.push(assert_eq_int('fuzz differential checker-negative wrong call arity',
    fuzz_differential_check_only_error_count(wrong_call_arity), 1))

  results
end