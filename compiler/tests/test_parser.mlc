// Unit tests for the parser (parse_program function).

import { TestResult, assert_eq_int, assert_true } from './test_runner'
import { tokenize } from '../frontend/lexer'
import { parse_program, parse_program_with_errors } from '../frontend/parser/decls'
import { Decl, DeclFn, DeclType, DeclTrait, DeclExtend, DeclImport, DeclExported, Expr, ExprStr, ExprBin, ExprIdent, ExprCall, ExprMethod, ExprMatch, MatchArm, Pat, PatOr, PatCtor, PatWild, PatIdent, ExprBlock, Stmt, StmtLetPat } from '../frontend/ast'
import { parse_expr } from '../frontend/parser/exprs'
import { parser_new } from '../frontend/parser/predicates'

fn parse_source(source: string) -> Program =
  parse_program(tokenize(source).tokens)

fn parse_source_errors(source: string) -> [string] =
  parse_program_with_errors(tokenize(source).tokens, '').errors

fn parse_expr_source(source: string) -> Shared<Expr> =
  parse_expr(parser_new(tokenize(source).tokens)).expr

fn parse_expr_errors(source: string) -> [string] =
  parse_expr(parser_new(tokenize(source).tokens)).parser.errors

fn expr_call_one_ident_argument(expression: Shared<Expr>, expected_function: string, expected_argument: string) -> bool =
  match expression {
    ExprCall(callee, arguments, _) =>
      match callee {
        ExprIdent(function_name, _) =>
          if function_name != expected_function || arguments.length() != 1 then false
          else
            match arguments[0] {
              ExprIdent(argument_name, _) => argument_name == expected_argument,
              _ => false
            }
          end,
        _ => false
      },
    _ => false
  }

fn pipe_case_logical_or_over_pipeline(expression: Shared<Expr>) -> bool =
  match expression {
    ExprBin(binary_operator, left_logical, right_logical, _) =>
      if binary_operator != '||' then false
      else
        match left_logical {
          ExprIdent(left_name, _) =>
            left_name == "a" && expr_call_one_ident_argument(right_logical, "c", "b"),
          _ => false
        }
      end,
    _ => false
  }

fn pipe_case_logical_and_over_pipeline(expression: Shared<Expr>) -> bool =
  match expression {
    ExprBin(binary_operator, left_conjunct, right_conjunct, _) =>
      if binary_operator != '&&' then false
      else
        match left_conjunct {
          ExprIdent(left_name, _) =>
            left_name == "a" && expr_call_one_ident_argument(right_conjunct, "c", "b"),
          _ => false
        }
      end,
    _ => false
  }

fn pipe_case_equality_right_operand_contains_pipeline(expression: Shared<Expr>) -> bool =
  match expression {
    ExprBin(binary_operator, left_equals, right_equals, _) =>
      if binary_operator != '==' then false
      else
        match left_equals {
          ExprIdent(left_name, _) =>
            left_name == "a" && expr_call_one_ident_argument(right_equals, "c", "b"),
          _ => false
        }
      end,
    _ => false
  }

fn pipe_pipeline_left_equals_shape(left_equals: Shared<Expr>, right_equals: Shared<Expr>) -> bool =
  match left_equals {
    ExprCall(callee, arguments, _) =>
      match callee {
        ExprIdent(function_name, _) =>
          match right_equals {
            ExprIdent(right_name, _) =>
              if function_name != "b" || right_name != "c" || arguments.length() != 1 then false
              else
                match arguments[0] {
                  ExprIdent(argument_name, _) => argument_name == "a",
                  _ => false
                }
              end,
            _ => false
          },
        _ => false
      },
    _ => false
  }

fn pipe_case_pipeline_binds_tighter_than_equality_on_left(expression: Shared<Expr>) -> bool =
  match expression {
    ExprBin(binary_operator, left_equals, right_equals, _) =>
      if binary_operator != '==' then false
      else pipe_pipeline_left_equals_shape(left_equals, right_equals)
      end,
    _ => false
  }

fn expr_match_arm_count(parsed_expression: Shared<Expr>) -> i32 =
  match parsed_expression {
    ExprMatch(_, arms, _) => do
      let mut count = 0
      while count < arms.length() do count = count + 1 end
      count
    end,
    _ => -1
  }

fn expr_match_arm_has_guard(parsed_expression: Shared<Expr>, arm_index: i32) -> bool =
  match parsed_expression {
    ExprMatch(_, arms, _) =>
      if arm_index < 0 || arm_index >= arms.length() then false
      else arms[arm_index].has_guard
      end,
    _ => false
  }

fn expr_guard_binary_operation(candidate_guard: Shared<Expr>) -> string =
  match candidate_guard {
    ExprBin(binary_operation, _, _, _) => binary_operation,
    _ => ''
  }

fn expr_pat_ident_binding_name(pattern: Shared<Pat>) -> string =
  match pattern {
    PatIdent(binding_name, _) => binding_name,
    _ => ''
  }

fn expr_pat_or_alt_count(pattern: Shared<Pat>) -> i32 =
  match pattern {
    PatOr(alts, _) => do
      let mut count = 0
      while count < alts.length() do count = count + 1 end
      count
    end,
    _ => -1
  }

fn expr_match_arm_guard_binary_operation(parsed_expression: Shared<Expr>, arm_index: i32) -> string =
  match parsed_expression {
    ExprMatch(_, arms, _) =>
      if arm_index < 0 || arm_index >= arms.length() then ''
      else expr_guard_binary_operation(arms[arm_index].when_condition)
      end,
    _ => ''
  }

fn expr_match_arm_pat_ident_name(parsed_expression: Shared<Expr>, arm_index: i32) -> string =
  match parsed_expression {
    ExprMatch(_, arms, _) =>
      if arm_index < 0 || arm_index >= arms.length() then ''
      else expr_pat_ident_binding_name(arms[arm_index].pat)
      end,
    _ => ''
  }

fn expr_match_arm_pat_or_alt_count(parsed_expression: Shared<Expr>, arm_index: i32) -> i32 =
  match parsed_expression {
    ExprMatch(_, arms, _) =>
      if arm_index < 0 || arm_index >= arms.length() then -1
      else expr_pat_or_alt_count(arms[arm_index].pat)
      end,
    _ => -1
  }

fn sample_parse_match_guard_brace() -> Shared<Expr> =
  parse_expr_source('match score { n if n >= 90 => 1 }')

fn sample_parse_match_guard_pipe() -> Shared<Expr> =
  parse_expr_source('match x | n if n > 0 => 1 end')

fn sample_parse_match_guard_or_pattern() -> Shared<Expr> =
  parse_expr_source('match x { A(r) | B(r) if r > 0 => r }')

fn decl_count(source: string) -> i32 =
  parse_source(source).decls.length()

fn first_decl(source: string) -> Shared<Decl> =
  parse_source(source).decls[0]

fn second_decl(source: string) -> Shared<Decl> =
  parse_source(source).decls[1]

fn trait_display_decl(program: Program) -> bool =
  match program.decls[0] {
    DeclTrait(name, _, methods) => name == 'Display' && methods.length() == 1,
    _ => false
  }

export fn parser_tests() -> [TestResult] = do
  let results: [TestResult] = []

  results.push(assert_eq_int('empty source - 0 decls',
    decl_count(''), 0))

  results.push(assert_eq_int('single fn decl - 1 decl',
    decl_count('fn f() -> i32 = 42'), 1))

  results.push(assert_eq_int('two fn decls - 2 decls',
    decl_count('fn f() -> i32 = 1\nfn g() -> i32 = 2'), 2))

  results.push(assert_eq_int('type decl - 1 decl',
    decl_count('type Color = Red | Green | Blue'), 1))

  results.push(assert_eq_int('fn with params - 1 decl',
    decl_count('fn add(x: i32, y: i32) -> i32 = x + y'), 1))

  results.push(assert_eq_int('fn with default param - 1 decl',
    decl_count('fn f(a: i32 = 1) -> i32 = a'), 1))

  results.push(assert_eq_int('fn with do block - 1 decl',
    decl_count('fn f() -> i32 = do\n  const x = 1\n  x\nend'), 1))

  results.push(assert_eq_int('type + fn - 2 decls',
    decl_count('type Color = Red\nfn f() -> i32 = 1'), 2))

  results.push(assert_eq_int('record type field default expression — parse decl count',
    decl_count('type Line = { offset: i32 = 10 + 20 }\nfn main() -> i32 = 0'), 2))

  results.push(assert_true('fn decl is DeclFn',
    match first_decl('fn f() -> i32 = 42') {
      DeclFn(_, _, _, _, _, _, _) => true,
      _ => false
    }))

  results.push(assert_true('type decl is DeclType',
    match first_decl('type Color = Red | Green') {
      DeclType(_, _, _, _) => true,
      _ => false
    }))

  results.push(assert_eq_int('fn with if expr - 1 decl',
    decl_count('fn f(x: i32) -> i32 = if x > 0 then 1 else 0 end'), 1))

  results.push(assert_eq_int('fn with for-in - 1 decl',
    decl_count('fn f(items: [i32]) -> i32 = do\n  let mut s = 0\n  for x in items do\n    s = s + x\n  end\n  s\nend'), 1))

  results.push(assert_eq_int('type + fn with match pipe arms - 2 decls',
    decl_count('type T = A(i32) | B\nfn f(x: T) -> i32 = match x | A(n) => n | B => 0\n'), 2))

  results.push(assert_eq_int('trait plus fn with where clause — 2 decls',
    decl_count('type Display { fn to_string(self: Self) -> string }\nfn f<T>(x: T) -> unit where T: Display = ()'), 2))

  results.push(assert_eq_int('fn with parenthesized lambda - 1 decl',
    decl_count('fn f() -> i32 = (() => 7)()'), 1))

  results.push(assert_true('extend method: self with type and extra param',
    match second_decl('type R = { a: i32 }\nextend R {\n  fn m(self: R, x: i32) -> i32 = x\n}') {
      DeclExtend(_, _, methods) =>
        match methods[0] {
          DeclFn(_, _, _, parameters, _, _, _) => parameters.length() == 2,
          _ => false
        },
      _ => false
    }))

  results.push(assert_eq_int('import star-as - 1 decl',
    decl_count('import * as helpers from "./infer_literals.mlc"'), 1))

  results.push(assert_true('import star-as: path and symbols',
    match first_decl('import * as helpers from "./infer_literals.mlc"') {
      DeclImport(path, symbols) =>
        path == './infer_literals.mlc' && symbols.length() == 2 && symbols[0] == "*" && symbols[1] == 'helpers',
      _ => false
    }))

  results.push(assert_eq_int('import named list - 1 decl',
    decl_count('import { foo, bar } from "./mod.mlc"'), 1))

  results.push(assert_true('import named list: path and symbols order',
    match first_decl('import { foo, bar } from "./mod.mlc"') {
      DeclImport(path, symbols) =>
        path == './mod.mlc' && symbols.length() == 2 && symbols[0] == 'foo' && symbols[1] == 'bar',
      _ => false
    }))

  results.push(assert_true('import single name in braces',
    match first_decl('import { only } from "./one.mlc"') {
      DeclImport(path, symbols) => path == './one.mlc' && symbols.length() == 1 && symbols[0] == 'only',
      _ => false
    }))

  // Or-pattern tests (B2)
  results.push(assert_true('or-pattern brace-style: PatOr produced',
    match parse_expr_source('match x { A(r) | B(r) => r }') {
      ExprMatch(_, arms, _) =>
        if arms.length() == 1 then
          match arms[0].pat {
            PatOr(alts, _) => alts.length() == 2,
            _ => false
          }
        else false end,
      _ => false
    }))

  results.push(assert_true('or-pattern pipe-style: PatOr produced',
    match parse_expr_source('match x | A(r) | B(r) => r end') {
      ExprMatch(_, arms, _) =>
        if arms.length() == 1 then
          match arms[0].pat {
            PatOr(alts, _) => alts.length() == 2,
            _ => false
          }
        else false end,
      _ => false
    }))

  results.push(assert_true('unit or-pattern: PatOr produced',
    match parse_expr_source('match x { Red | Green => 1, Blue => 2 }') {
      ExprMatch(_, arms, _) =>
        if arms.length() == 2 then
          match arms[0].pat {
            PatOr(alts, _) => alts.length() == 2,
            _ => false
          }
        else false end,
      _ => false
    }))

  results.push(assert_true('single pattern: no PatOr, no guard',
    match parse_expr_source('match x { A(r) => r }') {
      ExprMatch(_, arms, _) =>
        if arms.length() == 1 then
          if arms[0].has_guard then false
          else
            match arms[0].pat {
              PatCtor(name, _, _) => name == "A",
              _ => false
            }
          end
        else false end,
      _ => false
    }))

  results.push(assert_true('match arm guard brace-style',
    expr_match_arm_count(sample_parse_match_guard_brace()) == 1 &&
    expr_match_arm_has_guard(sample_parse_match_guard_brace(), 0) &&
    expr_match_arm_pat_ident_name(sample_parse_match_guard_brace(), 0) == "n" &&
    expr_match_arm_guard_binary_operation(sample_parse_match_guard_brace(), 0) == '>='))

  results.push(assert_true('match arm guard pipe-style',
    expr_match_arm_count(sample_parse_match_guard_pipe()) == 1 &&
    expr_match_arm_has_guard(sample_parse_match_guard_pipe(), 0) &&
    expr_match_arm_guard_binary_operation(sample_parse_match_guard_pipe(), 0) == ">"))

  results.push(assert_true('or-pattern with shared guard after alternatives',
    expr_match_arm_count(sample_parse_match_guard_or_pattern()) == 1 &&
    expr_match_arm_has_guard(sample_parse_match_guard_or_pattern(), 0) &&
    expr_match_arm_pat_or_alt_count(sample_parse_match_guard_or_pattern(), 0) == 2 &&
    expr_match_arm_guard_binary_operation(sample_parse_match_guard_or_pattern(), 0) == ">"))

  results.push(assert_true('match do delimiter with inner do arm body',
    match parse_expr_source('match x do\n  0 =>\n    do\n      2\n    end\n  _ => 3\nend') {
      ExprMatch(_, arms, _) =>
        if arms.length() == 2 then
          match arms[0].body {
            ExprBlock(_, _, _) => true,
            _ => false
          }
        else false end,
      _ => false
    }))

  results.push(assert_true('match catch-all: else => synonyms wildcard PatWild',
    match parse_expr_source('match x { 1 => 0, else => 1 }') {
      ExprMatch(_, arms, _) =>
        if arms.length() == 2 then
          match arms[1].pat {
            PatWild(_) => true,
            _ => false
          }
        else false end,
      _ => false
    }))

  // Template literal parser tests
  results.push(assert_eq_int('plain template literal - 1 decl',
    decl_count('fn f() -> string = `hello`'), 1))
  results.push(assert_eq_int('template with interpolation - 1 decl',
    decl_count("fn f(x: i32) -> string = `a \${x} b`"), 1))
  results.push(assert_true('plain template parses to ExprStr',
    match parse_expr_source('`hello`') {
      ExprStr(s, _) => s == 'hello',
      _ => false
    }))
  results.push(assert_true('template with interp parses to ExprBin',
    match parse_expr_source("`a \${x}`") {
      ExprBin(op, _, _, _) => op == "+",
      _ => false
    }))
  results.push(assert_true('template with only interp parses to ExprBin',
    match parse_expr_source("`\${x}`") {
      ExprBin(op, _, _, _) => op == "+",
      _ => false
    }))

  results.push(assert_true('let-else: has_else=true when else present',
    match parse_expr_source('do\n  let Some(v) = opt else return 0 end\n  0\nend') {
      ExprBlock(stmts, _, _) =>
        if stmts.length() >= 1 then
          match stmts[0] {
            StmtLetPat(_, _, _, _, has_else, _, _) => has_else,
            _ => false
          }
        else false end,
      _ => false
    }))

  results.push(assert_true('let-else: has_else=false without else',
    match parse_expr_source('do\n  let {x} = pt\n  0\nend') {
      ExprBlock(stmts, _, _) =>
        if stmts.length() >= 1 then
          match stmts[0] {
            StmtLetPat(_, _, _, _, has_else, _, _) => !has_else,
            _ => false
          }
        else false end,
      _ => false
    }))

  results.push(assert_true('pipe precedence: logical or binds looser than pipeline',
    pipe_case_logical_or_over_pipeline(parse_expr_source('a || b |> c'))))

  results.push(assert_true('pipe precedence: logical and binds looser than pipeline',
    pipe_case_logical_and_over_pipeline(parse_expr_source('a && b |> c'))))

  results.push(assert_true('pipe precedence: equality binds tighter than pipeline on right',
    pipe_case_equality_right_operand_contains_pipeline(parse_expr_source('a == b |> c'))))

  results.push(assert_true('pipe precedence: pipeline binds tighter than equality on left',
    pipe_case_pipeline_binds_tighter_than_equality_on_left(parse_expr_source('a |> b == c'))))

  results.push(assert_true('parse trait: DeclTrait with one method',
    trait_display_decl(parse_source('trait Display { fn to_string(self: Display) -> string }'))))

  results.push(assert_eq_int('parse export trait: single top-level decl',
    parse_source('export trait Display { fn to_string(self: Display) -> string }').decls.length(), 1))

  results.push(assert_true('parse decl: invalid function name yields parse error',
    parse_source_errors('fn @@@() -> i32 = 0').length() >= 1))

  results.push(assert_true('parse decl: empty type body after = yields parse error',
    parse_source_errors('type EmptyType =').length() >= 1))

  results.push(assert_true('parse decl: trait without { yields parse error',
    parse_source_errors('trait Broken').length() >= 1))

  results.push(assert_true('parse decl: unexpected token at top level yields parse error',
    parse_source_errors('123').length() >= 1))

  results.push(assert_true('parse expr: unexpected token yields parse error',
    parse_expr_errors('@@@').length() >= 1))

  results.push(assert_true('parse expr: unclosed ( yields parse error',
    parse_expr_errors('(1').length() >= 1))

  results.push(assert_true('parse expr: unclosed [ yields parse error',
    parse_expr_errors('[1').length() >= 1))

  results.push(assert_true('parse expr: unclosed argument list yields parse error',
    parse_expr_errors('f(1').length() >= 1))

  results.push(assert_true('parse program: unclosed do block yields parse error',
    parse_source_errors('fn f() -> i32 = do 1').length() >= 1))

  results.push(assert_true('parse program: unclosed match brace yields parse error',
    parse_source_errors('fn f() -> i32 = match x { A => 1').length() >= 1))

  results.push(assert_true('parse program: invalid let pattern yields parse error',
    parse_source_errors('fn f() -> i32 = do let @@@ = 1 end').length() >= 1))

  results
end
