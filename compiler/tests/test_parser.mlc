// Unit tests for the parser (parse_program function).

import { TestResult, assert_eq_int, assert_true } from "./test_runner"
import { tokenize } from "../lexer"
import { parse_program } from "../parser/decls"
import { Decl, DeclFn, DeclType, DeclExtend, DeclImport, Expr, ExprStr, ExprBin, ExprMethod, ExprMatch, MatchArm, Pat, PatOr, PatCtor, ExprBlock, Stmt, StmtLetPat } from "../ast"
import { parse_expr } from "../parser/exprs"
import { parser_new } from "../parser/preds"

fn parse_source(source: string) -> Program =
  parse_program(tokenize(source).tokens)

fn parse_expr_source(source: string) -> Shared<Expr> =
  parse_expr(parser_new(tokenize(source).tokens)).expr

fn decl_count(source: string) -> i32 =
  parse_source(source).decls.length()

fn first_decl(source: string) -> Shared<Decl> =
  parse_source(source).decls[0]

fn second_decl(source: string) -> Shared<Decl> =
  parse_source(source).decls[1]

export fn parser_tests() -> [TestResult] = do
  let results: [TestResult] = []

  results.push(assert_eq_int("empty source - 0 decls",
    decl_count(""), 0))

  results.push(assert_eq_int("single fn decl - 1 decl",
    decl_count("fn f() -> i32 = 42"), 1))

  results.push(assert_eq_int("two fn decls - 2 decls",
    decl_count("fn f() -> i32 = 1\nfn g() -> i32 = 2"), 2))

  results.push(assert_eq_int("type decl - 1 decl",
    decl_count("type Color = Red | Green | Blue"), 1))

  results.push(assert_eq_int("fn with params - 1 decl",
    decl_count("fn add(x: i32, y: i32) -> i32 = x + y"), 1))

  results.push(assert_eq_int("fn with default param - 1 decl",
    decl_count("fn f(a: i32 = 1) -> i32 = a"), 1))

  results.push(assert_eq_int("fn with do block - 1 decl",
    decl_count("fn f() -> i32 = do\n  const x = 1\n  x\nend"), 1))

  results.push(assert_eq_int("type + fn - 2 decls",
    decl_count("type Color = Red\nfn f() -> i32 = 1"), 2))

  results.push(assert_true("fn decl is DeclFn",
    match first_decl("fn f() -> i32 = 42") {
      DeclFn(_, _, _, _, _, _) => true,
      _ => false
    }))

  results.push(assert_true("type decl is DeclType",
    match first_decl("type Color = Red | Green") {
      DeclType(_, _, _, _) => true,
      _ => false
    }))

  results.push(assert_eq_int("fn with if expr - 1 decl",
    decl_count("fn f(x: i32) -> i32 = if x > 0 then 1 else 0 end"), 1))

  results.push(assert_eq_int("fn with for-in - 1 decl",
    decl_count("fn f(items: [i32]) -> i32 = do\n  let mut s = 0\n  for x in items do\n    s = s + x\n  end\n  s\nend"), 1))

  results.push(assert_eq_int("type + fn with match pipe arms - 2 decls",
    decl_count("type T = A(i32) | B\nfn f(x: T) -> i32 = match x | A(n) => n | B => 0\n"), 2))

  results.push(assert_eq_int("fn with parenthesized lambda - 1 decl",
    decl_count("fn f() -> i32 = (() => 7)()"), 1))

  results.push(assert_true("extend method: self with type and extra param",
    match second_decl("type R = { a: i32 }\nextend R {\n  fn m(self: R, x: i32) -> i32 = x\n}") {
      DeclExtend(_, _, methods) =>
        match methods[0] {
          DeclFn(_, _, _, parameters, _, _) => parameters.length() == 2,
          _ => false
        },
      _ => false
    }))

  results.push(assert_eq_int("import star-as - 1 decl",
    decl_count("import * as helpers from \"./infer_literals.mlc\""), 1))

  results.push(assert_true("import star-as: path and symbols",
    match first_decl("import * as helpers from \"./infer_literals.mlc\"") {
      DeclImport(path, symbols) =>
        path == "./infer_literals.mlc" && symbols.length() == 2 && symbols[0] == "*" && symbols[1] == "helpers",
      _ => false
    }))

  results.push(assert_eq_int("import named list - 1 decl",
    decl_count("import { foo, bar } from \"./mod.mlc\""), 1))

  results.push(assert_true("import named list: path and symbols order",
    match first_decl("import { foo, bar } from \"./mod.mlc\"") {
      DeclImport(path, symbols) =>
        path == "./mod.mlc" && symbols.length() == 2 && symbols[0] == "foo" && symbols[1] == "bar",
      _ => false
    }))

  results.push(assert_true("import single name in braces",
    match first_decl("import { only } from \"./one.mlc\"") {
      DeclImport(path, symbols) => path == "./one.mlc" && symbols.length() == 1 && symbols[0] == "only",
      _ => false
    }))

  // Or-pattern tests (B2)
  results.push(assert_true("or-pattern brace-style: PatOr produced",
    match parse_expr_source("match x { A(r) | B(r) => r }") {
      ExprMatch(_, arms, _) =>
        if arms.length() == 1 then
          match arms[0].pat {
            PatOr(alts, _) => alts.length() == 2,
            _ => false
          }
        else false end,
      _ => false
    }))

  results.push(assert_true("or-pattern pipe-style: PatOr produced",
    match parse_expr_source("match x | A(r) | B(r) => r end") {
      ExprMatch(_, arms, _) =>
        if arms.length() == 1 then
          match arms[0].pat {
            PatOr(alts, _) => alts.length() == 2,
            _ => false
          }
        else false end,
      _ => false
    }))

  results.push(assert_true("unit or-pattern: PatOr produced",
    match parse_expr_source("match x { Red | Green => 1, Blue => 2 }") {
      ExprMatch(_, arms, _) =>
        if arms.length() == 2 then
          match arms[0].pat {
            PatOr(alts, _) => alts.length() == 2,
            _ => false
          }
        else false end,
      _ => false
    }))

  results.push(assert_true("single pattern: no PatOr",
    match parse_expr_source("match x { A(r) => r }") {
      ExprMatch(_, arms, _) =>
        if arms.length() == 1 then
          match arms[0].pat {
            PatCtor(name, _, _) => name == "A",
            _ => false
          }
        else false end,
      _ => false
    }))

  results.push(assert_true("match catch-all: else => synonyms wildcard PatWild",
    match parse_expr_source("match x { 1 => 0, else => 1 }") {
      ExprMatch(_, arms, _) =>
        if arms.length() == 2 then
          match arms[1].pat {
            PatWild(_) => true,
            _ => false
          }
        else false end,
      _ => false
    }))

  // Template literal parser tests
  results.push(assert_eq_int("plain template literal - 1 decl",
    decl_count("fn f() -> string = `hello`"), 1))
  results.push(assert_eq_int("template with interpolation - 1 decl",
    decl_count("fn f(x: i32) -> string = `a \${x} b`"), 1))
  results.push(assert_true("plain template parses to ExprStr",
    match parse_expr_source("`hello`") {
      ExprStr(s, _) => s == "hello",
      _ => false
    }))
  results.push(assert_true("template with interp parses to ExprBin",
    match parse_expr_source("`a \${x}`") {
      ExprBin(op, _, _, _) => op == "+",
      _ => false
    }))
  results.push(assert_true("template with only interp parses to ExprBin",
    match parse_expr_source("`\${x}`") {
      ExprBin(op, _, _, _) => op == "+",
      _ => false
    }))

  results.push(assert_true("let-else: has_else=true when else present",
    match parse_expr_source("do\n  let Some(v) = opt else return 0 end\n  0\nend") {
      ExprBlock(stmts, _, _) =>
        if stmts.length() >= 1 then
          match stmts[0] {
            StmtLetPat(_, _, _, _, has_else, _, _) => has_else,
            _ => false
          }
        else false end,
      _ => false
    }))

  results.push(assert_true("let-else: has_else=false without else",
    match parse_expr_source("do\n  let {x} = pt\n  0\nend") {
      ExprBlock(stmts, _, _) =>
        if stmts.length() >= 1 then
          match stmts[0] {
            StmtLetPat(_, _, _, _, has_else, _, _) => !has_else,
            _ => false
          }
        else false end,
      _ => false
    }))

  results
end
