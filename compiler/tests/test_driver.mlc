import { TestResult, assert_true, assert_eq_str } from './test_runner'
import { driver_source_path_is_safe, resolve_import_path } from '../driver/path_normalize'
import { compile_modular } from '../driver/compile_driver'

export fn driver_tests() -> [TestResult] = do
  let results: [TestResult] = []

  results.push(assert_true('driver_source_path_is_safe accepts entry.mlc', driver_source_path_is_safe('entry.mlc')))
  results.push(assert_true('driver_source_path_is_safe rejects parent segment', !driver_source_path_is_safe('../entry.mlc')))
  results.push(assert_true('driver_source_path_is_safe rejects semicolon', !driver_source_path_is_safe('foo;bar.mlc')))

  results.push(assert_eq_str(
    'resolve_import_path bare Tcp to stdlib net/tcp.mlc',
    resolve_import_path('tmp/probe.mlc', 'Tcp'),
    'lib/mlc/common/stdlib/net/tcp.mlc'
  ))
  results.push(assert_eq_str(
    'resolve_import_path bare HttpServer to stdlib net/http_server.mlc',
    resolve_import_path('tmp/probe.mlc', 'HttpServer'),
    'lib/mlc/common/stdlib/net/http_server.mlc'
  ))
  results.push(assert_eq_str(
    'resolve_import_path bare Env to stdlib env/env.mlc',
    resolve_import_path('tmp/probe.mlc', 'Env'),
    'lib/mlc/common/stdlib/env/env.mlc'
  ))
  results.push(assert_eq_str(
    'resolve_import_path bare Log to stdlib log/logger.mlc',
    resolve_import_path('tmp/probe.mlc', 'Log'),
    'lib/mlc/common/stdlib/log/logger.mlc'
  ))
  results.push(assert_eq_str(
    'resolve_import_path bare Validate to stdlib validate/validate.mlc',
    resolve_import_path('tmp/probe.mlc', 'Validate'),
    'lib/mlc/common/stdlib/validate/validate.mlc'
  ))
  results.push(assert_eq_str(
    'resolve_import_path relative ./foo unchanged',
    resolve_import_path('tmp/probe.mlc', './foo'),
    'tmp/foo.mlc'
  ))

  const package_project_root = File.make_temp_directory('pkg_resolve_')
  File.write(`${package_project_root}/mlc.json`,
    "{\"name\":\"app\",\"dependencies\":{\"demo_pkg\":{\"git\":\"https://example.com/demo.git\",\"rev\":\"0123456789abcdef0123456789abcdef01234567\"}}}")
  File.write(`${package_project_root}/app.mlc`, "fn main() -> i32 = 0\n")
  File.write(`${package_project_root}/.mlc_packages/demo_pkg/math.mlc`, "export fn add(a: i32, b: i32) -> i32 = a + b\n")
  results.push(assert_eq_str(
    'resolve_import_path package demo_pkg/math',
    resolve_import_path(`${package_project_root}/app.mlc`, 'demo_pkg/math'),
    `${package_project_root}/.mlc_packages/demo_pkg/math.mlc`
  ))
  results.push(assert_eq_str(
    'resolve_import_path unknown package falls back relative',
    resolve_import_path(`${package_project_root}/app.mlc`, 'other_pkg/math'),
    `${package_project_root}/other_pkg/math.mlc`
  ))
  const escape_resolved = resolve_import_path(`${package_project_root}/app.mlc`, 'demo_pkg/../../outside')
  const package_prefix = `${package_project_root}/.mlc_packages/`
  results.push(assert_true(
    'resolve_import_path package escape not under .mlc_packages',
    !(escape_resolved.length() >= package_prefix.length()
      && escape_resolved.substring(0, package_prefix.length()) == package_prefix)
  ))

  const unsafe_compile = compile_modular('../bad.mlc', '', false, true, false, false, false, false, false, false, false, false, false)
  results.push(assert_true('compile_modular rejects unsafe entry path',
    match unsafe_compile { Err(_) => true, Ok(_) => false }))

  results
end
