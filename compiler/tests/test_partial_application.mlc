// Partial application and desugar regression tests.

import { TestResult, assert_eq_int, assert_true } from './test_runner'
import { tokenize } from '../frontend/lexer'
import { parse_program } from '../frontend/parser/decls'
import { check } from '../checker/check/check'
import { assert_code_contains } from './codegen_test_helpers'
import { gen_program } from '../codegen/module'

fn check_error_count(source: string) -> i32 =
  match check(parse_program(tokenize(source).tokens)) {
    Ok(_) => 0,
    Err(errors) => errors.length()
  }

export fn partial_application_tests() -> [TestResult] = do
  let results: [TestResult] = []

  results.push(assert_eq_int('partial: two-arg thunk call',
    check_error_count(
      'fn add(left: i32, right: i32) -> i32 = left + right\nfn main() -> i32 = do\n  let step = add(1, _)\n  step(2)\nend'
    ), 0))

  results.push(assert_eq_int('partial: three-arg nested',
    check_error_count(
      'fn triple(first: i32, second: i32, third: i32) -> i32 = first + second + third\nfn main() -> i32 = do\n  let one = triple(1, _, _)\n  let two = one(2, _)\n  two(3)\nend'
    ), 0))

  results.push(assert_eq_int('partial: pipe into partially applied callee',
    check_error_count(
      'fn add(left: i32, right: i32) -> i32 = left + right\nfn main() -> i32 = do\n  let bound = add(10, _)\n  3 |> bound\nend'
    ), 0))

  results.push(assert_eq_int('partial: match arm with partial call',
    check_error_count(
      'fn combine(left: i32, right: i32) -> i32 = left + right\nfn main() -> i32 = do\n  let value = 1\n  match value {\n    1 => combine(10, _)(2),\n    _ => 0\n  }\nend'
    ), 0))

  results.push(assert_true('partial: bare underscore is error',
    check_error_count('fn main() -> i32 = _') > 0))

  results.push(assert_code_contains('partial: codegen emits lambda for bound call',
    gen_program(parse_program(tokenize(
      'fn add(left: i32, right: i32) -> i32 = left + right\nfn main() -> i32 = do\n  let bound = add(1, _)\n  bound(2)\nend'
    ).tokens)),
    '[=]'))

  results
end
