import { TestResult, assert_eq_int } from './test_runner'
import { assert_code_contains, assert_type_generates } from './codegen_test_helpers'
import { tokenize } from '../frontend/lexer'
import { parse_program } from '../frontend/parser/decls'
import { check } from '../checker/check/check'
import { gen_expr } from '../codegen/eval'
import {print_expr} from '../cpp_emit/print'
import { create_codegen_context } from '../codegen/context'
import { empty_program } from './ast_builders'
import {
  SemanticExpressionMethod, SemanticExpressionIdent, SemanticExpressionLambda,
  SemanticExpressionBlock, SemanticExpressionInt
} from '../ir/semantic_ir'
import { span_unknown, TyGeneric, TyI32 } from '../frontend/ast'
import { TI32, TGeneric, TFn, TArray } from '../checker/registry'

fn check_error_count(source: string) -> i32 =
  match check(parse_program(tokenize(source).tokens)) {
    Ok(_) => 0,
    Err(errors) => errors.length()
  }

fn integer_type() -> Shared<Type> = Shared.new(TI32)
fn array_type() -> Shared<Type> = Shared.new(TArray(integer_type()))
fn mutex_array_type() -> Shared<Type> = Shared.new(TGeneric('Mutex', [array_type()]))

export fn mutex_syntax_tests() -> [TestResult] = do
  let results: [TestResult] = []

  results.push(assert_eq_int('Mutex.new array checks',
    check_error_count('fn main() -> Mutex<[i32]> = Mutex.new([])'), 0))

  results.push(assert_eq_int('mutex.lock mutates array',
    check_error_count(
      'fn main() -> i32 = do let guarded = Mutex.new([]); guarded.lock(values => do values.push(7); values.length() end) end'),
    0))

  results.push(assert_eq_int('mutex.lock rejects non-lambda',
    check_error_count('fn main() -> unit = do let guarded = Mutex.new([]); guarded.lock(7) end'),
    1))

  const return_value = Shared.new(SemanticExpressionInt(7, integer_type(), span_unknown()))
  const block = Shared.new(SemanticExpressionBlock([], return_value, integer_type(), span_unknown()))
  const lambda = Shared.new(SemanticExpressionLambda(
    ['value'], block, Shared.new(TFn([array_type()], integer_type())), span_unknown()))
  const mutex_receiver = Shared.new(SemanticExpressionIdent('guarded', mutex_array_type(), span_unknown()))
  const lock_call = Shared.new(SemanticExpressionMethod(
    mutex_receiver, 'lock', [lambda], [0], integer_type(), span_unknown()))
  const context = create_codegen_context(empty_program())
  const generated = print_expr(gen_expr(lock_call, context))
  results.push(assert_code_contains('mutex.lock in cpp', generated.to_string(), '.lock('))
  results.push(assert_code_contains('mutex lock ref param', generated.to_string(), "&"))
  results.push(assert_type_generates(
    'Mutex type in cpp', context,
    Shared.new(TyGeneric('Mutex', [Shared.new(TyI32)])),
    'mlc::concurrency::Mutex<int>'))

  results
end
