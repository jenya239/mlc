// Safety model demo (mlcc) — safe arithmetic; no `unsafe` keyword.

fn add(a: i32, b: i32) -> i32 = a + b
fn multiply(a: i32, b: i32) -> i32 = a * b
fn square(x: i32) -> i32 = x * x

fn main() -> i32 = do
  let result = add(square(3), multiply(2, 5))
  println("safe result=" + result.to_string())
  if result == 19 then 0 else 1 end
end
