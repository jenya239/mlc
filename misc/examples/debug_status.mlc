// Status line normalize/parse (mlcc).

fn parse_status(line: string) -> string = do
  let trimmed = line.trim().upper()
  if trimmed.starts_with("TODO") then
    "TODO"
  else if trimmed.starts_with("DOING") then
    "DOING"
  else if trimmed.starts_with("DONE") then
    "DONE"
  else
    "OTHER"
  end
end

fn main() -> i32 = do
  println(parse_status("TODO: something"))
  println(parse_status("DOING: now"))
  println(parse_status("DONE: done"))
  0
end
