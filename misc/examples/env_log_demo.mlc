# Env + Log demo (TRACK_STDLIB_ENV_LOGGING).
# mlcc: bare-name imports (see stdlib_logic_bare_smoke.mlc).
# Gate: scripts/run_env_log_gate.sh

import { get_or, has } from 'Env'
import { info, warn } from 'Log'

fn main() -> i32 = do
  let port = get_or("PORT", "8080")
  info("env_log demo start")
  warn("using port " + port)
  println(port)
  if has("PATH") then
    0
  else
    1
  end
end
