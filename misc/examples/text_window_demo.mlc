  TextShapingState,
  text_shaping_new,
  text_shaping_shape,
  text_shaping_glyph_id_at,
  text_shaping_glyph_advance_at,
  text_shaping_rasterize_glyph
} from '../gui/text_shaping'

fn gl_color_buffer_bit() -> i32 = 16384
fn gl_triangles() -> i32 = 4
fn gl_float() -> i32 = 5126
fn gl_array_buffer() -> i32 = 34962
fn gl_dynamic_draw() -> i32 = 35048
fn gl_fragment_shader() -> i32 = 35632
fn gl_vertex_shader() -> i32 = 35633
fn gl_compile_status() -> i32 = 35713
fn gl_link_status() -> i32 = 35714
fn gl_texture_2d() -> i32 = 3553
fn gl_texture0() -> i32 = 33984
fn gl_blend() -> i32 = 3042
fn gl_src_alpha() -> i32 = 770
fn gl_one_minus_src_alpha() -> i32 = 771

fn vertex_source() -> string =
  "attribute vec2 a_pos;\nattribute vec2 a_uv;\nvarying vec2 v_uv;\nvoid main() {\n  v_uv = a_uv;\n  gl_Position = vec4(a_pos, 0.0, 1.0);\n}\n"

fn a8_fragment_source() -> string =
  "varying vec2 v_uv;\nuniform sampler2D u_tex;\nvoid main() {\n  float a = texture2D(u_tex, v_uv).r;\n  gl_FragColor = vec4(0.95, 0.95, 0.98, a);\n}\n"

fn msdf_fragment_source() -> string =
  "varying vec2 v_uv;\nuniform sampler2D u_tex;\nfloat median(float r, float g, float b) {\n  return max(min(r, g), min(max(r, g), b));\n}\nvoid main() {\n  vec3 s = texture2D(u_tex, v_uv).rgb;\n  float sig = median(s.r, s.g, s.b);\n  float a = smoothstep(0.45, 0.55, sig);\n  gl_FragColor = vec4(0.3, 0.85, 0.55, a);\n}\n"

type AtlasSlot = { page_index: i32, x: i32, y: i32, width: i32, height: i32 }
type AtlasPage = {
  mode: i32, width: i32, height: i32, shelf_x: i32, shelf_y: i32, shelf_height: i32
}
type GlyphAtlas = { page_size: i32, pages: [AtlasPage] }
type GlyphAtlasPackOk = { atlas: GlyphAtlas, slot: AtlasSlot, error_code: i32 }
type Pass = {
  program: i32, buffer: i32, texture: i32,
  position_location: i32, uv_location: i32, vertex_count: i32, atlas_size: i32
}

fn atlas_page_empty(mode: i32, page_size: i32) -> AtlasPage =
  AtlasPage { mode: mode, width: page_size, height: page_size, shelf_x: 0, shelf_y: 0, shelf_height: 0 }

fn atlas_page_with_shelf(page: AtlasPage, shelf_x: i32, shelf_y: i32, shelf_height: i32) -> AtlasPage =
  AtlasPage {
    mode: page.mode, width: page.width, height: page.height,
    shelf_x: shelf_x, shelf_y: shelf_y, shelf_height: shelf_height
  }

fn atlas_pages_replace(pages: [AtlasPage], page_index: i32, page: AtlasPage) -> [AtlasPage] = do
  let mut rebuilt: [AtlasPage] = []
  let mut index = 0
  while index < pages.length() do
    if index == page_index then rebuilt.push(page) else rebuilt.push(pages[index]) end
    index = index + 1
  end
  rebuilt
end

fn glyph_atlas_find_last_page(atlas: GlyphAtlas, mode: i32) -> i32 = do
  let mut index = atlas.pages.length() - 1
  while index >= 0 do
    if atlas.pages[index].mode == mode then return index end
    index = index - 1
  end
  -1
end

fn glyph_atlas_pack(atlas: GlyphAtlas, mode: i32, glyph_width: i32, glyph_height: i32) -> GlyphAtlasPackOk = do
  if glyph_width <= 0 || glyph_height <= 0 || glyph_width > atlas.page_size || glyph_height > atlas.page_size then
    return GlyphAtlasPackOk {
      atlas: atlas,
      slot: AtlasSlot { page_index: -1, x: 0, y: 0, width: 0, height: 0 },
      error_code: 1
    }
  end
  let mut pages = atlas.pages
  let mut page_index = glyph_atlas_find_last_page(atlas, mode)
  let mut placed = false
  let mut slot_x = 0
  let mut slot_y = 0
  if page_index >= 0 then
    const page = pages[page_index]
    if page.shelf_height == 0 then
      pages = atlas_pages_replace(pages, page_index, atlas_page_with_shelf(page, glyph_width, 0, glyph_height))
      placed = true
    else if page.shelf_x + glyph_width <= page.width && glyph_height <= page.shelf_height then
      pages = atlas_pages_replace(pages, page_index, atlas_page_with_shelf(page, page.shelf_x + glyph_width, page.shelf_y, page.shelf_height))
      slot_x = page.shelf_x
      slot_y = page.shelf_y
      placed = true
    else
      const next_shelf_y = page.shelf_y + page.shelf_height
      if next_shelf_y + glyph_height <= page.height then
        pages = atlas_pages_replace(pages, page_index, atlas_page_with_shelf(page, glyph_width, next_shelf_y, glyph_height))
        slot_y = next_shelf_y
        placed = true
      end
    end
  end
  if !placed then
    page_index = pages.length()
    pages.push(atlas_page_empty(mode, atlas.page_size))
    pages = atlas_pages_replace(pages, page_index, atlas_page_with_shelf(pages[page_index], glyph_width, 0, glyph_height))
  end
  GlyphAtlasPackOk {
    atlas: GlyphAtlas { page_size: atlas.page_size, pages: pages },
    slot: AtlasSlot { page_index: page_index, x: slot_x, y: slot_y, width: glyph_width, height: glyph_height },
    error_code: 0
  }
end

fn compile_program(vertex_source_text: string, fragment_source_text: string) -> i32 = do
  const vertex_shader = gl_create_shader(gl_vertex_shader())
  gl_shader_source_string(vertex_shader, vertex_source_text)
  gl_compile_shader(vertex_shader)
  if gl_get_shader_iv_value(vertex_shader, gl_compile_status()) == 0 then
    return -12
  end
  const fragment_shader = gl_create_shader(gl_fragment_shader())
  gl_shader_source_string(fragment_shader, fragment_source_text)
  gl_compile_shader(fragment_shader)
  if gl_get_shader_iv_value(fragment_shader, gl_compile_status()) == 0 then
    gl_delete_shader(vertex_shader)
    return -13
  end
  const program = gl_create_program()
  gl_attach_shader(program, vertex_shader)
  gl_attach_shader(program, fragment_shader)
  gl_link_program(program)
  gl_delete_shader(vertex_shader)
  gl_delete_shader(fragment_shader)
  if gl_get_program_iv_value(program, gl_link_status()) == 0 then
    gl_delete_program(program)
    return -14
  end
  program
end

fn make_pass(fragment_source_text: string, atlas_size: i32) -> Pass = do
  const program = compile_program(vertex_source(), fragment_source_text)
  if program < 0 then
    return Pass {
      program: program, buffer: 0, texture: 0,
      position_location: -1, uv_location: -1, vertex_count: 0, atlas_size: atlas_size
    }
  end
  const position_location = gl_get_attrib_location_string(program, "a_pos")
  const uv_location = gl_get_attrib_location_string(program, "a_uv")
  const texture_location = gl_get_uniform_location_string(program, "u_tex")
  const buffer = gl_gen_buffer()
  const texture = gl_gen_texture()
  if position_location < 0 || uv_location < 0 || texture_location < 0 || buffer == 0 || texture == 0 then
    gl_delete_buffer(buffer)
    gl_delete_texture(texture)
    gl_delete_program(program)
    return Pass {
      program: -15, buffer: 0, texture: 0,
      position_location: -1, uv_location: -1, vertex_count: 0, atlas_size: atlas_size
    }
  end
  gl_use_program(program)
  gl_uniform_1i(texture_location, 0)
  Pass {
    program: program, buffer: buffer, texture: texture,
    position_location: position_location, uv_location: uv_location,
    vertex_count: 0, atlas_size: atlas_size
  }
end

fn destroy_pass(pass: Pass) -> i32 = do
  gl_delete_buffer(pass.buffer)
  gl_delete_texture(pass.texture)
  gl_delete_program(pass.program)
  0
end

fn draw_pass(pass: Pass, width: i32, height: i32) -> i32 = do
  gl_use_program(pass.program)
  gl_active_texture(gl_texture0())
  gl_bind_texture(gl_texture_2d(), pass.texture)
  gl_bind_buffer(gl_array_buffer(), pass.buffer)
  gl_enable_vertex_attrib_array(pass.position_location)
  gl_vertex_attrib_pointer_offset(pass.position_location, 2, gl_float(), 0, 16, 0)
  gl_enable_vertex_attrib_array(pass.uv_location)
  gl_vertex_attrib_pointer_offset(pass.uv_location, 2, gl_float(), 0, 16, 8)
  gl_draw_arrays(gl_triangles(), 0, pass.vertex_count)
  0
end

type ShapedAppendResult = {
  atlas: GlyphAtlas,
  shaping: TextShapingState,
  slot: AtlasSlot,
  error_code: i32
}

fn append_shaped_a8(
  font_path: string,
  text: string,
  pixel_size: i32,
  window_width: i32,
  window_height: i32,
  pen_x: i32,
  pen_y: i32,
  atlas: GlyphAtlas,
  shaping: TextShapingState,
  atlas_size: i32
) -> ShapedAppendResult = do
  const shaped = text_shaping_shape(shaping, font_path, pixel_size, text)
  if shaped.error_code != 0 then
    return ShapedAppendResult {
      atlas: atlas,
      shaping: shaped.state,
      slot: AtlasSlot { page_index: -1, x: 0, y: 0, width: 0, height: 0 },
      error_code: shaped.error_code
    }
  end
  let mut working = atlas
  let mut working_shaping = shaped.state
  let mut cursor_x = pen_x
  let mut index = 0
  let mut vertices = 0
  while index < shaped.glyph_count do
    const glyph_id = text_shaping_glyph_id_at(index)
    const raster = text_shaping_rasterize_glyph(
      working_shaping, font_path, pixel_size, glyph_id
    )
    if raster.error_code != 0 then
      return ShapedAppendResult {
        atlas: working,
        shaping: working_shaping,
        slot: AtlasSlot { page_index: -1, x: 0, y: 0, width: 0, height: 0 },
        error_code: raster.error_code
      }
    end
    const glyph_width_value = raster.width
    const glyph_height_value = raster.rows
    const bearing_x = raster.bearing_x
    const bearing_y = raster.bearing_y
    if glyph_width_value > 0 && glyph_height_value > 0 then
      const pack = glyph_atlas_pack(working, 0, glyph_width_value, glyph_height_value)
      if pack.error_code != 0 then
        return ShapedAppendResult {
          atlas: pack.atlas,
          shaping: working_shaping,
          slot: pack.slot,
          error_code: pack.error_code
        }
      end
      working = pack.atlas
      if gl_scratch_u8_blit_glyph_a8(atlas_size, pack.slot.x, pack.slot.y) != 0 then
        return ShapedAppendResult {
          atlas: working,
          shaping: working_shaping,
          slot: pack.slot,
          error_code: -30
        }
      end
      gl_scratch_push_screen_quad(
        window_width, window_height,
        cursor_x + bearing_x, pen_y - bearing_y,
        glyph_width_value, glyph_height_value,
        atlas_size, pack.slot.x, pack.slot.y, pack.slot.width, pack.slot.height
      )
      vertices = vertices + 6
    end
    cursor_x = cursor_x + text_shaping_glyph_advance_at(index) / 64
    index = index + 1
  end
  ShapedAppendResult {
    atlas: working,
    shaping: working_shaping,
    slot: AtlasSlot { page_index: vertices, x: 0, y: 0, width: 0, height: 0 },
    error_code: 0
  }
end

fn main() -> i32 = do
  const width = 800
  const height = 600
  const a8_atlas_size = 256
  const msdf_atlas_size = 128
  const font_path = "/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf"
  const begin_status = glfw_gl_context_begin(width, height)
  if begin_status != 0 then
    return begin_status
  end

  let mut a8_pass = make_pass(a8_fragment_source(), a8_atlas_size)
  if a8_pass.program < 0 then
    const error_code = a8_pass.program
    glfw_gl_context_end()
    return error_code
  end
  let mut msdf_pass = make_pass(msdf_fragment_source(), msdf_atlas_size)
  if msdf_pass.program < 0 then
    const error_code = msdf_pass.program
    destroy_pass(a8_pass)
    glfw_gl_context_end()
    return error_code
  end

  gl_scratch_u8_clear()
  gl_scratch_u8_resize_zero(a8_atlas_size * a8_atlas_size)
  gl_scratch_f32_clear()
  let mut a8_atlas = GlyphAtlas { page_size: a8_atlas_size, pages: [] }
  let mut shaping = text_shaping_new()

  // String 1 + 2 (A8 via HarfBuzz shape)
  const line1 = append_shaped_a8(
    font_path, "Hxpjy Agq", 28, width, height, 40, 48, a8_atlas, shaping, a8_atlas_size
  )
  if line1.error_code != 0 then
    destroy_pass(a8_pass)
    destroy_pass(msdf_pass)
    glfw_gl_context_end()
    return line1.error_code
  end
  a8_atlas = line1.atlas
  shaping = line1.shaping
  let mut a8_vertices = line1.slot.page_index

  const line2 = append_shaped_a8(
    font_path, "MLC", 28, width, height, 40, 90, a8_atlas, shaping, a8_atlas_size
  )
  if line2.error_code != 0 then
    destroy_pass(a8_pass)
    destroy_pass(msdf_pass)
    glfw_gl_context_end()
    return line2.error_code
  end
  a8_atlas = line2.atlas
  shaping = line2.shaping
  a8_vertices = a8_vertices + line2.slot.page_index

  // String 3 (MSDF codepoints)
  gl_scratch_rgb_resize_zero(msdf_atlas_size, msdf_atlas_size)
  let mut msdf_atlas = GlyphAtlas { page_size: msdf_atlas_size, pages: [] }
  let mut msdf_vertices = 0
  let mut msdf_pen = 40
  let mut codepoint_index = 0
  const codepoints: [i32] = [65, 97]
  while codepoint_index < codepoints.length() do
    const codepoint = codepoints[codepoint_index]
    if msdf_generate(font_path, codepoint, 32, 4) != 0 then
      destroy_pass(a8_pass)
      destroy_pass(msdf_pass)
      glfw_gl_context_end()
      return -40
    end
    const pack = glyph_atlas_pack(msdf_atlas, 1, msdf_width(), msdf_height())
    if pack.error_code != 0 then
      destroy_pass(a8_pass)
      destroy_pass(msdf_pass)
      glfw_gl_context_end()
      return -41
    end
    msdf_atlas = pack.atlas
    if gl_scratch_rgb_blit_msdf(msdf_atlas_size, pack.slot.x, pack.slot.y) != 0 then
      destroy_pass(a8_pass)
      destroy_pass(msdf_pass)
      glfw_gl_context_end()
      return -42
    end
    gl_scratch_push_screen_quad(
      width, height, msdf_pen, 160, 48, 48,
      msdf_atlas_size, pack.slot.x, pack.slot.y, pack.slot.width, pack.slot.height
    )
    msdf_vertices = msdf_vertices + 6
    msdf_pen = msdf_pen + 52
    codepoint_index = codepoint_index + 1
  end

  // Upload A8 batch (vertices currently in scratch from both A8 lines + MSDF quads mixed!)
  // Rebuild: clear and re-push A8 then MSDF separately into two buffers.
  // Simpler approach: upload textures now; rebuild vertex scratches per pass.

  gl_active_texture(gl_texture0())
  gl_bind_texture(gl_texture_2d(), a8_pass.texture)
  if gl_tex_image_2d_scratch_luminance(a8_atlas_size, a8_atlas_size) != 0 then
    destroy_pass(a8_pass)
    destroy_pass(msdf_pass)
    glfw_gl_context_end()
    return -50
  end
  gl_bind_texture(gl_texture_2d(), msdf_pass.texture)
  if gl_tex_image_2d_scratch_rgb(msdf_atlas_size, msdf_atlas_size) != 0 then
    destroy_pass(a8_pass)
    destroy_pass(msdf_pass)
    glfw_gl_context_end()
    return -51
  end

  // Rebuild A8 vertices only
  gl_scratch_f32_clear()
  a8_atlas = GlyphAtlas { page_size: a8_atlas_size, pages: [] }
  gl_scratch_u8_clear()
  gl_scratch_u8_resize_zero(a8_atlas_size * a8_atlas_size)
  const rebuild1 = append_shaped_a8(
    font_path, "Hxpjy Agq", 28, width, height, 40, 48, a8_atlas, shaping, a8_atlas_size
  )
  a8_atlas = rebuild1.atlas
  shaping = rebuild1.shaping
  a8_vertices = rebuild1.slot.page_index
  const rebuild2 = append_shaped_a8(
    font_path, "MLC", 28, width, height, 40, 90, a8_atlas, shaping, a8_atlas_size
  )
  a8_atlas = rebuild2.atlas
  shaping = rebuild2.shaping
  a8_vertices = a8_vertices + rebuild2.slot.page_index
  gl_bind_buffer(gl_array_buffer(), a8_pass.buffer)
  if gl_buffer_data_scratch(gl_array_buffer(), gl_dynamic_draw()) != 0 then
    destroy_pass(a8_pass)
    destroy_pass(msdf_pass)
    glfw_gl_context_end()
    return -52
  end
  a8_pass = Pass {
    program: a8_pass.program, buffer: a8_pass.buffer, texture: a8_pass.texture,
    position_location: a8_pass.position_location, uv_location: a8_pass.uv_location,
    vertex_count: a8_vertices, atlas_size: a8_atlas_size
  }
  // Re-upload A8 atlas after rebuild blits
  gl_bind_texture(gl_texture_2d(), a8_pass.texture)
  gl_tex_image_2d_scratch_luminance(a8_atlas_size, a8_atlas_size)

  // Rebuild MSDF vertices
  gl_scratch_f32_clear()
  msdf_vertices = 0
  msdf_pen = 40
  codepoint_index = 0
  while codepoint_index < codepoints.length() do
    const codepoint = codepoints[codepoint_index]
    msdf_generate(font_path, codepoint, 32, 4)
    // slots already packed in msdf_atlas from first pass — re-pack fresh
    codepoint_index = codepoint_index + 1
  end
  msdf_atlas = GlyphAtlas { page_size: msdf_atlas_size, pages: [] }
  gl_scratch_rgb_resize_zero(msdf_atlas_size, msdf_atlas_size)
  codepoint_index = 0
  msdf_pen = 40
  while codepoint_index < codepoints.length() do
    const codepoint = codepoints[codepoint_index]
    msdf_generate(font_path, codepoint, 32, 4)
    const pack = glyph_atlas_pack(msdf_atlas, 1, msdf_width(), msdf_height())
    msdf_atlas = pack.atlas
    gl_scratch_rgb_blit_msdf(msdf_atlas_size, pack.slot.x, pack.slot.y)
    gl_scratch_push_screen_quad(
      width, height, msdf_pen, 160, 48, 48,
      msdf_atlas_size, pack.slot.x, pack.slot.y, pack.slot.width, pack.slot.height
    )
    msdf_vertices = msdf_vertices + 6
    msdf_pen = msdf_pen + 52
    codepoint_index = codepoint_index + 1
  end
  gl_bind_buffer(gl_array_buffer(), msdf_pass.buffer)
  gl_buffer_data_scratch(gl_array_buffer(), gl_dynamic_draw())
  msdf_pass = Pass {
    program: msdf_pass.program, buffer: msdf_pass.buffer, texture: msdf_pass.texture,
    position_location: msdf_pass.position_location, uv_location: msdf_pass.uv_location,
    vertex_count: msdf_vertices, atlas_size: msdf_atlas_size
  }
  gl_bind_texture(gl_texture_2d(), msdf_pass.texture)
  gl_tex_image_2d_scratch_rgb(msdf_atlas_size, msdf_atlas_size)

  if a8_vertices < 12 || msdf_vertices < 12 then
    destroy_pass(a8_pass)
    destroy_pass(msdf_pass)
    glfw_gl_context_end()
    return -60
  end

  let mut frame_index = 0
  while glfw_gl_context_should_close() == 0 do
    const phase = glfw_gl_anim_unit()
    gl_viewport(0, 0, width, height)
    gl_clear_color_f64(0.04, 0.05 + phase * 0.12, 0.10 + phase * 0.08, 1.0)
    gl_clear(gl_color_buffer_bit())
    gl_enable(gl_blend())
    gl_blend_func(gl_src_alpha(), gl_one_minus_src_alpha())
    draw_pass(a8_pass, width, height)
    draw_pass(msdf_pass, width, height)
    glfw_gl_context_swap_poll()
    if has("MLC_GLFW_VISIBLE") then
      sleep_ms(50)
    end
    frame_index = frame_index + 1
    if frame_index >= 48 then
      break
    end
  end

  destroy_pass(a8_pass)
  destroy_pass(msdf_pass)
  glfw_gl_context_end()
  0
end
