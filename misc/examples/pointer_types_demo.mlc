// Pointer types smoke (mlcc) — Shared ownership.
// Full Owned/Weak/unsafe tour deferred (language surface incomplete for old demo).

type Box = { value: i32 }

fn process_box(box_value: Shared<Box>) -> i32 = box_value.value

fn main() -> i32 = do
  println("=== Pointer Types Demo ===")
  let shared = Shared.new(Box { value: 42 })
  let alias = shared
  let total = process_box(shared) + process_box(alias)
  println("shared sum=" + total.to_string())
  if total == 84 then 0 else 1 end
end
