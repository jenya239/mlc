// Interactive editor preview — EDITOR_MVP close surface + UX hit helpers.
// Glyphs are white → dark canvas; Solarized accents for syntax/selection/caret.
// Run: MLC_GLFW_VISIBLE=1 scripts/run_editor_live_demo.sh
import {
  glfw_gl_context_begin,
  glfw_gl_context_should_close,
  glfw_gl_context_swap_poll,
  glfw_gl_context_end,
  glfw_gl_window_width,
  glfw_gl_window_height,
  glfw_gl_take_scroll_y,
  glfw_gl_cursor_set,
  glfw_gl_mod_ctrl_down,
  glfw_gl_mod_shift_down,
  glfw_gl_mod_alt_down,
  glfw_gl_take_binding_key
} from '../../lib/mlc/common/stdlib/gl/gl_window.mlc'
