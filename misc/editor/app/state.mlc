// Wrap-aware / custom content height clamp (live soft-wrap max scroll).
export fn editor_app_clamp_scroll_to_content(
  app: EditorAppState,
  content_height: i32,
  viewport_height: i32
) -> EditorAppState =
  editor_app_set_scroll_y(
    app,
    editor_ux_clamp_scroll_offset(app.ux.scroll_offset_y, content_height, viewport_height)
  )

