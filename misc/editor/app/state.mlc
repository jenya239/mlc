fn editor_app_replace_session(
  app: EditorAppState,
  ux: EditorUxState,
  history: EditorHistory,
  overlay: DirtyCloseOverlay,
  last_command: string
) -> EditorAppState =
  EditorAppState {
    ux: ux,
    history: history,
    clipboard: app.clipboard,
    overlay: overlay,
    editor_focused: app.editor_focused,
    last_command: last_command,
    mouse_was_down: app.mouse_was_down,
    backspace_was_down: app.backspace_was_down,
    enter_was_down: app.enter_was_down,
    selecting_text: app.selecting_text,
    frame_index: app.frame_index
  }

fn editor_ux_with_tabs_and_selection(
  state: EditorUxState,
  tabs: TabSet,
  selection: EditorSelection
) -> EditorUxState =
  EditorUxState {
    window_width: state.window_width,
    window_height: state.window_height,
    focus: state.focus,
    panels: state.panels,
    tabs: tabs,
    selection: selection,
    scroll_offset_x: state.scroll_offset_x,
    scroll_offset_y: state.scroll_offset_y,
    cursor_shape: state.cursor_shape,
    clock_ms: state.clock_ms,
    tab_strip_height: state.tab_strip_height,
    overflows: state.overflows
  }

// Live chrome tab strip (explicit rect + classic layout widths). Close hit first, then activate.
export fn editor_app_click_tab_strip(
  app: EditorAppState,
  strip: UxRect,
  widths: [i32],
  point_x: i32,
  point_y: i32
) -> EditorAppTabClickResult = do
  const close_hit = tab_strip_hit_close_index_from_widths(
    strip, widths, point_x, point_y
  )
  if close_hit >= 0 then
    const outcome = tab_set_request_close(app.ux.tabs, close_hit)
    let mut next_ux = editor_ux_with_tabs_and_selection(
      app.ux, outcome.tabs, app.ux.selection
    )
    let mut next_history = app.history
    if !dirty_close_overlay_is_visible(outcome.overlay) && tab_set_has_active(outcome.tabs) then
      next_ux = editor_ux_with_tabs_and_selection(
        next_ux, outcome.tabs, selection_collapsed(0)
      )
      next_history = history_new()
    end
    return EditorAppTabClickResult {
      app: editor_app_replace_session(
        app, next_ux, next_history, outcome.overlay, "close_tab"
      ),
      handled: 1
    }
  end
  const hit = tab_strip_hit_index_from_widths(strip, widths, point_x, point_y)
  if hit >= 0 then
    const next_tabs = tab_set_set_active(app.ux.tabs, hit)
    const next_ux = editor_ux_with_tabs_and_selection(
      app.ux, next_tabs, selection_collapsed(0)
    )
    return EditorAppTabClickResult {
      app: editor_app_replace_session(
        app, next_ux, history_new(), app.overlay, "activate_tab"
      ),
      handled: 1
    }
  end
  EditorAppTabClickResult { app: app, handled: 0 }
end

export fn editor_app_bump_frame(app: EditorAppState) -> EditorAppState =
  EditorAppState {
    ux: app.ux,
    history: app.history,
    clipboard: app.clipboard,
    overlay: app.overlay,
    editor_focused: app.editor_focused,
    last_command: app.last_command,
    mouse_was_down: app.mouse_was_down,
    backspace_was_down: app.backspace_was_down,
    enter_was_down: app.enter_was_down,
    selecting_text: app.selecting_text,
    frame_index: app.frame_index + 1
  }
