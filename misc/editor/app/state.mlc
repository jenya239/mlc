fn editor_app_with_ux_and_history(
  app: EditorAppState,
  ux: EditorUxState,
  history: EditorHistory
) -> EditorAppState =
  EditorAppState {
    ux: ux,
    history: history,
    clipboard: app.clipboard,
    overlay: app.overlay,
    editor_focused: app.editor_focused,
    last_command: app.last_command,
    mouse_was_down: app.mouse_was_down,
    backspace_was_down: app.backspace_was_down,
    enter_was_down: app.enter_was_down,
    selecting_text: app.selecting_text,
    frame_index: app.frame_index
  }

fn editor_app_clock_ms(app: EditorAppState) -> i32 =
  app.frame_index * 16

export fn editor_app_insert_text(
  app: EditorAppState,
  text: string
) -> EditorAppState = do
  if !tab_set_has_active(app.ux.tabs) then
    return app
  end
  const active = tab_set_active(app.ux.tabs)
  const history = history_push_before_edit_kind(
    app.history,
    active.buffer.document,
    app.ux.selection,
    history_edit_insert_text(),
    editor_app_clock_ms(app)
  )
  editor_app_with_ux_and_history(app, editor_ux_insert_text_autoclose(app.ux, text), history)
end

export type EditorAppMultiInsertResult = {
  app: EditorAppState,
  multi: EditorMultiSelection
}

export fn editor_app_insert_text_with_multi(
  app: EditorAppState,
  multi: EditorMultiSelection,
  text: string
) -> EditorAppMultiInsertResult = do
  if !tab_set_has_active(app.ux.tabs) then
    return EditorAppMultiInsertResult { app: app, multi: multi }
  end
  const active = tab_set_active(app.ux.tabs)
  const history = history_push_before_edit_kind(
    app.history,
    active.buffer.document,
    app.ux.selection,
    history_edit_insert_text(),
    editor_app_clock_ms(app)
  )
  const inserted = editor_ux_insert_text_with_multi(app.ux, multi, text)
  EditorAppMultiInsertResult {
    app: editor_app_with_ux_and_history(app, inserted.state, history),
    multi: inserted.multi
  }
end

