// TRACK_EDITOR_MVP STEP=17 — clipboard Ctrl+A/C/X/V unit (inject buffer).
import {
  document_from_string,
  document_to_string,
  document_byte_length
} from '../document/piece_table'
import {
  selection_new,
  selection_collapsed,
  selection_start,
  selection_end,
  selection_length,
  selection_caret
} from '../document/selection'
import { clipboard_new, clipboard_get, clipboard_set } from '../clipboard'
import {
  edit_select_all,
  edit_copy,
  edit_cut,
  edit_paste
} from '../document/clipboard_edit'

fn main() -> i32 = do
  let mut document = document_from_string("hello world")
  let mut selection = selection_new(0, 5)
  let mut clipboard = clipboard_new()

  clipboard = edit_copy(document, selection, clipboard)
  if clipboard_get(clipboard) != "hello" then
    return 1
  end

  // Select all
  selection = edit_select_all(document)
  if selection_start(selection) != 0 || selection_end(selection) != 11 then
    return 2
  end

  // Cut "world" after narrowing
  selection = selection_new(6, 11)
  let mut cut = edit_cut(document, selection, clipboard)
  if clipboard_get(cut.clipboard) != "world" then
    return 3
  end
  if document_to_string(cut.document) != "hello " then
    return 4
  end
  if selection_caret(cut.selection) != 6 then
    return 5
  end

  // Paste back
  let mut pasted = edit_paste(cut.document, cut.selection, cut.clipboard)
  if document_to_string(pasted.document) != "hello world" then
    return 6
  end
  if selection_caret(pasted.selection) != 11 then
    return 7
  end

  // Paste replacing selection
  document = pasted.document
  selection = selection_new(0, 5)
  clipboard = clipboard_set(clipboard_new(), "hi")
  pasted = edit_paste(document, selection, clipboard)
  if document_to_string(pasted.document) != "hi world" then
    return 8
  end

  // Copy empty selection is no-op
  clipboard = edit_copy(
    pasted.document,
    selection_collapsed(0),
    clipboard_set(clipboard_new(), "keep")
  )
  if clipboard_get(clipboard) != "keep" then
    return 9
  end

  // Inject-style set (P2 test path without GLFW)
  clipboard = clipboard_set(clipboard_new(), "injected")
  pasted = edit_paste(
    document_from_string(""),
    selection_collapsed(0),
    clipboard
  )
  if document_to_string(pasted.document) != "injected" then
    return 10
  end
  if document_byte_length(pasted.document) != 8 then
    return 11
  end

  println(
    "[mlc-editor] clipboard_unit ok bytes=" +
      document_byte_length(pasted.document).to_string()
  )
  0
end
