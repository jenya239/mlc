// TRACK_EDITOR_MVP STEP=10 — LineIndex unit (offset ↔ line/col + dirty rebuild).
import {
  document_from_string,
  document_insert,
  document_byte_length
} from '../document/piece_table'
import {
  TextPosition,
  line_index_from_string,
  line_index_from_document,
  line_index_rebuild,
  line_index_line_count,
  line_index_line_start,
  line_index_offset_to_position,
  line_index_position_to_offset,
  line_index_matches_document
} from '../document/line_index'

fn main() -> i32 = do
  const empty = line_index_from_string("")
  if line_index_line_count(empty) != 1 then
    return 1
  end
  if line_index_line_start(empty, 0) != 0 then
    return 2
  end

  const sample = "hello\nworld\n"
  const sample_index = line_index_from_string(sample)
  if line_index_line_count(sample_index) != 3 then
    return 3
  end
  if line_index_line_start(sample_index, 0) != 0 then
    return 4
  end
  if line_index_line_start(sample_index, 1) != 6 then
    return 5
  end
  if line_index_line_start(sample_index, 2) != 12 then
    return 6
  end

  const at_w = line_index_offset_to_position(sample_index, 6)
  if at_w.line != 1 || at_w.column != 0 then
    return 7
  end
  const at_d = line_index_offset_to_position(sample_index, 10)
  if at_d.line != 1 || at_d.column != 4 then
    return 8
  end

  const back = line_index_position_to_offset(
    sample_index,
    TextPosition { line: 1, column: 4 }
  )
  if back != 10 then
    return 9
  end
  const round_trip = line_index_position_to_offset(
    sample_index,
    line_index_offset_to_position(sample_index, 10)
  )
  if round_trip != 10 then
    return 10
  end

  const document = document_from_string(sample)
  const from_document = line_index_from_document(document)
  if line_index_line_count(from_document) != 3 then
    return 11
  end
  if !line_index_matches_document(from_document, document) then
    return 12
  end

  // Dirty rebuild after insert of a newline mid-file.
  const edited = document_insert(document, 5, "\nX")
  const rebuilt = line_index_rebuild(edited)
  if !line_index_matches_document(rebuilt, edited) then
    return 13
  end
  if line_index_line_count(rebuilt) != 4 then
    return 14
  end
  if document_byte_length(edited) != sample.length() + 2 then
    return 15
  end
  const after_insert = line_index_offset_to_position(rebuilt, 6)
  if after_insert.line != 1 || after_insert.column != 0 then
    return 16
  end
  if line_index_line_start(rebuilt, 1) != 6 then
    return 17
  end

  println(
    "[mlc-editor] line_index_unit ok lines=" +
      line_index_line_count(rebuilt).to_string()
  )
  0
end
