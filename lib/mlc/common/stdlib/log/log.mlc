//! @module std/log/log
//! @category log
//! @type extern
//! @namespace mlc::log

# Structured JSON-line logging to stderr (TRACK_STDLIB_ENV_LOGGING).
# Format: {"level":"<level>","msg":"<escaped>"}

module Log

export extern fn error(message: string) -> void
export extern fn warn(message: string) -> void
export extern fn info(message: string) -> void
export extern fn debug(message: string) -> void
