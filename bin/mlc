#!/usr/bin/env ruby
# frozen_string_literal: true

require "optparse"
require "tmpdir"
require "fileutils"

ROOT_DIR = File.expand_path("..", __dir__)
$LOAD_PATH.unshift(File.join(ROOT_DIR, "lib"))
require "mlc/common/index"

def parse_arguments(argv)
  options = {
    emit_cpp: false,
    out_dir: "build",
    build: true,
    verbose: false
  }

  raw_args = []

  parser = OptionParser.new do |opts|
    opts.banner = "Usage: mlc [options] [file] [-- program-args]"

    opts.on("-oDIR", "--output=DIR", "Output directory (default: build)") do |path|
      options[:out_dir] = path
    end

    opts.on("--emit-cpp", "Only generate .hpp/.cpp, do not run g++") do
      options[:emit_cpp] = true
      options[:build] = false
    end

    opts.on("--no-build", "Only generate files, do not run g++") do
      options[:build] = false
    end

    opts.on("--verbose", "Print commands executed by the CLI") do
      options[:verbose] = true
    end

    opts.on("--version", "Show CLI version information") do
      puts "MLC CLI (experimental)"
      exit
    end

    opts.on("-h", "--help", "Show this help message") do
      puts opts
      exit
    end
  end

  argv_for_options = argv.dup
  separator_index = argv_for_options.index("--")
  program_args = separator_index ? argv_for_options[(separator_index + 1)..] : []
  program_args ||= []
  option_args = separator_index ? argv_for_options[0...separator_index] : argv_for_options

  begin
    parser.order!(option_args) { |nonopt| raw_args << nonopt }
  rescue OptionParser::ParseError => e
    warn e.message
    warn parser
    exit 1
  end

  input_args = raw_args

  if input_args.size > 1
    warn "Multiple input files provided: #{input_args.join(', ')}"
    warn parser
    exit 1
  end

  input_path = input_args.first
  { options: options, input_path: input_path, program_args: program_args }
end

def run_program(binary_path, program_args, verbose:)
  if verbose
    warn "Running: #{([binary_path] + program_args).join(' ')}"
  end

  system(binary_path, *program_args)
  status = $?
  exit(status ? status.exitstatus : 1)
end

def main
  parsed = parse_arguments(ARGV.dup)
  options = parsed[:options]
  program_args = parsed[:program_args]
  input_path = parsed[:input_path]

  entry_path, root_dir = resolve_entry_path(input_path)
  exit 1 unless entry_path

  run_modular(options, entry_path, root_dir, program_args)
end

def resolve_entry_path(input_path)
  if input_path.nil?
    return [nil, nil] if STDIN.tty?
    input_path = "-"
  end

  if input_path == "-"
    source = STDIN.read
    path = File.join(Dir.tmpdir, "mlc_stdin_#{Process.pid}.mlc")
    File.write(path, source)
    at_exit { File.delete(path) rescue nil }
    [path, Dir.pwd]
  elsif File.exist?(input_path)
    [File.expand_path(input_path), File.dirname(File.expand_path(input_path))]
  else
    warn "File not found: #{input_path}"
    [nil, nil]
  end
end

def run_modular(options, entry_path, root_dir, program_args)
  out_dir = options[:out_dir] || "build"
  if File.exist?(out_dir) && !File.directory?(out_dir)
    warn "-o must be a directory, not a file: #{out_dir}"
    exit 1
  end

  begin
    if options[:build] && !options[:emit_cpp]
      result = MLC.build_project(entry_path: entry_path, out_dir: out_dir, root_dir: root_dir)
      run_program(result[:binary], program_args, verbose: options[:verbose])
    else
      MLC.compile_project(entry_path: entry_path, out_dir: out_dir, root_dir: root_dir)
    end
  rescue MLC::ParseError, MLC::CompileError => e
    warn e.message
    exit 1
  end
end

main
