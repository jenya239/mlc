type Result<T, E> = Ok(T) | Err(E)

fn safe_div(a: i32, b: i32) -> Result<i32, string> =
  if b == 0 then Err('division by zero') else Ok(a / b) end

fn main() -> i32 = do
  match safe_div(10, 2) {
    Ok(value) => println(value.to_string()),
    Err(message) => println(message)
  }
  match safe_div(10, 0) {
    Ok(value) => println(value.to_string()),
    Err(message) => println(message)
  }
  0
end
