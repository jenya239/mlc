fn scan(source: string) -> i32 = do
  let mut digits = 0
  let mut letters = 0
  let mut index = 0
  while index < source.length() do
    let character = source.char_at(index)
    if character >= "0" && character <= "9" then
      digits = digits + 1
    else if character >= "a" && character <= "z" then
      letters = letters + 1
    end
    index = index + 1
  end
  digits * 10 + letters
end

fn main() -> i32 = do
  println(scan("ab1c2d3").to_string())
  0
end
