fn is_digit(character: string) -> bool = character >= "0" && character <= "9"

fn is_alpha(character: string) -> bool = character >= "a" && character <= "z"

fn classify(character: string) -> i32 =
  if is_digit(character) then 1
  else if is_alpha(character) then 2
  else 0
  end

fn main() -> i32 = do
  println(classify("5").to_string())
  println(classify("x").to_string())
  println(classify("!").to_string())
  0
end
